@model PharmaSmartWeb.Models.CommercialHubViewModel
@{
    Layout = "_Layout";
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background-color: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .enterprise-header { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 10px 16px; font-size: 13px; font-weight: 700; color: #063955; display: flex; align-items: center; justify-content: space-between; }
    .enterprise-body { padding: 16px; }
    .enterprise-kpi { background: white; border: 1px solid #d1d5db; border-radius: 2px; padding: 12px 16px; }
    .kpi-title { font-size: 12px; color: #64748b; margin-bottom: 4px; font-weight: 600; }
    .kpi-value { font-size: 20px; font-weight: 700; color: #01172a; display: flex; align-items: baseline; gap: 4px; }
    .kpi-sub { font-size: 11px; color: #94a3b8; font-weight: normal; }
    .enterprise-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .enterprise-table th { background: #f1f5f9; padding: 8px 12px; border-bottom: 1px solid #cbd5e1; border-top: 1px solid #cbd5e1; color: #334155; font-weight: 700; text-align: right; }
    .enterprise-table td { padding: 8px 12px; border-bottom: 1px solid #e2e8f0; color: #1e293b; }
    .status-badge { display: inline-block; padding: 2px 6px; border-radius: 2px; font-size: 10px; font-weight: 700; }
    .status-success { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
    .status-danger { background: #fff1f2; color: #e11d48; border: 1px solid #fecdd3; }
    .status-neutral { background: #f8fafc; color: #475569; border: 1px solid #e2e8f0; }
    .status-warning { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; }
    /* Shortcut Buttons */
    .hub-section { padding: 12px 16px; }
    .hub-section-title { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #94a3b8; margin-bottom: 0; width: auto; white-space: nowrap; }
    .shortcut-btn { display: inline-flex; align-items: center; gap: 6px; padding: 7px 14px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; text-decoration: none; transition: all 0.15s; border: 1px solid transparent; }
    .shortcut-primary { background: #063955; color: white; }
    .shortcut-primary:hover { background: #0a4f72; color: white; }
    .shortcut-green { background: #065f46; color: white; border-color: #047857; }
    .shortcut-green:hover { background: #047857; color: white; }
    .shortcut-secondary { background: white; color: #475569; border-color: #d1d5db; }
    .shortcut-secondary:hover { background: #f8fafc; color: #1e293b; border-color: #94a3b8; }
    .shortcut-danger { background: #fee2e2; color: #b91c1c; border-color: #fca5a5; }
    .shortcut-danger:hover { background: #fecaca; color: #991b1b; }
    .shortcut-amber { background: #fffbeb; color: #92400e; border-color: #fde68a; }
    .shortcut-amber:hover { background: #fef3c7; }
</style>

<div class="space-y-4 pb-10">

    <!-- 0. Quick Actions Bar -->
    <div class="enterprise-panel" style="border-top: 3px solid #063955;">
        <div class="hub-section">
            <!-- Sales Shortcuts Row -->
            <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap; padding-bottom:10px; border-bottom:1px solid #f1f5f9; margin-bottom:10px;">
                <span class="hub-section-title" style="color:#063955; font-size:11px;">
                    اختصارات المبيعات
                </span>
                <a href="/Sales/Create" class="shortcut-btn shortcut-primary">
                    <span class="material-symbols-outlined" style="font-size:14px;">point_of_sale</span>
                    إنشاء فاتورة POS
                </a>
                <a href="/Sales/CloseShift" class="shortcut-btn shortcut-amber">
                    <span class="material-symbols-outlined" style="font-size:14px;">lock_clock</span>
                    إغلاق الوردية
                </a>
            </div>
            <!-- Purchases Shortcuts Row -->
            <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                <span class="hub-section-title" style="color:#10b981; font-size:11px;">
                    اختصارات المشتريات
                </span>
                <a href="/Purchases/Create" class="shortcut-btn shortcut-green">
                    <span class="material-symbols-outlined" style="font-size:14px;">add_shopping_cart</span>
                    تسجيل توريد جديد
                </a>
            </div>
        </div>
    </div>

    <!-- 1. KPIs -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="enterprise-kpi border-t-2 border-t-[#063955]">
            <div class="kpi-title">المبيعات اليوم</div>
            <div class="kpi-value">
                @Model.TodaySales.ToString("N2") <span class="kpi-sub">@ViewBag.CurrencySymbol</span>
            </div>
            <div class="text-[11px] text-slate-500 mt-2">@Model.TodayInvoicesCount فاتورة تم إصدارها</div>
        </div>

        <div class="enterprise-kpi border-t-2 border-t-rose-600">
            <div class="kpi-title">المرتجعات اليوم</div>
            <div class="kpi-value">
                @Model.TodayReturns.ToString("N2") <span class="kpi-sub">@ViewBag.CurrencySymbol</span>
            </div>
            <div class="text-[11px] text-slate-500 mt-2">@Model.TodayReturnsCount فاتورة مرتجعة</div>
        </div>
        
        <div class="enterprise-kpi">
            <div class="kpi-title">المشتريات المنجزة</div>
            <div class="kpi-value">
                @Model.TotalPurchasesOperations <span class="kpi-sub">عملية</span>
            </div>
             <div class="text-[11px] text-slate-500 mt-2">إجمالي فواتير مشتريات اليوم</div>
        </div>

        <div class="enterprise-kpi">
            <div class="kpi-title">إجمالي العمليات التشغيلية</div>
            <div class="kpi-value">
                @Model.TotalOperationsToday <span class="kpi-sub">عملية</span>
            </div>
            <div class="text-[11px] text-slate-500 mt-2">اليوم</div>
        </div>
    </div>

    <!-- 2. Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <div class="enterprise-panel lg:col-span-2">
            <div class="enterprise-header">
                حركة المبيعات والمشتريات (7 أيام)
            </div>
            <div class="enterprise-body">
                <div class="h-[280px] w-full relative">
                    <canvas id="salesPurchasesChart"></canvas>
                </div>
            </div>
        </div>

        <div class="enterprise-panel">
            <div class="enterprise-header">
                ملخص العمليات اليوم
            </div>
            <div class="enterprise-body h-full">
                <div class="relative w-full h-[180px] flex items-center justify-center">
                    <canvas id="operationsDoughnut"></canvas>
                    <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none mt-2">
                        <span class="text-2xl font-bold text-slate-800">@Model.TotalOperationsToday</span>
                        <span class="text-[10px] font-bold text-slate-500">عملية</span>
                    </div>
                </div>
                <div class="mt-4 space-y-2 border-t border-slate-100 pt-4">
                    <div class="flex justify-between text-xs">
                        <span class="flex items-center gap-1"><span class="w-2 h-2 bg-[#063955]"></span> مبيعات</span>
                        <span class="font-bold text-slate-800">@Model.TotalSalesOperations</span>
                    </div>
                    <div class="flex justify-between text-xs">
                        <span class="flex items-center gap-1"><span class="w-2 h-2 bg-emerald-600"></span> مشتريات</span>
                        <span class="font-bold text-slate-800">@Model.TotalPurchasesOperations</span>
                    </div>
                    <div class="flex justify-between text-xs">
                        <span class="flex items-center gap-1"><span class="w-2 h-2 bg-rose-600"></span> مرتجعات</span>
                        <span class="font-bold text-slate-800">@Model.TotalReturnsOperations</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 3. Tables Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div class="enterprise-panel">
            <div class="enterprise-header">
                <span>أحدث المبيعات</span>
                <a href="/Sales/Index" class="text-[11px] font-normal text-blue-600 hover:underline">عرض الكل</a>
            </div>
            <div class="overflow-x-auto">
                <table class="enterprise-table">
                    <thead>
                        <tr>
                            <th>رقم الفاتورة</th>
                            <th>العميل / الدفع</th>
                            <th>المبلغ</th>
                            <th>الوقت</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var sale in Model.RecentSales)
                        {
                            <tr class="hover:bg-slate-50">
                                <td class="font-bold">@sale.InvoiceNumber</td>
                                <td>
                                    @sale.CustomerName
                                    @if(sale.PaymentMethod == "كاش" || sale.PaymentMethod == "Cash")
                                    {
                                        <span class="status-badge status-success mr-2">@sale.PaymentMethod</span>
                                    }
                                    else if(sale.PaymentMethod == "شبكة" || sale.PaymentMethod == "Card" || sale.PaymentMethod == "Bank")
                                    {
                                        <span class="status-badge status-neutral mr-2">@sale.PaymentMethod</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-warning mr-2">@sale.PaymentMethod</span>
                                    }
                                </td>
                                <td>@sale.TotalAmount.ToString("N2")</td>
                                <td>@sale.SaleDate.ToString("HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="enterprise-panel">
            <div class="enterprise-header">
                <span>أحدث المشتريات</span>
                <a href="/Purchases/Index" class="text-[11px] font-normal text-blue-600 hover:underline">عرض الكل</a>
            </div>
            <div class="overflow-x-auto">
                <table class="enterprise-table">
                    <thead>
                        <tr>
                            <th>رقم الفاتورة</th>
                            <th>المورد</th>
                            <th>المبلغ</th>
                            <th>الحالة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var pur in Model.RecentPurchases)
                        {
                            <tr class="hover:bg-slate-50">
                                <td class="font-bold">@pur.InvoiceNumber</td>
                                <td>@pur.SupplierName</td>
                                <td>@pur.TotalAmount.ToString("N2")</td>
                                <td>
                                    @if(pur.IsPaid)
                                    {
                                        <span class="status-badge status-success">مدفوعة</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-danger">غير مدفوعة</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chart.js"></script>
    <script>
        Chart.defaults.font.family = "'Arial', sans-serif";
        Chart.defaults.color = '#334155';
        
        const labelsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Last7DaysLabels));
        const salesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SalesLast7Days));
        const purchasesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PurchasesLast7Days));

        const ctxLine = document.getElementById('salesPurchasesChart');
        if (ctxLine) {
            new Chart(ctxLine.getContext('2d'), {
                type: 'bar',
                data: {
                    labels: labelsData,
                    datasets: [
                        {
                            label: 'المبيعات',
                            data: salesData,
                            backgroundColor: '#063955',
                            borderWidth: 0
                        },
                        {
                            label: 'المشتريات',
                            data: purchasesData,
                            backgroundColor: '#10b981',
                            borderWidth: 0
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', align: 'end', labels: { boxWidth: 10, font: { size: 12 } } },
                        tooltip: { backgroundColor: '#1e293b', titleFont: { size: 13 }, bodyFont: { size: 12 }, rtl: true }
                    },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#e2e8f0', drawBorder: false }, ticks: { font: { size: 11 } } },
                        x: { grid: { display: false }, ticks: { font: { size: 11 } } }
                    }
                }
            });
        }

        const ctxDoughnut = document.getElementById('operationsDoughnut');
        if (ctxDoughnut) {
            new Chart(ctxDoughnut.getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: ['مبيعات', 'مشتريات', 'مرتجعات'],
                    datasets: [{
                        data: [@Model.TotalSalesOperations, @Model.TotalPurchasesOperations, @Model.TotalReturnsOperations],
                        backgroundColor: ['#063955', '#10b981', '#e11d48'],
                        borderWidth: 1,
                        borderColor: '#ffffff',
                        hoverOffset: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: { display: false }, 
                        tooltip: { backgroundColor: '#1e293b', titleFont: { size: 13 }, bodyFont: { size: 12 }, rtl: true }
                    }
                }
            });
        }
    </script>
}
