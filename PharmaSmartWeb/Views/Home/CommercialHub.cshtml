@model PharmaSmartWeb.Models.CommercialHubViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "وحدة العمليات التجارية";
    string currency = ViewBag.CurrencySymbol?.ToString() ?? "ر.ي";
}

<!-- ===== رأس الوحدة ===== -->
<div class="flex flex-wrap justify-between items-start mb-5">
    <div class="flex items-center gap-3 mb-2 sm:mb-0">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-700 flex items-center justify-center shadow-sm">
            <i class="fas fa-shopping-cart text-white"></i>
        </div>
        <div>
            <h1 class="text-xl font-black text-gray-800">وحدة العمليات التجارية</h1>
            <p class="text-xs text-gray-500">المبيعات · المشتريات · المرتجعات · العملاء · الموردين</p>
        </div>
    </div>
    <div class="flex flex-wrap gap-2">
        <a href="/Sales/Create"
           class="quick-action-btn bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5 active:scale-95">
            <i class="fas fa-plus-circle"></i> فاتورة مبيعات POS
        </a>
        <a href="/Purchases/Create"
           class="quick-action-btn bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5 active:scale-95">
            <i class="fas fa-truck-loading"></i> تسجيل توريد
        </a>
        <a href="/Sales/CloseShift"
           class="quick-action-btn bg-amber-100 hover:bg-amber-200 text-amber-800 px-4 py-2 rounded-xl text-xs font-bold flex items-center gap-2 transition-all hover:-translate-y-0.5 active:scale-95">
            <i class="fas fa-lock"></i> إغلاق الوردية
        </a>
    </div>
</div>

<!-- ===== بطاقات KPI ===== -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-5">
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-blue-600">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">المبيعات اليوم</span>
            <i class="fas fa-cash-register text-blue-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@Model.TodaySales.ToString("N0")</div>
        <span class="text-xs text-blue-600 font-medium">@Model.TodayInvoicesCount فاتورة · @currency</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-rose-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">المرتجعات اليوم</span>
            <i class="fas fa-undo text-rose-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@Model.TodayReturns.ToString("N0")</div>
        <span class="text-xs text-rose-500 font-medium">@Model.TodayReturnsCount فاتورة مرتجعة</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-emerald-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">المشتريات المنجزة</span>
            <i class="fas fa-truck text-emerald-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@Model.TotalPurchasesOperations</div>
        <span class="text-xs text-emerald-600 font-medium">عملية شراء اليوم</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-violet-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">إجمالي العمليات</span>
            <i class="fas fa-chart-bar text-violet-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@Model.TotalOperationsToday</div>
        <span class="text-xs text-violet-600 font-medium">عملية تشغيلية اليوم</span>
    </div>
</div>

<!-- ===== قائمة اختصارات سريعة ===== -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100 px-5 py-3 mb-5 flex flex-wrap gap-2 items-center">
    <span class="text-xs text-gray-400 font-semibold ml-2">اختصارات:</span>
    <a href="/Sales/Index" class="px-3 py-1.5 bg-gray-50 hover:bg-blue-50 border border-gray-200 hover:border-blue-300 text-gray-700 hover:text-blue-700 rounded-lg text-xs font-semibold transition-all flex items-center gap-1.5">
        <i class="fas fa-file-invoice text-blue-400 text-[10px]"></i> سجل المبيعات
    </a>
    <a href="/SaleReturns/Index" class="px-3 py-1.5 bg-gray-50 hover:bg-rose-50 border border-gray-200 hover:border-rose-300 text-gray-700 hover:text-rose-700 rounded-lg text-xs font-semibold transition-all flex items-center gap-1.5">
        <i class="fas fa-undo text-rose-400 text-[10px]"></i> مرتجعات مبيعات
    </a>
    <a href="/Purchases/Index" class="px-3 py-1.5 bg-gray-50 hover:bg-emerald-50 border border-gray-200 hover:border-emerald-300 text-gray-700 hover:text-emerald-700 rounded-lg text-xs font-semibold transition-all flex items-center gap-1.5">
        <i class="fas fa-shopping-basket text-emerald-400 text-[10px]"></i> المشتريات
    </a>
    <a href="/PurchaseReturns/Index" class="px-3 py-1.5 bg-gray-50 hover:bg-amber-50 border border-gray-200 hover:border-amber-300 text-gray-700 hover:text-amber-700 rounded-lg text-xs font-semibold transition-all flex items-center gap-1.5">
        <i class="fas fa-box-open text-amber-400 text-[10px]"></i> مرتجعات مشتريات
    </a>
    <a href="/Customers/Index" class="px-3 py-1.5 bg-gray-50 hover:bg-indigo-50 border border-gray-200 hover:border-indigo-300 text-gray-700 hover:text-indigo-700 rounded-lg text-xs font-semibold transition-all flex items-center gap-1.5">
        <i class="fas fa-users text-indigo-400 text-[10px]"></i> العملاء
    </a>
    <a href="/Suppliers/Index" class="px-3 py-1.5 bg-gray-50 hover:bg-teal-50 border border-gray-200 hover:border-teal-300 text-gray-700 hover:text-teal-700 rounded-lg text-xs font-semibold transition-all flex items-center gap-1.5">
        <i class="fas fa-truck text-teal-400 text-[10px]"></i> الموردين
    </a>
    <a href="/Report/SalesSummary" class="px-3 py-1.5 bg-gray-50 hover:bg-violet-50 border border-gray-200 hover:border-violet-300 text-gray-700 hover:text-violet-700 rounded-lg text-xs font-semibold transition-all flex items-center gap-1.5">
        <i class="fas fa-chart-line text-violet-400 text-[10px]"></i> تقرير المبيعات
    </a>
</div>

<!-- ===== المحتوى الرئيسي: رسم بياني + جداول ===== -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mb-5">
    <!-- رسم بياني: المبيعات والمشتريات (7 أيام) -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 lg:col-span-2">
        <div class="flex justify-between items-center px-5 py-4 border-b border-gray-100">
            <h3 class="font-bold text-gray-800 text-sm">
                <i class="fas fa-chart-bar text-blue-500 ml-1.5"></i> حركة المبيعات والمشتريات (7 أيام)
            </h3>
            <a href="/Sales/Index" class="text-xs text-blue-600 hover:underline font-semibold">عرض الكل</a>
        </div>
        <div class="p-5">
            <canvas id="salesPurchasesChart" style="height:240px; max-height:240px;"></canvas>
        </div>
    </div>

    <!-- دونات: ملخص العمليات -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100">
        <div class="px-5 py-4 border-b border-gray-100">
            <h3 class="font-bold text-gray-800 text-sm">
                <i class="fas fa-chart-pie text-violet-500 ml-1.5"></i> ملخص العمليات اليوم
            </h3>
        </div>
        <div class="p-5">
            <div class="relative flex items-center justify-center" style="height:180px;">
                <canvas id="operationsDoughnut"></canvas>
                <div class="absolute text-center">
                    <div class="text-2xl font-black text-gray-800">@Model.TotalOperationsToday</div>
                    <div class="text-xs text-gray-500">عملية</div>
                </div>
            </div>
            <div class="mt-4 space-y-2 border-t border-gray-100 pt-4">
                <div class="flex justify-between text-xs text-gray-600">
                    <span class="flex items-center gap-2"><span class="w-2.5 h-2.5 rounded-sm bg-blue-700 inline-block"></span>مبيعات</span>
                    <span class="font-bold text-gray-800">@Model.TotalSalesOperations</span>
                </div>
                <div class="flex justify-between text-xs text-gray-600">
                    <span class="flex items-center gap-2"><span class="w-2.5 h-2.5 rounded-sm bg-emerald-600 inline-block"></span>مشتريات</span>
                    <span class="font-bold text-gray-800">@Model.TotalPurchasesOperations</span>
                </div>
                <div class="flex justify-between text-xs text-gray-600">
                    <span class="flex items-center gap-2"><span class="w-2.5 h-2.5 rounded-sm bg-rose-600 inline-block"></span>مرتجعات</span>
                    <span class="font-bold text-gray-800">@Model.TotalReturnsOperations</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== جداول: أحدث المبيعات والمشتريات ===== -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <!-- أحدث المبيعات -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100">
        <div class="flex justify-between items-center px-5 py-4 border-b border-gray-100">
            <h3 class="font-bold text-gray-800 text-sm">
                <i class="fas fa-file-invoice text-blue-500 ml-1.5"></i> أحدث المبيعات
            </h3>
            <a href="/Sales/Index" class="text-xs text-blue-600 hover:underline font-semibold">عرض الكل</a>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full data-table text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">رقم الفاتورة</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">العميل</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">المبلغ</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">الوقت</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentSales.Any())
                    {
                        <tr><td colspan="4" class="text-center py-8 text-gray-400 text-sm">لا توجد مبيعات اليوم</td></tr>
                    }
                    @foreach (var sale in Model.RecentSales)
                    {
                        <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors">
                            <td class="px-4 py-3 font-bold text-gray-800">@sale.InvoiceNumber</td>
                            <td class="px-4 py-3 text-gray-600">
                                @sale.CustomerName
                                @{
                                    var pmClass = (sale.PaymentMethod == "كاش" || sale.PaymentMethod == "Cash") ? "bg-emerald-50 text-emerald-700"
                                        : (sale.PaymentMethod == "آجل" || sale.PaymentMethod == "Credit") ? "bg-amber-50 text-amber-700"
                                        : "bg-gray-100 text-gray-600";
                                }
                                <span class="mr-1 text-[10px] px-1.5 py-0.5 rounded-full font-semibold @pmClass">@sale.PaymentMethod</span>
                            </td>
                            <td class="px-4 py-3 font-semibold text-blue-700">@sale.TotalAmount.ToString("N0")</td>
                            <td class="px-4 py-3 text-gray-400 text-xs">@sale.SaleDate.ToString("HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- أحدث المشتريات -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100">
        <div class="flex justify-between items-center px-5 py-4 border-b border-gray-100">
            <h3 class="font-bold text-gray-800 text-sm">
                <i class="fas fa-truck text-emerald-500 ml-1.5"></i> أحدث المشتريات
            </h3>
            <a href="/Purchases/Index" class="text-xs text-blue-600 hover:underline font-semibold">عرض الكل</a>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full data-table text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">رقم الفاتورة</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">المورد</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">المبلغ</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">الحالة</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentPurchases.Any())
                    {
                        <tr><td colspan="4" class="text-center py-8 text-gray-400 text-sm">لا توجد مشتريات اليوم</td></tr>
                    }
                    @foreach (var pur in Model.RecentPurchases)
                    {
                        <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors">
                            <td class="px-4 py-3 font-bold text-gray-800">@pur.InvoiceNumber</td>
                            <td class="px-4 py-3 text-gray-600">@pur.SupplierName</td>
                            <td class="px-4 py-3 font-semibold text-emerald-700">@pur.TotalAmount.ToString("N0")</td>
                            <td class="px-4 py-3">
                                @if (pur.IsPaid)
                                {
                                    <span class="text-[11px] bg-emerald-50 text-emerald-700 px-2.5 py-1 rounded-full font-semibold border border-emerald-100">مدفوع</span>
                                }
                                else
                                {
                                    <span class="text-[11px] bg-red-50 text-red-700 px-2.5 py-1 rounded-full font-semibold border border-red-100">آجل</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    Chart.defaults.font.family = "'system-ui', 'Segoe UI', sans-serif";
    Chart.defaults.color = '#475569';
    Chart.defaults.rtl = true;

    const labelsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Last7DaysLabels));
    const salesData  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SalesLast7Days));
    const purchData  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PurchasesLast7Days));

    const ctxBar = document.getElementById('salesPurchasesChart');
    if (ctxBar) {
        new Chart(ctxBar.getContext('2d'), {
            type: 'bar',
            data: {
                labels: labelsData,
                datasets: [
                    { label: 'المبيعات', data: salesData, backgroundColor: '#2563eb', borderRadius: 4, borderWidth: 0 },
                    { label: 'المشتريات', data: purchData, backgroundColor: '#10b981', borderRadius: 4, borderWidth: 0 }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'top', align: 'end', labels: { font: { size: 11 }, usePointStyle: true } },
                    tooltip: { backgroundColor: '#1e293b', rtl: true, titleFont: { size: 12 }, bodyFont: { size: 11 } }
                },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { font: { size: 10 } } },
                    x: { grid: { display: false }, ticks: { font: { size: 10 } } }
                }
            }
        });
    }

    const ctxDoughnut = document.getElementById('operationsDoughnut');
    if (ctxDoughnut) {
        new Chart(ctxDoughnut.getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['مبيعات', 'مشتريات', 'مرتجعات'],
                datasets: [{ data: [@Model.TotalSalesOperations, @Model.TotalPurchasesOperations, @Model.TotalReturnsOperations], backgroundColor: ['#1d4ed8', '#059669', '#e11d48'], borderWidth: 2, borderColor: '#fff', hoverOffset: 4 }]
            },
            options: {
                responsive: true, maintainAspectRatio: false, cutout: '72%',
                plugins: { legend: { display: false }, tooltip: { backgroundColor: '#1e293b', rtl: true } }
            }
        });
    }
</script>
}
