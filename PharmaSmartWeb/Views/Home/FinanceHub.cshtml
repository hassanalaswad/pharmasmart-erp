@model PharmaSmartWeb.Models.FinanceHubViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "لوحة تحكم المالية والحسابات";
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .enterprise-header { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 10px 16px; font-size: 13px; font-weight: 700; color: #063955; display: flex; align-items: center; justify-content: space-between; gap: 8px; }
    .enterprise-body { padding: 16px; }
    .enterprise-kpi { background: white; border: 1px solid #d1d5db; border-radius: 2px; padding: 12px 16px; position: relative; }
    .kpi-title { font-size: 12px; color: #64748b; margin-bottom: 4px; font-weight: 600; display: flex; justify-content: space-between; }
    .kpi-value { font-size: 20px; font-weight: 700; color: #0f172a; display: flex; align-items: baseline; gap: 4px; }
    .kpi-sub { font-size: 11px; color: #94a3b8; font-weight: normal; }
    .enterprise-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .enterprise-table th { background: #f1f5f9; padding: 8px 12px; border-bottom: 1px solid #cbd5e1; border-top: 1px solid #cbd5e1; color: #334155; font-weight: 700; text-align: right; }
    .enterprise-table td { padding: 8px 12px; border-bottom: 1px solid #e2e8f0; color: #1e293b; }
    .status-badge { display: inline-block; padding: 2px 6px; border-radius: 2px; font-size: 10px; font-weight: 700; }
    .status-success { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
    .status-danger { background: #fff1f2; color: #e11d48; border: 1px solid #fecdd3; }
    .status-neutral { background: #f8fafc; color: #475569; border: 1px solid #e2e8f0; }
    .status-warning { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; }
</style>

<!-- Header -->
<div class="enterprise-panel mb-4 p-3 flex justify-between items-center -mx-4 md:mx-0">
    <div class="flex items-center gap-3">
        <div>
            <h1 class="text-base font-bold text-[#063955]">وحدة المالية والحسابات</h1>
            <p class="text-[11px] text-slate-500 font-normal">إدارة الخزينة، الدفاتر، القيود اليومية والأطراف</p>
        </div>
    </div>
    <div class="flex items-center gap-4">
        <div class="text-left hidden md:block">
            <p class="text-xs font-bold text-slate-700">السنة المالية @DateTime.Now.Year</p>
            <p class="text-[10px] text-slate-500">@DateTime.Now.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("ar-YE"))</p>
        </div>
        @if(Model.JournalEntriesCount > 0)
        {
            <a href="/JournalEntries/Index" onclick="window.openSystemReportModal(this.href); return false;" class="bg-amber-50 border border-amber-200 text-amber-700 px-3 py-1 rounded-sm text-xs font-bold transition-colors flex items-center gap-1" title="قيود غير مرحلة">
                <span>قيود غير مرحلة: @Model.JournalEntriesCount</span>
            </a>
        }
    </div>
</div>

<div class="space-y-4 pb-10">

    <!-- 1. Financial KPIs -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Cash Balance -->
        <div class="enterprise-kpi border-t-2 border-t-[#063955]">
            <div class="kpi-title">رصيد الصندوق (النقدية)</div>
            <div class="kpi-value">
                @Model.TotalCash.ToString("N2") <span class="kpi-sub">@Settings.Currency</span>
            </div>
            <a href="/Report/DailyCashFlow" onclick="window.openSystemReportModal(this.href); return false;" class="text-[11px] text-blue-600 font-normal hover:underline mt-2 inline-block">عرض حركة الصندوق</a>
        </div>
        
        <!-- Bank Balances -->
        <div class="enterprise-kpi border-t-2 border-t-sky-600">
            <div class="kpi-title">إجمالي الأرصدة البنكية</div>
            <div class="kpi-value">
                @Model.TotalBankBalance.ToString("N2") <span class="kpi-sub">@Settings.Currency</span>
            </div>
            <span class="text-[11px] text-slate-500 font-normal mt-2 inline-block">الحسابات الخارجية والمصارف</span>
        </div>

        <!-- Accounts Receivable (Customers) -->
        <div class="enterprise-kpi border-t-2 border-t-emerald-600 bg-slate-50">
            <div class="kpi-title text-emerald-800 font-bold">ذمم العملاء (مستحقات لنا)</div>
            <div class="kpi-value text-emerald-900">
                @Model.AccountsReceivable.ToString("N2") <span class="kpi-sub">@Settings.Currency</span>
            </div>
            <a href="/Customers/Index" onclick="window.openSystemReportModal(this.href); return false;" class="text-[11px] text-emerald-700 font-normal hover:underline mt-2 inline-block">إدارة حسابات العملاء</a>
        </div>

        <!-- Accounts Payable (Suppliers) -->
        <div class="enterprise-kpi border-t-2 border-t-rose-600 bg-slate-50">
            <div class="kpi-title text-rose-800 font-bold">ذمم الموردين (مستحقات علينا)</div>
            <div class="kpi-value text-rose-900">
                @Model.AccountsPayable.ToString("N2") <span class="kpi-sub">@Settings.Currency</span>
            </div>
            <a href="/Suppliers/Index" onclick="window.openSystemReportModal(this.href); return false;" class="text-[11px] text-rose-700 font-normal hover:underline mt-2 inline-block">إدارة حسابات الموردين</a>
        </div>
    </div>

    <!-- 2. Charts & Analytics -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <!-- Main Chart: Cash Flow (In vs Out) -->
        <div class="enterprise-panel lg:col-span-2">
            <div class="enterprise-header">
                <div>حركة التدفق النقدي (Cash Flow) <span class="text-[10px] text-slate-500 font-normal mr-2">المقبوضات مقابل المدفوعات خلال الأسبوع الأخير (@Settings.Currency)</span></div>
            </div>
            <div class="enterprise-body">
                <div class="h-[300px] w-full">
                    <canvas id="cashFlowChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Secondary Chart: Liquidity Distribution -->
        <div class="enterprise-panel flex flex-col">
            <div class="enterprise-header">
                <div>توزيع السيولة النقدية <span class="text-[10px] text-slate-500 font-normal mr-2">أبرز الحسابات التي تحمل أرصدة</span></div>
            </div>
            <div class="enterprise-body flex-1 flex flex-col">
                <div class="flex-1 flex items-center justify-center relative min-h-[180px]">
                    <canvas id="liquidityDoughnut"></canvas>
                </div>
                <div class="mt-4 space-y-2 border-t border-slate-100 pt-4" id="liquidityLegend">
                    @for(int i = 0; i < Model.LiquidityLabels.Count; i++)
                    {
                        <div class="flex justify-between text-xs">
                            <span class="flex items-center gap-1"><span class="w-2 h-2 bg-slate-500 legend-dot"></span> @Model.LiquidityLabels[i]</span>
                            <span class="font-bold text-slate-800">@Model.LiquidityData[i].ToString("N0")</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- 3. Operational Tables (Vouchers & Journal Entries) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        
        <!-- Table 1: Recent Vouchers -->
        <div class="enterprise-panel">
            <div class="enterprise-header">
                <span>أحدث السندات (قبض / صرف)</span>
                <a href="/Vouchers/Index" onclick="window.openSystemReportModal(this.href); return false;" class="text-[11px] font-normal text-blue-600 hover:underline">سجل السندات</a>
            </div>
            <div class="overflow-x-auto">
                <table class="enterprise-table">
                    <thead>
                        <tr>
                            <th>رقم السند</th>
                            <th>المستفيد / الإشعار</th>
                            <th>النوع</th>
                            <th>المبلغ (@Settings.Currency)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var v in Model.RecentVouchers)
                        {
                            bool isReceipt = v.VoucherType == "Receipt" || v.VoucherType == "قبض";
                            <tr class="hover:bg-slate-50 cursor-pointer" onclick="window.openSystemReportModal('/Vouchers/Details/@v.VoucherId');">
                                <td class="font-bold">@v.VoucherNumber</td>
                                <td>
                                    @v.PayeePayerName
                                    <span class="text-[10px] text-slate-500 block truncate max-w-[150px]">@v.Notes</span>
                                </td>
                                <td>
                                    <span class="status-badge @(isReceipt ? "status-success" : "status-danger")">@(isReceipt ? "سند قبض" : "سند صرف")</span>
                                </td>
                                <td class="font-bold @(isReceipt ? "text-emerald-700" : "text-rose-700")" dir="ltr">@(isReceipt ? "+" : "-") @v.Amount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Table 2: Recent Journal Entries -->
        <div class="enterprise-panel">
            <div class="enterprise-header">
                <span>أحدث القيود والمطابقات</span>
                <a href="/JournalEntries/Index" onclick="window.openSystemReportModal(this.href); return false;" class="text-[11px] font-normal text-blue-600 hover:underline">دفتر اليومية</a>
            </div>
            <div class="overflow-x-auto">
                <table class="enterprise-table">
                    <thead>
                        <tr>
                            <th>رقم القيد</th>
                            <th>البيان / المصدر</th>
                            <th>الإجمالي (@Settings.Currency)</th>
                            <th>الحالة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var j in Model.RecentJournals)
                        {
                            <tr class="hover:bg-slate-50 cursor-pointer" onclick="window.openSystemReportModal('/JournalEntries/Details/@j.JournalId');">
                                <td class="font-bold">@j.JournalNumber</td>
                                <td>
                                    <span class="truncate max-w-[150px] inline-block">@j.Description</span>
                                    <span class="text-[10px] text-slate-500 block">@j.Source</span>
                                </td>
                                <td class="font-bold">@j.TotalAmount.ToString("N2")</td>
                                <td>
                                    <span class="status-badge @(j.IsPosted ? "status-success" : "status-warning")">@(j.IsPosted ? "مرحل" : "معلق")</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/lib/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            Chart.defaults.font.family = "'Arial', sans-serif";
            Chart.defaults.font.size = 12; 
            Chart.defaults.color = '#334155';
            Chart.defaults.rtl = true;

            // 1. Cash Flow Bar Chart (Inflows vs Outflows)
            const ctxFlow = document.getElementById('cashFlowChart').getContext('2d');
            new Chart(ctxFlow, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.CashFlowLabels)),
                    datasets: [
                        {
                            label: 'مقبوضات (In)',
                            data: @Html.Raw(Json.Serialize(Model.CashInflows)),
                            backgroundColor: '#10b981', 
                            borderWidth: 0
                        },
                        {
                            label: 'مدفوعات (Out)',
                            data: @Html.Raw(Json.Serialize(Model.CashOutflows)),
                            backgroundColor: '#e11d48', 
                            borderWidth: 0
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', align: 'end', labels: { boxWidth: 10, font: { size: 12 } } },
                        tooltip: { backgroundColor: '#1e293b', titleFont: { size: 13 }, bodyFont: { size: 12 }, rtl: true }
                    },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#e2e8f0', drawBorder: false }, ticks: { font: { size: 11 } } },
                        x: { grid: { display: false }, ticks: { font: { size: 11 } } }
                    },
                    barPercentage: 0.6,
                    categoryPercentage: 0.8
                }
            });

            // 2. Liquidity Distribution Doughnut Chart
            const ctxDoughnut = document.getElementById('liquidityDoughnut').getContext('2d');
            const dataColors = ['#063955', '#10b981', '#0ea5e9', '#d97706', '#e11d48'];
            new Chart(ctxDoughnut, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.LiquidityLabels)),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.LiquidityData)),
                        backgroundColor: dataColors.slice(0, @Html.Raw(Model.LiquidityLabels.Count)),
                        borderWidth: 1,
                        borderColor: '#ffffff',
                        hoverOffset: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%', 
                    plugins: {
                        legend: { display: false }, 
                        tooltip: { backgroundColor: '#1e293b', titleFont: { size: 13 }, bodyFont: { size: 12 }, rtl: true }
                    }
                }
            });

            // Color the list dots dynamically to match chart
            const legendDots = document.querySelectorAll('.legend-dot');
            legendDots.forEach((dot, index) => {
                if(index < dataColors.length) {
                    dot.style.backgroundColor = dataColors[index];
                }
            });
        });
    </script>
}
