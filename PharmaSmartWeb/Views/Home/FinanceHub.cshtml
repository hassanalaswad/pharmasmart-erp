@model PharmaSmartWeb.Models.FinanceHubViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "وحدة المالية والحسابات";
    string currency = Settings.Currency;
}

<!-- ===== رأس الوحدة ===== -->
<div class="flex flex-wrap justify-between items-start mb-5">
    <div class="flex items-center gap-3 mb-2 sm:mb-0">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-amber-500 to-yellow-600 flex items-center justify-center shadow-sm">
            <i class="fas fa-coins text-white"></i>
        </div>
        <div>
            <h1 class="text-xl font-black text-gray-800">وحدة المالية والحسابات</h1>
            <p class="text-xs text-gray-500">الخزينة · الدفاتر · القيود اليومية · الذمم · التسويات</p>
        </div>
    </div>
    <div class="flex flex-wrap gap-2 items-center">
        @if (Model.JournalEntriesCount > 0)
        {
            <a href="/JournalEntries/Index"
               class="bg-amber-50 border border-amber-200 text-amber-700 px-3 py-1.5 rounded-xl text-xs font-bold flex items-center gap-1.5 animate-pulse">
                <i class="fas fa-exclamation-triangle"></i> @Model.JournalEntriesCount قيد معلق
            </a>
        }
        <a href="/Vouchers/Create?type=receipt" class="quick-action-btn bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5">
            <i class="fas fa-hand-holding-usd"></i> سند قبض
        </a>
        <a href="/Vouchers/Create?type=payment" class="quick-action-btn bg-rose-600 hover:bg-rose-700 text-white px-4 py-2 rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5">
            <i class="fas fa-money-bill-wave"></i> سند صرف
        </a>
        <a href="/JournalEntries/Create" class="quick-action-btn bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5">
            <i class="fas fa-book-open"></i> قيد يومية
        </a>
    </div>
</div>

<!-- ===== بطاقات KPI ===== -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-5">
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-slate-700">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">رصيد الصندوق</span>
            <i class="fas fa-cash-register text-slate-600 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@Model.TotalCash.ToString("N0")</div>
        <a href="/Report/DailyCashFlow" class="text-xs text-slate-600 font-semibold hover:underline">حركة الصندوق ←</a>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-sky-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">الأرصدة البنكية</span>
            <i class="fas fa-university text-sky-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@Model.TotalBankBalance.ToString("N0")</div>
        <span class="text-xs text-sky-600 font-medium">@currency — أرصدة البنوك</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-emerald-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-emerald-700 font-semibold">ذمم العملاء (لنا)</span>
            <i class="fas fa-arrow-down text-emerald-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-emerald-700">@Model.AccountsReceivable.ToString("N0")</div>
        <a href="/Customers/Index" class="text-xs text-emerald-600 font-semibold hover:underline">حسابات العملاء ←</a>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-rose-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-rose-700 font-semibold">ذمم الموردين (علينا)</span>
            <i class="fas fa-arrow-up text-rose-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-rose-700">@Model.AccountsPayable.ToString("N0")</div>
        <a href="/Suppliers/Index" class="text-xs text-rose-600 font-semibold hover:underline">حسابات الموردين ←</a>
    </div>
</div>

<!-- ===== قائمة اختصارات سريعة ===== -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100 px-5 py-3 mb-5 flex flex-wrap gap-2 items-center">
    <span class="text-xs text-gray-400 font-semibold ml-2">اختصارات:</span>
    @foreach (var link in new[] {
        new { Href="/Vouchers/Index", Icon="fa-receipt", Text="السندات", Color="text-amber-400" },
        new { Href="/JournalEntries/Index", Icon="fa-book", Text="اليومية", Color="text-indigo-400" },
        new { Href="/Accounts/Index", Icon="fa-sitemap", Text="الدليل المحاسبي", Color="text-blue-400" },
        new { Href="/Customers/Index", Icon="fa-users", Text="العملاء", Color="text-emerald-400" },
        new { Href="/Suppliers/Index", Icon="fa-truck", Text="الموردين", Color="text-teal-400" },
        new { Href="/Report/DailyCashFlow", Icon="fa-chart-line", Text="التدفق النقدي", Color="text-sky-400" },
        new { Href="/Report/IncomeStatement", Icon="fa-file-chart-pie", Text="قائمة الدخل", Color="text-violet-400" },
    })
    {
        <a href="@link.Href" class="px-3 py-1.5 bg-gray-50 hover:bg-amber-50 border border-gray-200 hover:border-amber-300 text-gray-700 hover:text-amber-700 rounded-lg text-xs font-semibold transition-all flex items-center gap-1.5">
            <i class="fas @link.Icon @link.Color text-[10px]"></i> @link.Text
        </a>
    }
</div>

<!-- ===== الرسوم البيانية ===== -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mb-5">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 lg:col-span-2">
        <div class="flex justify-between items-center px-5 py-4 border-b border-gray-100">
            <h3 class="font-bold text-gray-800 text-sm">
                <i class="fas fa-chart-bar text-amber-500 ml-1.5"></i> التدفق النقدي — المقبوضات مقابل المدفوعات
            </h3>
            <span class="text-xs text-gray-400">@currency</span>
        </div>
        <div class="p-5"><canvas id="cashFlowChart" style="height:240px; max-height:240px;"></canvas></div>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100">
        <div class="px-5 py-4 border-b border-gray-100">
            <h3 class="font-bold text-gray-800 text-sm">
                <i class="fas fa-pie-chart text-sky-500 ml-1.5"></i> توزيع السيولة
            </h3>
        </div>
        <div class="p-5">
            <div class="relative flex items-center justify-center" style="height:180px;">
                <canvas id="liquidityDoughnut"></canvas>
            </div>
            <div class="mt-4 space-y-1.5 border-t border-gray-100 pt-4" id="liquidityLegend">
                @{
                    var lgColors = new[] { "#1e3a5f", "#10b981", "#0ea5e9", "#d97706", "#e11d48" };
                    for (int i = 0; i < Model.LiquidityLabels.Count; i++)
                    {
                        <div class="flex justify-between text-xs text-gray-600">
                            <span class="flex items-center gap-1.5">
                                <span class="w-2.5 h-2.5 rounded-sm inline-block" style="background:@lgColors[i % lgColors.Length]"></span>
                                @Model.LiquidityLabels[i]
                            </span>
                            <span class="font-bold text-gray-800">@Model.LiquidityData[i].ToString("N0")</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- ===== جداول السندات والقيود ===== -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100">
        <div class="flex justify-between items-center px-5 py-4 border-b border-gray-100">
            <h3 class="font-bold text-gray-800 text-sm">
                <i class="fas fa-receipt text-amber-500 ml-1.5"></i> أحدث السندات (قبض / صرف)
            </h3>
            <a href="/Vouchers/Index" class="text-xs text-blue-600 hover:underline font-semibold">سجل السندات</a>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full data-table text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">رقم السند</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">المستفيد</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">النوع</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">المبلغ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.RecentVouchers)
                    {
                        bool isReceipt = v.VoucherType == "Receipt" || v.VoucherType == "قبض";
                        <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors cursor-pointer" onclick="location.href='/Vouchers/Details/@v.VoucherId'">
                            <td class="px-4 py-3 font-bold text-gray-800">@v.VoucherNumber</td>
                            <td class="px-4 py-3 text-gray-600 text-xs">@v.PayeePayerName<br/><span class="text-gray-400">@(v.Notes != null && v.Notes.Length > 30 ? v.Notes.Substring(0, 30) + "..." : v.Notes)</span></td>
                            <td class="px-4 py-3">
                                <span class="text-[10px] px-2 py-0.5 rounded-full font-bold @(isReceipt ? "bg-emerald-50 text-emerald-700" : "bg-red-50 text-red-700")">@(isReceipt ? "سند قبض" : "سند صرف")</span>
                            </td>
                            <td class="px-4 py-3 font-bold @(isReceipt ? "text-emerald-600" : "text-red-600")" dir="ltr">@(isReceipt ? "+" : "-")@v.Amount.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100">
        <div class="flex justify-between items-center px-5 py-4 border-b border-gray-100">
            <h3 class="font-bold text-gray-800 text-sm">
                <i class="fas fa-book text-indigo-500 ml-1.5"></i> أحدث القيود اليومية
            </h3>
            <a href="/JournalEntries/Index" class="text-xs text-blue-600 hover:underline font-semibold">دفتر اليومية</a>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full data-table text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">رقم القيد</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">البيان</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">الإجمالي</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">الحالة</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var j in Model.RecentJournals)
                    {
                        <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors cursor-pointer" onclick="location.href='/JournalEntries/Details/@j.JournalId'">
                            <td class="px-4 py-3 font-bold text-gray-800">@j.JournalNumber</td>
                            <td class="px-4 py-3 text-xs text-gray-600">@j.Description<br/><span class="text-gray-400">@j.Source</span></td>
                            <td class="px-4 py-3 font-semibold text-gray-800">@j.TotalAmount.ToString("N0")</td>
                            <td class="px-4 py-3">
                                <span class="text-[10px] px-2 py-0.5 rounded-full font-bold @(j.IsPosted ? "bg-emerald-50 text-emerald-700" : "bg-amber-50 text-amber-700")">@(j.IsPosted ? "مرحل" : "معلق")</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    Chart.defaults.font.family = "'system-ui', sans-serif";
    Chart.defaults.color = '#475569';
    const dataColors = ['#1e3a5f', '#10b981', '#0ea5e9', '#d97706', '#e11d48'];

    const ctxFlow = document.getElementById('cashFlowChart');
    if (ctxFlow) {
        new Chart(ctxFlow.getContext('2d'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.CashFlowLabels)),
                datasets: [
                    { label: 'مقبوضات', data: @Html.Raw(Json.Serialize(Model.CashInflows)), backgroundColor: '#10b981', borderRadius: 4 },
                    { label: 'مدفوعات', data: @Html.Raw(Json.Serialize(Model.CashOutflows)), backgroundColor: '#e11d48', borderRadius: 4 }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'top', align: 'end', labels: { usePointStyle: true, font: { size: 11 } } }, tooltip: { backgroundColor: '#1e293b', rtl: true } },
                scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }
            }
        });
    }

    const ctxLiq = document.getElementById('liquidityDoughnut');
    if (ctxLiq) {
        new Chart(ctxLiq.getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.LiquidityLabels)),
                datasets: [{ data: @Html.Raw(Json.Serialize(Model.LiquidityData)), backgroundColor: dataColors.slice(0, @Html.Raw(Model.LiquidityLabels.Count.ToString())), borderWidth: 2, borderColor: '#fff' }]
            },
            options: { responsive: true, maintainAspectRatio: false, cutout: '72%', plugins: { legend: { display: false }, tooltip: { backgroundColor: '#1e293b', rtl: true } } }
        });
    }
</script>
}
