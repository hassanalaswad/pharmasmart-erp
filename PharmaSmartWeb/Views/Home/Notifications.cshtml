@model List<PharmaSmartWeb.Controllers.NotificationItemVm>
@{
    ViewData["Title"] = "مركز الإشعارات";
    ViewData["PageDescription"] = "تنبيهات المخزون والصلاحية والتحديثات الإدارية";
    int total     = ViewBag.TotalCount     ?? 0;
    int critical  = ViewBag.CriticalCount  ?? 0;
    int warning   = ViewBag.WarningCount   ?? 0;
    int invCount  = ViewBag.InventoryCount ?? 0;
    int admCount  = ViewBag.AdminCount     ?? 0;
}

<div class="max-w-4xl mx-auto space-y-5">

    <!-- KPI Summary -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="bg-white border border-slate-200 rounded-sm p-4 flex items-center gap-3 shadow-sm">
            <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center">
                <span class="material-symbols-outlined text-slate-500 text-[22px]">notifications</span>
            </div>
            <div>
                <p class="text-[10px] font-bold text-slate-400 uppercase">إجمالي</p>
                <p class="text-2xl font-black text-slate-800">@total</p>
            </div>
        </div>
        <div class="bg-white border border-red-200 border-r-4 border-r-red-500 rounded-sm p-4 flex items-center gap-3 shadow-sm">
            <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center">
                <span class="material-symbols-outlined text-red-500 text-[22px]">dangerous</span>
            </div>
            <div>
                <p class="text-[10px] font-bold text-red-400 uppercase">حرجة</p>
                <p class="text-2xl font-black text-red-600">@critical</p>
            </div>
        </div>
        <div class="bg-white border border-amber-200 border-r-4 border-r-amber-500 rounded-sm p-4 flex items-center gap-3 shadow-sm">
            <div class="w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center">
                <span class="material-symbols-outlined text-amber-500 text-[22px]">warning</span>
            </div>
            <div>
                <p class="text-[10px] font-bold text-amber-400 uppercase">تحذير</p>
                <p class="text-2xl font-black text-amber-600">@warning</p>
            </div>
        </div>
        <div class="bg-white border border-blue-200 border-r-4 border-r-blue-500 rounded-sm p-4 flex items-center gap-3 shadow-sm">
            <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center">
                <span class="material-symbols-outlined text-blue-500 text-[22px]">info</span>
            </div>
            <div>
                <p class="text-[10px] font-bold text-blue-400 uppercase">معلوماتية</p>
                <p class="text-2xl font-black text-blue-600">@(total - critical - warning)</p>
            </div>
        </div>
    </div>

    <!-- Tabs + Cards Panel -->
    <div class="bg-white border border-slate-200 rounded-sm shadow-sm overflow-hidden">
        <!-- Tabs -->
        <div class="flex border-b border-slate-200 bg-slate-50 overflow-x-auto">
            <button onclick="filterTab('all')" id="tab-all"
                class="tab-btn px-5 py-3 text-sm font-bold flex items-center gap-2 whitespace-nowrap border-b-2 border-primary text-primary">
                <span class="material-symbols-outlined text-[16px]">notifications</span>
                الكل <span class="bg-primary text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full">@total</span>
            </button>
            <button onclick="filterTab('inventory')" id="tab-inventory"
                class="tab-btn px-5 py-3 text-sm font-bold flex items-center gap-2 whitespace-nowrap border-b-2 border-transparent text-slate-500 hover:text-primary">
                <span class="material-symbols-outlined text-[16px]">inventory_2</span>
                المخزون <span class="bg-slate-200 text-slate-600 text-[10px] font-bold px-1.5 py-0.5 rounded-full">@invCount</span>
            </button>
            <button onclick="filterTab('admin')" id="tab-admin"
                class="tab-btn px-5 py-3 text-sm font-bold flex items-center gap-2 whitespace-nowrap border-b-2 border-transparent text-slate-500 hover:text-primary">
                <span class="material-symbols-outlined text-[16px]">admin_panel_settings</span>
                الإداري <span class="bg-slate-200 text-slate-600 text-[10px] font-bold px-1.5 py-0.5 rounded-full">@admCount</span>
            </button>
        </div>

        <!-- Cards -->
        <div id="notificationsList" class="divide-y divide-slate-100">
            @if (Model == null || !Model.Any())
            {
                <div class="flex flex-col items-center justify-center py-20 text-center">
                    <span class="material-symbols-outlined text-slate-200 text-[72px]">notifications_off</span>
                    <p class="text-lg font-black text-slate-400 mt-4">لا توجد تنبيهات حالياً</p>
                    <p class="text-sm text-slate-400 mt-1">النظام يعمل بشكل طبيعي، المخزون ضمن الحدود الآمنة.</p>
                    <a href="/Home/Index" class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-primary hover:underline">
                        <span class="material-symbols-outlined text-[16px]">home</span>
                        العودة للوحة التحكم
                    </a>
                </div>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <div class="notification-card flex items-start gap-4 px-5 py-4 hover:bg-slate-50 transition-colors"
                         data-category="@item.Category">

                        <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 border @item.BgColor mt-0.5">
                            <span class="material-symbols-outlined @item.IconColor text-[20px]">@item.Icon</span>
                        </div>

                        <div class="flex-1 min-w-0">
                            <div class="flex items-start justify-between gap-2">
                                <p class="text-sm font-bold text-slate-800 leading-snug">@item.Title</p>
                                <div class="flex items-center gap-1.5 flex-shrink-0">
                                    @{
                                        string severityLabel = item.Severity == "critical" ? "حرجة" : item.Severity == "warning" ? "تحذير" : "معلومة";
                                    }
                                    <span class="text-[10px] font-bold px-2 py-0.5 rounded-full text-white @item.BadgeColor">@severityLabel</span>
                                    <div class="w-2 h-2 rounded-full @item.BadgeColor flex-shrink-0"></div>
                                </div>
                            </div>
                            <p class="text-xs text-slate-500 font-medium mt-0.5 leading-relaxed">@item.Body</p>
                            @if (item.ActionUrl != "#" && item.ActionText != "—")
                            {
                                <a href="@item.ActionUrl"
                                   class="inline-flex items-center gap-1 text-[11px] font-bold text-primary hover:underline mt-1.5">
                                    <span class="material-symbols-outlined text-[12px]">arrow_back</span>
                                    @item.ActionText
                                </a>
                            }
                        </div>

                        <div class="text-[10px] font-bold text-slate-400 flex-shrink-0 mt-1">
                            @item.OccurredAt.ToString("dd/MM HH:mm")
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    function filterTab(category) {
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('border-primary', 'text-primary');
            btn.classList.add('border-transparent', 'text-slate-500');
        });
        const active = document.getElementById('tab-' + category);
        if (active) {
            active.classList.add('border-primary', 'text-primary');
            active.classList.remove('border-transparent', 'text-slate-500');
        }
        document.querySelectorAll('.notification-card').forEach(card => {
            const cat = card.getAttribute('data-category');
            card.style.display = (category === 'all' || cat === category) ? 'flex' : 'none';
        });
    }
</script>
}
