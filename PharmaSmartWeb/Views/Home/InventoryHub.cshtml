@model PharmaSmartWeb.Models.InventoryHubViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "وحدة المخزون والمستودعات";
    string currency = Settings.Currency;
}

<!-- ===== رأس الوحدة ===== -->
<div class="flex flex-wrap justify-between items-start mb-5">
    <div class="flex items-center gap-3 mb-2 sm:mb-0">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-teal-500 to-emerald-600 flex items-center justify-center shadow-sm">
            <i class="fas fa-boxes text-white"></i>
        </div>
        <div>
            <h1 class="text-xl font-black text-gray-800">وحدة المخزون والمستودعات</h1>
            <p class="text-xs text-gray-500">إدارة الأدوية · الجرد · التحويلات · الصلاحية · النواقص</p>
        </div>
    </div>
    <div class="flex flex-wrap gap-2 items-center">
        @if (Model.ShortagesCount > 0)
        {
            <span class="bg-red-50 border border-red-200 text-red-700 px-3 py-1.5 rounded-xl text-xs font-bold flex items-center gap-1.5 animate-pulse">
                <i class="fas fa-exclamation-circle"></i> @Model.ShortagesCount نقص
            </span>
        }
        <a href="/Inventory/ReceiveGoodsCreate" class="quick-action-btn bg-teal-600 hover:bg-teal-700 text-white px-4 py-2 rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5">
            <i class="fas fa-plus-circle"></i> استقبال بضاعة
        </a>
        <a href="/DrugTransfers/Create" class="quick-action-btn bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5">
            <i class="fas fa-exchange-alt"></i> تحويل مخزني
        </a>
        <a href="/Inventory/Shortages" class="quick-action-btn bg-red-50 hover:bg-red-100 text-red-700 border border-red-200 px-4 py-2 rounded-xl text-xs font-bold flex items-center gap-2 transition-all hover:-translate-y-0.5">
            <i class="fas fa-exclamation-triangle"></i> النواقص
        </a>
    </div>
</div>

<!-- ===== بطاقات KPI ===== -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-5">
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-teal-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">إجمالي الأصناف</span>
            <i class="fas fa-pills text-teal-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@Model.TotalDrugs.ToString("N0")</div>
        <span class="text-xs text-teal-600 font-medium">القيمة: @Model.TotalInventoryValue.ToString("N0") @currency</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-red-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-red-600 font-semibold">نواقص مخزون</span>
            <i class="fas fa-exclamation-circle text-red-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-red-700">@Model.ShortagesCount</div>
        <a href="/Inventory/Shortages" class="text-xs text-red-600 font-semibold hover:underline">طلب شراء عاجل ←</a>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-amber-400">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-amber-700 font-semibold">قارب انتهاء</span>
            <i class="fas fa-calendar-times text-amber-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-amber-700">@Model.ExpiringSoonCount</div>
        <a href="/Report/StockExpiry" class="text-xs text-amber-600 font-semibold hover:underline">مراقبة الصلاحيات ←</a>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-indigo-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">تحويلات معلقة</span>
            <i class="fas fa-truck text-indigo-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@Model.PendingTransfersCount</div>
        <a href="/DrugTransfers/Index" class="text-xs text-indigo-600 font-semibold hover:underline">معالجة التحويلات ←</a>
    </div>
</div>

<!-- ===== قائمة اختصارات سريعة ===== -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100 px-5 py-3 mb-5 flex flex-wrap gap-2 items-center">
    <span class="text-xs text-gray-400 font-semibold ml-2">اختصارات:</span>
    @foreach (var link in new[] {
        new { Href="/Drugs/Index", Icon="fa-capsules", Text="قاعدة الأدوية", Color="text-teal-400" },
        new { Href="/Inventory/Index", Icon="fa-warehouse", Text="الجرد", Color="text-indigo-400" },
        new { Href="/DrugTransfers/Index", Icon="fa-exchange-alt", Text="التحويلات", Color="text-blue-400" },
        new { Href="/Inventory/Shortages", Icon="fa-exclamation-triangle", Text="النواقص", Color="text-red-400" },
        new { Href="/Report/StockExpiry", Icon="fa-calendar-times", Text="الصلاحيات", Color="text-amber-400" },
        new { Href="/InventoryIntelligence/Index", Icon="fa-robot", Text="تحليل ABC", Color="text-violet-400" },
        new { Href="/Warehouses/Index", Icon="fa-building", Text="المستودعات", Color="text-gray-400" },
    })
    {
        <a href="@link.Href" class="px-3 py-1.5 bg-gray-50 hover:bg-teal-50 border border-gray-200 hover:border-teal-300 text-gray-700 hover:text-teal-700 rounded-lg text-xs font-semibold transition-all flex items-center gap-1.5">
            <i class="fas @link.Icon @link.Color text-[10px]"></i> @link.Text
        </a>
    }
</div>

<!-- ===== رسم بياني + جداول ===== -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mb-5">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 lg:col-span-2">
        <div class="flex justify-between items-center px-5 py-4 border-b border-gray-100">
            <h3 class="font-bold text-gray-800 text-sm">
                <i class="fas fa-chart-bar text-teal-500 ml-1.5"></i> قيمة المخزون حسب المجموعات العلاجية
            </h3>
            <a href="/InventoryIntelligence/Index" class="text-xs text-blue-600 hover:underline font-semibold">تحليل ABC</a>
        </div>
        <div class="p-5"><canvas id="inventoryGroupsChart" style="height:240px; max-height:240px;"></canvas></div>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100">
        <div class="px-5 py-4 border-b border-gray-100">
            <h3 class="font-bold text-gray-800 text-sm">
                <i class="fas fa-heartbeat text-rose-500 ml-1.5"></i> صحة المخزون
            </h3>
        </div>
        <div class="p-5">
            <div class="relative flex items-center justify-center" style="height:180px;">
                <canvas id="stockHealthDoughnut"></canvas>
                <div class="absolute text-center">
                    <div class="text-2xl font-black text-emerald-600">@Model.StockHealthyPercentage%</div>
                    <div class="text-xs text-gray-500">صالح</div>
                </div>
            </div>
            <div class="mt-4 space-y-2 border-t border-gray-100 pt-4">
                <div class="flex justify-between text-xs text-gray-600">
                    <span class="flex items-center gap-2"><span class="w-2.5 h-2.5 rounded-sm bg-emerald-500 inline-block"></span>متوفر وصالح</span>
                    <span class="font-bold">@Model.StockHealthyPercentage%</span>
                </div>
                <div class="flex justify-between text-xs text-gray-600">
                    <span class="flex items-center gap-2"><span class="w-2.5 h-2.5 rounded-sm bg-amber-500 inline-block"></span>قارب الانتهاء</span>
                    <span class="font-bold">@Model.StockExpiringPercentage%</span>
                </div>
                <div class="flex justify-between text-xs text-gray-600">
                    <span class="flex items-center gap-2"><span class="w-2.5 h-2.5 rounded-sm bg-red-500 inline-block"></span>نواقص/منتهي</span>
                    <span class="font-bold">@Model.StockDangerPercentage%</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== جداول التنبيهات والحركات ===== -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <!-- التنبيهات الحرجة -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100">
        <div class="flex justify-between items-center px-5 py-4 border-b border-red-50 bg-red-50 rounded-t-2xl">
            <h3 class="font-bold text-red-700 text-sm">
                <i class="fas fa-exclamation-circle ml-1.5"></i> تنبيهات حرجة (نواقص وصلاحيات)
            </h3>
            <a href="/Report/StockExpiry" class="text-xs text-red-600 hover:underline font-semibold">تقارير الرقابة</a>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full data-table text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">الدواء</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">التشغيلة</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">التنبيه</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">الإجراء</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.CriticalAlerts.Any())
                    {
                        <tr><td colspan="4" class="text-center py-8 text-gray-400 text-sm">لا توجد تنبيهات حرجة</td></tr>
                    }
                    @foreach (var alert in Model.CriticalAlerts)
                    {
                        var rowBg = alert.AlertSeverity == "error" ? "bg-red-50/50" : "bg-amber-50/50";
                        var badgeCls = alert.AlertSeverity == "error" ? "bg-red-100 text-red-700" : "bg-amber-100 text-amber-700";
                        var actionUrl = alert.AlertType == "نقص حاد" ? "/Purchases/Create" : "/DrugTransfers/Index";
                        var actionText = alert.AlertType == "نقص حاد" ? "شراء" : "تحويل";
                        <tr class="@rowBg border-b border-gray-50 hover:bg-gray-50 transition-colors">
                            <td class="px-4 py-3 font-semibold text-gray-800 text-xs">@alert.DrugName</td>
                            <td class="px-4 py-3 text-gray-500 text-xs">@alert.BatchNo</td>
                            <td class="px-4 py-3"><span class="text-[10px] px-2 py-0.5 rounded-full font-bold @badgeCls">@alert.AlertType</span></td>
                            <td class="px-4 py-3">
                                <a href="@actionUrl" class="text-xs text-blue-600 hover:underline font-semibold">@actionText ←</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- حركة المخزون اليوم -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100">
        <div class="flex justify-between items-center px-5 py-4 border-b border-gray-100">
            <h3 class="font-bold text-gray-800 text-sm">
                <i class="fas fa-exchange-alt text-teal-500 ml-1.5"></i> حركة المخزون اليوم
            </h3>
            <a href="/Inventory/Index" class="text-xs text-blue-600 hover:underline font-semibold">سجل الحركات</a>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full data-table text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">الصنف</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">نوع الحركة</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">الكمية</th>
                        <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">الوقت</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentMovements.Any())
                    {
                        <tr><td colspan="4" class="text-center py-8 text-gray-400 text-sm">لم تسجل حركات مخزنية اليوم</td></tr>
                    }
                    @foreach (var move in Model.RecentMovements)
                    {
                        var isPos = move.Quantity > 0;
                        var qtyColor = isPos ? "text-emerald-600" : "text-red-600";
                        var badge = isPos ? "bg-emerald-50 text-emerald-700" : "bg-red-50 text-red-700";
                        <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors">
                            <td class="px-4 py-3 font-semibold text-gray-800 text-xs">@move.DrugName</td>
                            <td class="px-4 py-3"><span class="text-[10px] px-2 py-0.5 rounded-full font-bold @badge">@move.MovementType</span></td>
                            <td class="px-4 py-3 font-bold @qtyColor" dir="ltr">@(isPos ? "+" : "")@move.Quantity</td>
                            <td class="px-4 py-3 text-gray-400 text-xs">@move.MovementDate.ToString("HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    Chart.defaults.font.family = "'system-ui', sans-serif";
    Chart.defaults.color = '#475569';

    const ctxBar = document.getElementById('inventoryGroupsChart');
    if (ctxBar) {
        new Chart(ctxBar.getContext('2d'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.ValuationLabels)),
                datasets: [{ label: 'قيمة المخزون (@currency)', data: @Html.Raw(Json.Serialize(Model.ValuationData)), backgroundColor: '#0d9488', borderRadius: 4, borderWidth: 0 }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false }, tooltip: { backgroundColor: '#1e293b', rtl: true } },
                scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }
            }
        });
    }

    const ctxD = document.getElementById('stockHealthDoughnut');
    if (ctxD) {
        new Chart(ctxD.getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['متوفر وصالح', 'قارب الانتهاء', 'نواقص/منتهي'],
                datasets: [{ data: [@Model.StockHealthyPercentage, @Model.StockExpiringPercentage, @Model.StockDangerPercentage], backgroundColor: ['#10b981', '#f59e0b', '#ef4444'], borderWidth: 2, borderColor: '#fff', hoverOffset: 4 }]
            },
            options: {
                responsive: true, maintainAspectRatio: false, cutout: '72%',
                plugins: { legend: { display: false }, tooltip: { backgroundColor: '#1e293b', rtl: true } }
            }
        });
    }
</script>
}
