@{
    ViewData["Title"] = "زراعة بيانات المحاكاة (Data Seeder)";
    Layout = "_Layout";
}

<div class="px-8 pb-12 max-w-7xl mx-auto mt-8 animate-in fade-in duration-500">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-6">
        <div class="space-y-1">
            <div class="flex items-center gap-3">
                <div class="p-3 bg-secondary-container rounded-sm shadow-sm shadow-primary/10">
                    <span class="material-symbols-outlined text-primary text-3xl" data-icon="database">database</span>
                </div>
                <div>
                    <h2 class="text-3xl font-extrabold text-primary tracking-tight">عقل المحاكاة <span class="text-outline font-mono">Data Seeder</span></h2>
                    <p class="text-outline text-sm">توليد بيانات وهمية لدعم مخططات التنبؤ والذكاء الاصطناعي</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-3xl mx-auto">
        <div class="bg-surface-container-lowest p-8 rounded-sm shadow-sm border border-surface-container text-center">
            <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6">
                <span class="material-symbols-outlined text-4xl text-primary">auto_awesome</span>
            </div>
            
            <h3 class="text-2xl font-black text-slate-800 mb-4">زراعة البيانات الكبرى للمشروع</h3>
            <p class="text-slate-500 mb-8 leading-relaxed">
                هذه العملية ستقوم بإضافة أدوية لتأكيد الأنماط (صيفي، شتوي، ربيعي)، ثم تنشئ آلاف السجلات من المشتريات والمبيعات مع مراعاة الموسمية لسنتين ماضيتين، وتولّد القيود المحاسبية الآلية بضغطة زر.
            </p>

            <button id="btnSeedData" onclick="startSeeding()" class="bg-gradient-to-bl from-primary to-primary-container text-white px-8 py-4 rounded-sm font-bold flex items-center justify-center gap-3 shadow-sm border border-slate-200 shadow-primary/20 hover:scale-105 active:scale-95 transition-all w-full md:w-2/3 mx-auto text-lg">
                <span class="material-symbols-outlined">play_arrow</span>
                بدء عملية الزراعة (استغراق ~ 2 دقيقة)
            </button>

            <!-- Progress State -->
            <div id="seedProgress" class="hidden mt-8 max-w-md mx-auto">
                <p class="text-primary font-bold mb-3 flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined animate-spin">refresh</span>
                    جاري التوليد وحقن قواعد البيانات...
                </p>
                <div class="w-full bg-slate-100 rounded-full h-2.5 overflow-hidden">
                    <div class="bg-primary h-2.5 rounded-full relative w-full overflow-hidden">
                        <div class="absolute inset-0 bg-white/20 animate-[pulse_1s_ease-in-out_infinite]"></div>
                    </div>
                </div>
            </div>

            <!-- Success State -->
            <div id="seedSuccess" class="hidden mt-8 bg-green-50 text-green-800 p-6 rounded-sm border border-green-200">
                <div class="flex items-center justify-center gap-2 mb-3">
                    <span class="material-symbols-outlined text-green-600 text-3xl">check_circle</span>
                    <h4 class="text-xl font-bold">اكتملت الزراعة بنجاح! 🚀</h4>
                </div>
                <p class="text-sm text-green-700 mb-4">تم تحميل أكثر من 2000 سجل في قاعدة البيانات.</p>
                <a href="/InventoryIntelligence/Index" class="inline-flex items-center gap-2 bg-white text-green-700 px-6 py-2 rounded-sm font-bold border border-green-300 hover:bg-green-100 transition-colors">
                    <span>الذهاب إلى ذكاء المخزون</span>
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
            </div>
            
            <!-- Error State -->
             <div id="seedError" class="hidden mt-8 bg-rose-50 text-error p-6 rounded-sm border border-rose-200">
                <div class="flex items-center justify-center gap-2 mb-3">
                    <span class="material-symbols-outlined text-error text-3xl">error</span>
                    <h4 class="text-xl font-bold">حدث خطأ</h4>
                </div>
                <p id="errorMessage" class="text-sm text-rose-700"></p>
                <button onclick="resetUI()" class="mt-4 bg-white text-error px-4 py-2 rounded-sm font-bold border border-rose-300 hover:bg-rose-100 transition-colors">إعادة المحاولة</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function resetUI() {
             document.getElementById('seedError').classList.add('hidden');
             document.getElementById('btnSeedData').classList.remove('hidden');
             document.getElementById('btnSeedData').classList.add('flex');
        }

        function startSeeding() {
            if(!confirm("احذر: هذه العملية ستقوم بإضافة آلاف السجلات. هذه الميزة مصممة لعرض مشروع التخرج فقط. هل تود المتابعة؟")) return;
            
            document.getElementById('btnSeedData').classList.add('hidden');
            document.getElementById('btnSeedData').classList.remove('flex');
            document.getElementById('seedProgress').classList.remove('hidden');
            document.getElementById('seedError').classList.add('hidden');
            
            fetch('/DataSeeder/SeedAllData', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(res => res.json())
            .then(data => {
                document.getElementById('seedProgress').classList.add('hidden');
                if (data.success) {
                    document.getElementById('seedSuccess').classList.remove('hidden');
                } else {
                    showError(data.message || "عذراً، حدث خطأ غير معروف.");
                }
            })
            .catch(err => {
                document.getElementById('seedProgress').classList.add('hidden');
                showError("حدث خطأ في الاتصال بالخادم. قد تكون العملية استغرقت وقتاً طويلاً. تحقق من السجلات.");
            });
        }
        
        function showError(msg) {
             document.getElementById('seedError').classList.remove('hidden');
             document.getElementById('errorMessage').innerText = msg;
        }
    </script>
}
