@model IEnumerable<PharmaSmartWeb.Models.Accounts>

@{
    ViewData["Title"] = "شجرة الحسابات المالية";
    var sortedAccounts = Model.OrderBy(a => a.AccountCode).ToList();
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .enterprise-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .enterprise-table th { background: #f1f5f9; padding: 8px 12px; border-bottom: 1px solid #cbd5e1; border-top: 1px solid #cbd5e1; color: #334155; font-weight: 700; text-align: right; }
    .enterprise-table td { padding: 8px 12px; border-bottom: 1px solid #f1f5f9; color: #1e293b; }
    .enterprise-table tr:hover td { background: #f8fafc; }
    .status-dot-green { width: 8px; height: 8px; border-radius: 50%; background: #059669; display: inline-block; }
    .status-dot-red { width: 8px; height: 8px; border-radius: 50%; background: #e11d48; display: inline-block; }
    .btn-primary { background: #063955; color: white; border: none; padding: 7px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; }
    .btn-primary:hover { background: #0a4f72; color: white; }
    .btn-sm { padding: 4px 8px; font-size: 11px; border-radius: 2px; font-weight: 700; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 3px; }
    .btn-add { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
    .btn-edit { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; }
    .account-type { display: inline-block; padding: 2px 8px; border-radius: 2px; font-size: 10px; font-weight: 700; }
    .page-title { font-size: 16px; font-weight: 700; color: #063955; }
    .page-sub { font-size: 12px; color: #64748b; }
    .toggle-btn { width: 22px; height: 22px; border-radius: 2px; background: #f1f5f9; border: 1px solid #e2e8f0; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; font-size: 14px; }
    @@media print {
        #accountsTree > div { display: table-row !important; }
        .no-print { display: none !important; }
    }
</style>

<!-- Page Header -->
<div class="enterprise-panel mb-4 p-3 flex justify-between items-center">
    <div>
        <h1 class="page-title">الدليل المحاسبي</h1>
        <p class="page-sub">إدارة وتصنيف الهيكل المالي للمنشأة. يمكنك توسيع أو طي الحسابات لعرض التفاصيل الفرعية بكل سهولة وتحديثها.</p>
    </div>
    <div style="display:flex; gap:8px;" class="no-print">
        <button onclick="window.print()" class="btn-primary" style="background:#475569;">
            <span class="material-symbols-outlined" style="font-size:16px;">print</span>
            طباعة الدليل
        </button>
        <a href="/Accounting/Create" class="btn-primary">
            <span class="material-symbols-outlined" style="font-size:16px;">add_circle</span>
            فتح حساب رئيسي
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="enterprise-panel mb-4 p-3 flex items-center gap-3" style="border-right: 4px solid #059669;">
        <span class="material-symbols-outlined" style="color:#059669; font-size: 18px;">check_circle</span>
        <span style="font-size:13px; color:#059669; font-weight:600;">@TempData["Success"]</span>
    </div>
}

<!-- Accounts Tree Table -->
<div class="enterprise-panel">
    <div style="background:#f8fafc; border-bottom:1px solid #e2e8f0; padding:10px 16px; font-size:13px; font-weight:700; color:#063955;">
        شجرة الحسابات المالية — (@sortedAccounts.Count() حساب)
    </div>
    <div style="overflow-x:auto; max-height:75vh; overflow-y:auto;" id="accountsTree">
        <table class="enterprise-table">
            <thead>
                <tr>
                    <th style="width:40%;">اسم ورقم الحساب</th>
                    <th style="text-align:center;">النوع والتصنيف</th>
                    <th style="text-align:center;">طبيعة الحساب</th>
                    <th style="text-align:center;">الحالة</th>
                    <th style="text-align:center;" class="no-print">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var acc in sortedAccounts)
                {
                    int level = acc.AccountCode.Length;
                    bool isLevel1 = acc.ParentAccountId == null || level == 1;
                    bool hasChildren = sortedAccounts.Any(a => a.ParentAccountId == acc.AccountId);
                    string paddingRem = $"{(level - 1) * 20}px";

                    string typeArabic = acc.AccountType switch {
                        "Assets" => "أصول", "Liabilities" => "التزامات", "Equity" => "حقوق ملكية",
                        "Revenue" => "إيرادات", "Expenses" => "مصروفات", _ => acc.AccountType ?? ""
                    };
                    string typeColor = acc.AccountType switch {
                        "Assets" => "#1d4ed8", "Liabilities" => "#e11d48", "Equity" => "#9333ea",
                        "Revenue" => "#059669", "Expenses" => "#d97706", _ => "#475569"
                    };

                    <tr data-account-id="@acc.AccountId"
                        data-parent-id="@(acc.ParentAccountId?.ToString() ?? "root")"
                        style="display: @(isLevel1 ? "table-row" : "none"); @(isLevel1 ? "background:#f8fafc;" : "")">
                        <td>
                            <div style="display:flex; align-items:center; gap:8px; padding-right: @paddingRem;">
                                @if (hasChildren)
                                {
                                    <button type="button" onclick="toggleChildren(this, '@acc.AccountId')" class="toggle-btn no-print">
                                        <span class="material-symbols-outlined toggle-icon" style="font-size:14px; transition:transform 0.2s;">chevron_left</span>
                                    </button>
                                }
                                else
                                {
                                    <span style="width:22px;"></span>
                                }
                                <div>
                                    <div style="font-weight:@(isLevel1 ? "700" : "600"); font-size:@(isLevel1 ? "13px" : "12px"); color:@(isLevel1 ? "#063955" : "#1e293b");">@acc.AccountName</div>
                                    <div style="font-family:monospace; font-size:10px; color:#94a3b8;">@acc.AccountCode</div>
                                </div>
                            </div>
                        </td>
                        <td style="text-align:center;">
                            <span class="account-type" style="background:@(typeColor + "15"); color:@typeColor; border:1px solid @(typeColor + "30");">@typeArabic</span>
                        </td>
                        <td style="text-align:center;">
                            @if (acc.AccountNature)
                            {
                                <span style="font-size:11px; font-weight:700; color:#059669; background:#ecfdf5; padding:2px 8px; border-radius:2px; border:1px solid #a7f3d0;">مدين (Debit)</span>
                            }
                            else
                            {
                                <span style="font-size:11px; font-weight:700; color:#e11d48; background:#fff1f2; padding:2px 8px; border-radius:2px; border:1px solid #fecdd3;">دائن (Credit)</span>
                            }
                        </td>
                        <td style="text-align:center;">
                            @if (acc.IsActive == true)
                            {
                                <span class="status-dot-green"></span>
                            }
                            else
                            {
                                <span class="status-dot-red"></span>
                            }
                        </td>
                        <td style="text-align:center;" class="no-print">
                            <div style="display:flex; justify-content:center; gap:4px;">
                                <a href="/Accounting/Create?parentId=@acc.AccountId" class="btn-sm btn-add" title="إضافة حساب فرعي">
                                    <span class="material-symbols-outlined" style="font-size:13px;">add</span>
                                </a>
                                <a href="/Accounting/Edit/@acc.AccountId" class="btn-sm btn-edit" title="تعديل الحساب">
                                    <span class="material-symbols-outlined" style="font-size:13px;">edit</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!sortedAccounts.Any())
                {
                    <tr>
                        <td colspan="5" style="text-align:center; padding:40px; color:#94a3b8;">
                            <span class="material-symbols-outlined" style="font-size:32px; display:block; margin-bottom:8px;">account_tree</span>
                            الشجرة المحاسبية فارغة. يرجى إضافة حسابات رئيسية لتبدأ.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div style="padding:8px 12px; background:#f8fafc; border-top:1px solid #e2e8f0; font-size:11px; color:#64748b;">
        إجمالي: @sortedAccounts.Count() حساب في الدليل المحاسبي
    </div>
</div>

<style>
    .expanded .toggle-icon { transform: rotate(-90deg) !important; }
</style>

<script>
    function toggleChildren(btn, parentId) {
        const isExpanded = btn.classList.contains('expanded');
        if (isExpanded) {
            btn.classList.remove('expanded');
            hideDescendants(parentId);
        } else {
            btn.classList.add('expanded');
            const rows = document.querySelectorAll('[data-parent-id="' + parentId + '"]');
            rows.forEach(row => { row.style.display = 'table-row'; });
        }
    }

    function hideDescendants(parentId) {
        const rows = document.querySelectorAll('[data-parent-id="' + parentId + '"]');
        rows.forEach(row => {
            row.style.display = 'none';
            const childBtn = row.querySelector('button');
            if (childBtn) childBtn.classList.remove('expanded');
            const childId = row.getAttribute('data-account-id');
            hideDescendants(childId);
        });
    }
</script>
