@model PharmaSmartWeb.Models.Accounts

@{
    ViewData["Title"] = "فتح حساب محاسبي جديد";
    Layout = "_ModalLayout";
    ViewBag.ModalPanelSize = "lg";
    ViewBag.ModalHeaderIcon = "account_balance";
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    @if (ViewBag.Error != null)
    {
        <div class="enterprise-alert-error">
            <span class="material-symbols-outlined" style="font-size:16px;">warning</span>
            @ViewBag.Error
        </div>
    }

    <div class="enterprise-section-title">
        <span class="material-symbols-outlined" style="font-size:18px;">tune</span>
        نطاق وتوجيه الحساب
    </div>

    <div class="enterprise-row" style="margin-bottom:20px;">
        <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;padding:12px 14px;border:1px solid #e2e8f0;border-radius:2px;background:#f8fafc;transition:border-color 0.15s;">
            <input type="radio" asp-for="BranchId" value="@ViewBag.ActiveBranchId" checked style="margin-top:3px;accent-color:#063955;cursor:pointer;" />
            <div>
                <div style="font-size:13px;font-weight:700;color:#063955;display:flex;align-items:center;gap:6px;">
                    <span class="material-symbols-outlined" style="font-size:16px;color:#0284c7;">store</span>
                    حساب مخصص للفرع
                </div>
                <div style="font-size:11px;color:#64748b;margin-top:3px;">مرتبط بالفرع النشط الحالي فقط ويظهر في عملياته.</div>
            </div>
        </label>
        <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;padding:12px 14px;border:1px solid #e2e8f0;border-radius:2px;background:#f8fafc;transition:border-color 0.15s;">
            <input type="radio" asp-for="BranchId" value="" style="margin-top:3px;accent-color:#063955;cursor:pointer;" />
            <div>
                <div style="font-size:13px;font-weight:700;color:#063955;display:flex;align-items:center;gap:6px;">
                    <span class="material-symbols-outlined" style="font-size:16px;color:#059669;">public</span>
                    حساب عام / رئيسي
                </div>
                <div style="font-size:11px;color:#64748b;margin-top:3px;">متاح لجميع الفروع ويستخدم للحسابات التجميعية الشاملة.</div>
            </div>
        </label>
    </div>

    <div class="enterprise-section-title">
        <span class="material-symbols-outlined" style="font-size:18px;">account_tree</span>
        بيانات الحساب
    </div>

    <div class="enterprise-row">
        <div>
            <label class="enterprise-label">الحساب الرئيسي (يتفرع منه) <span style="color:#e11d48;">*</span></label>
            <select asp-for="ParentAccountId" asp-items="ViewBag.ParentAccounts" id="parentAccount"
                    onchange="generateCode()" class="enterprise-select" required>
                <option value="">-- اختر الحساب الرئيسي --</option>
            </select>
        </div>
        <div>
            <label class="enterprise-label">كود الحساب (آلي)</label>
            <input asp-for="AccountCode" id="accountCode" required placeholder="يتم توليده آلياً..."
                   class="enterprise-input" readonly
                   style="font-family:monospace;font-weight:800;background:#f1f5f9;color:#063955;" />
        </div>
    </div>

    <div class="enterprise-row">
        <div>
            <label class="enterprise-label">اسم الحساب المالي <span style="color:#e11d48;">*</span></label>
            <input asp-for="AccountName" required placeholder="مثال: نقدية الصندوق" class="enterprise-input" />
        </div>
        <div>
            <label class="enterprise-label">التصنيف المحاسبي</label>
            <select asp-for="AccountType" id="accountType" required class="enterprise-select" style="pointer-events:none;background:#f1f5f9;color:#063955;">
                <option value="Assets">أصول (Assets)</option>
                <option value="Liabilities">خصوم (Liabilities)</option>
                <option value="Equity">حقوق ملكية (Equity)</option>
                <option value="Revenue">إيرادات (Revenue)</option>
                <option value="Expenses">مصروفات (Expenses)</option>
            </select>
        </div>
    </div>

    <div style="margin-bottom:16px;">
        <label class="enterprise-label">حالة الحساب</label>
        <select asp-for="IsActive" class="enterprise-select" style="max-width:20rem;">
            <option value="true">✅ نشط (متاح للاستخدام)</option>
            <option value="false">🔴 موقوف (غير متاح للعمليات)</option>
        </select>
    </div>

    <div class="enterprise-actions">
        <button type="button" onclick="modalNavigateBack()" class="enterprise-btn-cancel">إلغاء</button>
        <button type="submit" class="enterprise-btn-submit">
            <span class="material-symbols-outlined" style="font-size:16px;">save</span>
            حفظ الحساب
        </button>
    </div>
</form>

<script>
    function generateCode() {
        var parentId = document.getElementById("parentAccount").value;
        if (parentId) {
            fetch('/Accounting/GetNextAccountCode?parentId=' + parentId)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById("accountCode").value = data.code;
                        var typeSelect = document.getElementById("accountType");
                        var firstChar = data.code.charAt(0);
                        if (firstChar === '1') typeSelect.value = "Assets";
                        else if (firstChar === '2') typeSelect.value = "Liabilities";
                        else if (firstChar === '3') typeSelect.value = "Equity";
                        else if (firstChar === '4') typeSelect.value = "Revenue";
                        else if (firstChar === '5' || firstChar === '6') typeSelect.value = "Expenses";
                    }
                });
        } else {
            document.getElementById("accountCode").value = '';
        }
    }
</script>
