@model PharmaSmartWeb.Models.Accounts

@{
    ViewData["Title"] = "فتح حساب محاسبي جديد";
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .form-label { font-size: 12px; font-weight: 700; color: #063955; margin-bottom: 4px; display: block; }
    .form-control { width: 100%; border: 1px solid #cbd5e1; border-radius: 2px; padding: 7px 10px; font-size: 13px; }
    .form-control:focus { outline: none; border-color: #063955; }
    .form-control[readonly] { background: #f1f5f9; color: #063955; font-family: monospace; font-weight: 700; }
    .form-select { width: 100%; border: 1px solid #cbd5e1; border-radius: 2px; padding: 7px 10px; font-size: 13px; background: white; }
    .btn-submit { background: #063955; color: white; border: none; padding: 9px 24px; border-radius: 2px; font-size: 13px; font-weight: 700; cursor: pointer; }
    .btn-submit:hover { background: #0a4f72; }
    .btn-cancel { background: white; color: #475569; border: 1px solid #d1d5db; padding: 9px 20px; border-radius: 2px; font-size: 13px; font-weight: 700; text-decoration: none; display: inline-block; }
    .section-title { font-size: 13px; font-weight: 700; color: #063955; padding-bottom: 8px; border-bottom: 2px solid #063955; margin-bottom: 16px; }
    .alert-error { background: #fff1f2; border-right: 4px solid #e11d48; border-radius: 2px; padding: 10px 14px; font-size: 12px; color: #e11d48; margin-bottom: 16px; }
    .scope-option { border: 1px solid #d1d5db; border-radius: 2px; padding: 12px; cursor: pointer; display: flex; align-items: center; gap: 10px; }
    .scope-option:hover { border-color: #063955; background: #f8fafc; }
</style>

<div class="enterprise-panel mb-4 p-3 flex justify-between items-center">
    <div>
        <h1 style="font-size:16px; font-weight:700; color:#063955;">فتح حساب محاسبي جديد</h1>
        <p style="font-size:12px; color:#64748b;">أضف تفاصيل الحساب المالي الجديد للنظام. سيتم توليد رقم الحساب آلياً بناءً على الحساب الرئيسي.</p>
    </div>
    <a href="/Accounting/Index" class="btn-cancel">← العودة للدليل</a>
</div>

<div class="enterprise-panel" style="padding: 20px;">
    @if (ViewBag.Error != null)
    {
        <div class="alert-error">⚠ @ViewBag.Error</div>
    }

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="section-title">نطاق وتوجيه الحساب</div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;">
            <label class="scope-option">
                <input type="radio" asp-for="BranchId" value="@ViewBag.ActiveBranchId" checked />
                <div>
                    <div style="font-size:12px; font-weight:700; color:#063955;">حساب مخصص للفرع</div>
                    <div style="font-size:11px; color:#64748b;">مرتبط بالفرع النشط الحالي فقط ويظهر في عملياته.</div>
                </div>
            </label>
            <label class="scope-option">
                <input type="radio" asp-for="BranchId" value="" />
                <div>
                    <div style="font-size:12px; font-weight:700; color:#063955;">حساب عام / رئيسي</div>
                    <div style="font-size:11px; color:#64748b;">متاح لجميع الفروع ويستخدم للحسابات التجميعية الشاملة.</div>
                </div>
            </label>
        </div>

        <div class="section-title">بيانات الحساب</div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
            <div>
                <label class="form-label">الحساب الرئيسي (يتفرع منه) <span style="color:#e11d48;">*</span></label>
                <select asp-for="ParentAccountId" asp-items="ViewBag.ParentAccounts" id="parentAccount"
                        onchange="generateCode()" class="form-select" required>
                    <option value="">-- اختر الحساب الرئيسي --</option>
                </select>
            </div>
            <div>
                <label class="form-label">كود الحساب (آلي)</label>
                <input asp-for="AccountCode" id="accountCode" required placeholder="يتم توليده آلياً..." class="form-control" readonly />
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
            <div>
                <label class="form-label">اسم الحساب المالي <span style="color:#e11d48;">*</span></label>
                <input asp-for="AccountName" required placeholder="مثال: نقدية الصندوق" class="form-control" />
            </div>
            <div>
                <label class="form-label">التصنيف المحاسبي</label>
                <select asp-for="AccountType" id="accountType" required class="form-select" style="pointer-events:none; background:#f1f5f9;">
                    <option value="Assets">أصول (Assets)</option>
                    <option value="Liabilities">خصوم (Liabilities)</option>
                    <option value="Equity">حقوق ملكية (Equity)</option>
                    <option value="Revenue">إيرادات (Revenue)</option>
                    <option value="Expenses">مصروفات (Expenses)</option>
                </select>
            </div>
        </div>

        <div style="margin-bottom: 16px;">
            <label class="form-label">حالة الحساب</label>
            <select asp-for="IsActive" class="form-select" style="max-width:280px;">
                <option value="true">نشط (متاح للاستخدام)</option>
                <option value="false">موقوف (غير متاح للعمليات)</option>
            </select>
        </div>

        <div style="display:flex; justify-content:flex-end; gap:10px; padding-top:16px; border-top:1px solid #e2e8f0;">
            <a href="/Accounting/Index" class="btn-cancel">إلغاء</a>
            <button type="submit" class="btn-submit">
                <span class="material-symbols-outlined" style="font-size:15px; vertical-align:middle;">save</span>
                حفظ الحساب
            </button>
        </div>
    </form>
</div>

<script>
    function generateCode() {
        var parentId = document.getElementById("parentAccount").value;
        if (parentId) {
            fetch('/Accounting/GetNextAccountCode?parentId=' + parentId)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById("accountCode").value = data.code;
                        var typeSelect = document.getElementById("accountType");
                        var firstChar = data.code.charAt(0);
                        if (firstChar === '1') typeSelect.value = "Assets";
                        else if (firstChar === '2') typeSelect.value = "Liabilities";
                        else if (firstChar === '3') typeSelect.value = "Equity";
                        else if (firstChar === '4') typeSelect.value = "Revenue";
                        else if (firstChar === '5' || firstChar === '6') typeSelect.value = "Expenses";
                    }
                });
        } else {
            document.getElementById("accountCode").value = '';
        }
    }
</script>
