@model PharmaSmartWeb.Models.Accounts

@{
    ViewData["Title"] = "تعديل الحساب المالي";
    Layout = "_ModalLayout";
    ViewBag.ModalPanelSize = "lg";
    ViewBag.ModalHeaderIcon = "account_balance";
}

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="AccountId" />

    @if (ViewBag.Error != null)
    {
        <div class="enterprise-alert-error">
            <span class="material-symbols-outlined" style="font-size:16px;">warning</span>
            @ViewBag.Error
        </div>
    }

    <!-- معلومات الحساب الحالي -->
    <div class="enterprise-info-box" style="align-items:center;border-right: 4px solid #059669;background:#f0fdf4;">
        <div style="width:40px;height:40px;background:white;border:1px solid #d1fae5;border-radius:2px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <span class="material-symbols-outlined" style="font-size:20px;color:#059669;">account_balance_wallet</span>
        </div>
        <div style="flex:1;">
            <div style="font-size:10px;color:#64748b;font-weight:700;margin-bottom:2px;">الحساب الحالي</div>
            <div style="font-size:13px;font-weight:700;color:#063955;">@Model.AccountName</div>
        </div>
        <div style="font-size:14px;font-weight:800;color:#063955;font-family:monospace;background:white;border:1px solid #e2e8f0;padding:5px 10px;border-radius:2px;">
            @Model.AccountCode
        </div>
    </div>

    <div class="enterprise-section-title">
        <span class="material-symbols-outlined" style="font-size:18px;">tune</span>
        نطاق وتوجيه الحساب
    </div>

    <div class="enterprise-row" style="margin-bottom:20px;">
        <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;padding:12px 14px;border:1px solid #e2e8f0;border-radius:2px;background:#f8fafc;">
            <input type="radio" asp-for="BranchId" value="@ViewBag.ActiveBranchId" class="radio-input" style="margin-top:3px;accent-color:#063955;" />
            <div>
                <div style="font-size:13px;font-weight:700;color:#063955;display:flex;align-items:center;gap:6px;">
                    <span class="material-symbols-outlined" style="font-size:16px;color:#0284c7;">store</span>
                    حساب مخصص للفرع
                </div>
                <div style="font-size:11px;color:#64748b;margin-top:3px;">مرتبط بالفرع النشط الحالي فقط ويظهر في عملياته.</div>
            </div>
        </label>
        <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;padding:12px 14px;border:1px solid #e2e8f0;border-radius:2px;background:#f8fafc;">
            <input type="radio" asp-for="BranchId" value="" class="radio-input" style="margin-top:3px;accent-color:#063955;" />
            <div>
                <div style="font-size:13px;font-weight:700;color:#063955;display:flex;align-items:center;gap:6px;">
                    <span class="material-symbols-outlined" style="font-size:16px;color:#059669;">public</span>
                    حساب عام / رئيسي
                </div>
                <div style="font-size:11px;color:#64748b;margin-top:3px;">متاح لجميع الفروع ويستخدم للحسابات التجميعية الشاملة.</div>
            </div>
        </label>
    </div>

    <div class="enterprise-section-title">
        <span class="material-symbols-outlined" style="font-size:18px;">account_tree</span>
        بيانات الحساب
    </div>

    <div style="margin-bottom:16px;">
        <label class="enterprise-label">الحساب الرئيسي (يتفرع منه)</label>
        <select asp-for="ParentAccountId" asp-items="ViewBag.ParentAccounts" class="enterprise-select">
            <option value="">-- حساب جذري (في المستوى الأول) --</option>
        </select>
    </div>

    <div class="enterprise-row">
        <div>
            <label class="enterprise-label">كود الحساب</label>
            <input asp-for="AccountCode" required class="enterprise-input" dir="ltr" style="font-family:monospace;font-weight:800;" />
        </div>
        <div>
            <label class="enterprise-label">اسم الحساب المالي</label>
            <input asp-for="AccountName" required class="enterprise-input" />
        </div>
    </div>

    <div class="enterprise-row">
        <div style="opacity:0.75;pointer-events:none;">
            <label class="enterprise-label">التصنيف المحاسبي</label>
            <select asp-for="AccountType" required class="enterprise-select">
                <option value="Assets">أصول (Assets)</option>
                <option value="Liabilities">خصوم (Liabilities)</option>
                <option value="Equity">حقوق ملكية (Equity)</option>
                <option value="Revenue">إيرادات (Revenue)</option>
                <option value="Expenses">مصروفات (Expenses)</option>
            </select>
        </div>
        <div>
            <label class="enterprise-label">حالة الحساب</label>
            <select asp-for="IsActive" class="enterprise-select">
                <option value="true">✅ نشط (متاح للاستخدام)</option>
                <option value="false">🔴 موقوف (غير متاح للعمليات)</option>
            </select>
        </div>
    </div>

    <div class="enterprise-actions">
        <button type="button" onclick="modalNavigateBack()" class="enterprise-btn-cancel">إلغاء والتراجع</button>
        <button type="submit" class="enterprise-btn-warning">
            <span class="material-symbols-outlined" style="font-size:16px;">check_circle</span>
            حفظ التعديلات
        </button>
    </div>
</form>
