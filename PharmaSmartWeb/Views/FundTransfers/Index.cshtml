@model IEnumerable<PharmaSmartWeb.Models.Fundtransfers>

@{
    ViewData["Title"] = "سجل التحويلات المالية";
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .enterprise-header { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 10px 16px; font-size: 13px; font-weight: 700; color: #063955; }
    .enterprise-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .enterprise-table th { background: #f1f5f9; padding: 8px 12px; border-bottom: 1px solid #cbd5e1; border-top: 1px solid #cbd5e1; color: #334155; font-weight: 700; text-align: right; }
    .enterprise-table td { padding: 8px 12px; border-bottom: 1px solid #e2e8f0; color: #1e293b; }
    .enterprise-table tr:hover td { background: #f8fafc; }
    .btn-primary { background: #063955; color: white; border: none; padding: 7px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; }
    .btn-primary:hover { background: #0a4f72; color: white; }
    .btn-sm { padding: 4px 10px; font-size: 11px; border-radius: 2px; font-weight: 700; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
    .page-title { font-size: 16px; font-weight: 700; color: #063955; }
    .page-sub { font-size: 12px; color: #64748b; }
</style>

<!-- Page Header -->
<div class="enterprise-panel mb-4 p-3 flex justify-between items-center">
    <div>
        <h1 class="page-title">التحويلات المالية الداخلية</h1>
        <p class="page-sub">حركة نقل السيولة بين الصناديق والبنوك (Contra Entries).</p>
    </div>
    <a href="/FundTransfers/Create" class="btn-primary">
        <span class="material-symbols-outlined" style="font-size:16px;">swap_horiz</span>
        إجراء تحويل مالي
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="enterprise-panel mb-4 p-3 flex items-center gap-3" style="border-right: 4px solid #059669;">
        <span class="material-symbols-outlined" style="color:#059669; font-size:18px;">check_circle</span>
        <span style="font-size:13px; color:#059669; font-weight:600;">@TempData["Success"]</span>
    </div>
}

<!-- Data Table -->
<div class="enterprise-panel">
    <div class="enterprise-header">سجل التحويلات المالية — (@Model.Count() تحويل)</div>
    <div style="overflow-x:auto;">
        <table class="enterprise-table">
            <thead>
                <tr>
                    <th>رقم التحويل</th>
                    <th>التاريخ والوقت</th>
                    <th>من حساب (المرسل)</th>
                    <th>إلى حساب (المستقبل)</th>
                    <th style="text-align:center;">المبلغ</th>
                    <th style="text-align:center;">القيد</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" style="text-align:center; padding:40px; color:#94a3b8;">
                            <span class="material-symbols-outlined" style="font-size:32px; display:block; margin-bottom:8px;">swap_horiz</span>
                            لا توجد تحويلات مالية مسجلة في هذا الفرع.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong style="font-family:monospace; color:#063955;">#TRX-@item.TransferId.ToString("D5")</strong></td>
                        <td style="font-size:11px; color:#64748b;" dir="ltr">@item.TransferDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <div style="display:flex; align-items:center; gap:4px;">
                                <span class="material-symbols-outlined" style="font-size:13px; color:#e11d48;">arrow_upward</span>
                                <span>@item.FromAccount?.AccountName</span>
                            </div>
                        </td>
                        <td>
                            <div style="display:flex; align-items:center; gap:4px;">
                                <span class="material-symbols-outlined" style="font-size:13px; color:#059669;">arrow_downward</span>
                                <span>@item.ToAccount?.AccountName</span>
                            </div>
                        </td>
                        <td style="text-align:center; font-weight:700; font-size:13px; font-family:monospace;">
                            @item.Amount.ToString("N2") @ViewBag.CurrencySymbol
                        </td>
                        <td style="text-align:center;">
                            @if (item.JournalId != null)
                            {
                                <a href="/JournalEntries/Details/@item.JournalId" class="btn-sm" title="عرض القيد المحاسبي">
                                    <span class="material-symbols-outlined" style="font-size:13px;">receipt_long</span>
                                    القيد
                                </a>
                            }
                            else
                            {
                                <span style="color:#94a3b8; font-size:11px;">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div style="padding:8px 12px; background:#f8fafc; border-top:1px solid #e2e8f0; font-size:11px; color:#64748b;">
        إجمالي: @Model.Count() تحويل مالي — مجموع المبالغ: @Model.Sum(x => x.Amount).ToString("N2") @ViewBag.CurrencySymbol
    </div>
</div>