@model IEnumerable<PharmaSmartWeb.Models.Branchinventory>

@{
    ViewData["Title"] = "جرد المخزون الداخلي";
    var totalItems = Model.Count();
    var depletedItems = Model.Count(x => x.StockQuantity <= 0);
    var nearShortages = Model.Count(x => x.StockQuantity <= x.MinimumStockLevel && x.StockQuantity > 0);
    var safeItems = totalItems - depletedItems - nearShortages;
}

<!-- ===== رأس الصفحة ===== -->
<div class="flex flex-wrap justify-between items-start mb-5">
    <div class="flex items-center gap-3 mb-2 sm:mb-0">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-teal-600 to-emerald-700 flex items-center justify-center shadow-sm">
            <i class="fas fa-warehouse text-white"></i>
        </div>
        <div>
            <h1 class="text-xl font-black text-gray-800">جرد المخزون الداخلي</h1>
            <p class="text-xs text-gray-500">
                مراقبة الحالة اللحظية لـ <span class="font-bold text-sky-600">@ViewBag.BranchName</span>
            </p>
        </div>
    </div>
    <div class="flex gap-2 flex-wrap items-center">
        @if (depletedItems > 0 || nearShortages > 0)
        {
            <a href="/Inventory/Shortages"
               class="bg-red-50 border border-red-200 text-red-700 px-3 py-2 rounded-xl text-xs font-bold flex items-center gap-1.5 transition-colors hover:bg-red-100">
                <i class="fas fa-exclamation-triangle text-[10px]"></i> عرض النواقص (@(depletedItems + nearShortages))
            </a>
        }
        <a href="/Inventory/ReceiveGoodsCreate"
           class="quick-action-btn px-4 py-2 bg-teal-600 hover:bg-teal-700 text-white rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5">
            <i class="fas fa-boxes"></i> استقبال بضاعة
        </a>
        <button onclick="window.print()"
            class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl text-xs font-bold flex items-center gap-2 transition-colors print:hidden">
            <i class="fas fa-print text-gray-500"></i> طباعة
        </button>
    </div>
</div>

<!-- ===== بطاقات KPI ===== -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-5 print:hidden">
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-sky-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">إجمالي الأصناف</span>
            <i class="fas fa-pills text-sky-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@totalItems</div>
        <span class="text-xs text-gray-400">صنف في المخزون</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-emerald-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-emerald-700 font-semibold">أصناف آمنة</span>
            <i class="fas fa-check-circle text-emerald-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-emerald-600">@safeItems</div>
        <span class="text-xs text-gray-400">فوق حد الأمان</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-amber-400">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-amber-700 font-semibold">تحت حد الطلب</span>
            <i class="fas fa-arrow-down text-amber-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-amber-600">@nearShortages</div>
        <span class="text-xs text-gray-400">صنف يحتاج طلب</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-red-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-red-700 font-semibold">أصناف نافدة</span>
            <i class="fas fa-times-circle text-red-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-red-700">@depletedItems</div>
        <a href="/Purchases/Create" class="text-xs text-red-600 font-semibold hover:underline">طلب شراء عاجل ←</a>
    </div>
</div>

<!-- ===== جدول الجرد ===== -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100">
    <div class="flex justify-between items-center px-5 py-4 border-b border-gray-100">
        <h3 class="font-bold text-gray-800 text-sm">
            <i class="fas fa-list text-teal-500 ml-1.5"></i> سجل الجرد الداخلي
        </h3>
        <div class="relative print:hidden">
            <i class="fas fa-search absolute right-3 top-2.5 text-gray-400 text-xs"></i>
            <input id="invSearch" type="text" placeholder="بحث..."
                oninput="filterInv(this.value)"
                class="pr-8 pl-4 py-2 border border-gray-200 rounded-xl text-xs w-44 focus:outline-none focus:ring-2 focus:ring-teal-400" />
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full data-table text-sm" id="invTable">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">كود الدواء</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">الاسم التجاري</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">النطاق / الفرع</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">الرصيد الفعلي</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">حد الأمان</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">الحالة</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-12 text-gray-400">
                            <i class="fas fa-warehouse text-5xl mb-3 block text-gray-200"></i>
                            لا توجد أصناف مسجلة في هذا المستودع
                        </td>
                    </tr>
                }
                @foreach (var item in Model.OrderBy(i => i.Drug?.DrugName))
                {
                    var isDepleted = item.StockQuantity <= 0;
                    var isLow = item.StockQuantity <= item.MinimumStockLevel;
                    var qtyColor = isDepleted ? "text-red-700 font-black" : isLow ? "text-amber-600 font-black" : "text-emerald-600 font-semibold";
                    var statusText = isDepleted ? "نافد" : isLow ? "منخفض" : "آمن";
                    var statusBg = isDepleted ? "bg-red-50 text-red-700 border-red-100" : isLow ? "bg-amber-50 text-amber-700 border-amber-100" : "bg-emerald-50 text-emerald-700 border-emerald-100";
                    <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors inv-row">
                        <td class="px-5 py-3 font-mono text-sky-600 font-bold">#@item.DrugId.ToString("D4")</td>
                        <td class="px-5 py-3 font-semibold text-gray-800 inv-name">@item.Drug?.DrugName</td>
                        <td class="px-5 py-3">
                            <span class="text-[11px] px-2 py-0.5 bg-gray-100 border border-gray-200 text-gray-600 rounded-full font-semibold">
                                @(item.Branch?.BranchName ?? "مجمع الفروع")
                            </span>
                        </td>
                        <td class="px-5 py-3 text-center font-mono text-lg @qtyColor">@item.StockQuantity</td>
                        <td class="px-5 py-3 text-center font-mono text-gray-400">@item.MinimumStockLevel</td>
                        <td class="px-5 py-3">
                            <span class="text-[11px] px-2.5 py-1 border rounded-full font-bold @statusBg">@statusText</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
function filterInv(val) {
    const q = val.toLowerCase().trim();
    document.querySelectorAll('.inv-row').forEach(r => {
        const name = r.querySelector('.inv-name')?.innerText.toLowerCase() ?? '';
        r.style.display = q === '' || name.includes(q) ? '' : 'none';
    });
}
</script>
}