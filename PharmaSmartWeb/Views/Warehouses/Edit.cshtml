@model PharmaSmartWeb.Models.Warehouses

@{
    ViewData["Title"] = $"تعديل هيكل وتصنيفات: {Model.WarehouseName}";
    Layout = "_ModalLayout";
    ViewBag.ModalPanelSize = "lg";
    ViewBag.ModalHeaderIcon = "warehouse";

    string errorMsg = ViewBag.Error as string;
    string groupsJson = ViewBag.ItemGroupsJson as string ?? "[]";
}

@if (!string.IsNullOrEmpty(errorMsg))
{
    <div class="enterprise-alert-error">
        <span class="material-symbols-outlined" style="font-size:16px;">warning</span>
        @errorMsg
    </div>
}

<form asp-action="Edit" method="post" id="warehouseForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="WarehouseId" />

    <div class="enterprise-section-title">بيانات المستودع</div>

    <div class="enterprise-row">
        <div>
            <label class="enterprise-label">اسم المستودع <span style="color:#e11d48;">*</span></label>
            <input asp-for="WarehouseName" required class="enterprise-input" />
        </div>
        <div>
            <label class="enterprise-label">الموقع والتصنيف</label>
            <input asp-for="Location" class="enterprise-input" />
        </div>
    </div>

    <div style="border:1px solid #e2e8f0;border-radius:2px;padding:12px 16px;display:flex;justify-content:space-between;align-items:center;background:#f8fafc;flex-wrap:wrap;gap:12px;margin-bottom:20px;">
        <div>
            <div style="font-size:13px;font-weight:700;color:#0f172a;">حالة المستودع</div>
            <div style="font-size:11px;color:#64748b;margin-top:2px;">إذا تم الإيقاف، لا يمكن للمستخدمين النقل منه أو الصرف المباشر.</div>
        </div>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;background:white;padding:6px 12px;border:1px solid #cbd5e1;border-radius:2px;">
            <input type="checkbox" name="IsActive" value="true" @(Model.IsActive == true ? "checked" : "") style="width:15px;height:15px;cursor:pointer;accent-color:#063955;" />
            <input type="hidden" name="IsActive" value="false" />
            <span style="font-size:12px;font-weight:700;color:#063955;">@(Model.IsActive == true ? "نشط" : "غير نشط")</span>
        </label>
    </div>

    <!-- جدول الرفوف -->
    <div class="ph-modal-toolbar">
        <div style="display:flex;align-items:center;gap:0.35rem;">
            <span class="material-symbols-outlined text-[18px] opacity-95">shelves</span>
            <span style="font-size:0.75rem;font-weight:800;">أماكن التخزين (الرفوف / Zones)</span>
        </div>
        <button type="button" onclick="addShelfRow()" class="ph-btn-toolbar">
            <span class="material-symbols-outlined" style="font-size:14px;">add</span> رف إضافي
        </button>
    </div>
    <div class="ph-modal-toolbar-body" style="max-height:min(40vh,320px);overflow-y:auto;">
        <table style="width:100%;text-align:right;border-collapse:collapse;font-size:0.75rem;">
            <thead style="background:#f8fafc;position:sticky;top:0;z-index:1;">
                <tr>
                    <th style="padding:8px 12px;border-bottom:1px solid #e2e8f0;width:150px;">كود الرف</th>
                    <th style="padding:8px 12px;border-bottom:1px solid #e2e8f0;">المجموعة المرتبطة</th>
                    <th style="padding:8px 12px;border-bottom:1px solid #e2e8f0;width:50px;text-align:center;">إزالة</th>
                </tr>
            </thead>
            <tbody id="shelvesBody">
                @{ int i = 0; }
                @if (Model.Shelves != null)
                {
                    foreach (var shelf in Model.Shelves)
                    {
                        <tr id="shelfRow_@i" style="border-bottom:1px solid #e2e8f0;">
                            <td style="padding:6px 12px;">
                                <input type="hidden" name="Shelves[@i].ShelfId" value="@shelf.ShelfId" />
                                <input type="text" name="Shelves[@i].ShelfName" value="@shelf.ShelfName" required
                                       style="width:100%;border:1px solid #cbd5e1;border-radius:4px;padding:5px;font-family:monospace;font-weight:700;text-transform:uppercase;text-align:center;" />
                            </td>
                            <td style="padding:6px 12px;">
                                <select name="Shelves[@i].GroupId" class="shelf-group-select enterprise-select" data-selected="@shelf.GroupId" style="padding:5px;font-size:12px;">
                                    <option value="">-- عام (بدون تخصيص) --</option>
                                </select>
                                <input type="hidden" name="Shelves[@i].IsActive" value="true">
                            </td>
                            <td style="padding:6px 12px;text-align:center;">
                                <button type="button" onclick="removeShelf(@i)" style="background:#fff1f2;color:#e11d48;border:1px solid #fecdd3;border-radius:4px;width:28px;height:28px;display:inline-flex;align-items:center;justify-content:center;cursor:pointer;">
                                    <span class="material-symbols-outlined" style="font-size:14px;">delete</span>
                                </button>
                            </td>
                        </tr>
                        i++;
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="enterprise-actions">
        <button type="button" onclick="modalNavigateBack()" class="enterprise-btn-cancel">
            <span class="material-symbols-outlined" style="font-size:16px;">cancel</span>
            تراجع
        </button>
        <button type="submit" class="enterprise-btn-warning">
            <span class="material-symbols-outlined" style="font-size:16px;">sync_alt</span>
            حفظ تحديثات المستودع
        </button>
    </div>
</form>

@section Scripts {
    <script>
        const itemGroups = @Html.Raw(groupsJson);
        let shelfIndex = @(Model.Shelves?.Count ?? 0);

        window.onload = function() {
            const selects = document.querySelectorAll('.shelf-group-select');
            selects.forEach(select => {
                const selectedVal = select.getAttribute('data-selected');
                itemGroups.forEach(g => {
                    const isSelected = (selectedVal == g.id) ? "selected" : "";
                    select.insertAdjacentHTML('beforeend', `<option value="${g.id}" ${isSelected}>${g.name}</option>`);
                });
            });
        };

        function addShelfRow() {
            let groupOptions = '<option value="">-- عام (بدون تخصيص) --</option>';
            itemGroups.forEach(g => {
                groupOptions += `<option value="${g.id}">${g.name}</option>`;
            });

            const html = `
                <tr id="shelfRow_${shelfIndex}" style="border-bottom:1px solid #e2e8f0;">
                    <td style="padding:6px 12px;">
                        <input type="hidden" name="Shelves[${shelfIndex}].ShelfId" value="0" />
                        <input type="text" name="Shelves[${shelfIndex}].ShelfName" placeholder="A-01" required
                               style="width:100%;border:1px solid #cbd5e1;border-radius:4px;padding:5px;font-family:monospace;font-weight:700;text-transform:uppercase;text-align:center;" />
                    </td>
                    <td style="padding:6px 12px;">
                        <select name="Shelves[${shelfIndex}].GroupId" class="enterprise-select" style="padding:5px;font-size:12px;">
                            ${groupOptions}
                        </select>
                        <input type="hidden" name="Shelves[${shelfIndex}].IsActive" value="true">
                    </td>
                    <td style="padding:6px 12px;text-align:center;">
                        <button type="button" onclick="removeShelf(${shelfIndex})" style="background:#fff1f2;color:#e11d48;border:1px solid #fecdd3;border-radius:4px;width:28px;height:28px;display:inline-flex;align-items:center;justify-content:center;cursor:pointer;">
                            <span class="material-symbols-outlined" style="font-size:14px;">delete</span>
                        </button>
                    </td>
                </tr>
            `;

            document.getElementById('shelvesBody').insertAdjacentHTML('beforeend', html);
            shelfIndex++;
        }

        function removeShelf(index) {
            document.getElementById(`shelfRow_${index}`).remove();
        }
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
