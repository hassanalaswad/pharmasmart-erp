@model IEnumerable<PharmaSmartWeb.Models.Warehouses>

@{
    ViewData["Title"] = "إدارة المستودعات والرفوف";
}

@if (TempData["Success"] != null)
{
    <div class="bg-emerald-50 border border-emerald-200 border-r-4 border-r-emerald-500 rounded-xl p-3 mb-4 flex items-center gap-2 text-sm text-emerald-700">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}

<!-- ===== رأس الصفحة ===== -->
<div class="flex flex-wrap justify-between items-start mb-5">
    <div class="flex items-center gap-3 mb-2 sm:mb-0">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-blue-700 flex items-center justify-center shadow-sm">
            <i class="fas fa-warehouse text-white"></i>
        </div>
        <div>
            <h1 class="text-xl font-black text-gray-800">إدارة المستودعات والرفوف</h1>
            <p class="text-xs text-gray-500">مراقبة أماكن التخزين وتوجيه المجموعات الدوائية (Bin Locations)</p>
        </div>
    </div>
    <div class="flex gap-2 flex-wrap">
        <a href="/Warehouses/Create" class="quick-action-btn px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5 active:scale-95">
            <i class="fas fa-plus-circle"></i> إضافة مستودع جديد
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12 text-center">
        <i class="fas fa-boxes text-5xl mb-4 block text-gray-200"></i>
        <h3 class="text-lg font-bold text-gray-700 mb-1">لا توجد مستودعات</h3>
        <p class="text-sm text-gray-500">الرجاء إضافة مستودع للبدء بتنظيم التخزين</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        @foreach (var warehouse in Model)
        {
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col transition-all hover:shadow-md">
                <div class="px-4 py-3 bg-gray-50 border-b border-gray-100 flex justify-between items-center">
                    <div>
                        <div class="flex items-center gap-2">
                            <i class="fas fa-warehouse text-indigo-600"></i>
                            <strong class="text-sm font-bold text-gray-800">@warehouse.WarehouseName</strong>
                            @if (warehouse.IsActive == true)
                            {
                                <span class="bg-emerald-50 text-emerald-700 border border-emerald-200 px-2.5 py-0.5 rounded-full text-[10px] font-bold">نشط</span>
                            }
                            else
                            {
                                <span class="bg-red-50 text-red-700 border border-red-200 px-2.5 py-0.5 rounded-full text-[10px] font-bold">موقوف</span>
                            }
                        </div>
                        <div class="flex items-center gap-1 text-[11px] text-gray-500 mt-1">
                            <i class="fas fa-map-marker-alt text-gray-400"></i>
                            @(string.IsNullOrEmpty(warehouse.Location) ? "الموقع غير محدد" : warehouse.Location)
                        </div>
                    </div>
                    <a href="/Warehouses/Edit/@warehouse.WarehouseId" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white hover:bg-indigo-50 border border-gray-200 hover:border-indigo-200 text-gray-600 hover:text-indigo-700 rounded-lg text-xs font-semibold transition-colors">
                        <i class="fas fa-pen text-[10px]"></i> تعديل
                    </a>
                </div>

                <div class="p-4 flex-1">
                    <div class="text-[11px] font-bold text-gray-500 mb-3 flex items-center justify-between">
                        <span>الرفوف المتوفرة (@warehouse.Shelves.Count)</span>
                        <i class="fas fa-layer-group text-gray-300"></i>
                    </div>

                    @if (!warehouse.Shelves.Any())
                    {
                        <div class="bg-gray-50 rounded-xl p-4 text-center border border-dashed border-gray-200">
                            <p class="text-xs text-gray-500">لا توجد رفوف مضافة لهذا المستودع</p>
                        </div>
                    }
                    else
                    {
                        <div class="grid grid-cols-2 gap-2">
                            @foreach (var shelf in warehouse.Shelves)
                            {
                                <div class="flex items-center gap-2.5 px-3 py-2 bg-gray-50 border border-gray-100 rounded-xl hover:border-indigo-200 transition-colors">
                                    <div class="w-8 h-8 rounded-lg bg-orange-100 text-orange-600 flex items-center justify-center shrink-0">
                                        <i class="fas fa-bars"></i>
                                    </div>
                                    <div>
                                        <div class="font-bold text-xs text-gray-800 font-mono">@shelf.ShelfName</div>
                                        <div class="text-[10px] text-gray-500 mt-0.5 whitespace-nowrap overflow-hidden text-ellipsis w-[100px]" title="@(shelf.ItemGroup?.GroupName ?? "عام (الكل)")">
                                            @(shelf.ItemGroup != null ? shelf.ItemGroup.GroupName : "عام (الكل)")
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}