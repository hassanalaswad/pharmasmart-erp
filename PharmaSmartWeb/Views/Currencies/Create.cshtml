@model PharmaSmartWeb.Models.Currencies
@{
    Layout = "_ModalLayout";
    ViewData["Title"] = "إضافة عملة جديدة";
    ViewBag.ModalPanelSize = "md";
    ViewBag.ModalHeaderIcon = "payments";
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    @if (ViewBag.Error != null)
    {
        <div class="enterprise-alert-error">
            <span class="material-symbols-outlined" style="font-size:16px;">warning</span>
            @ViewBag.Error
        </div>
    }

    <div class="enterprise-section-title">بيانات العملة</div>

    <div class="enterprise-row">
        <div>
            <label class="enterprise-label">اسم العملة <span style="color:#e11d48;">*</span></label>
            <input type="text" asp-for="CurrencyName" required autocomplete="off" placeholder="أدخل اسم العملة..." class="enterprise-input" />
            <span asp-validation-for="CurrencyName" style="color:#e11d48;font-size:11px;display:block;margin-top:4px;"></span>
        </div>
        <div>
            <label class="enterprise-label">كود العملة (ISO) <span style="color:#e11d48;">*</span></label>
            <input type="text" asp-for="CurrencyCode" required autocomplete="off" placeholder="أدخل كود العملة..." class="enterprise-input" style="font-family:monospace;text-transform:uppercase;" />
            <span asp-validation-for="CurrencyCode" style="color:#e11d48;font-size:11px;display:block;margin-top:4px;"></span>
        </div>
    </div>

    <div style="margin-bottom:16px;">
        <label class="enterprise-label">سعر الصرف مقابل العملة المرجعية <span style="color:#e11d48;">*</span></label>
        <input type="number" asp-for="ExchangeRate" step="0.0001" min="0.0001" required placeholder="1.0000"
               class="enterprise-input" style="font-family:monospace;font-weight:800;max-width:16rem;" />
        <div style="font-size:11px;color:#64748b;margin-top:6px;">
            <span class="material-symbols-outlined" style="font-size:12px;vertical-align:middle;">info</span>
            سعر الصرف مقابل العملة الرئيسية للنظام. للعملة الأساسية اجعله 1.0000
        </div>
        <span asp-validation-for="ExchangeRate" style="color:#e11d48;font-size:11px;display:block;margin-top:4px;"></span>
    </div>

    <div class="enterprise-section-title" style="margin-top:24px;">إعدادات العملة</div>

    <div class="enterprise-row">
        <label style="display:flex;align-items:center;gap:10px;cursor:pointer;padding:10px 14px;border:1px solid #e2e8f0;border-radius:2px;background:#f8fafc;">
            <input type="checkbox" asp-for="IsBaseCurrency" style="width:15px;height:15px;cursor:pointer;accent-color:#063955;flex-shrink:0;" />
            <div>
                <div style="font-size:13px;font-weight:700;color:#0f172a;">العملة الأساسية (المرجعية)</div>
                <div style="font-size:11px;color:#64748b;margin-top:2px;">تحديد هذه العملة كعملة مرجعية للنظام</div>
            </div>
        </label>
        <label style="display:flex;align-items:center;gap:10px;cursor:pointer;padding:10px 14px;border:1px solid #e2e8f0;border-radius:2px;background:#f8fafc;">
            <input type="checkbox" asp-for="IsActive" checked style="width:15px;height:15px;cursor:pointer;accent-color:#063955;flex-shrink:0;" />
            <div>
                <div style="font-size:13px;font-weight:700;color:#0f172a;">العملة نشطة</div>
                <div style="font-size:11px;color:#64748b;margin-top:2px;">تفعيل استخدام هذه العملة في النظام</div>
            </div>
        </label>
    </div>

    <div class="enterprise-actions">
        <button type="button" onclick="modalNavigateBack()" class="enterprise-btn-cancel">
            <span class="material-symbols-outlined" style="font-size:16px;">close</span>
            إلغاء
        </button>
        <button type="submit" class="enterprise-btn-submit">
            <span class="material-symbols-outlined" style="font-size:16px;">add_circle</span>
            إضافة العملة
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
