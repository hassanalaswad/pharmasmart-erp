@model PharmaSmartWeb.Models.Currencies
@{
    Layout = "_ModalLayout";
    ViewData["Title"] = "إضافة عملة جديدة";
    ViewBag.ModalPanelSize = "md";
    ViewBag.ModalHeaderIcon = "payments";
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    @if (ViewBag.Error != null)
    {
        <div class="ph-alert-error">⚠ @ViewBag.Error</div>
    }

    <div class="ph-section-title">بيانات العملة</div>

    <div class="ph-form-grid ph-form-grid-2">
        <div>
            <label class="ph-form-label" for="CurrencyName">اسم العملة <span style="color:#e11d48;">*</span></label>
            <div style="display:flex;align-items:center;gap:0.35rem;">
                <span class="material-symbols-outlined" style="font-size:18px;color:#94a3b8;">payments</span>
                <input type="text" asp-for="CurrencyName" id="CurrencyName" required autocomplete="off" placeholder="مثال: ريال يمني" class="ph-form-control" style="flex:1;" />
            </div>
            <span asp-validation-for="CurrencyName" style="color:#e11d48;font-size:11px;"></span>
        </div>
        <div>
            <label class="ph-form-label" for="CurrencyCode">كود العملة (ISO) <span style="color:#e11d48;">*</span></label>
            <div style="display:flex;align-items:center;gap:0.35rem;">
                <span class="material-symbols-outlined" style="font-size:18px;color:#94a3b8;">tag</span>
                <input type="text" asp-for="CurrencyCode" id="CurrencyCode" required autocomplete="off" placeholder="مثال: YER / USD / SAR" class="ph-form-control" style="flex:1;font-family:monospace;text-transform:uppercase;" />
            </div>
            <span asp-validation-for="CurrencyCode" style="color:#e11d48;font-size:11px;"></span>
        </div>
    </div>

    <div class="ph-form-grid">
        <div>
            <label class="ph-form-label" for="ExchangeRate">سعر الصرف مقابل العملة المرجعية <span style="color:#e11d48;">*</span></label>
            <div style="display:flex;align-items:center;gap:0.35rem;">
                <span class="material-symbols-outlined" style="font-size:18px;color:#94a3b8;">currency_exchange</span>
                <input type="number" asp-for="ExchangeRate" id="ExchangeRate" step="0.0001" min="0.0001" required placeholder="1.0000" class="ph-form-control" style="flex:1;font-family:monospace;font-weight:800;max-width:14rem;" />
            </div>
            <div class="ph-info-note">سعر الصرف مقابل العملة الرئيسية للنظام. للعملة الأساسية اجعله 1.0000</div>
            <span asp-validation-for="ExchangeRate" style="color:#e11d48;font-size:11px;"></span>
        </div>
    </div>

    <div class="ph-form-grid ph-form-grid-2">
        <label class="ph-form-check" for="IsBaseCurrency">
            <input type="checkbox" asp-for="IsBaseCurrency" id="IsBaseCurrency" />
            <span class="ph-form-check-label">
                <strong>العملة الأساسية (المرجعية)</strong><br />
                <span style="font-size:0.6875rem;color:#64748b;">تحديد هذه العملة كعملة مرجعية للنظام</span>
            </span>
        </label>
        <label class="ph-form-check" for="IsActive">
            <input type="checkbox" asp-for="IsActive" id="IsActive" checked />
            <span class="ph-form-check-label">
                <strong>العملة نشطة</strong><br />
                <span style="font-size:0.6875rem;color:#64748b;">تفعيل استخدام هذه العملة في النظام</span>
            </span>
        </label>
    </div>

    <div class="ph-modal-actions">
        <button type="button" onclick="modalNavigateBack()" class="ph-btn-back">
            <span class="material-symbols-outlined" style="font-size:18px;">close</span>
            إلغاء
        </button>
        <button type="submit" class="ph-btn-primary">
            <span class="material-symbols-outlined" style="font-size:18px;">add_circle</span>
            إضافة العملة
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
