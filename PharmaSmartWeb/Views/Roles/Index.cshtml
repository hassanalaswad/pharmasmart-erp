@model IEnumerable<PharmaSmartWeb.Models.Userroles>

@{
    ViewData["Title"] = "الادوار والصلاحيات";
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .enterprise-header { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 10px 16px; font-size: 13px; font-weight: 700; color: #063955; }
    .role-card { background: white; border: 1px solid #d1d5db; border-radius: 2px; padding: 16px; transition: border-color 0.15s; }
    .role-card:hover { border-color: #063955; }
    .role-icon { width: 40px; height: 40px; border-radius: 4px; display: flex; align-items: center; justify-content: center; }
    .btn-manage { background: #063955; color: white; border: none; padding: 8px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; width: 100%; justify-content: center; }
    .btn-manage:hover { background: #0a4f72; color: white; }
    .role-badge { display: inline-block; padding: 2px 8px; border-radius: 2px; font-size: 10px; font-weight: 700; }
    .page-title { font-size: 16px; font-weight: 700; color: #063955; }
    .page-sub { font-size: 12px; color: #64748b; }
    .security-notice { background: #0c1a2e; color: white; border-radius: 2px; padding: 16px; margin-top: 20px; display: flex; align-items: center; justify-content: space-between; }
</style>

<!-- Page Header -->
<div class="enterprise-panel mb-4 p-3 flex justify-between items-center">
    <div>
        <h1 class="page-title">إدارة مجموعات الادوار</h1>
        <p class="page-sub">تخصيص مستويات الوصول للموظفين والكوادر الطبية</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="enterprise-panel mb-4 p-3 flex items-center gap-3" style="border-right: 4px solid #059669;">
        <span class="material-symbols-outlined" style="color:#059669; font-size:18px;">check_circle</span>
        <span style="font-size:13px; color:#059669; font-weight:600;">@TempData["Success"]</span>
    </div>
}

@if (!Model.Any())
{
    <div class="enterprise-panel p-10 text-center">
        <span class="material-symbols-outlined" style="font-size:40px; color:#cbd5e1; display:block; margin-bottom:8px;">group_off</span>
        <p style="color:#94a3b8; font-size:13px; font-weight:600;">لا توجد أدوار مضافة حالياً.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var role in Model)
        {
            var roleNameEn = role.RoleName?.ToLower() ?? "";
            string icon = "key"; string iconBg = "#f1f5f9"; string iconColor = "#475569";
            string badgeBg = "#f1f5f9"; string badgeColor = "#475569"; string badgeLabel = "مجموعة صلاحيات";
            string description = "تعديل أذونات شاشات النظام لهذا الدور الوظيفي والمستخدمين التابعين له.";

            if (roleNameEn.Contains("admin") || role.RoleId == 1)
            {
                icon = "security"; iconBg = "#fff1f2"; iconColor = "#e11d48";
                badgeBg = "#fff1f2"; badgeColor = "#e11d48"; badgeLabel = "وصول كامل";
                description = "مدير النظام الرئيسي. يتمتع بكافة الصلاحيات لإدارة المستخدمين، الإعدادات العامة، والبيانات.";
            }
            else if (roleNameEn.Contains("branchmanager") || role.RoleId == 2)
            {
                icon = "storefront"; iconBg = "#f3e8ff"; iconColor = "#9333ea";
                badgeBg = "#f3e8ff"; badgeColor = "#9333ea"; badgeLabel = "إدارة فروع";
                description = "مدير الفرع. يمتلك صلاحيات لإدارة فرعه ومراقبة أدائه التشغيلي وصلاحيات الموظفين فيه.";
            }
            else if (roleNameEn.Contains("pharmacist") || role.RoleId == 3)
            {
                icon = "prescriptions"; iconBg = "#eff6ff"; iconColor = "#1d4ed8";
                badgeBg = "#eff6ff"; badgeColor = "#1d4ed8"; badgeLabel = "طاقم طبي ومبيعات";
                description = "إدارة المخزون الدوائي، صرف الوصفات الطبية، وإدارة نقاط البيع النقدية.";
            }

            <div class="role-card">
                <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
                    <div class="role-icon" style="background:@iconBg; color:@iconColor;">
                        <span class="material-symbols-outlined" style="font-size:20px;">@icon</span>
                    </div>
                    <span class="role-badge" style="background:@badgeBg; color:@badgeColor; border:1px solid @badgeColor;">@badgeLabel</span>
                </div>
                <h3 style="font-size:14px; font-weight:700; color:#063955; margin-bottom:6px;">@(role.RoleArabicName ?? role.RoleName)</h3>
                <p style="font-size:11px; color:#64748b; line-height:1.6; margin-bottom:14px;">@description</p>
                <a asp-controller="Roles" asp-action="ManagePermissions" asp-route-roleId="@role.RoleId" class="btn-manage">
                    <span class="material-symbols-outlined" style="font-size:15px;">settings_suggest</span>
                    ضبط مصفوفة الصلاحيات
                </a>
            </div>
        }
    </div>

    <!-- Security Notice -->
    <div class="security-notice">
        <div style="display:flex; align-items:center; gap:12px;">
            <span class="material-symbols-outlined" style="color:#f59e0b; font-size:24px;">security</span>
            <div>
                <div style="font-size:12px; font-weight:700; color:#e2e8f0;">العزل والأمان الشامل</div>
                <div style="font-size:11px; color:#94a3b8; margin-top:2px;">
                    تضمن هذه الشاشة سياسة العزل الأمني (Vertical Security Isolation)، حيث لا يُسمح بتغيير صلاحيات مدير النظام الرئيسي. أي تغييرات أخرى تُطبق وتُحدث فورياً بفضل نظام تفريغ الكاش التلقائي.
                </div>
            </div>
        </div>
        <span class="material-symbols-outlined" style="font-size:60px; opacity:0.1; transform:rotate(-12deg);">encrypted</span>
    </div>
}
