@inject PharmaSmartWeb.Services.INavigationService Navigation
<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
 <meta charset="utf-8"/>
 <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
 <title>@ViewData["Title"] | @Settings.CompanyName</title>
 <link rel="manifest" href="/manifest.json" />
 <meta name="theme-color" content="#063955" />
 <script src="~/lib/tailwindcss.js"></script>
 <script src="~/js/tailwind.config.js"></script>
 <link href="~/css/cura-styles.css" rel="stylesheet"/>
 <link rel="stylesheet" href="~/css/local-fonts.css" />
 <!-- Chart.js -->
 <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
 <!-- Font Awesome 6 -->
 <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body class="text-on-surface flex rtl">
 <!-- Premium Global Preloader -->
 <div id="preloader" class="fixed inset-0 z-[9999] flex items-center justify-center bg-slate-50/80 backdrop-blur-md transition-all duration-300">
  <div class="flex flex-col items-center gap-5">
  <div class="relative flex items-center justify-center">
   <!-- Glowing Background -->
   <div class="absolute inset-0 bg-primary/20 rounded-full blur-xl animate-pulse"></div>
   <!-- Animated Rings -->
   <div class="w-16 h-16 border-[3px] border-slate-200 rounded-full"></div>
   <div class="w-16 h-16 border-[3px] border-primary border-t-transparent rounded-full animate-spin absolute top-0 left-0"></div>
   <!-- Center Icon -->
   <div class="absolute flex items-center justify-center bg-white w-10 h-10 rounded-full shadow-sm">
    <span class="material-symbols-outlined text-primary text-[20px] animate-pulse">hourglass_bottom</span>
   </div>
  </div>
  <div class="flex flex-col items-center">
   <div class="text-primary text-sm font-black tracking-widest uppercase animate-pulse">جاري التحميل...</div>
   <div class="text-slate-400 text-[10px] font-bold mt-1">يتم الآن تجهيز البيانات</div>
  </div>
  </div>
 </div>

 <script>
  // Hide preloader when page fully loaded
  window.addEventListener('load', function() {
   const preloader = document.getElementById('preloader');
   if (preloader) {
    preloader.style.opacity = '0';
    setTimeout(() => {
     preloader.style.visibility = 'hidden';
     preloader.style.display = 'none';
    }, 300);
   }
  });

  // Show preloader immediately on navigation to prevent the "frozen" feeling
  function showPreloader() {
   const preloader = document.getElementById('preloader');
   if (preloader) {
    preloader.style.display = 'flex';
    preloader.style.visibility = 'visible';
    preloader.style.opacity = '1';
   }
  }

  // Handle Form Submissions
  document.addEventListener('submit', function(e) {
   // Only show if form is not marked with data-noloader
   if (!e.target.hasAttribute('data-noloader')) {
    showPreloader();
   }
  });

  // Handle Link Clicks
  document.addEventListener('click', function(e) {
   const link = e.target.closest('a[href]');
   if (link) {
    const href = link.getAttribute('href');
    const target = link.getAttribute('target');
    
    // Ignore empty links, javascript, anchors, or new tabs
    if (!href || href.startsWith('javascript:') || href.startsWith('#') || target === '_blank') {
     return;
    }
    
    // Ignore modal toggles or specific exclusions
    if (link.hasAttribute('data-bs-toggle') || link.hasAttribute('data-noloader') || link.onclick) {
     return;
    }

    showPreloader();
   }
  });
 </script>
@{
 var currentController = Context.Request.RouteValues["controller"]?.ToString();
 var currentAction = Context.Request.RouteValues["action"]?.ToString();

 bool isMainHub = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase) 
 && string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);

 bool isPOSMode = string.Equals(currentController, "Sales", StringComparison.OrdinalIgnoreCase) 
 && string.Equals(currentAction, "Create", StringComparison.OrdinalIgnoreCase);


 bool isSubPage = !string.IsNullOrEmpty(currentAction)
 && !currentAction.Equals("Index", StringComparison.OrdinalIgnoreCase)
 && !currentAction.Equals("Login", StringComparison.OrdinalIgnoreCase)
 && !currentAction.EndsWith("Hub", StringComparison.OrdinalIgnoreCase)
 && !string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase);

 bool isReportsModule = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)
 && string.Equals(currentAction, "ReportsHub", StringComparison.OrdinalIgnoreCase);

 // احتياطي عندما لا يتوفر تاريخ متصفح (تبويب جديد، دخول مباشر، إلخ)
 string backFallbackUrl = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)
  ? "/Home/Index"
  : $"/{currentController}/Index";

 bool showHeaderBack = !isMainHub && ViewData["HideLayoutBack"] as bool? != true;
}

@if (!isMainHub && !isPOSMode)
{
<!-- Sidebar Navigation -->
<aside id="mainSidebar" class="print:hidden h-screen w-64 fixed right-0 top-0 border-l border-gray-100 bg-white z-50 flex flex-col shadow-xl">
 <!-- لوجو وعنوان النظام -->
 <div class="p-5 border-b border-gray-100 flex items-center gap-3 sticky top-0 bg-white z-10 flex-shrink-0">
  <a href="/Home/Index" class="flex items-center gap-3 flex-1 min-w-0">
   <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center shadow-sm flex-shrink-0">
    <i class="fas fa-prescription-bottle-alt text-white text-sm"></i>
   </div>
   <span class="font-bold text-base text-gray-800 truncate">@Settings.CompanyName</span>
  </a>
  <span class="text-xs bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full flex-shrink-0">v3</span>
  <button onclick="closeSidebar()" id="btnCloseSidebar" class="text-gray-400 hover:text-gray-700 flex-shrink-0" style="display:none;background:none;border:none;cursor:pointer;">
   <span class="material-symbols-outlined text-[18px]">close</span>
  </button>
 </div>

 <!-- شريط بحث داخل القائمة -->
 <div class="px-4 pt-3 pb-1 flex-shrink-0">
  <div class="relative">
   <i class="fas fa-search absolute right-3 top-2.5 text-gray-400 text-sm"></i>
   <input type="text" id="sidebarSearchInput" placeholder="بحث في القائمة..." class="w-full pr-9 pl-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-emerald-400 bg-gray-50" />
  </div>
 </div>

 <!-- معلومات المستخدم -->
 <div class="flex items-center gap-3 px-4 py-2.5 mx-3 mb-1 bg-gray-50 rounded-xl border border-gray-100 flex-shrink-0">
  <div class="w-9 h-9 rounded-full bg-gradient-to-br from-slate-700 to-slate-900 flex items-center justify-center text-white flex-shrink-0">
   <i class="fas fa-user-md text-sm"></i>
  </div>
  <div class="min-w-0">
   <p class="text-sm font-bold text-gray-800 truncate">@User.Identity?.Name</p>
   <p class="text-[10px] text-gray-500 font-medium truncate">
    @if (User.IsInRole("SuperAdmin")) { <span>مدير النظام</span> }
    else if (User.IsInRole("BranchManager")) { <span>مدير فرع</span> }
    else if (User.IsInRole("Cashier")) { <span>كاشير</span> }
    else if (User.IsInRole("Pharmacist")) { <span>صيدلي</span> }
    else { <span>مستخدم النظام</span> }
   </p>
  </div>
 </div>

 <!-- Dynamic Menu Rendering -->
 <nav class="space-y-1 flex-1 overflow-y-auto w-full custom-scrollbar px-3 pb-3" id="sidebarNavContainer">
 @{
 var allowedMenus = await Navigation.GetAllowedMenusAsync(User);
 }
 @{ int groupIndex = 0; }
 @foreach (var group in allowedMenus)
 {
 groupIndex++;
 bool hasActiveChild = group.Items.Any(item => !string.IsNullOrEmpty(item.Url) && item.Url != "/" && Context.Request.Path.Value?.StartsWith(item.Url, StringComparison.OrdinalIgnoreCase) == true);

 <div class="mt-2 mb-1 sidebar-menu-group">
 <button type="button"
  data-group-id="group-@groupIndex"
  onclick="toggleSidebarGroup(this)"
  class="sidebar-group-btn w-full flex items-center justify-between px-3 py-2.5 rounded-xl hover:bg-gray-100 transition-colors group cursor-pointer focus:outline-none text-right">
  <div class="flex items-center gap-2.5">
   <span class="material-symbols-outlined text-[18px] flex-shrink-0 @(hasActiveChild || isReportsModule ? "text-emerald-600" : "text-slate-400") group-hover:text-emerald-600 transition-colors">@group.Icon</span>
   <span class="text-[12px] font-bold @(hasActiveChild || isReportsModule ? "text-emerald-700" : "text-slate-600") group-hover:text-emerald-700 transition-colors">@group.Title</span>
  </div>
  <i class="fas fa-chevron-down text-xs text-slate-400 transition-transform duration-200 chevron-icon @(hasActiveChild || isReportsModule ? "rotate-180" : "")"></i>
 </button>

 <div id="menu-group-@groupIndex" class="mt-1 space-y-0.5 pr-5 border-r-2 border-gray-100 mr-4 overflow-hidden transition-all duration-300 @((hasActiveChild || isReportsModule) ? "" : "hidden")">
  @foreach (var item in group.Items)
  {
   var isActive = (!string.IsNullOrEmpty(item.Url) && item.Url != "/" && Context.Request.Path.Value?.StartsWith(item.Url, StringComparison.OrdinalIgnoreCase) == true);

   <a class="sidebar-menu-item flex items-center gap-2 px-3 py-2 rounded-lg text-sm transition-all duration-150 @(isActive ? "active-sidebar-item" : "text-gray-600 hover:bg-gray-50 hover:text-emerald-700")" href="@item.Url" onclick="closeSidebarOnMobile()">
    <span class="material-symbols-outlined text-[15px] flex-shrink-0 @(isActive ? "text-emerald-600" : "text-slate-400")" data-icon="@item.Icon">@item.Icon</span>
    <span class="text-[11.5px] leading-snug font-medium">@item.Title</span>
   </a>
  }
 </div>
 </div>
 }
 </nav>

 <!-- Dynamic Action Buttons at bottom of sidebar -->
 <div class="mt-4 pt-4 border-t border-slate-200 flex flex-col gap-3">
 @{
    string activeUnit = "Commercial"; 
    if (new[] { "Report", "InventoryIntelligence" }.Contains(currentController)) activeUnit = "Reports";
    else if (new[] { "Drugs", "Inventory" }.Contains(currentController)) activeUnit = "Inventory";
    else if (new[] { "Journal", "ChartOfAccounts", "Vouchers", "FinancialSettings" }.Contains(currentController)) activeUnit = "Finance";
    else if (new[] { "Admin", "Users", "Roles", "Branches", "Account" }.Contains(currentController)) activeUnit = "SystemSettings";
 }
 
  @if(activeUnit == "Commercial")
  {
     if (User.HasClaim("Permission", "Sales.Add") || User.IsInRole("SuperAdmin") || User.IsInRole("Cashier") || User.IsInRole("Pharmacist"))
     {
      <a href="/Sales/Create" class="w-full py-3 bg-emerald-600 text-white rounded-sm font-bold flex items-center justify-center gap-2 hover:opacity-90 shadow-sm transition-transform active:scale-95">
       <span class="material-symbols-outlined">point_of_sale</span> نقطة بيع سريعة
      </a>
      <div class="border-t border-slate-100 my-1"></div>
     }
  <a href="/Home/CommercialHub" class="w-full py-3 bg-[#063955] text-white rounded-sm font-bold flex items-center justify-center gap-2 hover:opacity-90 shadow-sm transition-transform active:scale-95">
  <span class="material-symbols-outlined" data-icon="dashboard">dashboard</span> لوحة التجارية
  </a>
  }
 else if (activeUnit == "Finance" && User.HasClaim("Permission", "JournalEntries.View"))
 {
 <a href="/Vouchers/Index" class="w-full py-3 bg-slate-800 text-white rounded-sm font-bold flex items-center justify-center gap-2 hover:opacity-90 shadow-sm transition-transform active:scale-95">
 <span class="material-symbols-outlined">receipt_long</span> إنشاء سند
 </a>
 }
 else if (activeUnit == "Inventory" && User.HasClaim("Permission", "Drug.View"))
 {
 <a href="/Drugs/Create" class="w-full py-3 bg-emerald-600 text-white rounded-sm font-bold flex items-center justify-center gap-2 hover:opacity-90 shadow-sm transition-transform active:scale-95">
 <span class="material-symbols-outlined">add_box</span> بطاقة صنف
 </a>
 }
 else if (activeUnit == "SystemSettings" && User.IsInRole("SuperAdmin"))
 {
 <a href="/Home/AdminHub" class="w-full py-3 bg-slate-800 text-white rounded-sm font-bold flex items-center justify-center gap-2 hover:opacity-90 shadow-sm transition-transform active:scale-95">
 <span class="material-symbols-outlined">admin_panel_settings</span> لوحة الإدارة
 </a>
 }
 else if (activeUnit != "Commercial")
 {
 <a href="/Home/DashboardHub" class="w-full py-3 bg-surface-container-high text-primary rounded-sm font-bold flex items-center justify-center gap-2 hover:bg-slate-200 transition-colors">
 <span class="material-symbols-outlined">dashboard</span> لوحة النظام
 </a>
 }
 </div>
</aside>
}
 <!-- Footer داخل السايدبار -->
 @if (!isMainHub && !isPOSMode)
 {
 <div class="px-4 py-3 border-t border-gray-100 text-xs text-gray-400 flex items-center gap-1.5 flex-shrink-0">
  <i class="fas fa-shield-alt text-emerald-500"></i>
  <span>عزل فروع • RBAC • AI تنبؤ</span>
 </div>
 }

<!-- Mobile Sidebar Overlay -->
<div id="mobileSidebarOverlay" onclick="closeSidebar()"></div>

<!-- Main Content Canvas -->
<main class="print:!m-0 print:!p-0 @(isMainHub || isPOSMode ? "" : "mr-64") p-5 min-h-screen flex-1 w-full max-w-full overflow-x-hidden bg-surface">

@if (!isPOSMode) {
<!-- Top Header Navigation -->
<header class="print:hidden sticky top-0 z-40 flex justify-between items-center w-full px-6 py-4 bg-white rounded-sm mb-8 shadow-sm border border-slate-100">
 <!-- Page Context -->
 <div class="flex items-center gap-3">
  <!-- زر الهامبرغر - يظهر فقط على الهاتف -->
  <button id="btnToggleSidebar" onclick="toggleSidebar()" title="القائمة">
   <span class="material-symbols-outlined" style="font-size:22px;">menu</span>
  </button>
  @if (showHeaderBack)
  {
  <button type="button" data-back-fallback="@backFallbackUrl" onclick="pharmaSmartNavigateBack(this.getAttribute('data-back-fallback'))" class="w-10 h-10 flex items-center justify-center rounded-sm bg-surface-container-high text-secondary hover:bg-primary hover:text-white transition-all shadow-sm group border-0 cursor-pointer" title="الرجوع للصفحة التي أتيت منها" aria-label="رجوع">
  <span class="material-symbols-outlined text-[20px] group-hover:-translate-x-1 transition-transform">arrow_forward</span>
  </button>
  <div class="h-8 w-px bg-slate-200"></div>
  }
  <div>
  <div class="flex items-center gap-3">
  <h2 class="text-2xl font-black text-primary tracking-tight">@ViewData["Title"]</h2>
  </div>
  @if(ViewData["PageDescription"] != null)
  {
  <p class="text-xs text-slate-500 font-bold mt-1">@ViewData["PageDescription"]</p>
  }
  </div>
  @RenderSection("SubHeaderNav", required: false)
 </div>

 <!-- Search & Global Actions -->
 <div class="flex items-center gap-4">
  <!-- Dynamic header actions injected from the child view -->
  @RenderSection("HeaderActions", required: false)

  <!-- Branch Selector (For SuperAdmin) -->
  @if ((User.IsInRole("SuperAdmin") || User.HasClaim("Permission", "System.ChangeBranch")) && !isSubPage)
  {
  <form asp-controller="Home" asp-action="ChangeActiveBranch" method="post" class="flex m-0 branch-selector">
  <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
  <div class="relative flex items-center bg-surface-container-highest rounded-full hover:bg-surface-variant transition-all h-10 w-48 border border-slate-200">
  <span class="material-symbols-outlined text-xl text-primary pointer-events-none absolute right-3">storefront</span>
  <select name="branchId" onchange="this.form.submit()" class="appearance-none bg-transparent w-full text-primary font-black text-sm border-none focus:ring-0 pr-10 pl-8 cursor-pointer h-full">
  @{ 
  var branchesList = ViewBag.Branches as IEnumerable<Branches> ?? Enumerable.Empty<Branches>();
  int headerScope = ViewBag.HeaderReportScopeId is int hs ? hs : int.TryParse(ViewBag.HeaderReportScopeId?.ToString(), out int p) ? p : 0;
  bool isAllBranches = headerScope == 0;
  }
  @if (isAllBranches)
  {
  <option value="0" selected>كافة الفروع</option>
  }
  else
  {
  <option value="0">كافة الفروع</option>
  }
  @foreach (var br in branchesList)
  {
  bool isSelected = (!isAllBranches && headerScope == br.BranchId);
  if (isSelected)
  {
  <option value="@br.BranchId" selected>@br.BranchName</option>
  }
  else
  {
  <option value="@br.BranchId">@br.BranchName</option>
  }
  }
  </select>
  <span class="material-symbols-outlined text-sm text-primary pointer-events-none absolute left-3">expand_more</span>
  </div>
  </form>
  }
  else
  {
  <div class="flex items-center gap-2 px-4 py-2 bg-surface-container-highest border border-slate-200 rounded-full text-primary font-black text-sm transition-all h-10 cursor-default whitespace-nowrap branch-selector">
  <span class="material-symbols-outlined text-xl">storefront</span>
  <span>@(ViewBag.ActiveBranchName?.ToString() ?? "الفرع الحالي")</span>
  </div>
  }

  <a href="/Home/Notifications" class="w-10 h-10 flex items-center justify-center rounded-full bg-slate-50 hover:bg-surface-container-highest transition-all text-secondary relative border border-slate-200" title="التنبيهات">
  <span class="material-symbols-outlined text-[20px]">notifications</span>
  @if (ViewBag.NotificationCount != null && (int)ViewBag.NotificationCount > 0)
  {
      <span class="absolute -top-1 -right-1 min-w-[20px] h-[20px] flex items-center justify-center bg-error text-white text-[10px] font-bold rounded-full border-2 border-white px-1">
          @(ViewBag.NotificationCount > 99 ? "99+" : ViewBag.NotificationCount)
      </span>
  }
  </a>
  
  <a href="/Account/ChangePassword" class="w-10 h-10 flex items-center justify-center rounded-full bg-slate-50 hover:bg-surface-variant transition-all text-secondary border border-slate-200" title="تغيير كلمة المرور">
  <span class="material-symbols-outlined text-[20px]">key</span>
  </a>

  <a href="/Account/Logout" class="w-10 h-10 flex items-center justify-center rounded-full bg-rose-50 hover:bg-error-container hover:text-error text-rose-400 transition-all border border-rose-100" title="تسجيل الخروج">
  <span class="material-symbols-outlined text-[20px]">logout</span>
  </a>
 </div>
</header>
}
 
 <!-- Render Body -->
 @RenderBody()

</main>
@RenderSection("Scripts", required: false)

