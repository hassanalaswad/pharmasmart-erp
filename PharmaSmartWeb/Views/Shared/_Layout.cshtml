@inject PharmaSmartWeb.Services.INavigationService Navigation
<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
 <meta charset="utf-8"/>
 <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
 <title>@ViewData["Title"] | @Settings.CompanyName</title>
 <link rel="manifest" href="/manifest.json" />
 <meta name="theme-color" content="#063955" />
 <script src="~/lib/tailwindcss.js"></script>
 <script src="~/js/tailwind.config.js"></script>
 <link href="~/css/cura-styles.css" rel="stylesheet"/>
 <link rel="stylesheet" href="~/css/local-fonts.css" />
 <!-- Chart.js -->
 <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
 <style>
    .sidebar-group-btn { transition: all 0.2s; }
    .sidebar-group-btn:hover { background-color: rgba(var(--md-sys-color-surface-variant-rgb, 241 245 249) / 0.6); }
    .submenu-item { transition: all 0.15s; }
    .submenu-item:hover { padding-right: 0.75rem; }
    .kpi-card, .quick-action-btn { transition: all 0.2s ease; }
    .kpi-card:hover, .quick-action-btn:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.08); }
    @@media (max-width: 768px) {
        .sidebar-mobile-hidden { transform: translateX(100%); }
        .sidebar-mobile-visible { transform: translateX(0); }
    }
    .data-table tbody tr:hover { background-color: #f8fafc; }
    .active-sidebar-item {
        background-color: rgb(var(--md-sys-color-primary-container-rgb, 209 246 230));
        color: rgb(var(--md-sys-color-primary-rgb, 6 57 85));
        border-right: 3px solid rgb(var(--md-sys-color-primary-rgb, 6 57 85));
    }
    /* Sidebar search */
    #sidebarSearch:focus { outline: none; box-shadow: 0 0 0 2px rgba(6,57,85,0.15); }
 </style>
</head>
<body class="text-on-surface flex rtl">
 <div class="flex h-screen overflow-hidden w-full">

 <!-- Premium Global Preloader -->
 <div id="preloader" class="fixed inset-0 z-[9999] flex items-center justify-center bg-slate-50/80 backdrop-blur-md transition-all duration-300">
  <div class="flex flex-col items-center gap-5">
  <div class="relative flex items-center justify-center">
   <!-- Glowing Background -->
   <div class="absolute inset-0 bg-primary/20 rounded-full blur-xl animate-pulse"></div>
   <!-- Animated Rings -->
   <div class="w-16 h-16 border-[3px] border-slate-200 rounded-full"></div>
   <div class="w-16 h-16 border-[3px] border-primary border-t-transparent rounded-full animate-spin absolute top-0 left-0"></div>
   <!-- Center Icon -->
   <div class="absolute flex items-center justify-center bg-white w-10 h-10 rounded-full shadow-sm">
    <span class="material-symbols-outlined text-primary text-[20px] animate-pulse">hourglass_bottom</span>
   </div>
  </div>
  <div class="flex flex-col items-center">
   <div class="text-primary text-sm font-black tracking-widest uppercase animate-pulse">جاري التحميل...</div>
   <div class="text-slate-400 text-[10px] font-bold mt-1">يتم الآن تجهيز البيانات</div>
  </div>
  </div>
 </div>

 <script>
  // Hide preloader when page fully loaded
  window.addEventListener('load', function() {
   const preloader = document.getElementById('preloader');
   if (preloader) {
    preloader.style.opacity = '0';
    setTimeout(() => {
     preloader.style.visibility = 'hidden';
     preloader.style.display = 'none';
    }, 300);
   }
  });

  // Show preloader immediately on navigation to prevent the "frozen" feeling
  function showPreloader() {
   const preloader = document.getElementById('preloader');
   if (preloader) {
    preloader.style.display = 'flex';
    preloader.style.visibility = 'visible';
    preloader.style.opacity = '1';
   }
  }

  // Handle Form Submissions
  document.addEventListener('submit', function(e) {
   // Only show if form is not marked with data-noloader
   if (!e.target.hasAttribute('data-noloader')) {
    showPreloader();
   }
  });

  // Handle Link Clicks
  document.addEventListener('click', function(e) {
   const link = e.target.closest('a[href]');
   if (link) {
    const href = link.getAttribute('href');
    const target = link.getAttribute('target');
    
    // Ignore empty links, javascript, anchors, or new tabs
    if (!href || href.startsWith('javascript:') || href.startsWith('#') || target === '_blank') {
     return;
    }
    
    // Ignore modal toggles or specific exclusions
    if (link.hasAttribute('data-bs-toggle') || link.hasAttribute('data-noloader') || link.onclick) {
     return;
    }

    showPreloader();
   }
  });
 </script>
@{
 var currentController = Context.Request.RouteValues["controller"]?.ToString();
 var currentAction = Context.Request.RouteValues["action"]?.ToString();

 // السيدبار يظهر دائماً (في كل الصفحات بما فيها الرئيسية)
 bool isMainHub = false;

 bool isPOSMode = string.Equals(currentController, "Sales", StringComparison.OrdinalIgnoreCase) 
 && string.Equals(currentAction, "Create", StringComparison.OrdinalIgnoreCase);


 bool isSubPage = !string.IsNullOrEmpty(currentAction)
 && !currentAction.Equals("Index", StringComparison.OrdinalIgnoreCase)
 && !currentAction.Equals("Login", StringComparison.OrdinalIgnoreCase)
 && !currentAction.EndsWith("Hub", StringComparison.OrdinalIgnoreCase)
 && !string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase);

 bool isReportsModule = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)
 && string.Equals(currentAction, "ReportsHub", StringComparison.OrdinalIgnoreCase);

 // احتياطي عندما لا يتوفر تاريخ متصفح (تبويب جديد، دخول مباشر، إلخ)
 string backFallbackUrl = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)
  ? "/Home/Index"
  : $"/{currentController}/Index";

 bool showHeaderBack = !isMainHub && ViewData["HideLayoutBack"] as bool? != true;
}

@if (!isPOSMode)
{
<!-- Sidebar Navigation -->
<aside id="sidebar" class="print:hidden w-72 bg-white shadow-xl border-l border-slate-100 flex-shrink-0 overflow-y-auto z-50 transition-all duration-300 fixed md:relative inset-y-0 right-0 sidebar-mobile-hidden md:sidebar-mobile-visible flex flex-col">
    <!-- Header: Logo + Company Name -->
    <div class="p-5 border-b border-slate-100 flex items-center gap-3 sticky top-0 bg-white z-10">
        <a href="/Home/Index" class="flex items-center gap-3 flex-1 min-w-0">
            <img src="/images/Logo.png" class="h-8 max-w-[32px] object-contain" alt="Logo" onerror="this.style.display='none'" />
            <span class="font-bold text-base text-primary tracking-tight truncate">@Settings.CompanyName</span>
        </a>
        <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full mr-auto font-bold">v3.0</span>
        <button onclick="toggleSidebar()" id="btnCloseSidebar" class="md:hidden text-slate-400 hover:text-slate-700 mr-2 focus:outline-none">
            <span class="material-symbols-outlined text-[20px]">close</span>
        </button>
    </div>

    <!-- شريط بحث داخل القائمة -->
    <div class="px-4 pt-4 pb-2">
        <div class="relative">
            <span class="material-symbols-outlined absolute right-3 top-2.5 text-slate-400 text-[18px] pointer-events-none">search</span>
            <input type="text" id="sidebarSearch" placeholder="بحث في القائمة..." 
                   class="w-full pr-9 pl-3 py-2 border border-slate-200 rounded-sm text-sm focus:outline-none focus:ring-1 focus:ring-primary bg-slate-50 placeholder-slate-400 font-medium">
        </div>
    </div>

    <!-- معلومات المستخدم مع الدور الفعلي -->
    <div class="flex items-center gap-3 px-4 py-3 mx-3 border border-slate-100 rounded-sm bg-surface-container-highest mb-2 shadow-sm">
        <div class="w-9 h-9 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-primary text-[18px]">person</span>
        </div>
        <div class="min-w-0">
            <p class="text-sm font-bold text-slate-800 truncate">@User.Identity?.Name</p>
            <p class="text-[11px] text-slate-500 font-semibold truncate">
             @if (User.IsInRole("SuperAdmin")) { <span>مدير النظام</span> }
             else if (User.IsInRole("BranchManager")) { <span>مدير فرع</span> }
             else if (User.IsInRole("Cashier")) { <span>كاشير</span> }
             else if (User.IsInRole("Pharmacist")) { <span>صيدلي</span> }
             else if (User.IsInRole("Accountant")) { <span>محاسب</span> }
             else if (User.IsInRole("Storekeeper")) { <span>أمين مستودع</span> }
             else { <span>مستخدم النظام</span> }
            </p>
        </div>
    </div>

    <!-- حاوية عناصر القائمة (مبنية ديناميكياً من الباك-إند) -->
    <nav id="sidebarNavContainer" class="px-3 pb-4 space-y-1 w-full custom-scrollbar flex-1 overflow-y-auto">
    @{
        var allowedMenus = await Navigation.GetAllowedMenusAsync(User);
    }
    @{ int groupIndex = 0; }
    @foreach (var group in allowedMenus)
    {
        groupIndex++;
        bool hasActiveChild = group.Items.Any(item => !string.IsNullOrEmpty(item.Url) && item.Url != "/" && Context.Request.Path.Value?.StartsWith(item.Url, StringComparison.OrdinalIgnoreCase) == true);

        <!-- إنشاء عنصر المجموعة -->
        <div class="group-item mb-1 sidebar-menu-group">
            <button type="button" data-group-id="menu-group-@groupIndex" onclick="toggleSidebarGroup(this)" 
                    class="sidebar-group-btn w-full flex items-center justify-between px-3 py-2.5 rounded-sm text-slate-700 hover:bg-surface-container-high transition focus:outline-none group">
                <div class="flex items-center gap-2.5">
                    <span class="material-symbols-outlined text-[18px] flex-shrink-0 @(hasActiveChild ? "text-primary" : "text-slate-400") group-hover:text-primary transition-colors">@group.Icon</span>
                    <span class="text-[12px] font-black uppercase leading-tight @(hasActiveChild ? "text-primary" : "text-slate-600") group-hover:text-primary transition-colors">@group.Title</span>
                </div>
                <span class="material-symbols-outlined text-[16px] text-slate-400 transition-transform duration-200 chevron-icon @(hasActiveChild || isReportsModule ? "rotate-180" : "")">expand_more</span>
            </button>
            <div id="menu-group-@groupIndex" class="submenu space-y-0.5 mt-1 border-r-[3px] border-slate-100 mr-5 pr-2 overflow-hidden transition-all duration-300 @((hasActiveChild || isReportsModule) ? "" : "hidden")">
                @foreach (var item in group.Items)
                {
                    var isActive = (!string.IsNullOrEmpty(item.Url) && item.Url != "/" && Context.Request.Path.Value?.StartsWith(item.Url, StringComparison.OrdinalIgnoreCase) == true);
                    var bgClass = isActive ? "bg-primary/10 text-primary font-bold rounded-sm shadow-sm active-sidebar-item" : "text-slate-600 hover:bg-surface-container-high hover:text-primary font-medium rounded-sm";
                    
                    <a href="@item.Url" onclick="closeSidebarOnMobile()" 
                       class="submenu-item sidebar-menu-item flex items-center gap-2 px-2 py-2 transition-all duration-150 @bgClass text-right">
                        <span class="material-symbols-outlined text-[16px] flex-shrink-0 @(isActive ? "text-primary" : "text-slate-400")" data-icon="@item.Icon">@item.Icon</span>
                        <span class="text-[11px] leading-snug">@item.Title</span>
                    </a>
                }
            </div>
        </div>
    }
    </nav>

    <!-- أزرار الإجراءات السياقية في أسفل السيدبار -->
    <div class="px-4 pt-3 pb-4 border-t border-slate-100 flex flex-col gap-2 bg-white sticky bottom-0">
    @{
        string activeUnit = "Commercial"; 
        if (new[] { "Report", "InventoryIntelligence" }.Contains(currentController)) activeUnit = "Reports";
        else if (new[] { "Drugs", "Inventory" }.Contains(currentController)) activeUnit = "Inventory";
        else if (new[] { "Journal", "ChartOfAccounts", "Vouchers", "FinancialSettings", "Accounting" }.Contains(currentController)) activeUnit = "Finance";
        else if (new[] { "Admin", "Users", "Roles", "Branches", "Account", "Employees" }.Contains(currentController)) activeUnit = "SystemSettings";
        else if (string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)) activeUnit = "Commercial";
    }
    
     @if (activeUnit == "Commercial")
     {
         if (User.HasClaim("Permission", "Sales.Add") || User.IsInRole("SuperAdmin") || User.IsInRole("Cashier") || User.IsInRole("Pharmacist") || User.IsInRole("BranchManager"))
         {
          <a href="/Sales/Create" class="w-full py-2.5 bg-emerald-600 text-white rounded-sm font-bold flex items-center justify-center gap-2 hover:opacity-90 shadow-sm transition-transform active:scale-95 text-sm">
           <span class="material-symbols-outlined text-[18px]">point_of_sale</span> نقطة بيع سريعة
          </a>
          <div class="border-t border-slate-100 my-0.5"></div>
         }
      @if (!User.IsInRole("Cashier") && !User.IsInRole("Pharmacist") && !User.IsInRole("BranchManager"))
      {
          <a href="/Home/Index" class="w-full py-2.5 bg-[#063955] text-white rounded-sm font-bold flex items-center justify-center gap-2 hover:opacity-90 shadow-sm transition-transform active:scale-95 text-sm">
          <span class="material-symbols-outlined text-[18px]">dashboard</span> لوحة التحكم
          </a>
      }
     }
    else if (activeUnit == "Finance" && User.HasClaim("Permission", "JournalEntries.View"))
    {
    <a href="/Vouchers/Index" class="w-full py-2.5 bg-slate-800 text-white rounded-sm font-bold flex items-center justify-center gap-2 hover:opacity-90 shadow-sm transition-transform active:scale-95 text-sm">
    <span class="material-symbols-outlined text-[18px]">receipt_long</span> إنشاء سند
    </a>
    }
    else if (activeUnit == "Inventory" && User.HasClaim("Permission", "Drug.View"))
    {
    <a href="/Drugs/Create" class="w-full py-2.5 bg-emerald-600 text-white rounded-sm font-bold flex items-center justify-center gap-2 hover:opacity-90 shadow-sm transition-transform active:scale-95 text-sm">
    <span class="material-symbols-outlined text-[18px]">add_box</span> بطاقة صنف
    </a>
    }
    else if (activeUnit == "SystemSettings" && User.IsInRole("SuperAdmin"))
    {
    <a href="/Home/AdminHub" class="w-full py-2.5 bg-slate-800 text-white rounded-sm font-bold flex items-center justify-center gap-2 hover:opacity-90 shadow-sm transition-transform active:scale-95 text-sm">
    <span class="material-symbols-outlined text-[18px]">admin_panel_settings</span> لوحة الإدارة
    </a>
    }
    else if (activeUnit != "Commercial")
    {
    <a href="/Home/Index" class="w-full py-2.5 bg-surface-container-high text-primary rounded-sm font-bold flex items-center justify-center gap-2 hover:bg-slate-200 transition-colors text-sm">
    <span class="material-symbols-outlined text-[18px]">dashboard</span> لوحة النظام
    </a>
    }
    </div>
</aside>
}
<!-- Mobile Sidebar Overlay -->
<div id="mobileSidebarOverlay" class="fixed inset-0 bg-gray-900 bg-opacity-50 z-40 hidden transition-opacity" onclick="toggleSidebar()"></div>


<!-- Main Content Canvas -->
<main class="print:!m-0 print:!p-0 p-5 min-h-screen flex-1 w-full max-w-full overflow-x-hidden bg-surface">
@if (!isPOSMode) {
<!-- Top Header Navigation -->
<header class="print:hidden sticky top-0 z-40 flex justify-between items-center w-full px-6 py-3 bg-white rounded-sm mb-6 shadow-sm border border-slate-100">
 <!-- Page Context -->
 <div class="flex items-center gap-3">
  <!-- زر الهامبرغر - يظهر فقط على الهاتف -->
  <button id="btnToggleSidebar" onclick="toggleSidebar()" title="القائمة" class="md:hidden text-slate-600">
   <span class="material-symbols-outlined text-[22px]">menu</span>
  </button>
  <!-- اسم الفرع النشط - يظهر فقط للهاتف أو للمستخدمين بدون dropdown -->
  @if (!User.IsInRole("SuperAdmin") && !User.HasClaim("Permission", "System.ChangeBranch"))
  {
  <div class="text-sm text-slate-500 bg-slate-100 px-3 py-1 rounded-full flex items-center gap-2 border border-slate-200">
   <span class="material-symbols-outlined text-[16px]">storefront</span>
   <span class="font-semibold">@(ViewBag.ActiveBranchName?.ToString() ?? "الفرع الرئيسي")</span>
  </div>
  }

  @if (showHeaderBack)
  {
  <button type="button" data-back-fallback="@backFallbackUrl" onclick="pharmaSmartNavigateBack(this.getAttribute('data-back-fallback'))" class="w-9 h-9 flex items-center justify-center rounded-sm bg-surface-container-high text-secondary hover:bg-primary hover:text-white transition-all shadow-sm group border-0 cursor-pointer" title="الرجوع للصفحة التي أتيت منها" aria-label="رجوع">
  <span class="material-symbols-outlined text-[20px] group-hover:-translate-x-1 transition-transform">arrow_forward</span>
  </button>
  }
 </div>

 <!-- Global Actions -->
 <div class="flex items-center gap-3">
  <!-- Dynamic header actions injected from the child view -->
  @RenderSection("HeaderActions", required: false)

  <!-- Branch Selector (For SuperAdmin) -->
  @if ((User.IsInRole("SuperAdmin") || User.HasClaim("Permission", "System.ChangeBranch")) && !isSubPage)
  {
  <form asp-controller="Home" asp-action="ChangeActiveBranch" method="post" class="flex m-0 branch-selector">
  <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
  <div class="relative flex items-center bg-surface-container-highest rounded-full hover:bg-surface-variant transition-all h-9 w-44 border border-slate-200">
  <span class="material-symbols-outlined text-xl text-primary pointer-events-none absolute right-3">storefront</span>
  <select name="branchId" onchange="this.form.submit()" class="appearance-none bg-transparent w-full text-primary font-black text-sm border-none focus:ring-0 pr-10 pl-8 cursor-pointer h-full">
  @{ 
  var branchesList = ViewBag.Branches as IEnumerable<Branches> ?? Enumerable.Empty<Branches>();
  int headerScope = ViewBag.HeaderReportScopeId is int hs ? hs : int.TryParse(ViewBag.HeaderReportScopeId?.ToString(), out int p) ? p : 0;
  bool isAllBranches = headerScope == 0;
  }
  @if (isAllBranches)
  {
  <option value="0" selected>كافة الفروع</option>
  }
  else
  {
  <option value="0">كافة الفروع</option>
  }
  @foreach (var br in branchesList)
  {
  bool isSelected = (!isAllBranches && headerScope == br.BranchId);
  if (isSelected) { <option value="@br.BranchId" selected>@br.BranchName</option> }
  else { <option value="@br.BranchId">@br.BranchName</option> }
  }
  </select>
  <span class="material-symbols-outlined text-sm text-primary pointer-events-none absolute left-3">expand_more</span>
  </div>
  </form>
  }
  else
  {
  <div class="flex items-center gap-2 px-3 py-1.5 bg-surface-container-highest border border-slate-200 rounded-full text-primary font-black text-sm h-9 cursor-default whitespace-nowrap branch-selector hidden md:flex">
  <span class="material-symbols-outlined text-[18px]">storefront</span>
  <span>@(ViewBag.ActiveBranchName?.ToString() ?? "الفرع الحالي")</span>
  </div>
  }

  <!-- 🔔 Bell Button + Dropdown -->
  <div class="relative" id="bellDropdownWrapper">
   <button id="bellBtn" onclick="toggleBellDropdown(event)"
    class="w-9 h-9 flex items-center justify-center rounded-full bg-slate-50 hover:bg-surface-container-highest transition-all text-secondary relative border border-slate-200" title="التنبيهات">
    <span class="material-symbols-outlined text-[20px]">notifications</span>
    @if (ViewBag.NotificationCount != null && (int)ViewBag.NotificationCount > 0)
    {
        <span id="bellBadge" class="absolute -top-1 -right-1 min-w-[18px] h-[18px] flex items-center justify-center bg-error text-white text-[10px] font-bold rounded-full border-2 border-white px-1">
            @(ViewBag.NotificationCount > 99 ? "99+" : ViewBag.NotificationCount)
        </span>
    }
   </button>
   <!-- Dropdown Panel -->
   <div id="bellDropdown" class="hidden absolute left-0 mt-2 w-80 bg-white rounded-sm shadow-2xl border border-slate-200 z-50 overflow-hidden" style="min-width:320px;">
    <div class="flex items-center justify-between px-4 py-3 bg-slate-50 border-b border-slate-200">
     <span class="font-black text-sm text-slate-800">التنبيهات</span>
     <span class="text-xs font-bold text-rose-600 bg-rose-50 px-2 py-0.5 rounded-full">
      @(ViewBag.NotificationCount ?? 0) غير مقروء
     </span>
    </div>
    <div id="bellDropdownItems" class="divide-y divide-slate-100 max-h-72 overflow-y-auto">
     @{
      int shortCnt = ViewBag.ShortagesCount ?? 0;
      int expCnt = ViewBag.ExpiringCount ?? 0;
      int loginFail = ViewBag.LoginFailuresCount ?? 0;
     }
     @if (shortCnt > 0)
     {
      <a href="/Inventory/Shortages" class="flex items-start gap-3 px-4 py-3 hover:bg-slate-50 transition-colors block">
       <div class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0 mt-0.5">
        <span class="material-symbols-outlined text-red-500 text-[16px]">inventory_2</span>
       </div>
       <div>
        <p class="text-sm font-bold text-slate-800">نواقص مخزون حرجة</p>
        <p class="text-xs text-slate-500 font-medium">@shortCnt صنف وصل للحد الأدنى</p>
        <p class="text-[10px] text-slate-400 mt-0.5">الآن</p>
       </div>
       <div class="w-2 h-2 rounded-full bg-red-500 mt-2 flex-shrink-0"></div>
      </a>
     }
     @if (expCnt > 0)
     {
      <a href="/Report/StockExpiry" class="flex items-start gap-3 px-4 py-3 hover:bg-slate-50 transition-colors block">
       <div class="w-8 h-8 rounded-full bg-amber-100 flex items-center justify-center flex-shrink-0 mt-0.5">
        <span class="material-symbols-outlined text-amber-500 text-[16px]">event_busy</span>
       </div>
       <div>
        <p class="text-sm font-bold text-slate-800">صلاحيات مقاربة للانتهاء</p>
        <p class="text-xs text-slate-500 font-medium">@expCnt تشغيلة تنتهي خلال شهرين</p>
        <p class="text-[10px] text-slate-400 mt-0.5">الآن</p>
       </div>
       <div class="w-2 h-2 rounded-full bg-amber-500 mt-2 flex-shrink-0"></div>
      </a>
     }
     @if (loginFail > 0)
     {
      <a href="/Admin/SystemLogs" class="flex items-start gap-3 px-4 py-3 hover:bg-slate-50 transition-colors block">
       <div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center flex-shrink-0 mt-0.5">
        <span class="material-symbols-outlined text-purple-500 text-[16px]">gpp_bad</span>
       </div>
       <div>
        <p class="text-sm font-bold text-slate-800">تنبيه أمني</p>
        <p class="text-xs text-slate-500 font-medium">@loginFail محاولة دخول فاشلة (24 ساعة)</p>
        <p class="text-[10px] text-slate-400 mt-0.5">الآن</p>
       </div>
       <div class="w-2 h-2 rounded-full bg-purple-500 mt-2 flex-shrink-0"></div>
      </a>
     }
     @if ((ViewBag.NotificationCount ?? 0) == 0)
     {
      <div class="flex flex-col items-center justify-center py-8 text-center">
