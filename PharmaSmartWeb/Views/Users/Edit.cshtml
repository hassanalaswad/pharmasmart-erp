@model PharmaSmartWeb.Models.Users

@{
    Layout = "_ModalLayout";
    ViewData["Title"] = $"تعديل حساب: {Model.Username}";
    ViewBag.ModalPanelSize = "lg";
    ViewBag.ModalHeaderIcon = "manage_accounts";
}

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="UserId" />

    @if (ViewBag.Error != null)
    {
        <div class="ph-alert-error">⚠ @ViewBag.Error</div>
    }

    <div class="ph-banner">
        <div style="display:flex;align-items:center;gap:0.625rem;">
            <span class="material-symbols-outlined" style="font-size:20px;color:#063955;">manage_accounts</span>
            <div>
                <div style="font-size:0.8125rem;font-weight:800;color:#063955;">تعديل: @Model.Username</div>
                <div style="font-size:0.6875rem;color:#64748b;">تعديل بيانات الحساب والصلاحيات</div>
            </div>
        </div>
        <div>
            <label class="ph-form-label" style="margin-bottom:0.2rem;">حالة الحساب</label>
            <select asp-for="IsActive" class="ph-form-select" style="width:10rem;">
                <option value="true">✅ حساب نشط</option>
                <option value="false">🔴 معطل</option>
            </select>
        </div>
    </div>

    <div class="ph-section-title">بيانات الحساب</div>

    <div class="ph-form-grid ph-form-grid-2">
        <div>
            <label class="ph-form-label">اسم الدخول <span style="color:#e11d48;">*</span></label>
            <input type="text" asp-for="Username" required autocomplete="off" class="ph-form-control" />
            <span asp-validation-for="Username" style="color:#e11d48;font-size:11px;"></span>
        </div>
        <div>
            <label class="ph-form-label">ربط بموظف (اختياري)</label>
            <select asp-for="EmployeeId" asp-items="ViewBag.EmployeeList" class="ph-form-select">
                <option value="">-- حساب إداري --</option>
            </select>
        </div>
    </div>

    <div class="ph-form-grid">
        <div>
            <label class="ph-form-label">كلمة مرور جديدة (اتركها فارغة إذا لم تريد التغيير)</label>
            <input type="password" asp-for="PasswordHash" autocomplete="new-password" placeholder="اترك فارغاً للاحتفاظ بالكلمة الحالية" class="ph-form-control" style="max-width:28rem;" />
        </div>
    </div>

    <div class="ph-section-title">الصلاحيات والفرع</div>

    <div class="ph-form-grid ph-form-grid-2">
        <div>
            <label class="ph-form-label">مجموعة الصلاحيات <span style="color:#e11d48;">*</span></label>
            <select asp-for="RoleId" asp-items="ViewBag.RoleList" required class="ph-form-select">
                <option value="">-- اختر الصلاحية --</option>
            </select>
        </div>
        <div>
            <label class="ph-form-label">فرع العمل الافتراضي <span style="color:#e11d48;">*</span></label>
            <select asp-for="DefaultBranchId" asp-items="ViewBag.BranchList" required class="ph-form-select">
                <option value="">-- اختر الفرع --</option>
            </select>
        </div>
    </div>

    <div class="ph-alert-warning">
        ⚠ تعديل الصلاحيات يسري فور حفظ التغييرات. تأكد من صحة الإعدادات قبل الحفظ.
    </div>

    <div class="ph-modal-actions">
        <button type="button" onclick="modalNavigateBack()" class="ph-btn-back">رجوع</button>
        <button type="submit" class="ph-btn-warning">
            <span class="material-symbols-outlined" style="font-size:18px;">save</span>
            حفظ التعديلات
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
