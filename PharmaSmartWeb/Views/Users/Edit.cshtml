@model PharmaSmartWeb.Models.Users

@{
    Layout = "_ModalLayout";
    ViewData["Title"] = $"تعديل حساب: {Model.Username}";
    ViewBag.ModalPanelSize = "lg";
    ViewBag.ModalHeaderIcon = "manage_accounts";
}

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="UserId" />

    @if (ViewBag.Error != null)
    {
        <div class="enterprise-alert-error">
            <span class="material-symbols-outlined" style="font-size:16px;">warning</span>
            @ViewBag.Error
        </div>
    }

    <!-- بنر معلومات الحساب + حالته -->
    <div class="enterprise-info-box" style="align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
        <div style="display:flex;align-items:center;gap:10px;">
            <span class="material-symbols-outlined" style="font-size:22px;color:#063955;">manage_accounts</span>
            <div>
                <div style="font-size:13px;font-weight:700;color:#063955;">تعديل: @Model.Username</div>
                <div style="font-size:11px;color:#64748b;">تعديل بيانات الحساب والصلاحيات</div>
            </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:4px;align-items:flex-start;">
            <label class="enterprise-label" style="margin-bottom:3px;">حالة الحساب</label>
            <select asp-for="IsActive" class="enterprise-select" style="width:10rem;">
                <option value="true">✅ حساب نشط</option>
                <option value="false">🔴 معطل</option>
            </select>
        </div>
    </div>

    <div class="enterprise-section-title">
        <span class="material-symbols-outlined" style="font-size:18px;">key</span>
        بيانات الحساب
    </div>

    <div class="enterprise-row">
        <div>
            <label class="enterprise-label">اسم الدخول <span style="color:#e11d48;">*</span></label>
            <input type="text" asp-for="Username" required autocomplete="off" class="enterprise-input" />
            <span asp-validation-for="Username" style="color:#e11d48;font-size:11px;display:block;margin-top:4px;"></span>
        </div>
        <div>
            <label class="enterprise-label">ربط بموظف (اختياري)</label>
            <select asp-for="EmployeeId" asp-items="ViewBag.EmployeeList" class="enterprise-select">
                <option value="">-- حساب إداري --</option>
            </select>
        </div>
    </div>

    <div style="margin-bottom:16px;">
        <label class="enterprise-label">كلمة مرور جديدة (اتركها فارغة إذا لم تريد التغيير)</label>
        <input type="password" asp-for="PasswordHash" autocomplete="new-password"
               placeholder="اترك فارغاً للاحتفاظ بالكلمة الحالية"
               class="enterprise-input" style="max-width:28rem;" />
    </div>

    <div class="enterprise-section-title" style="margin-top:24px;">
        <span class="material-symbols-outlined" style="font-size:18px;">admin_panel_settings</span>
        الصلاحيات والفرع
    </div>

    <div class="enterprise-row">
        <div>
            <label class="enterprise-label">مجموعة الصلاحيات <span style="color:#e11d48;">*</span></label>
            <select asp-for="RoleId" asp-items="ViewBag.RoleList" required class="enterprise-select">
                <option value="">-- اختر الصلاحية --</option>
            </select>
        </div>
        <div>
            <label class="enterprise-label">فرع العمل الافتراضي <span style="color:#e11d48;">*</span></label>
            <select asp-for="DefaultBranchId" asp-items="ViewBag.BranchList" required class="enterprise-select">
                <option value="">-- اختر الفرع --</option>
            </select>
        </div>
    </div>

    <div class="enterprise-info-box" style="background:#fffbeb;border-color:#fde68a;">
        <span class="material-symbols-outlined" style="color:#d97706;font-size:20px;">warning</span>
        <div style="font-size:12px;color:#92400e;font-weight:600;">
            تعديل الصلاحيات يسري فور حفظ التغييرات. تأكد من صحة الإعدادات قبل الحفظ.
        </div>
    </div>

    <div class="enterprise-actions">
        <button type="button" onclick="modalNavigateBack()" class="enterprise-btn-cancel">رجوع</button>
        <button type="submit" class="enterprise-btn-warning">
            <span class="material-symbols-outlined" style="font-size:16px;">save</span>
            حفظ التعديلات
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
