@model PharmaSmartWeb.Models.Users

@{
    Layout = "_ModalLayout";
    ViewData["Title"] = $"تعديل حساب: {Model.Username}";
}

<style>
    .form-label { font-size: 12px; font-weight: 700; color: #063955; margin-bottom: 4px; display: block; }
    .form-control { width: 100%; border: 1px solid #cbd5e1; border-radius: 2px; padding: 7px 10px; font-size: 13px; }
    .form-control:focus { outline: none; border-color: #063955; box-shadow: 0 0 0 2px rgba(6,57,85,0.1); }
    .form-select { width: 100%; border: 1px solid #cbd5e1; border-radius: 2px; padding: 7px 10px; font-size: 13px; background: white; }
    .btn-submit { background: #d97706; color: white; border: none; padding: 9px 24px; border-radius: 2px; font-size: 13px; font-weight: 700; cursor: pointer; }
    .btn-submit:hover { background: #b45309; }
    .btn-cancel { background: white; color: #475569; border: 1px solid #d1d5db; padding: 9px 20px; border-radius: 2px; font-size: 13px; font-weight: 700; cursor: pointer; }
    .section-title { font-size: 13px; font-weight: 700; color: #063955; padding-bottom: 8px; border-bottom: 2px solid #063955; margin-bottom: 16px; }
    .alert-warning { background: #fffbeb; border-right: 4px solid #d97706; border-radius: 2px; padding: 10px 14px; font-size: 12px; color: #92400e; }
    .alert-error { background: #fff1f2; border-right: 4px solid #e11d48; border-radius: 2px; padding: 10px 14px; font-size: 12px; color: #e11d48; }
    .user-banner { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 2px; padding: 12px 16px; margin-bottom: 16px; display: flex; align-items: center; justify-content: space-between; }
</style>

<form asp-action="Edit" method="post" style="padding: 20px;">
    <input type="hidden" asp-for="UserId" />

    @if (ViewBag.Error != null)
    {
        <div class="alert-error mb-4">⚠ @ViewBag.Error</div>
    }

    <!-- User Status Banner -->
    <div class="user-banner">
        <div style="display:flex; align-items:center; gap:10px;">
            <span class="material-symbols-outlined" style="font-size:20px; color:#063955;">manage_accounts</span>
            <div>
                <div style="font-size:13px; font-weight:700; color:#063955;">تعديل: @Model.Username</div>
                <div style="font-size:11px; color:#64748b;">تعديل بيانات الحساب والصلاحيات</div>
            </div>
        </div>
        <div>
            <label class="form-label" style="margin-bottom:2px;">حالة الحساب</label>
            <select asp-for="IsActive" class="form-select" style="width:160px;">
                <option value="true">✅ حساب نشط</option>
                <option value="false">🔴 معطل</option>
            </select>
        </div>
    </div>

    <div class="section-title">بيانات الحساب</div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
        <div>
            <label class="form-label">اسم الدخول <span style="color:#e11d48;">*</span></label>
            <input type="text" asp-for="Username" required autocomplete="off" class="form-control" />
            <span asp-validation-for="Username" style="color:#e11d48; font-size:11px;"></span>
        </div>

        <div>
            <label class="form-label">ربط بموظف (اختياري)</label>
            <select asp-for="EmployeeId" asp-items="ViewBag.EmployeeList" class="form-select">
                <option value="">-- حساب إداري --</option>
            </select>
        </div>
    </div>

    <div>
        <label class="form-label">كلمة مرور جديدة (اتركها فارغة إذا لم تريد التغيير)</label>
        <input type="password" asp-for="PasswordHash" autocomplete="new-password" placeholder="اترك فارغاً للاحتفاظ بالكلمة الحالية"
               class="form-control" style="max-width:400px;" />
    </div>

    <div class="section-title" style="margin-top:16px;">الصلاحيات والفرع</div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
        <div>
            <label class="form-label">مجموعة الصلاحيات <span style="color:#e11d48;">*</span></label>
            <select asp-for="RoleId" asp-items="ViewBag.RoleList" required class="form-select">
                <option value="">-- اختر الصلاحية --</option>
            </select>
        </div>

        <div>
            <label class="form-label">فرع العمل الافتراضي <span style="color:#e11d48;">*</span></label>
            <select asp-for="DefaultBranchId" asp-items="ViewBag.BranchList" required class="form-select">
                <option value="">-- اختر الفرع --</option>
            </select>
        </div>
    </div>

    <div class="alert-warning">
        ⚠ تعديل الصلاحيات يسري فور حفظ التغييرات. تأكد من صحة الإعدادات قبل الحفظ.
    </div>

    <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:20px; padding-top:16px; border-top:1px solid #e2e8f0;">
        <button type="button" onclick="history.back()" class="btn-cancel">رجوع</button>
        <button type="submit" class="btn-submit">
            <span class="material-symbols-outlined" style="font-size:15px; vertical-align:middle;">save</span>
            حفظ التعديلات
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}