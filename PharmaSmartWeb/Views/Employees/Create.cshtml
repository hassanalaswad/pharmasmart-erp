@model PharmaSmartWeb.Models.Employees

@{
    ViewData["Title"] = "إضافة موظف جديد";
    Layout = "_ModalLayout";
}

<style>
    .form-label { font-size: 12px; font-weight: 700; color: #063955; margin-bottom: 4px; display: block; }
    .form-control { width: 100%; border: 1px solid #cbd5e1; border-radius: 2px; padding: 7px 10px; font-size: 13px; }
    .form-control:focus { outline: none; border-color: #063955; }
    .form-select { width: 100%; border: 1px solid #cbd5e1; border-radius: 2px; padding: 7px 10px; font-size: 13px; background: white; }
    .btn-submit { background: #063955; color: white; border: none; padding: 9px 24px; border-radius: 2px; font-size: 13px; font-weight: 700; cursor: pointer; }
    .btn-submit:hover { background: #0a4f72; }
    .btn-cancel { background: white; color: #475569; border: 1px solid #d1d5db; padding: 9px 20px; border-radius: 2px; font-size: 13px; font-weight: 700; cursor: pointer; }
    .section-title { font-size: 13px; font-weight: 700; color: #063955; padding-bottom: 8px; border-bottom: 2px solid #063955; margin-bottom: 16px; }
    .alert-error { background: #fff1f2; border-right: 4px solid #e11d48; border-radius: 2px; padding: 10px 14px; font-size: 12px; color: #e11d48; margin-bottom: 16px; }
    .alert-info { background: #eff6ff; border-right: 4px solid #1d4ed8; border-radius: 2px; padding: 10px 14px; font-size: 12px; color: #1e40af; }
</style>

<form asp-action="Create" method="post" style="padding: 20px;">
    <input type="hidden" asp-for="IsActive" value="true" />

    @if (ViewBag.Error != null)
    {
        <div class="alert-error">⚠ @ViewBag.Error</div>
    }

    <div class="section-title">المعلومات الشخصية</div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
        <div>
            <label class="form-label">الاسم الكامل <span style="color:#e11d48;">*</span></label>
            <input asp-for="FullName" required class="form-control" placeholder="أدخل اسم الموظف" type="text" />
            <span asp-validation-for="FullName" style="color:#e11d48; font-size:11px;"></span>
        </div>
        <div>
            <label class="form-label">المسمى الوظيفي <span style="color:#e11d48;">*</span></label>
            <input asp-for="Position" required class="form-control" placeholder="مثال: طبيب عام، صيدلي..." type="text" />
        </div>
    </div>

    <div style="margin-bottom: 16px;">
        <label class="form-label">رقم الهاتف</label>
        <input asp-for="Phone" class="form-control" dir="ltr" placeholder="05XXXXXXXX" type="tel" style="max-width:300px;" />
    </div>

    <div class="section-title">تفاصيل العمل</div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
        <div>
            <label class="form-label">الفرع / القسم <span style="color:#e11d48;">*</span></label>
            <select asp-for="BranchId" asp-items="ViewBag.BranchList" required class="form-select">
                <option value="">اختر التوجيه الميداني</option>
            </select>
        </div>
        <div>
            <label class="form-label">الراتب الأساسي <span style="color:#e11d48;">*</span></label>
            <div style="display:flex; align-items:center; gap:6px;">
                <input asp-for="Salary" step="0.01" required class="form-control" placeholder="0.00" type="number" style="flex:1;" />
                <span style="font-size:12px; font-weight:700; color:#64748b; white-space:nowrap;">ر.ي</span>
            </div>
        </div>
    </div>

    <div class="alert-info">
        ℹ الموظف الجديد سيكون "نشطاً" بشكل افتراضي. يمكنك لاحقاً تعديل الحالة أو إيقاف الموظف من خلال شاشة التعديل.
    </div>

    <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:20px; padding-top:16px; border-top:1px solid #e2e8f0;">
        <button type="button" onclick="history.back()" class="btn-cancel">رجوع</button>
        <button type="submit" class="btn-submit">
            <span class="material-symbols-outlined" style="font-size:15px; vertical-align:middle;">save</span>
            حفظ واعتماد الموظف
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}