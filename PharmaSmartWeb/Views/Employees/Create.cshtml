@model PharmaSmartWeb.Models.Employees

@{
    ViewData["Title"] = "إضافة موظف جديد";
    Layout = "_ModalLayout";
    ViewBag.ModalPanelSize = "lg";
    ViewBag.ModalHeaderIcon = "badge";
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="IsActive" value="true" />

    @if (ViewBag.Error != null)
    {
        <div class="enterprise-alert-error">
            <span class="material-symbols-outlined" style="font-size:16px;">warning</span>
            @ViewBag.Error
        </div>
    }

    <div class="enterprise-section-title">
        <span class="material-symbols-outlined" style="font-size:18px;">person</span>
        المعلومات الشخصية
    </div>
    <div class="enterprise-row">
        <div>
            <label class="enterprise-label">الاسم الكامل <span style="color:#e11d48;">*</span></label>
            <input asp-for="FullName" required class="enterprise-input" placeholder="أدخل اسم الموظف" type="text" />
            <span asp-validation-for="FullName" style="color:#e11d48;font-size:11px;display:block;margin-top:4px;"></span>
        </div>
        <div>
            <label class="enterprise-label">المسمى الوظيفي <span style="color:#e11d48;">*</span></label>
            <input asp-for="Position" required class="enterprise-input" placeholder="مثال: طبيب عام، صيدلي..." type="text" />
        </div>
    </div>

    <div style="margin-bottom:16px;">
        <label class="enterprise-label">رقم الهاتف</label>
        <input asp-for="Phone" class="enterprise-input" dir="ltr" placeholder="05XXXXXXXX" type="tel" style="max-width:18rem;" />
    </div>

    <div class="enterprise-section-title" style="margin-top:24px;">
        <span class="material-symbols-outlined" style="font-size:18px;">work</span>
        تفاصيل العمل
    </div>
    <div class="enterprise-row">
        <div>
            <label class="enterprise-label">الفرع / القسم <span style="color:#e11d48;">*</span></label>
            <select asp-for="BranchId" asp-items="ViewBag.BranchList" required class="enterprise-select">
                <option value="">اختر التوجيه الميداني</option>
            </select>
        </div>
        <div>
            <label class="enterprise-label">الراتب الأساسي <span style="color:#e11d48;">*</span></label>
            <div style="display:flex;align-items:center;gap:0.5rem;">
                <input asp-for="Salary" step="0.01" required class="enterprise-input" placeholder="0.00" type="number" style="flex:1;" />
                <span style="font-size:12px;font-weight:800;color:#64748b;white-space:nowrap;">ر.ي</span>
            </div>
        </div>
    </div>

    <div class="enterprise-info-box" style="background:#f0f9ff;border-color:#bae6fd;">
        <span class="material-symbols-outlined" style="color:#0284c7;font-size:20px;">info</span>
        <div style="font-size:12px;color:#0369a1;font-weight:600;">
            الموظف الجديد سيكون «نشطاً» بشكل افتراضي. يمكنك لاحقاً تعديل الحالة من شاشة التعديل.
        </div>
    </div>

    <div class="enterprise-actions">
        <button type="button" onclick="modalNavigateBack()" class="enterprise-btn-cancel">رجوع</button>
        <button type="submit" class="enterprise-btn-submit">
            <span class="material-symbols-outlined" style="font-size:16px;">save</span>
            حفظ واعتماد الموظف
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
