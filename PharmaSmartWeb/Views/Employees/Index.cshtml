@model IEnumerable<PharmaSmartWeb.Models.Employees>

@{
    ViewData["Title"] = "سجل الموظفين";
    var totalCount = Model.Count();
    var activeCount = Model.Count(e => e.IsActive == true);
    var inactiveCount = Model.Count(e => e.IsActive != true);
    var hasSalaryViewingPermission = User.IsInRole("SuperAdmin") || User.HasClaim("Permission", "System.ChangeBranch");
}

@if (TempData["Success"] != null)
{
    <div class="bg-emerald-50 border border-emerald-200 border-r-4 border-r-emerald-500 rounded-xl p-3 mb-4 flex items-center gap-2 text-sm text-emerald-700">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}

<!-- ===== رأس الصفحة ===== -->
<div class="flex flex-wrap justify-between items-start mb-5">
    <div class="flex items-center gap-3 mb-2 sm:mb-0">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500 to-teal-700 flex items-center justify-center shadow-sm">
            <i class="fas fa-user-md text-white"></i>
        </div>
        <div>
            <h1 class="text-xl font-black text-gray-800">سجل الموظفين والكوادر الطبية</h1>
            <p class="text-xs text-gray-500">إدارة ومتابعة الكفاءات الطبية والإدارية في النظام</p>
        </div>
    </div>
    <div class="flex gap-2 flex-wrap">
        <a href="/Employees/Create" class="quick-action-btn px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5 active:scale-95">
            <i class="fas fa-user-plus"></i> إضافة موظف جديد
        </a>
    </div>
</div>

<!-- ===== بطاقات KPI ===== -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-5">
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-emerald-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">إجمالي الموظفين</span>
            <i class="fas fa-users text-emerald-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@totalCount</div>
        <span class="text-xs text-gray-400 font-medium">موظف مسجل بالفرع</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-teal-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-teal-700 font-semibold">الموظفون النشطون</span>
            <i class="fas fa-user-check text-teal-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-teal-600">@activeCount</div>
        <span class="text-xs text-gray-400 font-medium">موظف على رأس العمل</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-rose-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-rose-700 font-semibold">في إجازة / موقوفون</span>
            <i class="fas fa-user-times text-rose-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-rose-600">@inactiveCount</div>
        <span class="text-xs text-gray-400 font-medium">موظف غير نشط حالياً</span>
    </div>
</div>

<!-- ===== جدول الموظفين ===== -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100">
    <div class="flex flex-wrap justify-between items-center px-5 py-4 border-b border-gray-100 gap-3">
        <h3 class="font-bold text-gray-800 text-sm">
            <i class="fas fa-list text-emerald-500 ml-1.5"></i> قائمة الموظفين المسجلين
        </h3>
        <div class="relative">
            <i class="fas fa-search absolute right-3 top-2.5 text-gray-400 text-xs"></i>
            <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="البحث بالاسم أو التخصص..."
                class="pr-8 pl-4 py-2 border border-gray-200 rounded-xl text-xs w-56 focus:outline-none focus:ring-2 focus:ring-emerald-400" />
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full data-table text-sm" id="empTable">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">الاسم الكامل</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">التخصص / المنصب</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">رقم الهاتف</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">الفرع</th>
                    @if (hasSalaryViewingPermission)
                    {
                        <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">الراتب الأساسي</th>
                    }
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">الحالة</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="@(hasSalaryViewingPermission ? 7 : 6)" class="text-center py-12 text-gray-400">
                            <i class="fas fa-users-slash text-5xl mb-3 block text-gray-200"></i>
                            لا توجد سجلات موظفين في هذا النطاق.
                        </td>
                    </tr>
                }
                @foreach (var emp in Model)
                {
                    <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors search-row">
                        <td class="px-5 py-3 search-name">
                            <div class="flex items-center gap-2">
                                <div class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center shrink-0">
                                    <i class="fas fa-user-md text-xs"></i>
                                </div>
                                <span class="font-bold text-gray-800">@emp.FullName</span>
                            </div>
                        </td>
                        <td class="px-5 py-3 text-sm font-semibold text-gray-600 search-pos">@emp.Position</td>
                        <td class="px-5 py-3 font-mono text-gray-500 text-xs" dir="ltr">@emp.Phone</td>
                        <td class="px-5 py-3">
                            <span class="bg-gray-100 text-gray-600 border border-gray-200 px-2 py-0.5 rounded text-[11px] font-semibold">
                                @(emp.Branch?.BranchName ?? "غير محدد")
                            </span>
                        </td>
                        @if (hasSalaryViewingPermission)
                        {
                            <td class="px-5 py-3 text-center font-mono font-bold text-emerald-600 text-sm">@emp.Salary.ToString("N0")</td>
                        }
                        <td class="px-5 py-3 text-center">
                            @if (emp.IsActive == true)
                            {
                                <span class="text-[11px] px-2.5 py-1 bg-emerald-50 text-emerald-700 border border-emerald-100 rounded-full font-bold">نشط</span>
                            }
                            else
                            {
                                <span class="text-[11px] px-2.5 py-1 bg-rose-50 text-rose-700 border border-rose-100 rounded-full font-bold">موقوف</span>
                            }
                        </td>
                        <td class="px-5 py-3 text-center">
                            <a href="/Employees/Edit/@emp.EmployeeId" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-amber-50 hover:bg-amber-100 border border-amber-200 text-amber-700 rounded-lg text-xs font-semibold transition-all">
                                <i class="fas fa-pen text-[10px]"></i> تعديل
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 rounded-b-2xl">
        <span class="text-xs text-gray-500">إجمالي: <strong class="text-gray-700">@totalCount</strong> موظف مسجل</span>
    </div>
</div>

@section Scripts {
<script>
function filterTable() {
    const q = document.getElementById("searchInput").value.toLowerCase();
    document.querySelectorAll(".search-row").forEach(row => {
        const name = row.querySelector(".search-name")?.innerText.toLowerCase() ?? "";
        const pos = row.querySelector(".search-pos")?.innerText.toLowerCase() ?? "";
        row.style.display = (name.includes(q) || pos.includes(q)) ? "" : "none";
    });
}
</script>
}