@model PharmaSmartWeb.Controllers.FinancialMappingViewModel

@{
    ViewData["Title"] = "التوجيه المحاسبي للفرع";
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .page-title { font-size: 16px; font-weight: 700; color: #063955; }
    .page-sub { font-size: 12px; color: #64748b; }
    .btn-primary { background: #063955; color: white; border: none; padding: 7px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 6px; transition: 0.2s; text-decoration: none; }
    .btn-primary:hover { background: #0a4f72; color: white; }
    .btn-secondary { background: white; border: 1px solid #d1d5db; color: #475569; padding: 6px 12px; border-radius: 2px; font-size: 11px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 4px; transition: 0.2s; text-decoration: none; }
    .btn-secondary:hover { background: #f8fafc; color: #1e293b; border-color: #94a3b8; }
    .alert-success { background: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; padding: 12px 16px; border-radius: 2px; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 12px; }
    .alert-error { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; padding: 12px 16px; border-radius: 2px; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 12px; }
    .form-group { margin-bottom: 16px; }
    .form-label { display: block; font-size: 11px; font-weight: 700; color: #334155; margin-bottom: 4px; text-transform: uppercase; }
    .form-select { width: 100%; border: 1px solid #cbd5e1; border-radius: 2px; padding: 8px 12px; font-size: 12px; font-weight: 700; background-color: #f8fafc; color: #1e293b; outline: none; }
    .form-select:focus { border-color: #063955; background-color: white; }
    .setting-row { display: flex; align-items: center; padding: 16px; border-bottom: 1px solid #e2e8f0; background: white; }
    .setting-row:last-child { border-bottom: none; }
    .setting-icon { width: 40px; height: 40px; border-radius: 2px; background: #f1f5f9; display: flex; align-items: center; justify-content: center; margin-left: 16px; flex-shrink: 0; }
    .setting-info { flex-grow: 1; }
    .setting-title { font-size: 13px; font-weight: bold; color: #063955; margin-bottom: 2px; }
    .setting-desc { font-size: 11px; color: #64748b; font-weight: normal; }
    .setting-input { width: 300px; }
</style>

<div class="flex-1 overflow-y-auto p-6 space-y-4 max-w-5xl mx-auto">

    <!-- Header Panel -->
    <div class="enterprise-panel flex flex-col md:flex-row justify-between items-start md:items-center p-4 gap-4">
        <div>
            <nav class="flex items-center gap-2 text-slate-500 text-[11px] mb-1 font-semibold">
                <a href="/Home/Index" class="hover:text-[#063955]">الرئيسية</a>
                <span class="material-symbols-outlined text-[14px]">chevron_left</span>
                <span class="text-[#063955]">إعدادات النظام</span>
            </nav>
            <h1 class="page-title">التوجيه المحاسبي (ERP Engine)</h1>
            <p class="page-sub">التوجيه المحاسبي للفرع: <span style="font-weight: bold; color: #063955;">@Model.BranchName</span></p>
        </div>
        <div class="flex gap-2">
            <a href="/Accounting/Index" class="btn-secondary">
                <span class="material-symbols-outlined" style="font-size: 16px;">account_tree</span>
                الدليل المحاسبي
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success">
            <span class="material-symbols-outlined" style="font-size: 18px;">check_circle</span>
            @TempData["Success"]
        </div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert-error">
            <span class="material-symbols-outlined" style="font-size: 18px;">error</span>
            @ViewBag.Error
        </div>
    }

    <form asp-action="Index" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="BranchId" />
        <input type="hidden" asp-for="BranchName" />

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <!-- Main Form Column -->
            <div class="lg:col-span-2 space-y-4">
                <div class="enterprise-panel border-t-4 border-t-[#063955]">
                    <div class="p-4 border-b border-slate-200 bg-slate-50 flex justify-between items-center">
                        <h2 class="text-[14px] font-bold text-[#063955] flex items-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">tune</span> ربط الحسابات
                        </h2>
                    </div>

                    <div class="flex flex-col">
                        <!-- Sales -->
                        <div class="setting-row">
                            <div class="setting-icon text-[#0284c7]">
                                <span class="material-symbols-outlined">point_of_sale</span>
                            </div>
                            <div class="setting-info">
                                <h4 class="setting-title">إيرادات المبيعات</h4>
                                <p class="setting-desc">توجيه كافة المبيعات المباشرة وغير المباشرة</p>
                            </div>
                            <div class="setting-input">
                                <select asp-for="SalesRevenueAccountId" asp-items="ViewBag.SalesAccounts" class="form-select">
                                    <option value="">-- يرجى الاختيار --</option>
                                </select>
                            </div>
                        </div>

                        <!-- COGS -->
                        <div class="setting-row">
                            <div class="setting-icon text-[#dc2626]">
                                <span class="material-symbols-outlined">shopping_cart_checkout</span>
                            </div>
                            <div class="setting-info">
                                <h4 class="setting-title">تكلفة البضاعة المباعة (COGS)</h4>
                                <p class="setting-desc">تسجيل تكلفة المخزون المنصرف للعملاء</p>
                            </div>
                            <div class="setting-input">
                                <select asp-for="COGSAccountId" asp-items="ViewBag.COGSAccounts" class="form-select">
                                    <option value="">-- يرجى الاختيار --</option>
                                </select>
                            </div>
                        </div>

                        <!-- Inventory -->
                        <div class="setting-row">
                            <div class="setting-icon text-[#059669]">
                                <span class="material-symbols-outlined">medication_liquid</span>
                            </div>
                            <div class="setting-info">
                                <h4 class="setting-title">مخزون المستودع</h4>
                                <p class="setting-desc">الرصيد المدين للمشتريات وجرد المستودعات</p>
                            </div>
                            <div class="setting-input">
                                <select asp-for="InventoryAccountId" asp-items="ViewBag.InventoryAccounts" class="form-select">
                                    <option value="">-- يرجى الاختيار --</option>
                                </select>
                            </div>
                        </div>

                        <!-- Cash -->
                        <div class="setting-row">
                            <div class="setting-icon text-[#d97706]">
                                <span class="material-symbols-outlined">payments</span>
                            </div>
                            <div class="setting-info">
                                <h4 class="setting-title">الصندوق الافتراضي (Cash)</h4>
                                <p class="setting-desc">جميع التحصيلات والمصروفات النقدية الكاش</p>
                            </div>
                            <div class="setting-input">
                                <select asp-for="CashAccountId" asp-items="ViewBag.CashAccounts" class="form-select">
                                    <option value="">-- يرجى الاختيار --</option>
                                </select>
                            </div>
                        </div>

                        <!-- Bank -->
                        <div class="setting-row">
                            <div class="setting-icon text-[#4f46e5]">
                                <span class="material-symbols-outlined">account_balance</span>
                            </div>
                            <div class="setting-info">
                                <h4 class="setting-title">البنك الافتراضي (Bank)</h4>
                                <p class="setting-desc">نقاط البيع الإلكترونية POS والتحويلات</p>
                            </div>
                            <div class="setting-input">
                                <select asp-for="BankAccountId" asp-items="ViewBag.BankAccounts" class="form-select">
                                    <option value="">-- يرجى الاختيار --</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    
                    <div class="p-4 border-t border-slate-200 bg-slate-50 flex justify-end">
                        <button type="submit" class="btn-primary" style="padding: 10px 24px; font-size: 13px;">
                            <span class="material-symbols-outlined" style="font-size: 18px;">save</span> حفظ إعدادات الربط
                        </button>
                    </div>
                </div>
            </div>

            <!-- Sidebar Column -->
            <div class="lg:col-span-1 space-y-4">
                @{
                    int configured = 0;
                    if(Model.SalesRevenueAccountId.HasValue) configured++;
                    if(Model.COGSAccountId.HasValue) configured++;
                    if(Model.InventoryAccountId.HasValue) configured++;
                    if(Model.CashAccountId.HasValue) configured++;
                    if(Model.BankAccountId.HasValue) configured++;
                    
                    int percent = (configured * 100) / 5;
                }

                <div class="enterprise-panel p-5">
                    <h4 class="text-[12px] font-bold text-slate-500 uppercase tracking-widest mb-4">حالة الإعدادات</h4>
                    
                    <div class="flex justify-between items-center mb-2">
                        <div class="flex items-center gap-2">
                            <div class="w-2 h-2 rounded-[1px] @(percent == 100 ? "bg-[#059669]" : "bg-[#0284c7]")"></div>
                            <span class="text-[12px] font-bold text-[#334155]">اكتمال الربط المحاسبي</span>
                        </div>
                        <span class="font-black text-[#0f172a] text-[14px]">@percent%</span>
                    </div>
                    
                    <div class="w-full bg-slate-200 h-1.5 rounded-none overflow-hidden mb-4">
                        <div class="@(percent == 100 ? "bg-[#059669]" : "bg-[#0284c7]") h-full" style="width: @percent%"></div>
                    </div>
                    
                    @if(percent < 100)
                    {
                        <div class="bg-[#fffbeb] p-3 border border-[#fde68a] text-[11px] font-bold text-[#b45309] rounded-sm">
                            <span class="material-symbols-outlined text-[14px] align-middle">warning</span>
                            يرجى استكمال باقي الحسابات لضمان عمل القيود الآلية.
                        </div>
                    }
                </div>

                <div class="enterprise-panel p-5 bg-[#0f172a] text-white" style="border-color: #0f172a;">
                    <h4 class="text-[12px] font-bold text-[#94a3b8] uppercase tracking-widest mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-[16px]">memory</span> محاكاة القيود
                    </h4>
                    
                    <div class="font-mono text-[11px] space-y-3 pt-3 border-t border-slate-700">
                        <div class="flex justify-between">
                            <span class="text-[#38bdf8]">من حـ/ مبيعات</span>
                            <span class="font-bold tracking-wider">5,000.00 @Settings.Currency</span>
                        </div>
                        <div class="flex justify-between pr-4">
                            <span class="text-[#34d399]">إلى حـ/ إيرادات المبيعات</span>
                            <span class="font-bold tracking-wider">4,347.83 @Settings.Currency</span>
                        </div>
                    </div>
                    
                    <p class="text-[10px] text-slate-400 font-bold mt-4 pt-3 border-t border-slate-700 leading-relaxed">
                        تُبنى هذه القيود فوراً بمجرد حفظ الإعدادات وربط حسابات الإيرادات والضرائب.
                    </p>
                </div>
            </div>

        </div>
    </form>
</div>