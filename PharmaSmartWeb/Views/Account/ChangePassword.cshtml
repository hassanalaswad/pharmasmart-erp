@{
    Layout = null; // تعطيل القالب الرئيسي لهذه الصفحة
}

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>تغيير كلمة المرور - Cura Insight</title>
    
    <!-- Google Fonts Preconnect -->
    
    

    <!-- Material Symbols Outlined (Icons) -->
    

    <!-- Cairo Font (Arabic) -->
    

    <!-- Cura Insight Unified Theme Dependencies -->
    <script src="~/lib/tailwindcss.js"></script>
    <script src="~/js/tailwind.config.js"></script>
    <link href="~/css/cura-styles.css" rel="stylesheet" />
    
    <style>
        body { font-family: 'Cairo', sans-serif; }
        
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .shadow-sm {
            box-shadow: 0 20px 40px rgba(0, 72, 112, 0.08);
        }

        .signature-gradient {
            background: linear-gradient(135deg, #00314e 0%, #004870 100%);
        }
    </style>
    <link rel="stylesheet" href="~/css/local-fonts.css" />
</head>
<body class="bg-surface font-body text-on-surface">
    <div class="min-h-screen flex items-center justify-center relative overflow-hidden bg-surface-dim/40 ">
        <div class="absolute inset-0 z-0 overflow-hidden">
            <div class="grid grid-cols-12 gap-4 p-5 opacity-20 grayscale pointer-events-none">
                <div class="col-span-8 h-64 bg-white rounded-sm"></div>
                <div class="col-span-4 h-64 bg-white rounded-sm"></div>
                <div class="col-span-4 h-48 bg-white rounded-sm"></div>
                <div class="col-span-8 h-48 bg-white rounded-sm"></div>
            </div>
        </div>
        <div class="relative z-10 w-full max-w-lg mx-4">
            <div class="bg-surface-container-lowest rounded-sm shadow-sm border-none overflow-hidden">
                <div class="px-8 pt-8 pb-6 text-right">
                    <div class="flex justify-between items-center mb-6">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-sm signature-gradient flex items-center justify-center">
                                <span class="material-symbols-outlined text-white text-xl" data-icon="lock_reset">lock_reset</span>
                            </div>
                            <div>
                                <h1 class="text-xl font-bold font-headline text-primary">تغيير كلمة المرور - Cura Insight</h1>
                                <p class="text-xs text-on-secondary-container mt-1">يرجى إدخال تفاصيل الأمان الجديدة الخاصة بك</p>
                            </div>
                        </div>
                        <a href="@Url.Action("Index", "Home")" class="text-outline-variant hover:text-error transition-colors">
                            <span class="material-symbols-outlined" data-icon="close">close</span>
                        </a>
                    </div>
                    
                    @if (ViewBag.Error != null)
                    {
                        <div class="mb-6 bg-error-container/50 border-r-4 border-error p-4 rounded-sm flex items-center gap-3">
                            <span class="material-symbols-outlined text-error">error</span>
                            <p class="text-on-error-container text-xs font-bold">@ViewBag.Error</p>
                        </div>
                    }

                    <form asp-action="ChangePassword" asp-controller="Account" method="post" class="space-y-6">
                        @Html.AntiForgeryToken()
                        <div class="space-y-2">
                            <label class="block text-sm font-semibold text-primary pr-1">كلمة المرور الحالية</label>
                            <div class="relative group">
                                <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-outline-variant group-focus-within:text-primary-container transition-colors" data-icon="key">key</span>
                                <input class="w-full pr-12 pl-4 py-3.5 bg-surface-container-low border-none rounded-sm focus:ring-2 focus:ring-primary-container/20 focus:bg-surface-container-lowest transition-all placeholder:text-outline-variant"
                                       id="currentPassword" name="currentPassword" required placeholder="••••••••" type="password" />
                            </div>
                        </div>
                        <div class="h-px bg-surface-container-high w-full my-2"></div>
                        <div class="space-y-5">
                            <div class="space-y-2">
                                <label class="block text-sm font-semibold text-primary pr-1">كلمة المرور الجديدة</label>
                                <div class="relative group">
                                    <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-outline-variant group-focus-within:text-primary-container transition-colors" data-icon="lock_open">lock_open</span>
                                    <input class="w-full pr-12 pl-4 py-3.5 bg-surface-container-low border-none rounded-sm focus:ring-2 focus:ring-primary-container/20 focus:bg-surface-container-lowest transition-all placeholder:text-outline-variant"
                                           id="newPassword" name="newPassword" required placeholder="أدخل كلمة مرور قوية" type="password" />
                                </div>
                                <div class="flex gap-1.5 px-1 mt-2">
                                    <div class="h-1 flex-1 rounded-full bg-primary-container"></div>
                                    <div class="h-1 flex-1 rounded-full bg-primary-container"></div>
                                    <div class="h-1 flex-1 rounded-full bg-surface-container-high"></div>
                                    <div class="h-1 flex-1 rounded-full bg-surface-container-high"></div>
                                    <span class="text-[10px] text-on-secondary-container mr-2 font-medium">قوة متوسطة</span>
                                </div>
                            </div>
                            <div class="space-y-2">
                                <label class="block text-sm font-semibold text-primary pr-1">تأكيد كلمة المرور الجديدة</label>
                                <div class="relative group">
                                    <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-outline-variant group-focus-within:text-primary-container transition-colors" data-icon="verified_user">verified_user</span>
                                    <input class="w-full pr-12 pl-4 py-3.5 bg-surface-container-low border-none rounded-sm focus:ring-2 focus:ring-primary-container/20 focus:bg-surface-container-lowest transition-all placeholder:text-outline-variant"
                                           id="confirmPassword" name="confirmPassword" required placeholder="أعد إدخال كلمة المرور" type="password" />
                                </div>
                            </div>
                        </div>
                        <div class="bg-tertiary-fixed/30 p-4 rounded-sm flex gap-3 items-start border border-tertiary-fixed-dim/20">
                            <span class="material-symbols-outlined text-on-tertiary-fixed-variant" data-icon="info">info</span>
                            <p class="text-xs text-on-tertiary-fixed-variant leading-relaxed font-medium">
                                يجب أن تحتوي كلمة المرور على 8 أحرف على الأقل، بما في ذلك أرقام ورموز خاصة لضمان أقصى درجات الأمان لملفات المرضى.
                            </p>
                        </div>
                        <div class="flex flex-col sm:flex-row-reverse gap-3 pt-4">
                            <button class="signature-gradient text-white font-bold py-3.5 px-8 rounded-sm flex items-center justify-center gap-2 transition-all active:scale-95 shadow-sm border border-slate-200 shadow-primary-container/20" type="submit">
                                <span class="material-symbols-outlined text-xl" data-icon="save">save</span>
                                تحديث كلمة المرور
                            </button>
                            <a href="@Url.Action("Index", "Home")" class="bg-surface-container-high text-primary text-center font-semibold py-3.5 px-8 rounded-sm transition-all hover:bg-surface-variant active:scale-95">
                                إلغاء العملية
                            </a>
                        </div>
                    </form>
                </div>
                <div class="bg-surface-container-low px-8 py-4 flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-on-secondary-container text-sm" data-icon="shield">shield</span>
                        <span class="text-[11px] text-on-secondary-container font-medium">نظام تشفير Cura Insight المتطور</span>
                    </div>
                </div>
            </div>
            <div class="mt-8 text-center">
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/50 rounded-full border border-white/20">
                    <div class="w-2 h-2 rounded-full bg-primary-container animate-pulse"></div>
                    <span class="text-xs font-bold text-primary tracking-wide">Cura Insight Enterprise</span>
                </div>
            </div>
        </div>
    </div>
</body>
</html>