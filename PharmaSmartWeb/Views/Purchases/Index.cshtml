@model IEnumerable<PharmaSmartWeb.Models.Purchases>

@{
    ViewData["Title"] = "سجل التوريدات";
    string currency = Settings.Currency;
}

@if (TempData["Success"] != null)
{
    <div class="bg-emerald-50 border border-emerald-200 border-r-4 border-r-emerald-500 rounded-xl p-3 mb-4 flex items-center gap-2 text-sm text-emerald-700">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}

<!-- ===== رأس الصفحة ===== -->
<div class="flex flex-wrap justify-between items-start mb-5">
    <div class="flex items-center gap-3 mb-2 sm:mb-0">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500 to-teal-700 flex items-center justify-center shadow-sm">
            <i class="fas fa-truck-loading text-white"></i>
        </div>
        <div>
            <h1 class="text-xl font-black text-gray-800">سجل المشتريات (التوريدات)</h1>
            <p class="text-xs text-gray-500">متابعة فواتير الموردين، الدفعات وإدخالات المخزون</p>
        </div>
    </div>
    <div class="flex gap-2 flex-wrap">
        <a href="/PurchaseReturns/Index"
           class="px-4 py-2 bg-amber-50 hover:bg-amber-100 text-amber-700 border border-amber-200 rounded-xl text-xs font-bold flex items-center gap-2 transition-colors">
            <i class="fas fa-undo"></i> مرتجعات المشتريات
        </a>
        <a href="/Purchases/Create"
           class="quick-action-btn px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5 active:scale-95">
            <i class="fas fa-truck"></i> تسجيل توريد جديد
        </a>
    </div>
</div>

<!-- ===== بطاقات KPI ===== -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-5">
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-emerald-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">إجمالي المدفوع</span>
            <i class="fas fa-check-circle text-emerald-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-emerald-600">@ViewBag.TotalPaid.ToString("N0")</div>
        <span class="text-xs text-gray-400 font-medium">@currency — مدفوع نقداً/بنك</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-rose-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-rose-700 font-semibold">ديون الموردين</span>
            <i class="fas fa-exclamation-circle text-rose-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-rose-700">@ViewBag.TotalUnpaid.ToString("N0")</div>
        <span class="text-xs text-rose-500 font-medium">@ViewBag.UnpaidCount فواتير معلقة</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-sky-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">إجمالي الفواتير</span>
            <i class="fas fa-file-invoice text-sky-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@ViewBag.TotalPurchasesCount</div>
        <span class="text-xs text-gray-400 font-medium">قيمة: @ViewBag.TotalAmountAll.ToString("N0") @currency</span>
    </div>
</div>

<!-- ===== جدول المشتريات ===== -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100">
    <div class="flex flex-wrap justify-between items-center px-5 py-4 border-b border-gray-100 gap-3">
        <h3 class="font-bold text-gray-800 text-sm">
            <i class="fas fa-list text-emerald-500 ml-1.5"></i> قائمة التوريدات (@Model.Count() فاتورة)
        </h3>
        <div class="relative">
            <i class="fas fa-search absolute right-3 top-2.5 text-gray-400 text-xs"></i>
            <input id="searchInput" onkeyup="filterTable()" type="text"
                placeholder="البحث برقم الفاتورة أو اسم المورد..."
                class="pr-8 pl-4 py-2 border border-gray-200 rounded-xl text-xs w-56 focus:outline-none focus:ring-2 focus:ring-emerald-400" />
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full data-table text-sm" id="purchasesTable">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-4 py-3 text-center text-gray-500 font-semibold text-xs w-10">#</th>
                    <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">رقم الفاتورة</th>
                    <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">المورد</th>
                    <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">التاريخ</th>
                    <th class="px-4 py-3 text-right text-gray-600 font-semibold text-xs">حالة الدفع</th>
                    <th class="px-4 py-3 text-center text-gray-600 font-semibold text-xs">الإجمالي</th>
                    <th class="px-4 py-3 text-center text-gray-600 font-semibold text-xs">الصافي</th>
                    <th class="px-4 py-3 text-center text-gray-600 font-semibold text-xs">إجراءات</th>
                </tr>
            </thead>
            <tbody id="purchasesBody">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-12 text-gray-400">
                            <i class="fas fa-truck text-5xl mb-3 block text-gray-200"></i>
                            لم يتم تسجيل أي فواتير مشتريات حتى الآن
                        </td>
                    </tr>
                }
                @{ int rowNum = 1; }
                @foreach (var item in Model)
                {
                    <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors search-row">
                        <td class="px-4 py-3 text-center text-gray-400 text-xs">@(rowNum.ToString("D2"))</td>
                        <td class="px-4 py-3">
                            <span class="font-mono font-bold text-emerald-700 search-invoice">@item.InvoiceNumber</span>
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-2 search-supplier">
                                <div class="w-6 h-6 rounded-lg bg-emerald-100 text-emerald-700 flex items-center justify-center text-xs font-bold flex-shrink-0">
                                    @(item.Supplier?.SupplierName?.Substring(0, 1) ?? "؟")
                                </div>
                                <span class="font-semibold text-gray-800">@(item.Supplier?.SupplierName ?? "غير محدد")</span>
                            </div>
                        </td>
                        <td class="px-4 py-3 text-xs text-gray-500 font-mono" dir="ltr">@item.PurchaseDate.ToString("yyyy-MM-dd")</td>
                        <td class="px-4 py-3">
                            @if (item.PaymentStatus == "Paid")
                            {
                                <span class="text-[11px] px-2.5 py-1 bg-emerald-50 text-emerald-700 border border-emerald-100 rounded-full font-bold">مدفوعة</span>
                            }
                            else
                            {
                                <span class="text-[11px] px-2.5 py-1 bg-red-50 text-red-700 border border-red-100 rounded-full font-bold">آجل</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-center font-mono text-gray-500 text-xs">@item.TotalAmount.ToString("N2")</td>
                        <td class="px-4 py-3 text-center font-mono font-black text-emerald-700">@item.NetAmount.ToString("N2")</td>
                        <td class="px-4 py-3 text-center">
                            <div class="flex justify-center gap-1.5">
                                <a href="/Purchases/Details/@item.PurchaseId"
                                   class="px-2.5 py-1.5 bg-blue-50 hover:bg-blue-100 border border-blue-200 text-blue-700 rounded-lg text-xs font-semibold transition-colors">
                                    <i class="fas fa-eye text-[10px]"></i>
                                </a>
                                <a href="/Purchases/Edit/@item.PurchaseId"
                                   class="px-2.5 py-1.5 bg-amber-50 hover:bg-amber-100 border border-amber-200 text-amber-700 rounded-lg text-xs font-semibold transition-colors">
                                    <i class="fas fa-pen text-[10px]"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                    rowNum++;
                }
            </tbody>
        </table>
    </div>
    <!-- footer + pagination -->
    <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 rounded-b-2xl flex flex-wrap items-center justify-between gap-3">
        <span class="text-xs text-gray-500">الفواتير المعروضة: <strong class="text-gray-700">@Model.Count()</strong></span>
        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
        {
            <div class="flex gap-2 items-center">
                <span class="text-xs text-gray-500">صفحة @ViewBag.CurrentPage من @ViewBag.TotalPages</span>
                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="?page=@(ViewBag.CurrentPage - 1)"
                       class="px-4 py-2 bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 rounded-xl text-xs font-semibold">السابق</a>
                }
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="?page=@(ViewBag.CurrentPage + 1)"
                       class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl text-xs font-bold">التالي</a>
                }
            </div>
        }
    </div>
</div>

<script>
function filterTable() {
    const q = document.getElementById("searchInput").value.toLowerCase();
    document.querySelectorAll(".search-row").forEach(row => {
        const inv = row.querySelector(".search-invoice")?.innerText.toLowerCase() ?? "";
        const sup = row.querySelector(".search-supplier")?.innerText.toLowerCase() ?? "";
        row.style.display = (inv.includes(q) || sup.includes(q)) ? "" : "none";
    });
}
</script>