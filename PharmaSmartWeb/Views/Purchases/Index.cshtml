@model IEnumerable<PharmaSmartWeb.Models.Purchases>

@{
    ViewData["Title"] = "سجل التوريدات";
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .enterprise-header { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 10px 16px; font-size: 13px; font-weight: 700; color: #063955; }
    .enterprise-kpi { background: white; border: 1px solid #d1d5db; border-radius: 2px; padding: 12px 16px; }
    .kpi-title { font-size: 11px; color: #64748b; font-weight: 600; margin-bottom: 4px; }
    .kpi-value { font-size: 22px; font-weight: 700; color: #0f172a; }
    .enterprise-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .enterprise-table th { background: #f1f5f9; padding: 8px 12px; border-bottom: 1px solid #cbd5e1; border-top: 1px solid #cbd5e1; color: #334155; font-weight: 700; text-align: right; }
    .enterprise-table td { padding: 8px 12px; border-bottom: 1px solid #e2e8f0; color: #1e293b; }
    .enterprise-table tr:hover td { background: #f8fafc; }
    .status-paid { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; padding: 2px 8px; border-radius: 2px; font-size: 11px; font-weight: 700; }
    .status-unpaid { background: #fff1f2; color: #e11d48; border: 1px solid #fecdd3; padding: 2px 8px; border-radius: 2px; font-size: 11px; font-weight: 700; }
    .btn-primary { background: #063955; color: white; border: none; padding: 7px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; }
    .btn-primary:hover { background: #0a4f72; color: white; }
    .btn-back { background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; padding: 7px 14px; border-radius: 2px; font-size: 12px; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; }
    .btn-sm { padding: 4px 10px; font-size: 11px; border-radius: 2px; font-weight: 700; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; }
    .btn-view { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
    .btn-edit { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; }
    .search-input { border: 1px solid #d1d5db; border-radius: 2px; padding: 6px 10px; font-size: 12px; width: 260px; }
    .search-input:focus { outline: none; border-color: #063955; }
    .page-title { font-size: 16px; font-weight: 700; color: #063955; }
    .stat-card { background: white; border: 1px solid #d1d5db; border-radius: 2px; padding: 14px 16px; }
</style>

@if (TempData["Success"] != null)
{
    <div class="enterprise-panel mb-4 p-3 flex items-center gap-3" style="border-right: 4px solid #059669;">
        <span class="material-symbols-outlined" style="color:#059669; font-size:18px;">check_circle</span>
        <span style="font-size:13px; color:#059669; font-weight:600;">@TempData["Success"]</span>
    </div>
}

<!-- Page Header -->
<div class="enterprise-panel mb-4 p-3 flex justify-between items-center">
    <div>
        <h1 class="page-title">سجل المشتريات (التوريدات)</h1>
        <p style="font-size:12px; color:#64748b;">متابعة فواتير الموردين، إدارة الدفعات (Batches)، وإدخالات المخزون الخاصة بالمركز الطبي.</p>
    </div>
    <div style="display:flex; gap:8px;">
       
        <a href="/Purchases/Create" class="btn-primary">
            <span class="material-symbols-outlined" style="font-size:16px;">local_shipping</span>
            تسجيل توريد جديد
        </a>
    </div>
</div>

<!-- KPIs -->
<div class="grid grid-cols-3 gap-3 mb-4">
    <div class="stat-card" style="border-right: 4px solid #059669;">
        <div class="kpi-title">إجمالي المدفوع نقداً/بنك</div>
        <div class="kpi-value" style="color:#059669;">@ViewBag.TotalPaid.ToString("N2")</div>
        <div style="font-size:10px; color:#94a3b8;">ر.ي — من إجمالي المشتريات</div>
    </div>
    <div class="stat-card" style="border-right: 4px solid #e11d48;">
        <div class="kpi-title">الديون المستحقة للموردين</div>
        <div class="kpi-value" style="color:#e11d48;">@ViewBag.TotalUnpaid.ToString("N2")</div>
        <div style="font-size:10px; color:#94a3b8;">ر.ي — @ViewBag.UnpaidCount فواتير معلقة السداد</div>
    </div>
    <div class="stat-card">
        <div class="kpi-title">إجمالي الفواتير المسجلة</div>
        <div class="kpi-value">@ViewBag.TotalPurchasesCount</div>
        <div style="font-size:10px; color:#94a3b8;">فاتورة — الإجمالي الدفتري: @ViewBag.TotalAmountAll.ToString("N2") ر.ي</div>
    </div>
</div>

<!-- Data Table -->
<div class="enterprise-panel">
    <div class="enterprise-header flex justify-between items-center">
        <span>قائمة التوريدات — (@Model.Count() فاتورة)</span>
        <input id="searchInput" onkeyup="filterTable()" class="search-input" placeholder="البحث برقم الفاتورة أو اسم المورد..." type="text" />
    </div>
    <div style="overflow-x:auto;">
        <table class="enterprise-table" id="purchasesTable">
            <thead>
                <tr>
                    <th style="text-align:center; width:40px;">#</th>
                    <th>رقم الفاتورة</th>
                    <th>المورد</th>
                    <th>التاريخ</th>
                    <th>حالة الدفع</th>
                    <th style="text-align:center;">إجمالي المبلغ</th>
                    <th style="text-align:center;">صافي المبلغ</th>
                    <th style="text-align:center;">الإجراءات</th>
                </tr>
            </thead>
            <tbody id="purchasesBody">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" style="text-align:center; padding:40px; color:#94a3b8;">
                            <span class="material-symbols-outlined" style="font-size:32px; display:block; margin-bottom:8px;">receipt_long</span>
                            لم يتم تسجيل أي فواتير مشتريات حتى الآن.
                        </td>
                    </tr>
                }
                @{ int rowNum = 1; }
                @foreach (var item in Model)
                {
                    <tr class="search-row">
                        <td style="text-align:center; color:#94a3b8; font-size:11px;">@(rowNum.ToString("D2"))</td>
                        <td class="search-invoice">
                            <strong style="font-family:monospace; color:#063955;">@item.InvoiceNumber</strong>
                        </td>
                        <td class="search-supplier">
                            <div style="display:flex; align-items:center; gap:7px;">
                                <span class="material-symbols-outlined" style="font-size:16px; color:#64748b;">business</span>
                                <span style="font-weight:600;">@(item.Supplier?.SupplierName ?? "غير محدد")</span>
                            </div>
                        </td>
                        <td style="font-size:11px; color:#64748b;" dir="ltr">@item.PurchaseDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (item.PaymentStatus == "Paid")
                            {
                                <span class="status-paid">مدفوعة</span>
                            }
                            else
                            {
                                <span class="status-unpaid">غير مدفوعة (آجل)</span>
                            }
                        </td>
                        <td style="text-align:center; font-family:monospace; color:#64748b;">@item.TotalAmount.ToString("N2") ر.ي</td>
                        <td style="text-align:center; font-family:monospace; font-weight:700; color:#063955;">@item.NetAmount.ToString("N2") ر.ي</td>
                        <td style="text-align:center;">
                            <div style="display:flex; justify-content:center; gap:5px;">
                                <a href="/Purchases/Details/@item.PurchaseId" class="btn-sm btn-view">
                                    <span class="material-symbols-outlined" style="font-size:13px;">visibility</span>
                                </a>
                                <a href="/Purchases/Edit/@item.PurchaseId" class="btn-sm btn-edit">
                                    <span class="material-symbols-outlined" style="font-size:13px;">edit</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                    rowNum++;
                }
            </tbody>
        </table>
    </div>
    <div style="padding:8px 12px; background:#f8fafc; border-top:1px solid #e2e8f0; display:flex; justify-content:space-between; align-items:center;">
        <span style="font-size:11px; color:#64748b;">إجمالي الفواتير المعروضة بالصفحة: <strong>@Model.Count()</strong></span>
        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
        {
            <div style="display:flex; gap:6px; align-items:center; font-size:11px; color:#64748b;">
                <span>صفحة @ViewBag.CurrentPage من @ViewBag.TotalPages</span>
                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="?page=@(ViewBag.CurrentPage - 1)" style="padding:3px 8px; background:#f1f5f9; border:1px solid #e2e8f0; border-radius:2px; text-decoration:none; color:#475569; font-weight:700;">السابق</a>
                }
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="?page=@(ViewBag.CurrentPage + 1)" style="padding:3px 8px; background:#063955; border-radius:2px; text-decoration:none; color:white; font-weight:700;">التالي</a>
                }
            </div>
        }
    </div>
</div>

<script>
    function filterTable() {
        let input = document.getElementById("searchInput").value.toLowerCase();
        let rows = document.querySelectorAll(".search-row");
        rows.forEach(row => {
            let inv = row.querySelector(".search-invoice")?.innerText.toLowerCase() ?? "";
            let sup = row.querySelector(".search-supplier")?.innerText.toLowerCase() ?? "";
            row.style.display = (inv.includes(input) || sup.includes(input)) ? "" : "none";
        });
    }
</script>