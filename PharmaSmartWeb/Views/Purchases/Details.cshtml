@model PharmaSmartWeb.Models.Purchases

@{
    ViewData["Title"] = "تفاصيل فاتورة المشتريات - Cura Insight";
}

<style>
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .btn-action { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border-radius: 2px; font-size: 13px; font-weight: 700; cursor: pointer; text-decoration: none; transition: background 0.1s; border: none;}
    .btn-return { background: #fee2e2; color: #b91c1c; border: 1px solid #fca5a5; }
    .btn-return:hover { background: #fecaca; }
    .btn-edit { background: #fef3c7; color: #b45309; border: 1px solid #fde68a; }
    .btn-edit:hover { background: #fde68a; }
    .btn-primary { background: #063955; color: white; }
    .btn-primary:active { transform: scale(0.98); }
    @@media print { .no-print { display: none !important; } }
</style>

<div style="max-width:1100px; margin:0 auto; padding-bottom:60px; padding-top:24px;">

    <!-- Header Section -->
    <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:32px; flex-wrap:wrap; gap:24px;">
        <div>
            <div style="font-size:11px; font-weight:700; color:#64748b; margin-bottom:4px;">
                <a href="/Purchases/Index" style="color:#64748b; text-decoration:none;">المشتريات</a> / <span style="color:#0284c7;">تفاصيل الفاتورة #@Model.InvoiceNumber</span>
            </div>
            <div style="display:flex; align-items:center; gap:12px;">
                <div style="background:#e0f2fe; color:#0284c7; padding:8px; border-radius:2px; display:flex; align-items:center; justify-content:center;">
                    <span class="material-symbols-outlined" style="font-size:28px;">receipt_long</span>
                </div>
                <h1 style="font-size:24px; font-weight:900; color:#063955; margin:0;">تفاصيل فاتورة المشتريات</h1>
            </div>
        </div>
        
        <div style="display:flex; gap:12px; flex-wrap:wrap;" class="no-print">
            @if (Model.IsReturn != true)
            {
                <a href="/PurchasesReturn/Create/@Model.PurchaseId" class="btn-action btn-return">
                    <span class="material-symbols-outlined">assignment_return</span> مرتجع للمورد
                </a>
            }
            <a href="/Purchases/Edit/@Model.PurchaseId" class="btn-action btn-edit">
                <span class="material-symbols-outlined">edit_square</span> تعديل الفاتورة
            </a>
            <a href="/JournalEntries/ViewRelatedJournal?refType=Purchase&refNo=@Model.InvoiceNumber" class="btn-action" style="background:#059669; color:white; border: 1px solid #047857;">
                <span class="material-symbols-outlined">account_balance</span> القيد المحاسبي الآلي
            </a>
            <button class="btn-action btn-primary" onclick="window.print()">
                <span class="material-symbols-outlined">print</span> طباعة الإيصال
            </button>
        </div>
    </div>

    <!-- Invoice Document Card -->
    <div class="enterprise-panel" style="box-shadow:0 10px 25px rgba(0,0,0,0.05); overflow:hidden;">
        
        <!-- Invoice Header Details -->
        <div style="padding:40px; border-bottom:1px solid #e2e8f0; background:linear-gradient(135deg, white 0%, #f8fafc 100%); display:flex; justify-content:space-between; flex-wrap:wrap; gap:40px;">
            <div style="flex:1;">
                <p style="font-size:10px; font-weight:900; color:#64748b; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:4px;">المورد / Supplier</p>
                <h2 style="font-size:28px; font-weight:900; color:#063955; margin:0;">@(Model.Supplier?.SupplierName ?? "غير محدد")</h2>
                
                <div style="margin-top:12px;">
                    @if (Model.PaymentStatus == "Paid")
                    {
                        <span style="background:#d1fae5; color:#065f46; border:1px solid #a7f3d0; padding:4px 12px; font-size:11px; font-weight:900; border-radius:20px; display:inline-flex; align-items:center; gap:4px;">
                            <span class="material-symbols-outlined" style="font-size:14px;">check_circle</span> تم السداد
                        </span>
                    }
                    else
                    {
                        <span style="background:#ffe4e6; color:#be123c; border:1px solid #fecdd3; padding:4px 12px; font-size:11px; font-weight:900; border-radius:20px; display:inline-flex; align-items:center; gap:4px;">
                            <span class="material-symbols-outlined" style="font-size:14px;">pending_actions</span> فاتورة آجلة
                        </span>
                    }
                </div>

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:32px; border-top:1px solid #e2e8f0; padding-top:24px; margin-top:24px;">
                    <div>
                        <p style="font-size:10px; font-weight:900; color:#64748b; text-transform:uppercase;">المستلم / Received By</p>
                        <p style="font-weight:700; color:#0f172a; margin-top:4px;">@(Model.User?.Username ?? "أمين المخزن")</p>
                    </div>
                    <div>
                        <p style="font-size:10px; font-weight:900; color:#64748b; text-transform:uppercase;">تاريخ التوريد / Supply Date</p>
                        <p style="font-weight:700; color:#0f172a; margin-top:4px; font-family:monospace;">@Model.PurchaseDate.ToString("yyyy-MM-dd | HH:mm")</p>
                    </div>
                </div>
            </div>
            
            <div style="text-align:right;">
                <p style="font-size:10px; font-weight:900; color:#64748b; text-transform:uppercase; margin-bottom:4px;">رقم الفاتورة / Invoice No.</p>
                <p style="font-size:36px; font-weight:900; font-family:monospace; color:#0284c7; margin:0;">#@Model.InvoiceNumber</p>
                
                <div style="margin-top:40px;">
                    <h3 style="font-size:18px; font-weight:900; color:#063955; margin:0;">Cura Insight Center</h3>
                    <p style="font-size:12px; color:#64748b; font-weight:700; margin-top:4px;">قسم المشتريات والخدمات اللوجستية</p>
                </div>
            </div>
        </div>

        <!-- Items List Table -->
        <div style="overflow-x:auto;">
            <table style="width:100%; text-align:right; border-collapse:collapse; font-size:13px;">
                <thead>
                    <tr style="background:#063955; color:white;">
                        <th style="padding:12px 24px; font-weight:900; font-size:12px;">#</th>
                        <th style="padding:12px 24px; font-weight:900; font-size:12px; width:30%;">الصنف والوحدة / Product</th>
                        <th style="padding:12px 24px; font-weight:900; font-size:12px; text-align:center;">التشغيلة / Batch</th>
                        <th style="padding:12px 24px; font-weight:900; font-size:12px; text-align:center;">الانتهاء / Expiry</th>
                        <th style="padding:12px 24px; font-weight:900; font-size:12px; text-align:center;">الكمية + مجاني / Qty</th>
                        <th style="padding:12px 24px; font-weight:900; font-size:12px; text-align:center;">التكلفة / Cost</th>
                        <th style="padding:12px 24px; font-weight:900; font-size:12px; text-align:center;">البيع / Sell</th>
                        <th style="padding:12px 24px; font-weight:900; font-size:12px; text-align:left;">الإجمالي / Total</th>
                    </tr>
                </thead>
                <tbody style="background:white;">
                    @{ int rowIdx = 1; }
                    @foreach (var item in Model.Purchasedetails)
                    {
                        <tr style="border-bottom:1px solid #e2e8f0; transition:background 0.1s;">
                            <td style="padding:16px 24px; font-weight:900; color:#94a3b8;">@rowIdx</td>
                            <td style="padding:16px 24px;">
                                <div style="font-weight:900; color:#063955;">@(item.Drug?.DrugName ?? "صنف محذوف")</div>
                                <div style="font-size:11px; color:#64748b; background:#f1f5f9; border:1px solid #cbd5e1; display:inline-block; padding:2px 6px; border-radius:2px; margin-top:4px;">@(item.Drug?.MainUnit ?? "وحدة")</div>
                            </td>
                            <td style="padding:16px 24px; text-align:center; font-family:monospace; font-weight:900;">
                                <span style="background:#f8fafc; border:1px solid #e2e8f0; padding:2px 8px; border-radius:2px;">@item.BatchNumber</span>
                            </td>
                            <td style="padding:16px 24px; text-align:center; font-family:monospace; font-weight:900; color:#e11d48;">@item.ExpiryDate.ToString("yyyy-MM")</td>
                            <td style="padding:16px 24px; text-align:center;">
                                <span style="font-weight:900; font-size:16px;">@item.Quantity</span>
                                @if(item.BonusQuantity > 0)
                                {
                                    <span style="color:#059669; font-size:11px; font-weight:900; background:#d1fae5; padding:2px 4px; border-radius:2px; margin-right:4px;">+@item.BonusQuantity</span>
                                }
                            </td>
                            <td style="padding:16px 24px; text-align:center; font-family:monospace; font-weight:900;">@item.CostPrice.ToString("N2")</td>
                            <td style="padding:16px 24px; text-align:center; font-family:monospace; font-weight:900; color:#059669;">@item.SellingPrice.ToString("N2")</td>
                            <td style="padding:16px 24px; text-align:left; font-family:monospace; font-weight:900; color:#063955;">@((item.Quantity * item.CostPrice).ToString("N2"))</td>
                        </tr>
                        rowIdx++;
                    }
                </tbody>
            </table>
        </div>

        <!-- Footer Details & Totals -->
        <div style="padding:40px; background:#f8fafc; display:flex; justify-content:space-between; flex-wrap:wrap; gap:48px; border-top:1px solid #e2e8f0;">
            
            <!-- Notes & Signatures -->
            <div style="flex:1;">
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div style="background:white; padding:24px; border-radius:2px; border:1px solid #e2e8f0; margin-bottom:32px;">
                        <p style="font-size:10px; font-weight:900; color:#64748b; text-transform:uppercase; margin-bottom:8px;">ملاحظات الفاتورة / Notes</p>
                        <p style="font-size:13px; color:#0f172a; font-style:italic; line-height:1.6; font-weight:700;">@Model.Notes</p>
                    </div>
                }

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:32px; padding-top:24px;">
                    <div style="border-top:2px dashed #cbd5e1; padding-top:16px;">
                        <p style="font-size:10px; font-weight:900; color:#64748b; text-transform:uppercase;">توقيع المستلم</p>
                        <p style="margin-top:32px; color:#cbd5e1; text-align:center;">............</p>
                    </div>
                    <div style="border-top:2px dashed #cbd5e1; padding-top:16px;">
                        <p style="font-size:10px; font-weight:900; color:#64748b; text-transform:uppercase;">الاعتماد / الإدارة</p>
                        <p style="margin-top:32px; color:#cbd5e1; text-align:center;">............</p>
                    </div>
                </div>
            </div>

            <!-- Totals Breakdown -->
            <div style="width:100%; max-width:350px;">
                <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 16px; background:white; border:1px solid #e2e8f0; border-radius:2px; margin-bottom:12px;">
                    <span style="color:#64748b; font-size:12px; font-weight:900;">عدد الأصناف</span>
                    <span style="font-weight:900;">@Model.Purchasedetails.Count</span>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 16px; background:white; border:1px solid #e2e8f0; border-radius:2px; margin-bottom:12px;">
                    <span style="color:#64748b; font-size:12px; font-weight:900;">المبلغ الإجمالي</span>
                    <span style="font-family:monospace; font-weight:900;">@Model.TotalAmount.ToString("N2") <span style="font-size:10px;">SAR</span></span>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 16px; background:#ecfdf5; border:1px solid #a7f3d0; border-radius:2px; margin-bottom:12px;">
                    <span style="color:#047857; font-size:12px; font-weight:900;">خصم مكتسب (-)</span>
                    <span style="font-family:monospace; font-weight:900; color:#047857;">@Model.Discount.ToString("N2") <span style="font-size:10px;">SAR</span></span>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 16px; background:white; border:1px solid #e2e8f0; border-radius:2px; margin-bottom:24px;">
                    <span style="color:#e11d48; font-size:12px; font-weight:900;">ضريبة مضافة (+)</span>
                    <span style="font-family:monospace; font-weight:900; color:#e11d48;">@Model.TaxAmount.ToString("N2") <span style="font-size:10px;">SAR</span></span>
                </div>

                <div style="padding:24px; background:linear-gradient(135deg, #00314e 0%, #004870 100%); color:white; border-radius:2px;">
                    <p style="font-size:11px; font-weight:900; color:#7dd3fc; text-transform:uppercase; margin-bottom:8px;">صافي المستحق للمورد</p>
                    <div style="display:flex; align-items:baseline; gap:8px; justify-content:flex-end;">
                        <span style="font-size:36px; font-weight:900; font-family:monospace; letter-spacing:-1px;">@Model.NetAmount.ToString("N2")</span>
                        <span style="font-size:14px; font-weight:900; color:#7dd3fc;">SAR</span>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>