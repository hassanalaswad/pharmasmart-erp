@inject PharmaSmartWeb.Services.ISystemSettingsService Settings
@{
    Layout = "_ModalLayout";
    ViewData["Title"] = "التحليل المالي للأرباح والخسائر";
    var revenues = ViewBag.Revenues as List<PharmaSmartWeb.Models.PnlAccountViewModel> ?? new List<PharmaSmartWeb.Models.PnlAccountViewModel>();
    var expenses = ViewBag.Expenses as List<PharmaSmartWeb.Models.PnlAccountViewModel> ?? new List<PharmaSmartWeb.Models.PnlAccountViewModel>();
    decimal totalRev = ViewBag.TotalRevenue ?? 0m;
    decimal totalExp = ViewBag.TotalExpenses ?? 0m;
    decimal netProfit = ViewBag.NetProfit ?? 0m;
}

<style>
    .rpt-page { width: 210mm; min-height: 297mm; margin: 20px auto; background: white; padding: 35px 40px; box-sizing: border-box; box-shadow: 0 4px 6px -1px rgb(0 0 0/0.1); font-family: "Cairo","Segoe UI",Tahoma; }
    .rpt-topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .rpt-brand { display: flex; align-items: center; gap: 12px; }
    .rpt-brand img { max-height: 55px; max-width: 110px; object-fit: contain; }
    .rpt-brand .rpt-name { font-size: 18px; font-weight: 800; color: #063955; }
    .rpt-tag { border: 1px solid #cbd5e1; background: #f8fafc; color: #475569; padding: 5px 15px; font-size: 11px; font-weight: bold; letter-spacing: 1px; }
    .rpt-title { text-align: center; margin: 20px 0; }
    .rpt-title h2 { margin: 0; font-size: 22px; font-weight: 800; color: #0f172a; }
    .rpt-title span { font-size: 12px; color: #64748b; text-transform: uppercase; }
    .rpt-info { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; border: 1px solid #e2e8f0; background: #f8fafc; padding: 14px 16px; margin-bottom: 20px; }
    .rpt-info-cell { font-size: 12px; line-height: 2; }
    .rpt-info-cell strong { color: #063955; display: inline-block; width: 90px; }
    .rpt-divider { border-top: 2px solid #e2e8f0; margin: 16px 0; }
    .rpt-two-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    .rpt-col-box { border: 1px solid #ccc; overflow: hidden; }
    .rpt-col-hdr { padding: 10px 12px; font-weight: bold; font-size: 12px; display: flex; justify-content: space-between; }
    .rpt-col-row { display: flex; justify-content: space-between; padding: 7px 12px; border-top: 1px solid #f0f4f8; font-size: 12px; }
    .rpt-net-box { padding: 16px; display: flex; justify-content: space-between; align-items: center; border: 2px solid; }
    .rpt-notes { margin-top: 20px; font-size: 11px; color: #64748b; }
    .rpt-signatures { margin-top: 50px; display: flex; justify-content: space-between; }
    .rpt-signatures div { text-align: center; font-size: 12px; font-weight: bold; color: #334155; }
    .rpt-signatures div span { display: block; margin-bottom: 28px; color: #94a3b8; }
    .rpt-footer { margin-top: 30px; padding-top: 10px; border-top: 1px solid #e2e8f0; font-size: 11px; color: #64748b; display: flex; justify-content: space-between; }
    /* Filter */
    .rpt-filter { border: 1px solid #d1d5db; border-top: 3px solid #063955; padding: 14px; margin-bottom: 20px; }
    .form-input { border: 1px solid #cbd5e1; border-radius: 2px; padding: 8px 10px; font-size: 12px; font-weight: 600; background-color: #f8fafc; outline: none; }
    .form-label { font-size: 10px; font-weight: bold; color: #64748b; text-transform: uppercase; margin-bottom: 2px; display: block; }
    .btn-p { background: #063955; color: white; border: none; padding: 8px 16px; font-size: 12px; font-weight: 700; cursor: pointer; }
    /* Chart container */
    .chart-area { display: grid; grid-template-columns: 2fr 1fr; gap: 14px; margin-bottom: 20px; }
    .chart-box { border: 1px solid #e2e8f0; padding: 14px; background: white; }
    @@media print {
        body { background: white !important; }
        .no-print { display: none !important; }
        .rpt-page { box-shadow: none; margin: 0; }
    }
</style>

<!-- Filter (No Print) -->
<div class="rpt-filter no-print" style="display:flex; gap:12px; align-items:flex-end; flex-wrap:wrap;">
    <h2 style="font-size:14px; font-weight:800; color:#063955; margin:0; flex:1;">تقرير الأرباح والخسائر</h2>
    <form method="get" style="display:flex; gap:10px; align-items:flex-end;">
        <div><label class="form-label">من تاريخ</label><input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-input"></div>
        <div><label class="form-label">إلى تاريخ</label><input type="date" name="toDate" value="@ViewBag.ToDate" class="form-input"></div>
        <button type="submit" class="btn-p">تحديث</button>
        <button type="button" onclick="window.print()" style="background:white; border:1px solid #d1d5db; color:#475569; padding:8px 12px; font-size:12px; cursor:pointer;">🖨</button>
    </form>
</div>

<!-- Charts (No Print) -->
<div class="chart-area no-print">
    <div class="chart-box">
        <h3 style="font-size:12px; font-weight:bold; color:#063955; margin:0 0 12px 0;">توزيع المصروفات التشغيلية</h3>
        <div style="height:240px;"><canvas id="expensesChart"></canvas></div>
    </div>
    <div class="chart-box" style="display:flex; flex-direction:column; gap:12px;">
        <h3 style="font-size:12px; font-weight:bold; color:#063955; margin:0;">مقارنة الدخل والخرج</h3>
        <div style="flex:1;"><canvas id="comparisonChart"></canvas></div>
        <div style="padding:10px; border:1px solid @(netProfit >= 0 ? "#a7f3d0" : "#fecdd3"); background:@(netProfit >= 0 ? "#ecfdf5" : "#fff1f2"); text-align:center;">
            <p style="font-size:10px; color:#64748b; margin:0 0 4px 0; text-transform:uppercase; font-weight:bold;">صافي الربح</p>
            <span style="font-size:20px; font-weight:900; color:@(netProfit >= 0 ? "#059669" : "#e11d48"); font-family:monospace;">@netProfit.ToString("N2")</span>
        </div>
    </div>
</div>

<!-- ===== OFFICIAL REPORT PAGE ===== -->
<div class="rpt-page">

    <!-- Top Bar -->
    <div class="rpt-topbar">
        <div class="rpt-brand">
            @if (!string.IsNullOrEmpty(Settings.CompanyLogoPath))
            {
                <img src="@Settings.CompanyLogoPath" alt="@Settings.CompanyName">
            }
            <div class="rpt-name">@Settings.CompanyName</div>
        </div>
        <div class="rpt-tag">OFFICIAL REPORT</div>
    </div>

    <!-- Title -->
    <div class="rpt-title">
        <h2>تقرير الأرباح والخسائر</h2>
        <span>Profit &amp; Loss Report</span>
    </div>

    <!-- Info Grid -->
    <div class="rpt-info">
        <div class="rpt-info-cell">
            <strong>اسم المؤسسة:</strong> @Settings.CompanyName<br>
            <strong>إجمالي الإيرادات:</strong> @totalRev.ToString("N2") @Settings.Currency<br>
            <strong>إجمالي المصروفات:</strong> @totalExp.ToString("N2") @Settings.Currency<br>
            <strong>تم بواسطة:</strong> @(User.Identity?.Name ?? "النظام")
        </div>
        <div class="rpt-info-cell">
            <strong>رقم التقرير:</strong> PNL-@DateTime.Now.ToString("yyyyMMdd-HHmm")<br>
            <strong>الفترة:</strong> @ViewBag.FromDate → @ViewBag.ToDate<br>
            <strong>تاريخ الإصدار:</strong> @DateTime.Now.ToString("yyyy/MM/dd HH:mm")<br>
            <strong>النتيجة:</strong> @(netProfit >= 0 ? "✓ ربح" : "✗ خسارة")
        </div>
    </div>

    <div class="rpt-divider"></div>

    <!-- Two-Column Layout -->
    <div class="rpt-two-cols">
        <div class="rpt-col-box" style="border-top:4px solid #059669;">
            <div class="rpt-col-hdr" style="background:#ecfdf5; color:#059669;">
                <span>بنود الإيرادات</span>
                <span style="font-family:monospace;">@totalRev.ToString("N2")</span>
            </div>
            @foreach (var item in revenues)
            {
                <div class="rpt-col-row">
                    <div>
                        <div style="font-weight:bold; color:#063955; font-size:12px;">@item.Name</div>
                        <div style="font-size:10px; color:#94a3b8; font-family:monospace;">@item.Code</div>
                    </div>
                    <span style="font-family:monospace; font-weight:bold; color:#059669;">@item.Total.ToString("N2")</span>
                </div>
            }
        </div>
        <div class="rpt-col-box" style="border-top:4px solid #e11d48;">
            <div class="rpt-col-hdr" style="background:#fff1f2; color:#e11d48;">
                <span>بنود المصروفات</span>
                <span style="font-family:monospace;">@totalExp.ToString("N2")</span>
            </div>
            @foreach (var item in expenses)
            {
                <div class="rpt-col-row">
                    <div>
                        <div style="font-weight:bold; color:#063955; font-size:12px;">@item.Name</div>
                        <div style="font-size:10px; color:#94a3b8; font-family:monospace;">@item.Code</div>
                    </div>
                    <span style="font-family:monospace; font-weight:bold; color:#e11d48;">@item.Total.ToString("N2")</span>
                </div>
            }
        </div>
    </div>

    <!-- Net Profit -->
    <div class="rpt-net-box" style="border-color:@(netProfit >= 0 ? "#059669" : "#e11d48"); background:@(netProfit >= 0 ? "#ecfdf5" : "#fff1f2");">
        <div>
            <div style="font-size:11px; font-weight:bold; color:#64748b; text-transform:uppercase;">صافي الربح المالي (Net Profit)</div>
        </div>
        <div style="font-size:26px; font-weight:900; color:@(netProfit >= 0 ? "#059669" : "#e11d48"); font-family:monospace;" dir="ltr">
            @netProfit.ToString("N2") @Settings.Currency
        </div>
    </div>

    <!-- Notes -->
    <div class="rpt-notes">
        ملاحظة: هذا التقرير تم إنشاؤه تلقائيًا من النظام ويعتبر وثيقة رسمية قابلة للمراجعة.
    </div>

    <!-- Signatures -->
    <div class="rpt-signatures">
        <div><span>___________</span>المدير العام</div>
        <div><span>___________</span>المحاسب</div>
        <div><span>___________</span>الختم الرسمي</div>
    </div>

    <!-- Footer -->
    <div class="rpt-footer">
        <div>@Settings.CompanyName © @DateTime.Now.Year</div>
        <div>نظام فارما سمارت ERP</div>
    </div>

</div>

<script src="~/lib/chart.js"></script>
<script>
    const ctxExp = document.getElementById('expensesChart')?.getContext('2d');
    if (ctxExp) new Chart(ctxExp, { type: 'bar', data: { labels: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.ExpenseLabels ?? new string[0])), datasets: [{ label: 'قيمة المصروف', data: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.ExpenseValues ?? new decimal[0])), backgroundColor: '#e11d48', borderWidth: 1, borderRadius: 2 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } } });
    const ctxComp = document.getElementById('comparisonChart')?.getContext('2d');
    if (ctxComp) new Chart(ctxComp, { type: 'doughnut', data: { labels: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.ComparisonLabels ?? new string[0])), datasets: [{ data: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.ComparisonValues ?? new decimal[0])), backgroundColor: ['#059669', '#e11d48'], borderWidth: 1 }] }, options: { responsive: true, maintainAspectRatio: false, cutout: '70%', plugins: { legend: { position: 'bottom' } } } });
</script>