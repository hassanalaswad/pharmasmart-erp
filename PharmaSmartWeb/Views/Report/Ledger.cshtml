@model IEnumerable<PharmaSmartWeb.Models.Journaldetails>

@{
    Layout = (ViewBag.LayoutTheme == "drawer" || ViewBag.LayoutTheme == "modal") ? null : "_ReportLayout";
    ViewData["Title"] = "كشف حساب تفصيلي - الأستاذ المساعد";
    ViewData["Subtitle"] = "Detailed Ledger Statement";
    var selectedAccount = ViewBag.SelectedAccount as PharmaSmartWeb.Models.Accounts;
    decimal runningBalance = ViewBag.OpeningBalance ?? 0m;
    bool accountNature = selectedAccount?.AccountNature ?? true;

    // ===== Info Grid Values (will show in _ReportLayout info-grid) =====
    ViewBag.ReportNumber = "LDG-" + DateTime.Now.ToString("yyyyMMdd-HHmm");
    ViewBag.ReportPeriod = (ViewBag.FromDate != null && ViewBag.ToDate != null)
        ? $"{ViewBag.FromDate} إلى {ViewBag.ToDate}"
        : "-";
    ViewBag.ReportAccountInfo = selectedAccount != null
        ? $"{selectedAccount.AccountCode} - {selectedAccount.AccountName}"
        : "لم يتم تحديد الحساب بعد";
}

@* ===== FILTER BAR — Renders OUTSIDE .page (no print) ===== *@
@section Filter {
    <div class="report-filter-bar">
        <form method="get" asp-action="Ledger" style="display:contents;">
            <div style="flex:3; min-width:240px;">
                <label class="rf-label">اختيار الحساب</label>
                <select name="accountId" required>
                    <option value="">-- ابحث أو اختر الحساب --</option>
                    @if (ViewBag.Accounts != null)
                    {
                        foreach (var acc in ViewBag.Accounts)
                        {
                            bool isSel = selectedAccount != null && selectedAccount.AccountId == acc.AccountId;
                            <option value="@acc.AccountId" selected="@isSel">@acc.AccountCode - @acc.AccountName</option>
                        }
                    }
                </select>
            </div>
            <div style="flex:1; min-width:140px;">
                <label class="rf-label">من تاريخ</label>
                <input type="date" name="fromDate" value="@ViewBag.FromDate" dir="ltr" required>
            </div>
            <div style="flex:1; min-width:140px;">
                <label class="rf-label">إلى تاريخ</label>
                <input type="date" name="toDate" value="@ViewBag.ToDate" dir="ltr" required>
            </div>
            <button type="submit" class="rf-btn-submit">تحديث البيانات</button>
            <button type="button" onclick="window.print()" class="rf-btn-print">🖨 طباعة</button>
        </form>
    </div>
}

@* ===== REPORT BODY (renders inside .page via _ReportLayout @RenderBody()) ===== *@
@if (selectedAccount != null)
{
    <!-- Account Nature Badge -->
    <div style="display:flex; justify-content:flex-start; gap:10px; align-items:center; margin-bottom:14px;">
        <div style="border:1px solid #e2e8f0; padding:8px 14px; background:#f8fafc; display:flex; gap:16px; align-items:center; font-size:12px;">
            <div>
                <span style="color:#64748b; font-size:10px; font-weight:bold; display:block; margin-bottom:1px;">اسم الحساب</span>
                <strong style="color:#063955;">@selectedAccount.AccountName</strong>
            </div>
            <div style="border-right:1px solid #e2e8f0; padding-right:16px;">
                <span style="color:#64748b; font-size:10px; font-weight:bold; display:block; margin-bottom:1px;">رقم الحساب</span>
                <strong style="font-family:monospace; color:#0284c7;">@selectedAccount.AccountCode</strong>
            </div>
            <div style="border-right:1px solid #e2e8f0; padding-right:16px;">
                <span style="color:#64748b; font-size:10px; font-weight:bold; display:block; margin-bottom:1px;">طبيعة الحساب</span>
                <span style="font-size:11px; font-weight:bold; padding:2px 8px; @(accountNature ? "background:#ecfdf5; color:#059669; border:1px solid #a7f3d0;" : "background:#fef2f2; color:#e11d48; border:1px solid #fecdd3;")">
                    @(accountNature ? "مدين (Debit)" : "دائن (Credit)")
                </span>
            </div>
            <div style="border-right:1px solid #e2e8f0; padding-right:16px;">
                <span style="color:#64748b; font-size:10px; font-weight:bold; display:block; margin-bottom:1px;">العملة</span>
                <span>ريال يمني (YER)</span>
            </div>
        </div>
    </div>

    <!-- Ledger Table -->
    <table class="report-table">
        <thead>
            <tr>
                <th style="width:130px;">التاريخ</th>
                <th style="width:90px; text-align:center;">رقم القيد</th>
                <th>البيان / تفاصيل الحركة</th>
                <th style="width:130px; background:#ecfdf5; color:#065f46; text-align:left;">مدين (+)</th>
                <th style="width:130px; background:#fef2f2; color:#991b1b; text-align:left;">دائن (-)</th>
                <th style="width:150px; text-align:left;">الرصيد التراكمي</th>
            </tr>
        </thead>
        <tbody>
            <!-- Opening Balance Row -->
            <tr style="background:#f0f9ff;">
                <td style="font-family:monospace; font-size:11px; color:#64748b;" dir="ltr">@ViewBag.FromDate</td>
                <td style="text-align:center; color:#94a3b8; font-size:11px;">-</td>
                <td style="font-style:italic; color:#063955; font-size:11px;">الرصيد الافتتاحي المدور من الفترة السابقة</td>
                <td style="color:#94a3b8; text-align:left;">-</td>
                <td style="color:#94a3b8; text-align:left;">-</td>
                <td style="font-family:monospace; font-weight:bold; color:#0284c7; background:#e0f2fe; text-align:left;">
                    @(ViewBag.OpeningBalance?.ToString("N2") ?? "0.00")
                </td>
            </tr>

            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" style="text-align:center; padding:30px 20px; color:#94a3b8; font-style:italic;">
                        لا توجد حركات مسجلة لهذا الحساب خلال الفترة المحددة.
                    </td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    if (accountNature) runningBalance += (item.Debit - item.Credit);
                    else runningBalance += (item.Credit - item.Debit);

                    <tr>
                        <td style="font-family:monospace; font-size:11px; color:#64748b;" dir="ltr">@item.Journal.JournalDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td style="text-align:center; font-family:monospace; color:#0284c7; font-weight:bold; font-size:11px;">@item.JournalId</td>
                        <td style="font-size:12px;">@item.Journal.Description</td>
                        <td style="font-family:monospace; text-align:left; font-weight:bold; color:@(item.Debit > 0 ? "#059669" : "#94a3b8");">
                            @(item.Debit > 0 ? item.Debit.ToString("N2") : "0.00")
                        </td>
                        <td style="font-family:monospace; text-align:left; font-weight:bold; color:@(item.Credit > 0 ? "#e11d48" : "#94a3b8");">
                            @(item.Credit > 0 ? item.Credit.ToString("N2") : "0.00")
                        </td>
                        <td style="font-family:monospace; font-weight:bold; color:@(runningBalance >= 0 ? "#063955" : "#e11d48"); background:#f8fafc; text-align:left;">
                            @runningBalance.ToString("N2")
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    @if (ViewBag.LayoutTheme == "drawer" || ViewBag.LayoutTheme == "modal")
    {
        <div style="background:#f8fafc; padding:12px; margin-top:16px; border:1px solid #e2e8f0; display:flex; justify-content:space-between; align-items:center;">
            <div style="display:flex; gap:16px;">
                <div><span style="font-size:11px; color:#64748b;">إجمالي مدين:</span><span style="color:#059669; font-weight:bold; margin-right:4px;">@Model.Sum(x => x.Debit).ToString("N2")</span></div>
                <div><span style="font-size:11px; color:#64748b;">إجمالي دائن:</span><span style="color:#e11d48; font-weight:bold; margin-right:4px;">@Model.Sum(x => x.Credit).ToString("N2")</span></div>
            </div>
            <div>
                <span style="font-size:13px; color:#063955; font-weight:bold;">الرصيد الختامي:</span>
                <span style="font-size:15px; font-weight:bold;" dir="ltr">
                    @runningBalance.ToString("N2") <small style="font-size:11px; color:#64748b;">@(accountNature ? "(مدين)" : "(دائن)")</small>
                </span>
            </div>
        </div>
    }
    else
    {
        @section Summary {
            <div><span>إجمالي مدين:</span><span style="color:#059669; font-weight:bold;">@Model.Sum(x => x.Debit).ToString("N2")</span></div>
            <div><span>إجمالي دائن:</span><span style="color:#e11d48; font-weight:bold;">@Model.Sum(x => x.Credit).ToString("N2")</span></div>
            <div>
                <span style="font-size:15px; color:#063955;">الرصيد الختامي:</span>
                <span style="font-size:15px;" dir="ltr">
                    @runningBalance.ToString("N2") <small style="font-size:11px; color:#64748b;">@(accountNature ? "(مدين)" : "(دائن)")</small>
                </span>
            </div>
        }
    }
}
else
{
    <div style="text-align:center; padding:60px 20px; color:#94a3b8; background:#f8fafc; border:1px dashed #cbd5e1;">
        <div style="font-size:36px; margin-bottom:12px;">📒</div>
        <p style="font-size:14px; font-weight:bold; margin:0;">يرجى تحديد الحساب والفترة الزمنية من شريط الفلتر أعلاه.</p>
    </div>
}