@model PharmaSmartWeb.Models.ReportCenterViewModel

@{
    ViewData["Title"] = "مركز التقارير الاستراتيجي";
    bool isGlobalScope = ViewBag.IsGlobalScope ?? false;
    string scopeColor = isGlobalScope ? "#4f46e5" : "#059669";
    string scopeBg = isGlobalScope ? "#e0e7ff" : "#ecfdf5";
}

<style>
    body { background-color: #f4f6f8; font-family: "Segoe UI", Tahoma; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .page-title { font-size: 16px; font-weight: 700; color: #063955; }
    .page-sub { font-size: 12px; color: #64748b; }
    .kpi-box { padding: 16px; background: white; border-radius: 2px; border: 1px solid #d1d5db; border-right-width: 4px; }
    .kpi-title { font-size: 11px; text-transform: uppercase; color: #64748b; font-weight: 700; letter-spacing: 0.05em; margin-bottom: 4px; }
    .kpi-value { font-size: 24px; font-weight: 800; color: #063955; }
    .scope-badge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border-radius: 2px; font-size: 12px; font-weight: 700; border: 1px solid #cbd5e1; }
    .report-card { background: white; border: 1px solid #e2e8f0; border-radius: 2px; padding: 16px; display: flex; align-items: flex-start; gap: 16px; transition: 0.2s; text-decoration: none; }
    .report-card:hover { border-color: #94a3b8; background: #f8fafc; transform: translateY(-1px); box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .report-icon { width: 40px; height: 40px; border-radius: 2px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
    .report-title { font-size: 14px; font-weight: 700; color: #1e293b; margin-bottom: 4px; }
    .report-desc { font-size: 11px; color: #64748b; font-weight: 600; line-height: 1.4; }
</style>

<div style="flex:1; overflow-y:auto; padding:24px; display:flex; flex-direction:column; gap:16px;">
    <!-- Header Area -->
    <div class="enterprise-panel" style="padding:16px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;">
        <div style="display:flex; align-items:center; gap:16px;">
            <div style="background:@scopeBg; color:@scopeColor; padding:10px; border:1px solid @scopeColor; border-radius:2px;">
                <span class="material-symbols-outlined" style="font-size:24px;">leaderboard</span>
            </div>
            <div>
                <h1 class="page-title">مركز التقارير الاستراتيجي</h1>
                <p class="page-sub">
                    @(isGlobalScope ? "قاعدة البيانات المركزية لتحليل أداء كافة فروع المؤسسة." : "تحليل الأداء التشغيلي والمالي للفرع الحالي.")
                </p>
            </div>
        </div>
        <div class="scope-badge" style="background:#f8fafc; color:#475569;">
            <span class="material-symbols-outlined" style="font-size:16px; color:@scopeColor;">@(isGlobalScope ? "public" : "store")</span>
            نطاق التقرير: @(isGlobalScope ? "المؤسسة ككل" : "الفرع النشط")
        </div>
    </div>

    <!-- KPI Grid -->
    <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:12px;">
        <div class="kpi-box" style="border-right-color:#0284c7;">
            <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
                <span class="material-symbols-outlined" style="color:#0284c7;">payments</span>
                <span style="font-size:10px; font-weight:700; color:#94a3b8; background:#f1f5f9; padding:2px 6px;">هذا الشهر</span>
            </div>
            <p class="kpi-title">إجمالي الإيرادات</p>
            <h3 class="kpi-value">@Model.MonthlyRevenue.ToString("N2") <span style="font-size:12px; font-weight:normal; color:#64748b;">ر.ي</span></h3>
        </div>

        <div class="kpi-box" style="border-right-color:#e11d48;">
            <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
                <span class="material-symbols-outlined" style="color:#e11d48;">trending_down</span>
                <span style="font-size:10px; font-weight:700; color:#94a3b8; background:#f1f5f9; padding:2px 6px;">هذا الشهر</span>
            </div>
            <p class="kpi-title">إجمالي المصروفات</p>
            <h3 class="kpi-value">@Model.MonthlyExpenses.ToString("N2") <span style="font-size:12px; font-weight:normal; color:#64748b;">ر.ي</span></h3>
        </div>

        <div class="kpi-box" style="border-right-color:#dc2626;">
            <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
                <span class="material-symbols-outlined" style="color:#dc2626;">warning</span>
                <a href="/Report/StockExpiry" style="font-size:10px; font-weight:700; color:#dc2626; text-decoration:underline;">عرض التفاصيل</a>
            </div>
            <p class="kpi-title">أصناف منتهية الصلاحية</p>
            <h3 class="kpi-value" style="color:#dc2626;">@Model.ExpiredItemsCount <span style="font-size:12px; font-weight:normal; color:#64748b;">صنف</span></h3>
        </div>

        <div class="kpi-box" style="border-right-color:#059669;">
            <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
                <span class="material-symbols-outlined" style="color:#059669;">receipt_long</span>
            </div>
            <p class="kpi-title">إجمالي العمليات المنفذة</p>
            <h3 class="kpi-value">@Model.TotalTransactions <span style="font-size:12px; font-weight:normal; color:#64748b;">عملية</span></h3>
        </div>
    </div>

    <!-- Reports Section -->
    <div class="enterprise-panel" style="padding:20px;">
        <h3 style="font-size:14px; font-weight:bold; color:#063955; margin:0 0 16px 0; display:flex; align-items:center; gap:8px;">
            <span class="material-symbols-outlined" style="font-size:18px;">folder_open</span>
            التقارير التفصيلية المتاحة
        </h3>

        <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px;">

            <a href="/Report/IncomeStatement" class="report-card">
                <div class="report-icon" style="background:#f0f9ff; color:#0284c7; border:1px solid #bae6fd;">
                    <span class="material-symbols-outlined">request_quote</span>
                </div>
                <div>
                    <h5 class="report-title">قائمة الدخل والأرباح</h5>
                    <p class="report-desc">تحليل تفصيلي للإيرادات والمصروفات لمعرفة صافي الربح والخسارة.</p>
                </div>
            </a>

            <a href="/Report/DailyCashFlow" class="report-card">
                <div class="report-icon" style="background:#ecfdf5; color:#059669; border:1px solid #a7f3d0;">
                    <span class="material-symbols-outlined">account_balance</span>
                </div>
                <div>
                    <h5 class="report-title">حركة السيولة والصناديق</h5>
                    <p class="report-desc">تتبع حركة النقد المباشرة داخل الصناديق والبنوك والحسابات المالية.</p>
                </div>
            </a>

            <a href="/Report/ShortageForecast" class="report-card">
                <div class="report-icon" style="background:#faf5ff; color:#9333ea; border:1px solid #e9d5ff;">
                    <span class="material-symbols-outlined">insights</span>
                </div>
                <div>
                    <h5 class="report-title">التنبؤ الذكي بالطلب</h5>
                    <p class="report-desc">توقعات الطلب المستقبلية والنواقص المحتملة باستخدام الذكاء الاصطناعي.</p>
                </div>
            </a>

            <a href="/Report/StockExpiry" class="report-card">
                <div class="report-icon" style="background:#fff7ed; color:#ea580c; border:1px solid #fed7aa;">
                    <span class="material-symbols-outlined">event_busy</span>
                </div>
                <div>
                    <h5 class="report-title">رقابة تواريخ الصلاحية</h5>
                    <p class="report-desc">مراقبة الأدوية القريبة من الانتهاء وتصنيفها حسب درجات الخطورة الزمنية.</p>
                </div>
            </a>

            <a href="/PharmacistSalesReport/Index" class="report-card">
                <div class="report-icon" style="background:#f0fdfa; color:#0d9488; border:1px solid #99f6e4;">
                    <span class="material-symbols-outlined">analytics</span>
                </div>
                <div>
                    <h5 class="report-title">إنتاجية الفروع</h5>
                    <p class="report-desc">مقارنة شاملة لإيرادات، مصروفات، وصافي أرباح كل فرع على حدة.</p>
                </div>
            </a>

            <a href="/Report/Ledger" class="report-card">
                <div class="report-icon" style="background:#f0f0ff; color:#4f46e5; border:1px solid #c7d2fe;">
                    <span class="material-symbols-outlined">menu_book</span>
                </div>
                <div>
                    <h5 class="report-title">كشف الحساب (الأستاذ)</h5>
                    <p class="report-desc">تعقب حركات حساب محدد خلال فترة زمنية مع الرصيد التراكمي.</p>
                </div>
            </a>

        </div>
    </div>
</div>