@model IEnumerable<PharmaSmartWeb.Models.Sales>
@{
    ViewData["Title"] = "سجل المبيعات";
    string currency = Settings.Currency;
    decimal totalToday = (decimal)(ViewBag.TotalSalesToday ?? 0m);
    int invoicesToday = (int)(ViewBag.TotalInvoicesToday ?? 0);
    decimal avgCart = (decimal)(ViewBag.AverageCartValueToday ?? 0m);
}

<!-- ===== رأس الصفحة ===== -->
<div class="flex flex-wrap justify-between items-start mb-5">
    <div class="flex items-center gap-3 mb-2 sm:mb-0">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-indigo-700 flex items-center justify-center shadow-sm">
            <i class="fas fa-file-invoice text-white"></i>
        </div>
        <div>
            <h1 class="text-xl font-black text-gray-800">سجل فواتير المبيعات</h1>
            <p class="text-xs text-gray-500">
                <a href="/Home/Index" class="hover:text-blue-600">الرئيسية</a>
                <i class="fas fa-chevron-left text-[10px] mx-1.5 text-gray-400"></i>
                <a href="/Home/CommercialHub" class="hover:text-blue-600">العمليات التجارية</a>
                <i class="fas fa-chevron-left text-[10px] mx-1.5 text-gray-400"></i>
                <span class="text-blue-600 font-semibold">المبيعات</span>
            </p>
        </div>
    </div>
    <div class="flex flex-wrap gap-2">
        <a href="/Home/CommercialHub" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl text-xs font-bold flex items-center gap-2 transition-colors">
            <i class="fas fa-th-large"></i> لوحة التحكم
        </a>
        <a href="/Sales/CloseShift" class="px-4 py-2 bg-amber-50 hover:bg-amber-100 text-amber-700 border border-amber-200 rounded-xl text-xs font-bold flex items-center gap-2 transition-colors">
            <i class="fas fa-lock"></i> إغلاق الوردية
        </a>
        <a href="/Sales/Create" class="quick-action-btn px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5 active:scale-95">
            <i class="fas fa-cash-register"></i> نقطة البيع POS
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="bg-emerald-50 border border-emerald-200 border-r-4 border-r-emerald-500 rounded-xl p-3 mb-4 flex items-center gap-2 text-sm text-emerald-700">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}

<!-- ===== بطاقات KPI ===== -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-5">
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-blue-600">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">إجمالي مبيعات اليوم</span>
            <i class="fas fa-chart-line text-blue-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@totalToday.ToString("N0")</div>
        <span class="text-xs text-blue-600 font-medium">@currency</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-emerald-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">الفواتير المنفذة اليوم</span>
            <i class="fas fa-file-invoice text-emerald-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-emerald-600">@invoicesToday</div>
        <span class="text-xs text-gray-400 font-medium">فاتورة</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-amber-400">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">متوسط قيمة السلة</span>
            <i class="fas fa-shopping-basket text-amber-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-amber-600">@avgCart.ToString("N0")</div>
        <span class="text-xs text-gray-400 font-medium">@currency / فاتورة</span>
    </div>
</div>

<!-- ===== جدول المبيعات ===== -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100">
    <div class="flex flex-wrap justify-between items-center px-5 py-4 border-b border-gray-100 gap-3">
        <h3 class="font-bold text-gray-800 text-sm">
            <i class="fas fa-list text-blue-500 ml-1.5"></i> قائمة الفواتير
        </h3>
        <div class="flex gap-2 items-center flex-wrap">
            <!-- بحث سريع -->
            <div class="relative">
                <i class="fas fa-search absolute right-3 top-2.5 text-gray-400 text-xs"></i>
                <input type="text" id="salesSearch" placeholder="بحث بالفاتورة أو العميل..."
                    class="pr-8 pl-4 py-2 border border-gray-200 rounded-xl text-xs w-48 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-blue-400"
                    oninput="filterSales(this.value)" />
            </div>
            <a href="/SaleReturns/Create" class="px-3 py-2 bg-rose-50 hover:bg-rose-100 text-rose-700 border border-rose-200 rounded-xl text-xs font-semibold flex items-center gap-1.5 transition-colors">
                <i class="fas fa-undo text-xs"></i> مرتجع مبيعات
            </a>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full data-table text-sm" id="salesTable">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">رقم الفاتورة</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">العميل</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">التاريخ والوقت</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">طريقة الدفع</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">الإجمالي الصافي</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">خيارات</th>
                </tr>
            </thead>
            <tbody id="salesBody">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-12 text-gray-400">
                            <i class="fas fa-file-invoice text-5xl mb-3 block text-gray-200"></i>
                            لا توجد مبيعات مسجلة في هذا الفرع حالياً
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    var customerName = item.Customer?.FullName ?? "عميل نقدي";
                    var customerInit = customerName.Length > 0 ? customerName.Substring(0, 1) : "؟";
                    <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors sale-row">
                        <td class="px-5 py-3 font-bold text-blue-700">#@item.SaleId.ToString("D4")</td>
                        <td class="px-5 py-3">
                            <div class="flex items-center gap-2">
                                <div class="w-7 h-7 rounded-lg bg-blue-100 text-blue-700 flex items-center justify-center text-xs font-bold flex-shrink-0">
                                    @customerInit
                                </div>
                                <span class="font-semibold text-gray-800">@customerName</span>
                            </div>
                        </td>
                        <td class="px-5 py-3">
                            <div class="font-medium text-gray-700 text-xs">@item.SaleDate.ToString("yyyy/MM/dd")</div>
                            <div class="text-gray-400 text-[11px]">@item.SaleDate.ToString("hh:mm tt")</div>
                        </td>
                        <td class="px-5 py-3">
                            @if (item.SalePayments != null && item.SalePayments.Any())
                            {
                                foreach (var p in item.SalePayments)
                                {
                                    var pmBadge = p.PaymentMethod == "Cash" ? "bg-emerald-50 text-emerald-700 border-emerald-100"
                                        : p.PaymentMethod == "Bank" ? "bg-sky-50 text-sky-700 border-sky-100"
                                        : "bg-amber-50 text-amber-700 border-amber-100";
                                    <span class="text-[10px] px-2 py-0.5 rounded-full font-bold border @pmBadge ml-1">
                                        @p.PaymentMethod @p.Amount.ToString("N0")
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-[10px] px-2 py-0.5 rounded-full font-bold bg-emerald-50 text-emerald-700 border border-emerald-100">نقدي</span>
                            }
                        </td>
                        <td class="px-5 py-3 font-black text-blue-700 text-sm">@item.NetAmount.ToString("N2")</td>
                        <td class="px-5 py-3 text-center">
                            <a href="/Sales/Details/@item.SaleId"
                               class="inline-flex items-center gap-1 px-3 py-1.5 bg-gray-50 hover:bg-blue-50 border border-gray-200 hover:border-blue-300 text-gray-600 hover:text-blue-700 rounded-lg text-xs font-semibold transition-all">
                                <i class="fas fa-eye text-[10px]"></i> عرض
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- ترقيم الصفحات -->
    @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
    {
        <div class="px-5 py-3 border-t border-gray-100 bg-gray-50 rounded-b-2xl flex flex-wrap items-center justify-between gap-3">
            <span class="text-gray-500 text-xs">الصفحة @ViewBag.CurrentPage من @ViewBag.TotalPages</span>
            <div class="flex gap-2">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="?page=@(ViewBag.CurrentPage - 1)"
                       class="px-4 py-2 bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 rounded-xl text-xs font-semibold transition-colors">
                        <i class="fas fa-chevron-right ml-1 text-[10px]"></i> السابق
                    </a>
                }
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="?page=@(ViewBag.CurrentPage + 1)"
                       class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-xl text-xs font-bold transition-colors">
                        التالي <i class="fas fa-chevron-left mr-1 text-[10px]"></i>
                    </a>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
function filterSales(val) {
    const q = val.toLowerCase().trim();
    document.querySelectorAll('#salesBody .sale-row').forEach(row => {
        const txt = row.innerText.toLowerCase();
        row.style.display = q === '' || txt.includes(q) ? '' : 'none';
    });
}
</script>
}