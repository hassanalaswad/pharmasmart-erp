@model PharmaSmartWeb.Models.ItemGroups

@{
    ViewData["Title"] = "إضافة رمز / مجموعة";
    Layout = "_ModalLayout";
    ViewBag.ModalPanelSize = "md";
    ViewBag.ModalHeaderIcon = "category";
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="ph-form-grid ph-form-grid-2">
        <div>
            <label class="ph-form-label">الرمز (Code)</label>
            <input asp-for="GroupCode" placeholder="مثال: A, B, G-01" class="ph-form-control" style="font-family:monospace;text-transform:uppercase;" />
        </div>
        <div>
            <label class="ph-form-label">اسم المجموعة <span style="color:#e11d48;">*</span></label>
            <input asp-for="GroupName" required placeholder="مثال: مسكنات الألم" class="ph-form-control" />
        </div>
    </div>

    <div class="ph-form-grid">
        <div>
            <label class="ph-form-label">ملاحظات / وصف</label>
            <input asp-for="Description" class="ph-form-control" placeholder="وصف مختصر للمجموعة العلاجية..." />
        </div>
    </div>

    <div class="ph-form-panel">
        <div>
            <div class="ph-form-panel-title">تفعيل المجموعة</div>
            <div class="ph-form-panel-hint">تحديد ما إذا كانت المجموعة الدوائية ستظهر في قوائم اختيار الأدوية وتوجيه المخزون.</div>
        </div>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
            <input asp-for="IsActive" type="checkbox" checked style="width:1rem;height:1rem;cursor:pointer;accent-color:#063955;" />
            <span style="font-size:0.75rem;font-weight:800;color:#063955;">نشطة</span>
        </label>
    </div>

    <div class="ph-modal-actions">
        <button type="button" onclick="modalNavigateBack()" class="ph-btn-back">
            <span class="material-symbols-outlined" style="font-size:18px;">cancel</span>
            إلغاء العملية
        </button>
        <button type="submit" class="ph-btn-primary">
            <span class="material-symbols-outlined" style="font-size:18px;">category</span>
            إنشاء المجموعة
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
