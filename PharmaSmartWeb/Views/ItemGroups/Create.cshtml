@model PharmaSmartWeb.Models.ItemGroups

@{
    ViewData["Title"] = "إضافة رمز / مجموعة";
    Layout = "_ModalLayout";
    ViewBag.ModalWidth = "max-w-[600px]";
}

<style>
    .form-label { font-size: 11px; font-weight: 700; color: #063955; margin-bottom: 4px; display: block; }
    .form-control { width: 100%; border: 1px solid #cbd5e1; border-radius: 2px; padding: 7px 10px; font-size: 13px; background: #f8fafc; }
    .form-control:focus { outline: none; border-color: #063955; background: white; }
    .btn-submit { background: #063955; color: white; border: none; padding: 9px 22px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; }
    .btn-cancel { background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; padding: 9px 18px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; }
</style>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
        <div>
            <label class="form-label">الرمز (Code)</label>
            <input asp-for="GroupCode" placeholder="مثال: A, B, G-01" class="form-control" style="font-family:monospace; text-transform:uppercase;" />
        </div>
        <div>
            <label class="form-label">اسم المجموعة <span style="color:#e11d48;">*</span></label>
            <input asp-for="GroupName" required placeholder="مثال: مسكنات الألم" class="form-control" />
        </div>
    </div>

    <div style="margin-bottom:14px;">
        <label class="form-label">ملاحظات / وصف</label>
        <input asp-for="Description" class="form-control" placeholder="وصف مختصر للمجموعة العلاجية..." />
    </div>

    <div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:2px; padding:12px 14px; display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
        <div>
            <div style="font-size:12px; font-weight:700; color:#063955;">تفعيل المجموعة</div>
            <div style="font-size:10px; color:#94a3b8; margin-top:2px;">تحديد ما إذا كانت المجموعة الدوائية ستظهر في قوائم اختيار الأدوية وتوجيه المخزون.</div>
        </div>
        <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
            <input asp-for="IsActive" type="checkbox" checked style="width:16px; height:16px; cursor:pointer;" />
            <span style="font-size:12px; font-weight:700; color:#063955;">نشطة</span>
        </label>
    </div>

    <div style="display:flex; justify-content:flex-end; gap:10px; padding-top:14px; border-top:1px solid #e2e8f0;">
        <button type="button" onclick="history.back()" class="btn-cancel">
            <span class="material-symbols-outlined" style="font-size:15px;">cancel</span>
            إلغاء العملية
        </button>
        <button type="submit" class="btn-submit">
            <span class="material-symbols-outlined" style="font-size:15px;">category</span>
            إنشاء المجموعة
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}