@model PharmaSmartWeb.Models.ItemGroups

@{
    ViewData["Title"] = $"تعديل مجموعة: {Model.GroupCode}";
    Layout = "_ModalLayout";
    ViewBag.ModalPanelSize = "md";
    ViewBag.ModalHeaderIcon = "edit_note";
}

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="GroupId" />

    <div class="ph-form-grid ph-form-grid-2">
        <div>
            <label class="ph-form-label">الرمز (Code)</label>
            <input asp-for="GroupCode" class="ph-form-control" style="font-family:monospace;text-transform:uppercase;" />
        </div>
        <div>
            <label class="ph-form-label">اسم المجموعة <span style="color:#e11d48;">*</span></label>
            <input asp-for="GroupName" required class="ph-form-control" />
        </div>
    </div>

    <div class="ph-form-grid">
        <div>
            <label class="ph-form-label">ملاحظات / وصف</label>
            <input asp-for="Description" class="ph-form-control" />
        </div>
    </div>

    <div class="ph-form-panel">
        <div>
            <div class="ph-form-panel-title">تفعيل المجموعة</div>
            <div class="ph-form-panel-hint">تحديد ما إذا كانت المجموعة الدوائية ستظهر في قوائم اختيار الأدوية وتوجيه المخزون.</div>
        </div>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
            <input type="checkbox" name="IsActive" value="true" @(Model.IsActive == true ? "checked" : "") style="width:1rem;height:1rem;cursor:pointer;accent-color:#063955;" />
            <input type="hidden" name="IsActive" value="false" />
            <span style="font-size:0.75rem;font-weight:800;color:#063955;">نشطة</span>
        </label>
    </div>

    <div class="ph-modal-actions">
        <button type="button" onclick="modalNavigateBack()" class="ph-btn-back">
            <span class="material-symbols-outlined" style="font-size:18px;">cancel</span>
            إلغاء التعديل
        </button>
        <button type="submit" class="ph-btn-warning">
            <span class="material-symbols-outlined" style="font-size:18px;">sync_alt</span>
            حفظ التحديثات
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
