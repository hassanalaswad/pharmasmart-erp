@{
    Layout = "_Layout";
    ViewData["Title"] = "الذكاء المخزني المالي (ABC, EOQ & Budget)";
}
@Html.AntiForgeryToken()

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .page-title { font-size: 18px; font-weight: 800; color: #063955; margin-bottom: 4px; }
    .page-sub { font-size: 12px; color: #64748b; }
    .btn-primary { background: #063955; color: white; border: none; padding: 8px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 6px; transition: 0.2s; text-decoration: none; }
    .btn-primary:hover { background: #0a4f72; color: white; }
    .btn-secondary { background: white; border: 1px solid #d1d5db; color: #475569; padding: 8px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 6px; transition: 0.2s; text-decoration: none; }
    .btn-secondary:hover { background: #f8fafc; color: #1e293b; border-color: #94a3b8; }
    .enterprise-table { width: 100%; border-collapse: collapse; font-size: 12px; text-align: right; }
    .enterprise-table th { background: #f8fafc; padding: 10px 16px; border-bottom: 1px solid #cbd5e1; color: #334155; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; font-size: 11px; }
    .enterprise-table td { padding: 10px 16px; border-bottom: 1px solid #e2e8f0; color: #1e293b; }
    .kpi-box { padding: 16px; background: white; border-radius: 2px; border: 1px solid #d1d5db; border-right-width: 4px; }
    .alert-success { background: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; padding: 12px 16px; border-radius: 2px; margin-bottom: 16px; display: flex; align-items: center; justify-content: space-between; gap: 8px; font-weight: 700; font-size: 12px; }
    .alert-error { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; padding: 12px 16px; border-radius: 2px; margin-bottom: 16px; display: flex; align-items: center; justify-content: space-between; gap: 8px; font-weight: 700; font-size: 12px; }
</style>

<div class="w-full mx-auto p-6 space-y-4">

    <!-- Header Panel -->
    <div class="enterprise-panel flex flex-col md:flex-row justify-between items-start md:items-center p-5 gap-4">
        <div>
            <h1 class="page-title">الذكاء المخزني وخطط المشتريات</h1>
            <p class="page-sub">دمج باريتو (ABC) والطلب (EOQ) مع الميزانية المالية والأدوية المنقذة للحياة.</p>
        </div>
        <div class="flex gap-2 flex-wrap items-center">
            <button id="btnCalcABC" onclick="runABCAlgorithm()" class="btn-secondary">
                <i class="fas fa-sync"></i> 1. تحديث خوارزمية ABC
            </button>
            <div style="display:inline-flex; align-items:center; border:1px solid #d1d5db; border-radius:2px; overflow:hidden; background:white;">
                <select id="internalDataModel" style="border:none; outline:none; padding:8px 10px; font-size:12px; font-weight:700; color:#063955; background:transparent; cursor:pointer;" title="اختر نموذج التنبؤ للبيانات الداخلية">
                    <option value="prophet">Prophet 🐍</option>
                    <option value="vertex">Google Vertex AI 🧠</option>
                </select>
                <button id="btnGetEOQ" onclick="fetchEOQRecommendations()" class="btn-primary" style="background: #059669; border-radius:0;">
                    <i class="fas fa-magic"></i> 2. توليد خطة الشراء
                </button>
            </div>
            <div style="position: relative; display: inline-flex; align-items: center;">
                <button id="btnGetEOQExcel" onclick="document.getElementById('excelFileInput').click()" class="btn-secondary" style="border-color: #7c3aed; color: #7c3aed; padding-left: 12px;">
                    <i class="fas fa-file-excel"></i> 3. توليد من Excel خارجي
                    <span style="font-size:10px; background:#ede9fe; color:#5b21b6; padding:1px 6px; border-radius:3px; margin-right:4px; font-weight:700;">Google Vertex AI 🧠</span>
                </button>
            </div>
            <input type="file" id="excelFileInput" style="display:none" accept=".xlsx, .xls, .csv" onchange="uploadExcelForSmartPlan(this)" />
        </div>
    </div>

    <!-- ABC Dashboards Panel -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
        <div class="enterprise-panel p-6 flex flex-col items-center justify-center text-center bg-gradient-to-br from-slate-50 to-white">
            <div class="w-16 h-16 rounded-full bg-error/10 text-error flex items-center justify-center mb-3">
                <span class="text-2xl font-black">A</span>
            </div>
            <h3 class="text-sm font-bold text-slate-700 mb-1">أصناف عالية القيمة</h3>
            <p class="text-xs text-slate-500 mb-3">تمثل 80% من إيرادات الصيدلية. تتطلب طلب متكرر ورقابة صارمة.</p>
            <span class="bg-error text-white text-xl font-bold px-4 py-1 rounded-sm shadow-sm">@(ViewBag.CountA ?? 0) صنف</span>
        </div>
        
        <div class="enterprise-panel p-6 flex flex-col items-center justify-center text-center bg-gradient-to-br from-slate-50 to-white">
            <div class="w-16 h-16 rounded-full bg-warning/10 text-amber-500 flex items-center justify-center mb-3">
                <span class="text-2xl font-black">B</span>
            </div>
            <h3 class="text-sm font-bold text-slate-700 mb-1">أصناف متوسطة</h3>
            <p class="text-xs text-slate-500 mb-3">تمثل 15% من الإيرادات. طلب معتدل ورقابة دورية لدعم المخزون.</p>
            <span class="bg-amber-500 text-white text-xl font-bold px-4 py-1 rounded-sm shadow-sm">@(ViewBag.CountB ?? 0) صنف</span>
        </div>

        <div class="enterprise-panel p-6 flex flex-col items-center justify-center text-center bg-gradient-to-br from-slate-50 to-white">
            <div class="w-16 h-16 rounded-full bg-emerald-500/10 text-emerald-600 flex items-center justify-center mb-3">
                <span class="text-2xl font-black">C</span>
            </div>
            <h3 class="text-sm font-bold text-slate-700 mb-1">أصناف منخفضة القيمة</h3>
            <p class="text-xs text-slate-500 mb-3">تمثل 5% من الإيرادات. تدار بمرونة وتطلب بكميات كبيرة نادراً.</p>
            <span class="bg-emerald-500 text-white text-xl font-bold px-4 py-1 rounded-sm shadow-sm">@(ViewBag.CountC ?? 0) صنف</span>
        </div>
    </div>

    <!-- Liquidity Panel -->
    <div id="liquidityContainer" class="hidden enterprise-panel p-6 bg-[#0f172a] text-white" style="border-color: #0f172a;">
        <div class="flex justify-between items-end mb-4">
            <div>
                <p class="text-[11px] font-bold uppercase tracking-widest text-[#34d399] mb-1">السيولة النقدية المتاحة (صناديق وبنوك)</p>
                <h2 id="lblLiquidity" class="text-3xl font-mono font-black tracking-tighter">0.00</h2>
            </div>
            <div class="text-right">
                <p class="text-[11px] font-bold uppercase tracking-widest text-[#fb7185] mb-1">تكلفة الطلبية المقترحة</p>
                <h2 id="lblOrderCost" class="text-2xl font-mono font-black tracking-tighter text-[#cbd5e1]">0.00</h2>
            </div>
        </div>
        <div class="w-full bg-[#1e293b] rounded-none h-2">
            <div id="budgetProgressBar" class="bg-[#10b981] h-full transition-all duration-500" style="width: 0%"></div>
        </div>
    </div>

    <div id="alert-container" class="mb-4 hidden"></div>

    <!-- Data Table Panel -->
    <div class="enterprise-panel">
        <div class="p-4 border-b border-slate-200 bg-slate-50 flex justify-between items-center">
            <h3 class="text-[14px] font-bold text-[#063955] flex items-center gap-2">
                <i class="fas fa-clipboard-list text-[#0284c7]"></i> خطة المشتريات الموجهة
            </h3>
        </div>
        <div class="overflow-x-auto">
            <table class="enterprise-table">
                <thead>
                    <tr>
                        <th style="width: 250px;">الصنف (الدواء)</th>
                        <th style="text-align: center;">التصنيف</th>
                        <th style="text-align: center;" title="بناءً على تحليل Prophet ومعدل الاستهلاك">الطلب المتوقع والتنبؤ 🤖</th>
                        <th style="text-align: center;">التكلفة التقديرية</th>
                        <th style="text-align: center; background: #ecfdf5; color: #065f46;">الكمية المقترحة (EOQ)</th>
                        <th style="text-align: center; background: #f0f9ff; color: #0284c7;">الكمية المعتمدة</th>
                        <th style="text-align: left;">حالة الميزانية</th>
                    </tr>
                </thead>
                <tbody id="eoq-table-body">
                    <tr>
                        <td colspan="7" class="p-10 text-center text-slate-500 font-bold">
                            <span style="display:block; font-size:13px; color:#334155;">اضغط على "توليد خطة الشراء" للبدء بالتحليل وسحب توقعات النواقص.</span>
                            <span style="display:flex; gap:8px; justify-content:center; margin-top:8px;">
                                <span style="background:#d1fae5; color:#065f46; font-size:11px; padding:2px 8px; border-radius:4px; font-weight:700;">قاعدة البيانات → Prophet 🐍</span>
                                <span style="background:#ede9fe; color:#5b21b6; font-size:11px; padding:2px 8px; border-radius:4px; font-weight:700;">Excel خارجي → Google Vertex AI 🧠</span>
                            </span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

    <!-- Mapping Modal -->
    <div id="excelMappingModal" class="hidden fixed inset-0 bg-gray-900 bg-opacity-50 flex items-center justify-center z-50">
        <div class="bg-white rounded-md shadow-lg p-6 w-[450px] max-w-full">
            <h3 class="text-lg font-bold text-[#063955] mb-2"><i class="fas fa-columns text-[#0284c7]"></i> مطابقة أعمدة الإكسل</h3>
            <p class="text-sm text-gray-500 mb-6">يرجى تحديد الأعمدة الصحيحة من ملفك لضمان دقة التحليل والتنبؤ.</p>
            
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-gray-700 mb-1">اسم الدواء (Drug Name)</label>
                    <select id="mapDrugCol" class="w-full border border-gray-300 rounded p-2 text-sm focus:border-[#0284c7] focus:ring-1 focus:ring-[#0284c7]"></select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-700 mb-1">تاريخ البيع (Date)</label>
                    <select id="mapDateCol" class="w-full border border-gray-300 rounded p-2 text-sm focus:border-[#0284c7] focus:ring-1 focus:ring-[#0284c7]"></select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-700 mb-1">الكمية المباعة (Quantity)</label>
                    <select id="mapQtyCol" class="w-full border border-gray-300 rounded p-2 text-sm focus:border-[#0284c7] focus:ring-1 focus:ring-[#0284c7]"></select>
                </div>
            </div>

            <div class="mt-8 flex justify-end gap-2">
                <button onclick="closeMappingModal()" class="btn-secondary">إلغاء</button>
                <button onclick="submitExcelMapping()" id="btnSubmitMapping" class="btn-primary" style="background:#0284c7;">
                    تأكيد وتوليد الخطة <i class="fas fa-magic"></i>
                </button>
            </div>
        </div>
    </div>

<script>
    function invIntelAntiForgeryHeaders() {
        const el = document.querySelector('input[name="__RequestVerificationToken"]');
        const t = el ? el.value : '';
        return t ? { 'RequestVerificationToken': t } : {};
    }

    async function runABCAlgorithm() {
        const btn = document.getElementById('btnCalcABC');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري التحليل...';
        btn.disabled = true;

        try {
            const response = await fetch('/InventoryIntelligence/CalculateABC', { method: 'POST', headers: invIntelAntiForgeryHeaders() });
            if (response.ok) {
                showAlert('success', 'نجاح', await response.text());
                fetchEOQRecommendations();
            } else {
                showAlert('error', 'فشل', await response.text());
            }
        } catch (err) { showAlert('error', 'خطأ', 'فشل الاتصال بالخادم.'); }
        finally { btn.innerHTML = '<i class="fas fa-sync"></i> 1. تحديث خوارزمية ABC'; btn.disabled = false; }
    }

    let currentPlanId = 0;

    async function fetchEOQRecommendations() {
        const btn = document.getElementById('btnGetEOQ');
        const container = document.getElementById('alert-container');
        container.classList.add('hidden');
        
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري التحليل وصناعة الخطة 🤖...';
        btn.disabled = true;

        const selectedModel = document.getElementById('internalDataModel') ? document.getElementById('internalDataModel').value : 'prophet';
        try {
            const response = await fetch('/InventoryIntelligence/GenerateSmartPlan?model=' + selectedModel, { method: 'POST', headers: invIntelAntiForgeryHeaders() });
            if (response.ok) {
                const data = await response.json();
                if (data.success) {
                    currentPlanId = data.planId;
                    showAlert('success', 'نجاح', data.message);
                    await loadPlanDetails(currentPlanId);
                } else {
                    showAlert('error', 'تنبيه', data.message || "حدث خطأ");
                }
            } else {
                showAlert('error', 'تنبيه', await response.text());
            }
        } catch (err) { showAlert('error', 'خطأ', 'فشل الاتصال.'); }
        finally { btn.innerHTML = '<i class="fas fa-magic"></i> 2. توليد خطة الشراء'; btn.disabled = false; }
    }

    let pendingExcelFile = null;

    async function uploadExcelForSmartPlan(input) {
        if (!input.files || input.files.length === 0) return;
        
        const btn = document.getElementById('btnGetEOQExcel');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري قراءة الملف...';
        btn.disabled = true;

        pendingExcelFile = input.files[0];
        const formData = new FormData();
        formData.append('excelFile', pendingExcelFile);

        try {
            const response = await fetch('/InventoryIntelligence/ExtractExcelHeaders', { 
                method: 'POST',
                headers: invIntelAntiForgeryHeaders(),
                body: formData
            });
            if (response.ok) {
                const data = await response.json();
                if (data.success) {
                    populateMappingOptions(data.headers);
                    document.getElementById('excelMappingModal').classList.remove('hidden');
                } else {
                    showAlert('error', 'تنبيه', data.message || "فشل قراءة الملف");
                }
            } else {
                showAlert('error', 'تنبيه', await response.text());
            }
        } catch (err) { showAlert('error', 'خطأ', 'فشل الاتصال.'); }
        finally { 
            btn.innerHTML = '<i class="fas fa-file-excel"></i> 3. توليد من ملف Excel خارجي'; 
            btn.disabled = false; 
            input.value = ''; 
        }
    }

    function populateMappingOptions(headers) {
        const selects = ['mapDrugCol', 'mapDateCol', 'mapQtyCol'];
        selects.forEach(id => {
            const el = document.getElementById(id);
            el.innerHTML = '';
            headers.forEach((h, index) => {
                el.innerHTML += `<option value="${index}">${h}</option>`;
            });
        });
        
        if(headers.length >= 3) {
            document.getElementById('mapDrugCol').selectedIndex = 0;
            document.getElementById('mapDateCol').selectedIndex = 1;
            document.getElementById('mapQtyCol').selectedIndex = 2;
        }
    }

    function closeMappingModal() {
        document.getElementById('excelMappingModal').classList.add('hidden');
        pendingExcelFile = null;
    }

    async function submitExcelMapping() {
        if (!pendingExcelFile) return;
        
        const drugCol = document.getElementById('mapDrugCol').value;
        const dateCol = document.getElementById('mapDateCol').value;
        const qtyCol = document.getElementById('mapQtyCol').value;

        closeMappingModal();
        
        const container = document.getElementById('alert-container');
        container.classList.add('hidden');
        
        const btn = document.getElementById('btnGetEOQExcel');
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري التحليل المعمق...';
        btn.disabled = true;

        const formData = new FormData();
        formData.append('excelFile', pendingExcelFile);
        formData.append('drugCol', drugCol);
        formData.append('dateCol', dateCol);
        formData.append('qtyCol', qtyCol);

        try {
            const response = await fetch('/InventoryIntelligence/GenerateSmartPlanFromExcel', { 
                method: 'POST',
                headers: invIntelAntiForgeryHeaders(),
                body: formData
            });
            if (response.ok) {
                const data = await response.json();
                if (data.success) {
                    currentPlanId = data.planId;
                    showAlert('success', 'نجاح الاستيراد', data.message);
                    await loadPlanDetails(currentPlanId);
                } else {
                    showAlert('error', 'تنبيه', data.message || "حدث خطأ أثناء تحليل الإكسل");
                }
            } else {
                showAlert('error', 'تنبيه', await response.text());
            }
        } catch (err) { showAlert('error', 'خطأ', 'فشل الاتصال.'); }
        finally { 
            btn.innerHTML = '<i class="fas fa-file-excel"></i> 3. توليد من ملف Excel خارجي'; 
            btn.disabled = false; 
            pendingExcelFile = null;
        }
    }

    async function loadPlanDetails(planId) {
        document.getElementById('liquidityContainer').classList.add('hidden');
        const container = document.querySelector('.overflow-x-auto');
        container.innerHTML = '<div class="p-10 text-center"><i class="fas fa-spinner fa-spin text-3xl text-[#0284c7]"></i><p class="mt-2 text-slate-500 font-bold">جاري تحميل تفاصيل الخطة المعتمدة...</p></div>';
        
        try {
            const response = await fetch('/InventoryIntelligence/GetPlanDetails?id=' + planId);
            if (response.ok) {
                const html = await response.text();
                container.innerHTML = html;
            } else {
                showAlert('error', 'تنبيه', 'فشل تحميل بيانات الخطة.');
            }
        } catch (err) {
             showAlert('error', 'تنبيه', 'خطأ في الشبكة.');
        }
    }

    async function updatePlanDetail(detailId, approvedQty) {
        try {
            await fetch(`/InventoryIntelligence/UpdatePlanDetail?detailId=${detailId}&approvedQuantity=${approvedQty}`, { method: 'POST' });
            // تحديث الجدول كاملاً لإعادة احتساب الإجماليات
            await loadPlanDetails(currentPlanId);
        } catch(err) {
            console.error("فشل التحديث", err);
        }
    }

    function printSmartPlan() {
        if(currentPlanId === 0) {
            showAlert('error', 'تنبيه', 'يرجى توليد الخطة أولاً.');
            return;
        }
        window.open('/InventoryIntelligence/SmartPlanPrint/' + currentPlanId, '_blank');
    }

    function showAlert(type, title, message) {
        const container = document.getElementById('alert-container');
        const alertClass = type === 'success' ? 'alert-success' : 'alert-error';
        const icon = type === 'success' ? 'check_circle' : 'error';
        container.innerHTML = `
            <div class="${alertClass}">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined" style="font-size: 16px;">${icon}</span>
                    <span>${title}: ${message}</span>
                </div>
                <button onclick="this.parentElement.remove()" style="background:transparent; border:none; cursor:pointer;" class="text-slate-400 hover:text-slate-600">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        `;
        container.classList.remove('hidden');
    }
</script>