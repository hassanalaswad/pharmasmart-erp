@model IEnumerable<PharmaSmartWeb.Models.Purchases>
@using PharmaSmartWeb.Infrastructure

@{
    ViewData["Title"] = "سجل مرتجعات المشتريات";
    var total = Model.Any() ? Model.Sum(x => x.NetAmount) : 0;
    var count = Model.Count();
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .enterprise-header { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 10px 16px; font-size: 13px; font-weight: 700; color: #063955; }
    .enterprise-kpi { background: white; border: 1px solid #d1d5db; border-radius: 2px; padding: 12px 16px; }
    .kpi-title { font-size: 11px; color: #64748b; font-weight: 600; margin-bottom: 4px; }
    .kpi-value { font-size: 22px; font-weight: 700; color: #0f172a; }
    .enterprise-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .enterprise-table th { background: #f1f5f9; padding: 8px 12px; border-bottom: 1px solid #cbd5e1; border-top: 1px solid #cbd5e1; color: #334155; font-weight: 700; text-align: right; }
    .enterprise-table td { padding: 8px 12px; border-bottom: 1px solid #e2e8f0; color: #1e293b; }
    .enterprise-table tr:hover td { background: #f8fafc; }
    .btn-primary { background: #063955; color: white; border: none; padding: 7px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; }
    .btn-primary:hover { background: #0a4f72; color: white; }
    .btn-sm { padding: 4px 10px; font-size: 11px; border-radius: 2px; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
    .page-title { font-size: 16px; font-weight: 700; color: #063955; }
</style>

@if (TempData["Success"] != null)
{
    <div class="enterprise-panel mb-4 p-3 flex items-center gap-3" style="border-right: 4px solid #059669;">
        <span class="material-symbols-outlined" style="color:#059669; font-size:18px;">check_circle</span>
        <span style="font-size:13px; color:#059669; font-weight:600;">@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="enterprise-panel mb-4 p-3 flex items-center gap-3" style="border-right: 4px solid #e11d48;">
        <span class="material-symbols-outlined" style="color:#e11d48; font-size:18px;">error</span>
        <span style="font-size:13px; color:#e11d48; font-weight:600;">@TempData["Error"]</span>
    </div>
}

<!-- Page Header -->
<div class="enterprise-panel mb-4 p-3 flex justify-between items-center">
    <div>
        <h1 class="page-title">سجل مرتجعات المشتريات</h1>
        <p style="font-size:12px; color:#64748b;">متابعة الفواتير المعكوسة المرتجعة للموردين.</p>
    </div>
    <a href="/Purchases/Index" class="btn-primary">
        <span class="material-symbols-outlined" style="font-size:15px;">arrow_forward</span>
        لوحة المشتريات
    </a>
</div>

<!-- KPIs -->
<div class="grid grid-cols-3 gap-3 mb-4">
    <div class="enterprise-kpi" style="border-right:4px solid #e11d48;">
        <div class="kpi-title">إجمالي عدد المرتجعات</div>
        <div class="kpi-value" style="color:#e11d48;">@count</div>
    </div>
    <div class="enterprise-kpi" style="border-right:4px solid #e11d48;">
        <div class="kpi-title">إجمالي قيمة المرتجعات</div>
        <div class="kpi-value" style="color:#e11d48;">@total.ToString("N2")</div>
        <div style="font-size:10px; color:#94a3b8;">ر.ي</div>
    </div>
    <div class="enterprise-kpi" style="background:#063955;">
        <div class="kpi-title" style="color:#94a3b8;">وصول سريع</div>
        <a href="/Purchases/Index" style="color:white; font-size:13px; font-weight:700; text-decoration:none; display:flex; align-items:center; gap:6px; margin-top:8px;">
            <span class="material-symbols-outlined" style="font-size:16px;">arrow_forward</span>
            إدارة فواتير المشتريات
        </a>
    </div>
</div>

<!-- Data Table -->
<div class="enterprise-panel">
    <div class="enterprise-header">القائمة التفصيلية للمرتجعات — (@count مرتجع)</div>
    <div style="overflow-x:auto;">
        <table class="enterprise-table">
            <thead>
                <tr>
                    <th>رقم المرتجع</th>
                    <th style="text-align:center;">الفاتورة الأصلية</th>
                    <th>اسم المورد</th>
                    <th>التاريخ</th>
                    <th style="text-align:center;">قيمة المرتجع</th>
                    <th style="text-align:center;">المسؤول</th>
                    <th style="text-align:center;">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align:center; padding:40px; color:#94a3b8;">
                            <span class="material-symbols-outlined" style="font-size:32px; display:block; margin-bottom:8px;">inventory_2</span>
                            لا توجد سجلات مرتجعات حالياً.
                            <br />
                            <a href="/Purchases/Index" style="color:#063955; font-size:12px; font-weight:700;">الذهاب للمشتريات</a>
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong style="font-family:monospace; color:#063955;">#D5-@item.PurchaseId.ToString("D4")</strong></td>
                        <td style="text-align:center;">
                            <span style="background:#f1f5f9; padding:2px 8px; border-radius:2px; font-family:monospace; font-size:11px; border:1px solid #e2e8f0;">
                                INV-@(item.ParentPurchaseId?.ToString("D4") ?? "---")
                            </span>
                        </td>
                        <td style="font-weight:600;">@(item.Supplier?.SupplierName ?? "مورد محذوف")</td>
                        <td style="font-size:11px; color:#64748b;" dir="ltr">@item.PurchaseDate.ToString("yyyy/MM/dd")</td>
                        <td style="text-align:center; font-weight:700; font-family:monospace; color:#e11d48;">
                            @item.NetAmount.ToString("N2") ر.ي
                        </td>
                        <td style="text-align:center;">
                            <span style="font-size:11px; color:#475569;">@(item.User?.Username ?? "System")</span>
                        </td>
                        <td style="text-align:center;">
                            <a asp-controller="Purchases" asp-action="Details" asp-route-id="@item.PurchaseId" class="btn-sm">
                                <span class="material-symbols-outlined" style="font-size:13px;">visibility</span>
                                التفاصيل
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Any())
    {
        <div style="padding:8px 12px; background:#f8fafc; border-top:1px solid #e2e8f0; font-size:11px; color:#64748b;">
            عرض @count من أصل @count سجل مرتجع
        </div>
    }
</div>