@model PharmaSmartWeb.Models.Suppliers

@{
    ViewData["Title"] = $"تعديل المورد: {Model.SupplierName}";
    Layout = "_ModalLayout";
    ViewBag.ModalPanelSize = "lg";
    ViewBag.ModalHeaderIcon = "local_shipping";
}

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    @if (ViewBag.Error != null || TempData["Error"] != null)
    {
        <div class="ph-alert-error">⚠ @(ViewBag.Error ?? TempData["Error"])</div>
    }

    <input type="hidden" asp-for="SupplierId" />
    <input type="hidden" asp-for="AccountId" />
    <input type="hidden" asp-for="CreatedAt" />

    <div class="ph-info-row">
        <span class="material-symbols-outlined" style="font-size:18px;color:#475569;">account_balance</span>
        <div style="flex:1;min-width:0;">
            <div style="font-size:0.625rem;color:#94a3b8;font-weight:700;">الحساب المالي المرتبط بالدليل</div>
            <div style="font-size:0.75rem;font-weight:800;color:#0f172a;">
                @(Model.Account?.AccountCode ?? "---") — @(Model.Account?.AccountName ?? "غير مربوط")
            </div>
        </div>
        <span style="font-size:0.625rem;background:#e2e8f0;padding:0.15rem 0.5rem;border-radius:4px;color:#475569;font-weight:800;">للقراءة فقط</span>
    </div>

    <div class="ph-section-muted">بيانات المورد</div>
    <div class="ph-form-grid ph-form-grid-2">
        <div>
            <label class="ph-form-label">اسم المورد <span style="color:#e11d48;">*</span></label>
            <input asp-for="SupplierName" required class="ph-form-control" placeholder="مثال: شركة الأدوية العالمية" />
        </div>
        <div>
            <label class="ph-form-label">المسؤول عن التواصل</label>
            <input asp-for="ContactPerson" class="ph-form-control" placeholder="الاسم الثلاثي للمندوب" />
        </div>
        <div>
            <label class="ph-form-label">رقم الهاتف / الجوال</label>
            <input asp-for="Phone" class="ph-form-control" dir="ltr" placeholder="05XXXXXXXX" type="tel" />
        </div>
        <div>
            <label class="ph-form-label">العنوان بالتفصيل</label>
            <input asp-for="Address" class="ph-form-control" placeholder="المدينة، الحي، اسم الشارع، رقم المبنى" />
        </div>
    </div>

    <div class="ph-form-panel">
        <div style="display:flex;align-items:center;gap:0.625rem;">
            <span class="material-symbols-outlined" style="font-size:18px;color:#063955;">verified_user</span>
            <div>
                <div class="ph-form-panel-title">حالة المورد (النشاط)</div>
                <div class="ph-form-panel-hint">تفعيل أو إيقاف التعامل مع المورد (الإيقاف لن يؤثر على السجلات السابقة)</div>
            </div>
        </div>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
            <input type="checkbox" name="IsActive" value="true" @(Model.IsActive == true ? "checked" : "") style="width:1rem;height:1rem;cursor:pointer;accent-color:#063955;" />
            <input type="hidden" name="IsActive" value="false" />
            <span style="font-size:0.75rem;font-weight:800;color:#063955;">@(Model.IsActive == true ? "نشط" : "غير نشط")</span>
        </label>
    </div>

    <div class="ph-modal-actions">
        <button type="button" onclick="modalNavigateBack()" class="ph-btn-back">إلغاء التعديل</button>
        <button type="submit" class="ph-btn-warning">
            <span class="material-symbols-outlined" style="font-size:18px;">save</span>
            حفظ التحديثات
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
