@model PharmaSmartWeb.Models.Suppliers

@{
    ViewData["Title"] = "إضافة مورد دوائي جديد";
    bool isPopup = ViewBag.IsPopup == true;
    Layout = isPopup ? "_PopupLayout" : "_ModalLayout";
    ViewBag.ModalPanelSize = "lg";
    ViewBag.ModalHeaderIcon = "local_shipping";
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    @* حقل مخفي لتمرير وضع الـ Popup إلى الـ POST action *@
    <input type="hidden" name="isPopup" value="@(isPopup ? "true" : "false")" />

    @if (ViewBag.Error != null || TempData["Error"] != null)
    {
        <div class="enterprise-alert-error">
            <span class="material-symbols-outlined" style="font-size:16px;">warning</span>
            @(ViewBag.Error ?? TempData["Error"])
        </div>
    }

    <div class="enterprise-section-title">
        <span class="material-symbols-outlined" style="font-size:18px;">domain</span>
        البيانات الأساسية للشركة / المصنع
    </div>

    <div class="enterprise-row">
        <div>
            <label class="enterprise-label">اسم المورد <span style="color:#e11d48;">*</span></label>
            <input asp-for="SupplierName" required class="enterprise-input" placeholder="مثال: شركة الأدوية العالمية" type="text" />
            <span asp-validation-for="SupplierName" style="color:#e11d48;font-size:11px;margin-top:4px;display:block;"></span>
        </div>
        <div>
            <label class="enterprise-label">المسؤول عن التواصل</label>
            <input asp-for="ContactPerson" class="enterprise-input" placeholder="الاسم الثلاثي للمندوب" type="text" />
        </div>
        <div>
            <label class="enterprise-label">رقم الهاتف / الجوال</label>
            <input asp-for="Phone" class="enterprise-input" dir="ltr" placeholder="05XXXXXXXX" type="tel" />
        </div>
        <div>
            <label class="enterprise-label">العنوان بالتفصيل</label>
            <input asp-for="Address" class="enterprise-input" placeholder="المدينة، الحي، اسم الشارع، رقم المبنى" type="text" />
        </div>
    </div>

    <div class="enterprise-info-box" style="margin-top:8px;background:#f0f9ff;border-color:#bae6fd;">
        <span class="material-symbols-outlined" style="color:#0284c7;font-size:26px;">account_balance_wallet</span>
        <div style="flex:1;">
            <strong style="font-size:13px;color:#0369a1;display:block;margin-bottom:12px;">التوجيه المحاسبي الآلي للمورد</strong>
            <label class="enterprise-label" style="color:#059669;">الحساب الرئيسي المرتبط <span style="color:#e11d48;">*</span></label>
            <select name="ParentAccountId" required class="enterprise-select" style="border-color:#bbf7d0;max-width:400px;">
                <option value="">-- اختر مجموعة الموردين في الدليل المالي --</option>
                @if (ViewBag.ParentAccounts != null)
                {
                    foreach (var acc in ViewBag.ParentAccounts)
                    {
                        <option value="@acc.Value">@acc.Text</option>
                    }
                }
            </select>
            <div style="font-size:11px;color:#64748b;margin-top:6px;">
                <span class="material-symbols-outlined" style="font-size:12px;vertical-align:middle;">info</span>
                سيتم إنشاء كود فرعي تلقائياً لهذا المورد تحت الحساب المختار في شجرة الحسابات.
            </div>
        </div>
    </div>

    <div class="enterprise-actions">
        <button type="button" onclick="modalNavigateBack()" class="enterprise-btn-cancel">إلغاء الإضافة</button>
        <button type="submit" class="enterprise-btn-submit">
            <span class="material-symbols-outlined" style="font-size:16px;">save</span>
            إنشاء المورد وفتح حساب مالي
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}