@model IEnumerable<PharmaSmartWeb.Models.Journalentries>

@{
    ViewData["Title"] = "دفتر اليومية العامة";
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .enterprise-header { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 10px 16px; font-size: 13px; font-weight: 700; color: #063955; }
    .enterprise-kpi { background: white; border: 1px solid #d1d5db; border-radius: 2px; padding: 12px 16px; }
    .kpi-title { font-size: 11px; color: #64748b; font-weight: 600; margin-bottom: 4px; }
    .kpi-value { font-size: 22px; font-weight: 700; color: #0f172a; }
    .enterprise-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .enterprise-table th { background: #f1f5f9; padding: 8px 12px; border-bottom: 1px solid #cbd5e1; border-top: 1px solid #cbd5e1; color: #334155; font-weight: 700; text-align: right; }
    .enterprise-table td { padding: 8px 12px; border-bottom: 1px solid #e2e8f0; color: #1e293b; }
    .enterprise-table tr:hover td { background: #f8fafc; }
    .status-posted { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; padding: 2px 8px; border-radius: 2px; font-size: 11px; font-weight: 700; }
    .status-draft { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; padding: 2px 8px; border-radius: 2px; font-size: 11px; font-weight: 700; }
    .btn-primary { background: #063955; color: white; border: none; padding: 7px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; }
    .btn-primary:hover { background: #0a4f72; color: white; }
    .btn-view { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; padding: 4px 10px; border-radius: 2px; font-size: 11px; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; }
    .search-input { border: 1px solid #d1d5db; border-radius: 2px; padding: 6px 10px; font-size: 12px; width: 260px; }
    .search-input:focus { outline: none; border-color: #063955; }
    .page-title { font-size: 16px; font-weight: 700; color: #063955; }
    .page-sub { font-size: 12px; color: #64748b; }
</style>

<!-- Page Header -->
<div class="enterprise-panel mb-4 p-3 flex justify-between items-center">
    <div>
        <h1 class="page-title">دفتر اليومية العامة</h1>
        <p class="page-sub">سجل الحركات المالية والقيود المحاسبية للفرع الرئيسي.</p>
    </div>
    <a href="/JournalEntries/Create" class="btn-primary">
        <span class="material-symbols-outlined" style="font-size:16px;">add_circle</span>
        إضافة قيد يدوي
    </a>
</div>

<!-- KPIs -->
<div class="grid grid-cols-3 gap-3 mb-4">
    <div class="enterprise-kpi" style="border-right: 4px solid #063955;">
        <div class="kpi-title">إجمالي حجم التعاملات</div>
        <div class="kpi-value">@ViewBag.TotalVolume.ToString("N2")</div>
        <div style="font-size:10px; color:#94a3b8;">ر.ي</div>
    </div>
    <div class="enterprise-kpi">
        <div class="kpi-title">إجمالي القيود</div>
        <div class="kpi-value">@ViewBag.TotalEntriesCount.ToString("N0")</div>
    </div>
    <div class="enterprise-kpi">
        <div class="kpi-title">قيود مسودة</div>
        <div class="kpi-value" style="color:#d97706;">@ViewBag.DraftedEntriesCount.ToString("N0")</div>
    </div>
</div>

<!-- Data Table -->
<div class="enterprise-panel">
    <div class="enterprise-header flex justify-between items-center">
        <span>قائمة القيود المحاسبية</span>
        <input type="text" id="searchInput" class="search-input" placeholder="البحث برقم القيد أو الوصف..." onkeyup="filterTable()" />
    </div>
    <div style="overflow-x:auto;">
        <table class="enterprise-table" id="dataTable">
            <thead>
                <tr>
                    <th>رقم القيد</th>
                    <th>التاريخ</th>
                    <th>الوصف والفرع</th>
                    <th>القيمة الإجمالية</th>
                    <th style="text-align:center;">الحالة</th>
                    <th style="text-align:center;">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" style="text-align:center; padding:40px; color:#94a3b8;">
                            <span class="material-symbols-outlined" style="font-size:32px; display:block; margin-bottom:8px;">folder_open</span>
                            لا توجد قيود مسجلة في النظام حتى الآن.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    decimal entryTotal = item.Journaldetails?.Sum(d => d.Debit) ?? 0;
                    <tr class="searchable-row">
                        <td><strong style="font-family:monospace; color:#063955;">#JE-@item.JournalId</strong></td>
                        <td>
                            <div style="font-size:12px;">@item.JournalDate.ToString("yyyy-MM-dd")</div>
                            <div style="font-size:10px; color:#94a3b8;" dir="ltr">@item.JournalDate.ToString("hh:mm tt")</div>
                        </td>
                        <td>
                            <div style="font-size:12px; font-weight:600;">@item.Description</div>
                            <div style="font-size:10px; color:#63955; display:flex; align-items:center; gap:3px;">
                                <span class="material-symbols-outlined" style="font-size:12px;">location_on</span>
                                @(item.Branch?.BranchName ?? "المركز الرئيسي")
                            </div>
                        </td>
                        <td style="font-weight:700; font-family:monospace;">
                            @entryTotal.ToString("N2") ر.ي
                        </td>
                        <td style="text-align:center;">
                            @if (item.IsPosted)
                            {
                                <span class="status-posted">مرحّل</span>
                            }
                            else
                            {
                                <span class="status-draft">مسودة</span>
                            }
                        </td>
                        <td style="text-align:center;">
                            <a href="/JournalEntries/Details/@item.JournalId" class="btn-view">
                                <span class="material-symbols-outlined" style="font-size:13px;">visibility</span>
                                عرض
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div style="padding:8px 12px; background:#f8fafc; border-top:1px solid #e2e8f0; display:flex; justify-content:space-between; align-items:center;">
        <span id="tableInfo" style="font-size:11px; color:#64748b;">
            عرض @Model.Count() قيد من إجمالي @ViewBag.TotalEntriesCount.ToString("N0")
        </span>
        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
        {
            <div style="display:flex; gap:6px; align-items:center; font-size:11px; color:#64748b;">
                <span>صفحة @ViewBag.CurrentPage من @ViewBag.TotalPages</span>
                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="?page=@(ViewBag.CurrentPage - 1)" style="padding:3px 8px; background:#f1f5f9; border:1px solid #e2e8f0; border-radius:2px; text-decoration:none; color:#475569; font-weight:700;">السابق</a>
                }
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="?page=@(ViewBag.CurrentPage + 1)" style="padding:3px 8px; background:#063955; border-radius:2px; text-decoration:none; color:white; font-weight:700;">التالي</a>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    function filterTable() {
        var input = document.getElementById("searchInput").value.toLowerCase();
        var rows = document.querySelectorAll(".searchable-row");
        var visibleCount = 0;
        rows.forEach(row => {
            if (row.innerText.toLowerCase().includes(input)) {
                row.style.display = "";
                visibleCount++;
            } else {
                row.style.display = "none";
            }
        });
        document.getElementById("tableInfo").innerText = "تمت تصفية " + visibleCount + " قيد";
    }
</script>
}