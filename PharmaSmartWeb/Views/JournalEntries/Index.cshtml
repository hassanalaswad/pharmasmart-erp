@model IEnumerable<PharmaSmartWeb.Models.Journalentries>

@{
    ViewData["Title"] = "دفتر اليومية العامة";
}

@if (TempData["Success"] != null)
{
    <div class="bg-emerald-50 border border-emerald-200 border-r-4 border-r-emerald-500 rounded-xl p-3 mb-4 flex items-center gap-2 text-sm text-emerald-700">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}

<!-- ===== رأس الصفحة ===== -->
<div class="flex flex-wrap justify-between items-start mb-5">
    <div class="flex items-center gap-3 mb-2 sm:mb-0">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-600 to-blue-800 flex items-center justify-center shadow-sm">
            <i class="fas fa-book text-white"></i>
        </div>
        <div>
            <h1 class="text-xl font-black text-gray-800">دفتر اليومية العامة</h1>
            <p class="text-xs text-gray-500">سجل الحركات المالية والقيود المحاسبية للفرع</p>
        </div>
    </div>
    <div class="flex gap-2 flex-wrap">
        <a href="/JournalEntries/Create" class="quick-action-btn px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5 active:scale-95">
            <i class="fas fa-plus-circle"></i> إضافة قيد يدوي
        </a>
    </div>
</div>

<!-- ===== بطاقات KPI ===== -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-5">
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-indigo-600">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">إجمالي حجم التعاملات</span>
            <i class="fas fa-coins text-indigo-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@ViewBag.TotalVolume.ToString("N2")</div>
        <span class="text-xs text-gray-400 font-medium">إجمالي الحركات (ر.ي)</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-blue-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-blue-700 font-semibold">إجمالي القيود</span>
            <i class="fas fa-list-ol text-blue-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-blue-600">@ViewBag.TotalEntriesCount.ToString("N0")</div>
        <span class="text-xs text-gray-400 font-medium">قيد مسجل</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-amber-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-amber-700 font-semibold">قيود مسودة</span>
            <i class="fas fa-edit text-amber-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-amber-600">@ViewBag.DraftedEntriesCount.ToString("N0")</div>
        <span class="text-xs text-gray-400 font-medium">قيد غير مرحل (قيد المراجعة)</span>
    </div>
</div>

<!-- ===== جدول اليومية ===== -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100">
    <div class="flex flex-wrap justify-between items-center px-5 py-4 border-b border-gray-100 gap-3">
        <h3 class="font-bold text-gray-800 text-sm">
            <i class="fas fa-list text-indigo-500 ml-1.5"></i> قائمة القيود المحاسبية
        </h3>
        <div class="relative">
            <i class="fas fa-search absolute right-3 top-2.5 text-gray-400 text-xs"></i>
            <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="البحث برقم القيد أو الوصف..."
                class="pr-8 pl-4 py-2 border border-gray-200 rounded-xl text-xs w-56 focus:outline-none focus:ring-2 focus:ring-indigo-400" />
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full data-table text-sm" id="dataTable">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">رقم القيد</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">التاريخ</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">الوصف والفرع</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">القيمة الإجمالية</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">الحالة</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-12 text-gray-400">
                            <i class="fas fa-folder-open text-5xl mb-3 block text-gray-200"></i>
                            لا توجد قيود مسجلة في النظام حتى الآن.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    decimal entryTotal = item.Journaldetails?.Sum(d => d.Debit) ?? 0;
                    <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors search-row">
                        <td class="px-5 py-3 font-mono font-bold text-indigo-700 search-id">#JE-@item.JournalId.ToString("D4")</td>
                        <td class="px-5 py-3">
                            <div class="font-bold text-xs text-gray-700">@item.JournalDate.ToString("yyyy-MM-dd")</div>
                            <div class="text-[10px] text-gray-400 font-mono mt-0.5" dir="ltr">@item.JournalDate.ToString("hh:mm tt")</div>
                        </td>
                        <td class="px-5 py-3 search-desc">
                            <div class="font-bold text-gray-800 text-xs">@item.Description</div>
                            <div class="text-[10px] text-gray-500 mt-1 flex items-center gap-1">
                                <i class="fas fa-map-marker-alt text-gray-400"></i>
                                @(item.Branch?.BranchName ?? "المركز الرئيسي")
                            </div>
                        </td>
                        <td class="px-5 py-3 text-center font-bold font-mono text-gray-700 text-sm">
                            @entryTotal.ToString("N2")
                        </td>
                        <td class="px-5 py-3 text-center">
                            @if (item.IsPosted)
                            {
                                <span class="text-[11px] px-2.5 py-1 bg-emerald-50 text-emerald-700 border border-emerald-100 rounded-full font-bold">مرحّل</span>
                            }
                            else
                            {
                                <span class="text-[11px] px-2.5 py-1 bg-amber-50 text-amber-700 border border-amber-100 rounded-full font-bold">مسودة</span>
                            }
                        </td>
                        <td class="px-5 py-3 text-center">
                            <a href="/JournalEntries/Details/@item.JournalId" class="inline-flex items-center gap-1 px-3 py-1.5 bg-blue-50 hover:bg-blue-100 border border-blue-200 text-blue-700 rounded-lg text-xs font-semibold transition-all">
                                <i class="fas fa-eye text-[10px]"></i> عرض
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="flex flex-wrap justify-between items-center px-5 py-3 bg-gray-50 border-t border-gray-100 rounded-b-2xl">
        <span id="tableInfo" class="text-xs text-gray-500">
            عرض @Model.Count() قيد من إجمالي @ViewBag.TotalEntriesCount.ToString("N0")
        </span>
        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
        {
            <div class="flex items-center gap-2 text-xs text-gray-500">
                <span>صفحة @ViewBag.CurrentPage من @ViewBag.TotalPages</span>
                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="?page=@(ViewBag.CurrentPage - 1)" class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg hover:bg-gray-100 font-bold transition-colors">السابق</a>
                }
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="?page=@(ViewBag.CurrentPage + 1)" class="px-3 py-1.5 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-bold transition-colors">التالي</a>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
function filterTable() {
    const q = document.getElementById("searchInput").value.toLowerCase();
    let count = 0;
    document.querySelectorAll(".search-row").forEach(row => {
        const id = row.querySelector(".search-id")?.innerText.toLowerCase() ?? "";
        const desc = row.querySelector(".search-desc")?.innerText.toLowerCase() ?? "";
        if (id.includes(q) || desc.includes(q)) {
            row.style.display = "";
            count++;
        } else {
            row.style.display = "none";
        }
    });
    document.getElementById("tableInfo").innerText = "تمت تصفية " + count + " قيد";
}
</script>
}