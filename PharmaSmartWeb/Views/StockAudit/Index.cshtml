@model IEnumerable<PharmaSmartWeb.Models.Stockaudits>

@{
    ViewData["Title"] = "سجل الجرد والتسويات";
}

<style>
    body { font-family: "Segoe UI", Tahoma; background: #eef1f5; margin: 0; }
    /* Screen Layout */
    .screen-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; max-width: 1200px; margin: 0 auto; }
    .screen-header { background:#f8fafc; border-bottom:1px solid #e2e8f0; padding:10px 16px; font-size:13px; font-weight:700; color:#063955; display:flex; justify-content:space-between; align-items:center; }
    .enterprise-kpi { background:white; border:1px solid #d1d5db; border-radius:2px; padding:14px 18px; }
    .kpi-title { font-size:11px; color:#64748b; font-weight:600; margin-bottom:4px; }
    .kpi-value { font-size:22px; font-weight:700; color:#0f172a; }
    .enterprise-table { width:100%; border-collapse:collapse; font-size:12px; }
    .enterprise-table th { background:#f1f5f9; padding:8px 12px; border-bottom:1px solid #cbd5e1; border-top:1px solid #cbd5e1; color:#334155; font-weight:700; text-align:right; }
    .enterprise-table td { padding:8px 12px; border-bottom:1px solid #e2e8f0; color:#1e293b; }
    .enterprise-table tr:hover td { background:#f8fafc; }
    .status-done { background:#ecfdf5; color:#059669; border:1px solid #a7f3d0; padding:2px 8px; border-radius:2px; font-size:11px; font-weight:700; }
    .status-pending { background:#fffbeb; color:#d97706; border:1px solid #fde68a; padding:2px 8px; border-radius:2px; font-size:11px; font-weight:700; }
    .btn-primary { background:#063955; color:white; border:none; padding:7px 16px; border-radius:2px; font-size:12px; font-weight:700; cursor:pointer; display:inline-flex; align-items:center; gap:6px; text-decoration:none; }
    .btn-primary:hover { background:#0a4f72; color:white; }
    .btn-sm { padding:4px 10px; font-size:11px; border-radius:2px; font-weight:700; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:4px; background:#eff6ff; color:#1d4ed8; border:1px solid #bfdbfe; }
    .page-title { font-size:16px; font-weight:700; color:#063955; }
    .page-sub { font-size:12px; color:#64748b; }
    /* --- Print Page (Official Template) --- */
    .page { display:none; }
    @@media print {
        body { background: white !important; }
        .no-print { display: none !important; }
        .page { display: block; width: 210mm; min-height: 297mm; margin: auto; background: white; padding: 40px; box-sizing: border-box; }
        .top-bar { display: flex; justify-content: space-between; align-items: center; }
        .brand .name { font-size: 18px; font-weight: bold; color: #063955; }
        .report-tag { border: 1px solid #000; padding: 5px 15px; font-size: 12px; font-weight: bold; }
        .title { text-align: center; margin: 30px 0; }
        .title h2 { margin: 0; font-size: 22px; font-weight: 800; color: #063955; }
        .title span { font-size: 12px; color: #555; }
        .info-grid-p { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; border: 1px solid #ccc; padding: 15px; }
        .info-box { font-size: 13px; line-height: 1.8; }
        .divider { margin: 25px 0; border-top: 2px solid #000; }
        .print-table { width: 100%; border-collapse: collapse; }
        .print-table th, .print-table td { border: 1px solid #000; padding: 7px 10px; text-align: center; font-size: 12px; }
        .print-table th { background: #f0f0f0; font-weight: bold; }
        .print-summary { margin-top: 20px; width: 280px; margin-right: auto; }
        .print-summary div { display: flex; justify-content: space-between; border-bottom: 1px dashed #000; padding: 5px 0; font-size: 13px; }
        .print-notes { margin-top: 30px; font-size: 12px; color: #444; }
        .print-signatures { margin-top: 60px; display: flex; justify-content: space-between; }
        .print-signatures div { text-align: center; font-size: 12px; }
        .print-footer { margin-top: 40px; font-size: 11px; display: flex; justify-content: space-between; border-top: 1px solid #ccc; padding-top: 8px; }
    }
</style>

<!-- ===== SCREEN VIEW ===== -->
<div style="max-width:1200px; margin:0 auto; padding:16px;" class="no-print">
    <!-- Page Header -->
    <div class="screen-panel mb-4" style="padding:12px 16px; display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
        <div>
            <h1 class="page-title">سجل الجرد والتسويات</h1>
            <p class="page-sub">متابعة كافة عمليات جرد المخزن وتعديلات الكميات للفرع الحالي. يتيح لك هذا السجل تدقيق الفروقات.</p>
        </div>
        <div style="display:flex; gap:8px;">
            <button onclick="window.print()" class="btn-primary" style="background:#475569;">
                <span class="material-symbols-outlined" style="font-size:16px;">print</span>
                تصدير PDF
            </button>
            <a href="/StockAudit/Create" class="btn-primary">
                <span class="material-symbols-outlined" style="font-size:16px;">fact_check</span>
                إجراء جرد جديد
            </a>
        </div>
    </div>

    <!-- KPIs -->
    <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:12px;">
        <div class="enterprise-kpi">
            <div class="kpi-title">إجمالي عمليات الجرد</div>
            <div class="kpi-value">@Model.Count()</div>
        </div>
        <div class="enterprise-kpi">
            <div class="kpi-title">المكتملة</div>
            <div class="kpi-value" style="color:#059669;">@Model.Count(a => a.Status == "مكتمل")</div>
        </div>
        <div class="enterprise-kpi">
            <div class="kpi-title">قيد المعالجة</div>
            <div class="kpi-value" style="color:#d97706;">@Model.Count(a => a.Status != "مكتمل")</div>
        </div>
        <div class="enterprise-kpi">
            <div class="kpi-title">آخر تحديث</div>
            <div style="font-size:16px; font-weight:700; color:#063955; margin-top:4px;">@DateTime.Now.ToString("HH:mm")</div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="screen-panel">
        <div class="screen-header">
            <span>سجلات التدقيق والجرد</span>
        </div>
        <div style="overflow-x:auto;">
            <table class="enterprise-table">
                <thead>
                    <tr>
                        <th>رقم السند</th>
                        <th>تاريخ الجرد</th>
                        <th>المسؤول</th>
                        <th>الملاحظات</th>
                        <th>الحالة</th>
                        <th style="text-align:center;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" style="text-align:center; padding:40px; color:#94a3b8;">
                                <span class="material-symbols-outlined" style="font-size:32px; display:block; margin-bottom:8px;">inbox</span>
                                لم يتم إجراء أي عمليات جرد في هذا الفرع بعد.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong style="font-family:monospace; color:#063955;">#@item.AuditId</strong></td>
                            <td style="font-size:11px; color:#64748b;" dir="ltr">@item.AuditDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <div style="display:flex; align-items:center; gap:6px;">
                                    <div style="width:26px; height:26px; border-radius:50%; background:#e8f0fe; display:flex; align-items:center; justify-content:center;">
                                        <span class="material-symbols-outlined" style="font-size:14px; color:#063955;">person</span>
                                    </div>
                                    <span style="font-size:12px; font-weight:600;">@item.User?.Username</span>
                                </div>
                            </td>
                            <td style="font-style:italic; color:#64748b;">
                                @(string.IsNullOrEmpty(item.Notes) ? "بدون ملاحظات" : item.Notes)
                            </td>
                            <td>
                                @if (item.Status == "مكتمل")
                                { <span class="status-done">مكتمل</span> }
                                else
                                { <span class="status-pending">@item.Status</span> }
                            </td>
                            <td style="text-align:center;">
                                <a href="/StockAudit/Details/@item.AuditId" class="btn-sm">
                                    <span class="material-symbols-outlined" style="font-size:13px;">visibility</span>
                                    تفاصيل
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div style="padding:8px 12px; background:#f8fafc; border-top:1px solid #e2e8f0; font-size:11px; color:#64748b;">
            إجمالي: @Model.Count() عملية جرد مسجلة
        </div>
    </div>
</div>

<!-- ===== PRINT VIEW (Official Report Template) ===== -->
<div class="page">

    <!-- Top Bar -->
    <div class="top-bar">
        <div class="brand">
            <div class="name">💊 PharmaSmart</div>
        </div>
        <div class="report-tag">OFFICIAL REPORT</div>
    </div>

    <!-- Title -->
    <div class="title">
        <h2>سجل الجرد والتسويات</h2>
        <span>Stock Audit &amp; Adjustments Register</span>
    </div>

    <!-- Info Grid -->
    <div class="info-grid-p">
        <div class="info-box">
            <strong>اسم المؤسسة:</strong> PharmaSmart<br>
            <strong>إجمالي عمليات الجرد:</strong> @Model.Count()<br>
            <strong>المكتملة:</strong> @Model.Count(a => a.Status == "مكتمل")<br>
            <strong>قيد المعالجة:</strong> @Model.Count(a => a.Status != "مكتمل")
        </div>
        <div class="info-box">
            <strong>رقم التقرير:</strong> AUD-@DateTime.Now.ToString("yyyyMMdd")<br>
            <strong>تاريخ الإصدار:</strong> @DateTime.Now.ToString("yyyy/MM/dd HH:mm")<br>
            <strong>تم بواسطة:</strong> System Admin
        </div>
    </div>

    <div class="divider"></div>

    <!-- Print Table -->
    <table class="print-table">
        <thead>
            <tr>
                <th style="width:40px;">#</th>
                <th style="width:80px;">رقم السند</th>
                <th>تاريخ الجرد</th>
                <th>المسؤول</th>
                <th>الملاحظات</th>
                <th style="width:70px;">الحالة</th>
            </tr>
        </thead>
        <tbody>
            @{int n = 1;}
            @foreach (var item in Model)
            {
                <tr>
                    <td>@n</td>
                    <td style="font-family:monospace; font-weight:bold; color:#063955;">#@item.AuditId</td>
                    <td style="font-family:monospace; font-size:11px;" dir="ltr">@item.AuditDate.ToString("yyyy-MM-dd HH:mm")</td>
                    <td style="font-weight:600;">@item.User?.Username</td>
                    <td style="font-style:italic; color:#64748b; text-align:right;">@(string.IsNullOrEmpty(item.Notes) ? "بدون ملاحظات" : item.Notes)</td>
                    <td style="font-weight:bold; color:@(item.Status == "مكتمل" ? "#059669" : "#d97706");">@item.Status</td>
                </tr>
                n++;
            }
        </tbody>
    </table>

    <!-- Summary -->
    <div class="print-summary">
        <div><span>إجمالي عمليات الجرد:</span><span style="font-weight:bold;">@Model.Count()</span></div>
        <div><span style="color:#059669;">المكتملة:</span><span style="font-weight:bold; color:#059669;">@Model.Count(a => a.Status == "مكتمل")</span></div>
        <div><span style="color:#d97706;">قيد المعالجة:</span><span style="font-weight:bold; color:#d97706;">@Model.Count(a => a.Status != "مكتمل")</span></div>
    </div>

    <!-- Notes -->
    <div class="print-notes">
        ملاحظة: هذا التقرير تم إنشاؤه تلقائيًا من النظام ويعتبر وثيقة رسمية قابلة للمراجعة.
    </div>

    <!-- Signatures -->
    <div class="print-signatures">
        <div>___________<br>المدير العام</div>
        <div>___________<br>مسؤول المخزون</div>
        <div>___________<br>الختم الرسمي</div>
    </div>

    <!-- Footer -->
    <div class="print-footer">
        <div>PharmaSmart © @DateTime.Now.Year</div>
        <div>www.pharmasmart.com</div>
    </div>

</div>