@model List<PharmaSmartWeb.Controllers.StockAuditDetailViewModel>

@{
    ViewData["Title"] = "جرد وتسوية مخزنية";
}

<div class="max-w-7xl mx-auto p-6 space-y-6 animate-in fade-in duration-500">
    <form asp-action="Create" method="post" id="auditForm">
        @Html.AntiForgeryToken()

        <!-- Sticky Header Section -->
        <div class="bg-surface-container-lowest/90 sticky top-0 z-40 p-6 rounded-sm border border-surface-container flex flex-col md:flex-row justify-between items-start md:items-center gap-4 transition-all shadow-sm mb-6">
            <div>
                <h2 class="text-2xl font-bold text-primary mb-1">جرد وتسوية مخزنية</h2>
                <div class="flex gap-4 text-sm text-on-surface-variant">
                    <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[18px]" data-icon="location_on">location_on</span> فرع: @ViewBag.BranchName</span>
                    <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[18px]" data-icon="calendar_today">calendar_today</span> @DateTime.Now.ToString("dd MMMM yyyy")</span>
                    <span class="bg-secondary-container text-on-secondary-container px-2 py-0.5 rounded text-xs font-bold">مسودة جديدة</span>
                </div>
            </div>
            <div class="flex gap-3">
                <a href="/StockAudit/Index" class="px-6 py-2.5 rounded-sm border border-outline-variant text-on-surface-variant hover:bg-surface-container transition-colors font-medium">إلغاء العملية</a>
                <button type="submit" class="px-6 py-2.5 rounded-sm bg-[#063955] text-white flex items-center gap-2 font-bold shadow-sm border border-slate-200 shadow-primary/20 hover:scale-[1.02] transition-transform">
                    <span class="material-symbols-outlined" data-icon="task_alt">task_alt</span>
                    تأكيد وترحيل الجرد
                </button>
            </div>
        </div>

        <!-- Bento Layout Content -->
        <div class="grid grid-cols-12 gap-6">
            <!-- Main Audit Table -->
            <div class="col-span-12 bg-surface-container-lowest rounded-sm shadow-sm overflow-hidden border border-surface-container">
                <div class="px-6 py-4 bg-surface-container-low flex justify-between items-center border-b border-surface-container">
                    <h3 class="font-bold text-primary flex items-center gap-2">
                        <span class="material-symbols-outlined" data-icon="inventory_2">inventory_2</span>
                        قائمة الأصناف المطلوب جردها
                    </h3>
                    <div class="bg-primary-container text-white px-3 py-1 rounded-full border border-primary">
                        <span class="text-[10px] font-bold">@Model.Count أصناف</span>
                    </div>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-right border-collapse" id="auditTable">
                        <thead>
                            <tr class="bg-surface-container-lowest border-b border-surface-container text-on-surface-variant text-sm">
                                <th class="px-6 py-4 font-bold">الصنف / الباركود</th>
                                <th class="px-6 py-4 font-bold text-center">الكمية النظامية</th>
                                <th class="px-6 py-4 font-bold text-center">الكمية الفعلية</th>
                                <th class="px-6 py-4 font-bold text-center">الفارق</th>
                                <th class="px-6 py-4 font-bold text-left">قيمة التسوية</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-surface-container">
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                <tr class="hover:bg-surface-container-low/50 transition-colors">
                                    <td class="px-6 py-5">
                                        <input type="hidden" name="auditResults[@i].DrugId" value="@Model[i].DrugId" />
                                        <input type="hidden" name="auditResults[@i].UnitCost" value="@Model[i].UnitCost" id="cost_@i" />
                                        <input type="hidden" name="auditResults[@i].SystemQty" value="@Model[i].SystemQty" id="sysQty_@i" />

                                        <div class="flex flex-col">
                                            <span class="font-bold text-on-surface">@Model[i].DrugName</span>
                                            <span class="text-xs text-on-surface-variant font-mono">@Model[i].Barcode</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-5 text-center text-on-surface-variant font-medium">@Model[i].SystemQty وحدة</td>
                                    <td class="px-6 py-5 text-center">
                                        <input class="w-24 bg-surface-container-low border border-outline-variant/30 rounded-sm focus:ring-2 focus:ring-primary/20 text-center font-bold px-2 py-1" 
                                               type="number" name="auditResults[@i].PhysicalQty" value="@Model[i].SystemQty" oninput="updateVariance(@i)" id="physQty_@i" />
                                    </td>
                                    <td class="px-6 py-5 text-center">
                                        <span id="varBadge_@i" class="inline-flex items-center gap-1 bg-surface-container-high text-on-surface-variant px-3 py-1 rounded-full text-xs font-bold border border-outline-variant/20">
                                            <span class="material-symbols-outlined text-[14px]" id="varIcon_@i" data-icon="horizontal_rule">horizontal_rule</span>
                                            <span id="varText_@i">متطابق</span>
                                        </span>
                                    </td>
                                    <td class="px-6 py-5 font-bold text-on-surface-variant text-left" id="valText_@i">0.00 SAR</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Footer Section: Notes & Summary -->
            <div class="col-span-12 lg:col-span-8">
                <div class="bg-surface-container-lowest rounded-sm p-6 shadow-sm h-full border border-surface-container">
                    <label class="block text-primary font-bold mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined" data-icon="edit_note">edit_note</span>
                        ملاحظات الجرد والتسوية
                    </label>
                    <textarea name="notes" class="w-full bg-surface-container-low border border-outline-variant/20 rounded-sm focus:ring-2 focus:ring-primary/20 p-4 text-on-surface leading-relaxed" placeholder="اكتب أي ملاحظات تتعلق بأسباب العجز أو الفائض المكتشف..." rows="6"></textarea>
                </div>
            </div>

            <div class="col-span-12 lg:col-span-4">
                <div class="bg-[#063955] rounded-sm p-5 shadow-sm border border-slate-200 shadow-primary/30 text-white flex flex-col justify-between h-full relative overflow-hidden">
                    <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-white/5 rounded-full blur-3xl"></div>
                    
                    <div class="relative z-10">
                        <p class="text-primary-fixed text-lg font-medium mb-2 opacity-80">صافي قيمة التسوية المالية</p>
                        <h4 id="netAdjustmentDisplay" class="text-5xl font-black tracking-tight mb-2 text-white" dir="ltr">0.00</h4>
                        <p class="text-primary-fixed/60 text-sm font-bold tracking-widest uppercase">Saudi Riyals (SAR)</p>
                    </div>
                    
                    <div class="relative z-10 pt-8 border-t border-white/10 mt-8 space-y-3">
                        <div class="flex justify-between text-sm items-center">
                            <span class="opacity-80">إجمالي قيمة العجز:</span>
                            <span class="font-bold text-rose-300" id="totalDeficitDisplay" dir="ltr">0.00- SAR</span>
                        </div>
                        <div class="flex justify-between text-sm items-center">
                            <span class="opacity-80">إجمالي قيمة الفائض:</span>
                            <span class="font-bold text-emerald-300" id="totalSurplusDisplay" dir="ltr">0.00+ SAR</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
<style>
    .bg-\[\#063955\] { background: linear-gradient(135deg, #00314e 0%, #004870 100%); }
    .text-primary-fixed { color: #7dd3fc; }
</style>
<script>
    function updateVariance(idx) {
        const sysQty = parseInt(document.getElementById(`sysQty_${idx}`).value) || 0;
        const physQty = parseInt(document.getElementById(`physQty_${idx}`).value) || 0;
        const cost = parseFloat(document.getElementById(`cost_${idx}`).value) || 0;

        const diff = physQty - sysQty;
        const val = diff * cost;

        const badge = document.getElementById(`varBadge_${idx}`);
        const text = document.getElementById(`varText_${idx}`);
        const icon = document.getElementById(`varIcon_${idx}`);
        const valDisplay = document.getElementById(`valText_${idx}`);

        if (diff === 0) {
            badge.className = "inline-flex items-center gap-1 bg-surface-container-high text-on-surface-variant px-3 py-1 rounded-full text-xs font-bold border border-outline-variant/20";
            icon.innerText = "horizontal_rule";
            text.innerText = "متطابق";
            valDisplay.className = "px-6 py-5 font-bold text-on-surface-variant text-left";
            valDisplay.innerText = "0.00 SAR";
        } else if (diff < 0) {
            badge.className = "inline-flex items-center gap-1 bg-rose-100 text-rose-700 px-3 py-1 rounded-full text-xs font-bold border border-rose-200";
            icon.innerText = "trending_down";
            text.innerText = Math.abs(diff) + " عجز";
            valDisplay.className = "px-6 py-5 font-bold text-rose-600 text-left";
            valDisplay.innerText = val.toLocaleString('en-US', { minimumFractionDigits: 2 }) + " SAR";
        } else {
            badge.className = "inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full text-xs font-bold border border-emerald-200";
            icon.innerText = "trending_up";
            text.innerText = diff + " فائض";
            valDisplay.className = "px-6 py-5 font-bold text-emerald-600 text-left";
            valDisplay.innerText = "+" + val.toLocaleString('en-US', { minimumFractionDigits: 2 }) + " SAR";
        }

        calculateNetTotal();
    }

    function calculateNetTotal() {
        let total = 0;
        let deficit = 0;
        let surplus = 0;
        
        const rows = document.querySelectorAll('#auditTable tbody tr');
        rows.forEach((row, idx) => {
            const sysQty = parseInt(document.getElementById(`sysQty_${idx}`).value) || 0;
            const physQty = parseInt(document.getElementById(`physQty_${idx}`).value) || 0;
            const cost = parseFloat(document.getElementById(`cost_${idx}`).value) || 0;
            
            const diff = physQty - sysQty;
            const val = diff * cost;
            
            total += val;
            if(val < 0) deficit += val;
            if(val > 0) surplus += val;
        });

        const display = document.getElementById('netAdjustmentDisplay');
        display.innerText = total.toLocaleString('en-US', { minimumFractionDigits: 2 });
        document.getElementById('totalDeficitDisplay').innerText = deficit.toLocaleString('en-US', { minimumFractionDigits: 2 }) + " SAR";
        document.getElementById('totalSurplusDisplay').innerText = "+" + surplus.toLocaleString('en-US', { minimumFractionDigits: 2 }) + " SAR";

        if (total < 0) display.className = "text-5xl font-black tracking-tight mb-2 text-rose-300";
        else if (total > 0) display.className = "text-5xl font-black tracking-tight mb-2 text-emerald-300";
        else display.className = "text-5xl font-black tracking-tight mb-2 text-white";
    }
</script>