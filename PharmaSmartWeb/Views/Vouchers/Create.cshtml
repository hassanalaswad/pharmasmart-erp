@{
    string type = ViewBag.VoucherType;
    ViewData["Title"] = (type == "Receipt" ? "سند قبض مالي" : "سند صرف مالي");
    var isReceipt = type == "Receipt";
}

<script src="~/lib/sweetalert2.js"></script>

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .enterprise-header { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; }
    .form-label { font-size: 11px; font-weight: 700; color: #64748b; margin-bottom: 4px; display: block; text-transform: uppercase; letter-spacing: 0.05em; }
    .form-control { width: 100%; border: 1px solid #cbd5e1; border-radius: 2px; padding: 12px 14px; font-size: 14px; background: #f8fafc; color: #0f172a; font-weight:700;}
    .form-control:focus { outline: none; border-color: #063955; background: white; box-shadow:0 0 0 2px rgba(6,57,85,0.1); }
    .input-icon-container { position: relative; display: flex; align-items: center; }
    .input-icon { position: absolute; left: 14px; color: #94a3b8; font-size: 18px; pointer-events: none; }
    .form-control-with-icon { padding-left: 40px; }
    
    .btn-submit { background: linear-gradient(135deg, #00314e 0%, #004870 100%); color: white; border: none; padding: 14px 24px; border-radius: 2px; font-size: 15px; font-weight: 900; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; flex: 2; transition: transform 0.1s; }
    .btn-submit:active { transform: scale(0.98); }
    .btn-cancel { background: white; color: #475569; border: 1px solid #cbd5e1; padding: 14px 24px; border-radius: 2px; font-size: 15px; font-weight: 700; cursor: pointer; text-align: center; flex: 1; transition: background 0.1s;}
    .btn-cancel:hover { background: #f8fafc; }
</style>

@if (ViewBag.Error != null || TempData["Error"] != null)
{
    <div class="enterprise-panel" style="max-width:800px; margin: 0 auto 24px auto; background:#fff1f2; border-right:4px solid #e11d48; padding:16px; display:flex; align-items:center; gap:16px;">
        <span class="material-symbols-outlined" style="color:#e11d48; font-size:32px;">error</span>
        <div>
            <h3 style="font-weight:700; color:#9f1239; font-size:14px;">تعذر حفظ السند</h3>
            <p style="color:#e11d48; font-size:12px; font-weight:600; margin-top:4px;">@(ViewBag.Error ?? TempData["Error"])</p>
        </div>
    </div>
}

<div style="max-width:800px; margin:0 auto; padding-bottom:60px;">
    <div class="enterprise-panel" style="overflow:hidden; box-shadow:0 10px 25px rgba(0,0,0,0.05);">
        
        <!-- Header -->
        <div class="enterprise-header">
            <div style="display:flex; align-items:center; gap:16px;">
                <div style="width:48px; height:48px; border-radius:4px; display:flex; align-items:center; justify-content:center; @(isReceipt ? "background:#d1fae5; color:#059669;" : "background:#ffe4e6; color:#e11d48;")">
                    <span class="material-symbols-outlined" style="font-size:24px;">@(isReceipt ? "arrow_downward" : "arrow_upward")</span>
                </div>
                <div>
                    <h2 style="font-size:20px; font-weight:900; color:#063955; margin:0;">@ViewData["Title"]</h2>
                    <p style="font-size:12px; color:#64748b; font-weight:600; margin-top:2px;">تسجيل عملية مالية جديدة في النظام</p>
                </div>
            </div>
            <div style="background:white; padding:6px 12px; border-radius:2px; font-family:monospace; font-weight:900; color:#063955; border:1px solid #e2e8f0; font-size:14px;">
                @(isReceipt ? "RV" : "PV")-@DateTime.Now.ToString("yyyyMM")-AUTO
            </div>
        </div>

        <!-- Form -->
        <form id="voucherForm" asp-action="Create" method="post" style="padding:24px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="voucherType" value="@type" />

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:24px;">
                
                <!-- Date -->
                <div>
                    <label class="form-label">تاريخ السند <span style="color:#e11d48;">*</span></label>
                    <div class="input-icon-container">
                        <span class="material-symbols-outlined input-icon">calendar_today</span>
                        <input name="date" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" required class="form-control form-control-with-icon" />
                    </div>
                </div>

                <!-- Reference -->
                <div>
                    <label class="form-label">رقم المرجع (الشيك/الحوالة)</label>
                    <div class="input-icon-container">
                        <span class="material-symbols-outlined input-icon">tag</span>
                        <input name="referenceNo" id="referenceNo" placeholder="أدخل الرقم التوثيقي إن وجد..." type="text" class="form-control form-control-with-icon" />
                    </div>
                </div>

                <!-- Payee -->
                <div style="grid-column: span 2;">
                    <label class="form-label">@(isReceipt ? "استلمنا من السيد/الجهة" : "يُصرف للسيد/الجهة") <span style="color:#e11d48;">*</span></label>
                    <div class="input-icon-container">
                        <span class="material-symbols-outlined input-icon">person</span>
                        <input name="payeePayerName" required placeholder="أدخل الاسم الثلاثي أو اسم الشركة..." type="text" class="form-control form-control-with-icon" />
                    </div>
                </div>

                <!-- Cash/Bank Account -->
                <div>
                    <label class="form-label">حساب النقدية/البنك <span style="color:#e11d48;">*</span></label>
                    <select name="mainAccountId" required class="form-control">
                        <option value="">-- اختر الصندوق أو البنك --</option>
                        @foreach (var acc in ViewBag.Funds)
                        {
                            <option value="@acc.AccountId">@acc.AccountCode - @acc.AccountName</option>
                        }
                    </select>
                </div>

                <!-- Counter Account -->
                <div>
                    <label class="form-label">الحساب المقابل (دليل الحسابات) <span style="color:#e11d48;">*</span></label>
                    <select name="secondAccountId" required class="form-control">
                        <option value="">-- اختر الحساب من الدليل --</option>
                        @foreach (var acc in ViewBag.AllAccounts)
                        {
                            <option value="@acc.AccountId">@acc.AccountCode - @acc.AccountName</option>
                        }
                    </select>
                </div>
            </div>

            <!-- Amount Section -->
            <div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:2px; padding:24px; display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
                <div style="flex:1;">
                    <label style="font-size:11px; font-weight:900; color:#063955; text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:8px;">مبلغ السند <span style="color:#e11d48;">*</span></label>
                    <div style="display:flex; align-items:baseline; gap:8px; background:white; border:1px solid #cbd5e1; padding:8px 16px; border-radius:2px;">
                        <input name="amount" id="amountInput" required placeholder="0.00" type="number" step="0.01" min="0.01" dir="ltr" style="border:none; outline:none; font-size:28px; font-weight:900; color:#063955; width:100%; font-family:monospace;" />
                        <span style="font-size:18px; font-weight:700; color:#94a3b8;">SAR</span>
                    </div>
                </div>
                <div style="width:64px; height:64px; background:white; border:1px solid #e2e8f0; border-radius:4px; display:flex; align-items:center; justify-content:center; margin-right:24px;">
                    <span class="material-symbols-outlined" style="color:#063955; font-size:32px;">payments</span>
                </div>
            </div>

            <!-- Notes -->
            <div style="margin-bottom:24px;">
                <label class="form-label">البيان / ملاحظات إضافية <span style="color:#e11d48;">*</span></label>
                <textarea name="notes" required placeholder="اكتب تفاصيل العملية هنا للرجوع إليها لاحقاً..." rows="3" class="form-control" style="resize:vertical;"></textarea>
            </div>

            <!-- Actions -->
            <div style="display:flex; gap:16px; border-top:1px solid #e2e8f0; padding-top:24px;">
                <button type="button" onclick="submitSecureForm()" class="btn-submit">
                    <span class="material-symbols-outlined">task_alt</span> حفظ واعتماد السند
                </button>
                <button type="button" onclick="history.back()" class="btn-cancel">إلغاء</button>
            </div>
        </form>
    </div>
</div>

<script>
    function sanitizeFormInputsForServer() {
        const amountInput = document.getElementById('amountInput');
        if (amountInput.value && /[٠-٩۰-۹]/.test(amountInput.value)) {
            let val = amountInput.value.replace(/[٠-٩]/g, d => "٠١٢٣٤٥٦٧٨٩".indexOf(d)).replace(/[۰-۹]/g, d => "۰۱۲۳۴۵۶۷۸۹".indexOf(d));
            amountInput.value = val;
        }
    }

    function submitSecureForm() {
        const form = document.getElementById('voucherForm');

        if (!form.checkValidity()) {
            const invalidInputs = form.querySelectorAll(':invalid');
            invalidInputs.forEach(input => {
                input.style.borderColor = '#e11d48';
                input.style.boxShadow = '0 0 0 2px rgba(225,29,72,0.1)';
                
                input.addEventListener('input', function () {
                    if (this.checkValidity()) {
                        this.style.borderColor = '#cbd5e1';
                        this.style.boxShadow = 'none';
                    }
                }, { once: true });
            });

            Swal.fire({
                icon: 'warning',
                title: 'بيانات إلزامية ناقصة',
                text: 'يرجى تعبئة جميع الحقول المحددة باللون الأحمر.',
                confirmButtonText: 'حسناً',
                confirmButtonColor: '#ef4444'
            });

            form.reportValidity();
            return;
        }

        sanitizeFormInputsForServer();
        form.submit();
    }
</script>