@model IEnumerable<PharmaSmartWeb.Models.Journalentries>

@{
    ViewData["Title"] = "سجل السندات المالية";
    string currency = Settings.Currency ?? "ر.ي";
    var receiptsTotal = Model.Where(v => v.ReferenceType == "Receipt").Sum(v => v.Journaldetails?.Sum(d => d.Debit) ?? 0);
    var paymentsTotal = Model.Where(v => v.ReferenceType == "Payment").Sum(v => v.Journaldetails?.Sum(d => d.Credit) ?? 0);
    var totalVouchersCount = Model.Count();
}

@if (TempData["Success"] != null)
{
    <div class="bg-emerald-50 border border-emerald-200 border-r-4 border-r-emerald-500 rounded-xl p-3 mb-4 flex items-center gap-2 text-sm text-emerald-700">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}

<!-- ===== رأس الصفحة ===== -->
<div class="flex flex-wrap justify-between items-start mb-5">
    <div class="flex items-center gap-3 mb-2 sm:mb-0">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-teal-600 to-emerald-800 flex items-center justify-center shadow-sm">
            <i class="fas fa-receipt text-white"></i>
        </div>
        <div>
            <h1 class="text-xl font-black text-gray-800">سندات القبض والصرف</h1>
            <p class="text-xs text-gray-500">الأرشيف الكامل لكافة السندات المالية الصادرة والواردة</p>
        </div>
    </div>
    <div class="flex gap-2 flex-wrap">
        <a href="/Vouchers/Create?type=Payment" class="px-4 py-2 bg-rose-50 hover:bg-rose-100 text-rose-700 border border-rose-200 rounded-xl text-xs font-bold flex items-center gap-2 transition-colors">
            <i class="fas fa-minus-circle"></i> سند صرف جديد
        </a>
        <a href="/Vouchers/Create?type=Receipt" class="quick-action-btn px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5 active:scale-95">
            <i class="fas fa-plus-circle"></i> سند قبض جديد
        </a>
    </div>
</div>

<!-- ===== بطاقات KPI ===== -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-5">
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-emerald-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-emerald-700 font-semibold">إجمالي المقبوضات</span>
            <i class="fas fa-arrow-down text-emerald-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-emerald-700">@receiptsTotal.ToString("N2")</div>
        <span class="text-xs text-gray-400 font-medium">مخبوضات واردة (@currency)</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-rose-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-rose-700 font-semibold">إجمالي المصروفات</span>
            <i class="fas fa-arrow-up text-rose-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-rose-700">@paymentsTotal.ToString("N2")</div>
        <span class="text-xs text-gray-400 font-medium">مدفوعات صادرة (@currency)</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-teal-600">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">عدد السندات الكلي</span>
            <i class="fas fa-file-invoice text-teal-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@totalVouchersCount</div>
        <span class="text-xs text-gray-400 font-medium">إجمالي السندات</span>
    </div>
</div>

<!-- ===== جدول السندات ===== -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100">
    <div class="flex flex-wrap justify-between items-center px-5 py-4 border-b border-gray-100 gap-3">
        <h3 class="font-bold text-gray-800 text-sm">
            <i class="fas fa-list text-teal-500 ml-1.5"></i> قائمة السندات الأخيرة
        </h3>
        <div class="relative">
            <i class="fas fa-search absolute right-3 top-2.5 text-gray-400 text-xs"></i>
            <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="البحث..."
                class="pr-8 pl-4 py-2 border border-gray-200 rounded-xl text-xs w-56 focus:outline-none focus:ring-2 focus:ring-teal-400" />
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full data-table text-sm" id="vouchersTable">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">رقم السند</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">التاريخ</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">النوع</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">المستلم / الدافع</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">المبلغ الإجمالي</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-12 text-gray-400 font-bold">
                            <i class="fas fa-folder-open text-5xl mb-3 block text-gray-200"></i>
                            لا توجد سندات مسجلة في النظام حالياً.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    decimal amount = item.ReferenceType == "Receipt" ? (item.Journaldetails?.Sum(d => d.Debit) ?? 0) : (item.Journaldetails?.Sum(d => d.Credit) ?? 0);
                    string typeLabel = item.ReferenceType == "Receipt" ? "سند قبض" : "سند صرف";
                    string badgeClass = item.ReferenceType == "Receipt" ? "bg-emerald-50 text-emerald-700 border-emerald-100" : "bg-rose-50 text-rose-700 border-rose-100";
                    string typeIcon = item.ReferenceType == "Receipt" ? "fa-arrow-down" : "fa-arrow-up";
                    bool isCash = string.IsNullOrEmpty(item.ReferenceNo);
                    string paymentIcon = isCash ? "fa-money-bill-wave" : "fa-university";

                    <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors search-row">
                        <td class="px-5 py-3 font-mono font-bold text-gray-800 search-id">#@item.JournalId.ToString("D5")</td>
                        <td class="px-5 py-3 text-center font-bold text-gray-700 search-date">@item.JournalDate.ToString("yyyy-MM-dd")</td>
                        <td class="px-5 py-3 text-center search-type">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold border @badgeClass">
                                <i class="fas @typeIcon"></i> @typeLabel
                            </span>
                        </td>
                        <td class="px-5 py-3 search-name">
                            <div class="flex items-center gap-2">
                                <div class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center text-slate-500 shrink-0">
                                    <i class="fas @paymentIcon"></i>
                                </div>
                                <div>
                                    <p class="font-bold text-xs text-gray-800 max-w-[200px] truncate" title="@item.PayeePayerName">@(string.IsNullOrEmpty(item.PayeePayerName) ? "---" : item.PayeePayerName)</p>
                                    <p class="text-[10px] text-gray-500 max-w-[200px] truncate" title="@item.Description">@item.Description</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-5 py-3 text-left font-bold text-gray-800 font-mono text-sm">@amount.ToString("N2")</td>
                        <td class="px-5 py-3 text-center">
                            <div class="flex items-center justify-center gap-1.5">
                                <a href="/Vouchers/Details/@item.JournalId" class="p-1.5 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="عرض التفاصيل">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="/Vouchers/Details/@item.JournalId?print=true" class="p-1.5 text-gray-600 hover:bg-gray-100 rounded-lg transition-colors" title="طباعة السند">
                                    <i class="fas fa-print"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 rounded-b-2xl">
        <span class="text-xs text-gray-500">إجمالي: <strong class="text-gray-700">@Model.Count()</strong> سند مسجل</span>
    </div>
</div>

@section Scripts {
<script>
function filterTable() {
    const q = document.getElementById("searchInput").value.toLowerCase();
    document.querySelectorAll(".search-row").forEach(row => {
        const text = row.innerText.toLowerCase();
        row.style.display = text.includes(q) ? "" : "none";
    });
}
</script>
}