@model IEnumerable<PharmaSmartWeb.Models.Journalentries>

@{
    ViewData["Title"] = "سجل السندات المالية";
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .page-title { font-size: 16px; font-weight: 700; color: #063955; }
    .page-sub { font-size: 12px; color: #64748b; }
    .btn-primary { background: #063955; color: white; border: none; padding: 7px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 6px; transition: 0.2s; text-decoration: none; }
    .btn-primary:hover { background: #0a4f72; color: white; }
    .btn-danger-outline { background: white; color: #e11d48; border: 1px solid #fecdd3; padding: 7px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 6px; transition: 0.2s; text-decoration: none; }
    .btn-danger-outline:hover { background: #fff1f2; text-decoration: none; }
    .btn-secondary { background: white; border: 1px solid #d1d5db; color: #475569; padding: 6px 12px; border-radius: 2px; font-size: 11px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 4px; transition: 0.2s; text-decoration: none; }
    .btn-secondary:hover { background: #f8fafc; color: #1e293b; }
    .enterprise-table { width: 100%; border-collapse: collapse; font-size: 12px; text-align: right; }
    .enterprise-table th { background: #f1f5f9; padding: 10px 16px; border-bottom: 1px solid #cbd5e1; color: #334155; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; font-size: 11px; }
    .enterprise-table td { padding: 10px 16px; border-bottom: 1px solid #e2e8f0; color: #1e293b; }
    .kpi-box { padding: 16px; background: white; border-radius: 2px; border: 1px solid #d1d5db; border-right-width: 4px; display: flex; flex-direction: column; justify-content: space-between; }
    .kpi-title { font-size: 11px; text-transform: uppercase; color: #64748b; font-weight: 700; letter-spacing: 0.05em; margin-bottom: 8px; flex-grow: 1; }
    .kpi-value { font-size: 24px; font-weight: 800; color: #063955; }
    .badge-receipt { display: inline-flex; align-items: center; justify-content: center; gap: 4px; padding: 2px 8px; border-radius: 2px; font-size: 10px; font-weight: 700; background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
    .badge-payment { display: inline-flex; align-items: center; justify-content: center; gap: 4px; padding: 2px 8px; border-radius: 2px; font-size: 10px; font-weight: 700; background: #fff1f2; color: #e11d48; border: 1px solid #fecdd3; }
</style>

<div class="flex-1 overflow-y-auto p-6 space-y-4">

    <!-- Header Panel -->
    <div class="enterprise-panel flex flex-col md:flex-row justify-between items-start md:items-center p-4 gap-4">
        <div>
            <nav class="flex items-center gap-2 text-slate-500 text-[11px] mb-1 font-semibold">
                <a href="/Home/Index" class="hover:text-[#063955]">الرئيسية</a>
                <span class="material-symbols-outlined text-[14px]">chevron_left</span>
                <span class="text-[#063955]">سجل السندات المالية</span>
            </nav>
            <h1 class="page-title">سندات القبض والصرف</h1>
            <p class="page-sub">الأرشيف الكامل لكافة السندات المالية الصادرة والواردة.</p>
        </div>
        <div class="flex gap-2">
            <a href="/Vouchers/Create?type=Payment" class="btn-danger-outline">
                <span class="material-symbols-outlined" style="font-size: 16px;">remove_circle</span>
                سند صرف جديد
            </a>
            <a href="/Vouchers/Create?type=Receipt" class="btn-primary">
                <span class="material-symbols-outlined" style="font-size: 16px;">add_circle</span>
                سند قبض جديد
            </a>
        </div>
    </div>

    <!-- KPIs -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="kpi-box" style="border-right-color: #059669;">
            <div class="flex justify-between items-start mb-2">
                <span class="material-symbols-outlined" style="color: #059669;">account_balance_wallet</span>
            </div>
            <p class="kpi-title">إجمالي المقبوضات</p>
            <h3 class="kpi-value text-[#059669]">
                @Model.Where(v => v.ReferenceType == "Receipt").Sum(v => v.Journaldetails?.Sum(d => d.Debit) ?? 0).ToString("N2") 
                <span style="font-size: 12px; font-weight: normal; color: #64748b;">@Settings.Currency</span>
            </h3>
        </div>

        <div class="kpi-box" style="border-right-color: #e11d48;">
            <div class="flex justify-between items-start mb-2">
                <span class="material-symbols-outlined" style="color: #e11d48;">payments</span>
            </div>
            <p class="kpi-title">إجمالي المصروفات</p>
            <h3 class="kpi-value text-[#e11d48]">
                @Model.Where(v => v.ReferenceType == "Payment").Sum(v => v.Journaldetails?.Sum(d => d.Credit) ?? 0).ToString("N2") 
                <span style="font-size: 12px; font-weight: normal; color: #64748b;">@Settings.Currency</span>
            </h3>
        </div>

        <div class="kpi-box" style="border-right-color: #063955;">
            <div class="flex justify-between items-start mb-2">
                <span class="material-symbols-outlined" style="color: #063955;">receipt_long</span>
            </div>
            <p class="kpi-title">عدد السندات الكلي</p>
            <h3 class="kpi-value">
                @Model.Count() <span style="font-size: 12px; font-weight: normal; color: #64748b;">سند</span>
            </h3>
        </div>
    </div>

    <!-- Data Table -->
    <div class="enterprise-panel">
        <div class="p-4 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
            <h4 class="text-[14px] font-bold text-[#063955]">قائمة السندات الأخيرة</h4>
        </div>
        
        <div class="overflow-x-auto">
            <table class="enterprise-table">
                <thead>
                    <tr>
                        <th style="width: 120px;">رقم السند</th>
                        <th style="text-align: center; width: 120px;">التاريخ</th>
                        <th style="text-align: center; width: 120px;">النوع</th>
                        <th>المستلم / الدافع</th>
                        <th style="text-align: left; width: 150px;">المبلغ الإجمالي</th>
                        <th style="text-align: center; width: 100px;">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="p-10 text-center text-slate-500 font-bold">لا توجد سندات مسجلة في النظام حالياً.</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        decimal amount = item.ReferenceType == "Receipt" ? (item.Journaldetails?.Sum(d => d.Debit) ?? 0) : (item.Journaldetails?.Sum(d => d.Credit) ?? 0);
                        string typeLabel = item.ReferenceType == "Receipt" ? "سند قبض" : "سند صرف";
                        string badgeClass = item.ReferenceType == "Receipt" ? "badge-receipt" : "badge-payment";
                        string typeIcon = item.ReferenceType == "Receipt" ? "arrow_downward" : "arrow_upward";
                        bool isCash = string.IsNullOrEmpty(item.ReferenceNo);
                        string paymentIcon = isCash ? "payments" : "account_balance";

                        <tr class="hover:bg-slate-50">
                            <td class="font-bold text-[#063955]">#@item.JournalId.ToString("D5")</td>
                            <td class="text-center font-bold text-slate-700">@item.JournalDate.ToString("yyyy-MM-dd")</td>
                            <td class="text-center">
                                <span class="@badgeClass">
                                    <span class="material-symbols-outlined" style="font-size: 14px;">@typeIcon</span>
                                    @typeLabel
                                </span>
                            </td>
                            <td>
                                <div class="flex items-center gap-2">
                                    <div class="w-8 h-8 rounded-sm bg-slate-100 flex items-center justify-center text-slate-600 shrink-0">
                                        <span class="material-symbols-outlined" style="font-size: 16px;">@paymentIcon</span>
                                    </div>
                                    <div>
                                        <p class="font-bold text-[13px] text-[#063955] truncate max-w-[200px]" title="@item.PayeePayerName">@(string.IsNullOrEmpty(item.PayeePayerName) ? "---" : item.PayeePayerName)</p>
                                        <p class="text-[10px] text-slate-500 truncate max-w-[200px]" title="@item.Description">@item.Description</p>
                                    </div>
                                </div>
                            </td>
                            <td class="text-left font-extrabold text-[#063955] text-[14px]">@amount.ToString("N2")</td>
                            <td class="text-center">
                                <div class="flex items-center justify-center gap-1">
                                    <a href="/Vouchers/Details/@item.JournalId" class="btn-secondary" style="padding: 4px; background: transparent;" title="عرض التفاصيل">
                                        <span class="material-symbols-outlined" style="font-size: 16px;">visibility</span>
                                    </a>
                                    <a href="/Vouchers/Details/@item.JournalId?print=true" class="btn-secondary" style="padding: 4px; background: transparent;" title="طباعة السند">
                                        <span class="material-symbols-outlined" style="font-size: 16px;">print</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>