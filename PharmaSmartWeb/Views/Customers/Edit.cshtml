@model PharmaSmartWeb.Models.Customers

@{
    Layout = "_ModalLayout";
    ViewData["Title"] = $"تعديل ملف العميل: {Model.FullName}";
    ViewBag.ModalPanelSize = "lg";
    ViewBag.ModalHeaderIcon = "person";
}

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="CustomerId" />
    <input type="hidden" asp-for="AccountId" />
    <input type="hidden" asp-for="CreatedAt" />

    @if (ViewBag.Error != null)
    {
        <div class="enterprise-alert-error">
            <span class="material-symbols-outlined" style="font-size:16px;">warning</span>
            @ViewBag.Error
        </div>
    }

    <!-- الحساب المالي المرتبط -->
    <div class="enterprise-info-box" style="align-items:center;">
        <span class="material-symbols-outlined" style="font-size:24px;color:#475569;">account_balance_wallet</span>
        <div style="flex:1;min-width:0;">
            <div style="font-size:11px;color:#64748b;font-weight:700;margin-bottom:2px;">الحساب المالي المرتبط</div>
            <div style="font-size:13px;font-weight:700;color:#0f172a;font-family:monospace;">
                @(Model.Account?.AccountCode ?? "---") — @(Model.Account?.AccountName ?? "غير مربوط")
            </div>
        </div>
        <span style="font-size:11px;background:#e2e8f0;padding:4px 8px;border-radius:2px;color:#475569;font-weight:700;">للقراءة فقط</span>
    </div>

    <div class="enterprise-section-title">بيانات العميل الأساسية والتواصل</div>

    <div class="enterprise-row">
        <div>
            <label class="enterprise-label">الاسم الكامل / اسم الشركة <span style="color:#e11d48;">*</span></label>
            <input asp-for="FullName" required class="enterprise-input" placeholder="مثال: محمد علي / شركة النور" />
        </div>
        <div>
            <label class="enterprise-label">رقم الهاتف</label>
            <input asp-for="Phone" dir="ltr" class="enterprise-input" placeholder="05XXXXXXXX" type="tel" />
        </div>
        <div>
            <label class="enterprise-label">الحد الائتماني (أقصى دين)</label>
            <input asp-for="CreditLimit" type="number" step="0.01" class="enterprise-input" placeholder="0.00" />
        </div>
        <div>
            <label class="enterprise-label">العنوان والتفاصيل</label>
            <input asp-for="Address" class="enterprise-input" placeholder="المدينة، الحي، اسم الشارع" />
        </div>
    </div>

    <div class="enterprise-section-title" style="margin-top:24px;">حالة النظام</div>

    <div style="border:1px solid #e2e8f0;border-radius:2px;padding:12px 16px;display:flex;justify-content:space-between;align-items:center;background:#f8fafc;flex-wrap:wrap;gap:12px;">
        <div style="display:flex;align-items:center;gap:12px;">
            <span class="material-symbols-outlined" style="font-size:20px;color:#063955;">verified_user</span>
            <div>
                <div style="font-size:13px;font-weight:700;color:#0f172a;">حالة العميل (النشاط)</div>
                <div style="font-size:11px;color:#64748b;margin-top:2px;">إيقاف العميل سيمنع إجراء عمليات بيع وتوليد مديونيات آجلة عليه.</div>
            </div>
        </div>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;background:white;padding:6px 12px;border:1px solid #cbd5e1;border-radius:2px;">
            <input type="checkbox" name="IsActive" value="true" @(Model.IsActive == true ? "checked" : "") style="width:15px;height:15px;cursor:pointer;accent-color:#063955;" />
            <input type="hidden" name="IsActive" value="false" />
            <span style="font-size:12px;font-weight:700;color:#063955;">@(Model.IsActive == true ? "حساب نشط" : "حساب موقوف")</span>
        </label>
    </div>

    <div class="enterprise-actions">
        <button type="button" onclick="modalNavigateBack()" class="enterprise-btn-cancel">إلغاء التعديل</button>
        <button type="submit" class="enterprise-btn-warning">
            <span class="material-symbols-outlined" style="font-size:16px;">save</span>
            حفظ التحديثات
        </button>
    </div>
</form>