@model PharmaSmartWeb.Models.Customers

@{
    Layout = "_ModalLayout";
    ViewData["Title"] = "إضافة عميل جديد";
    ViewBag.ModalPanelSize = "lg";
    ViewBag.ModalHeaderIcon = "person_add";
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    @if (ViewBag.Error != null)
    {
        <div class="enterprise-alert-error">
            <span class="material-symbols-outlined" style="font-size:16px;">warning</span>
            @ViewBag.Error
        </div>
    }

    <div class="enterprise-section-title">
        <span class="material-symbols-outlined" style="font-size:18px;">badge</span>
        البيانات الشخصية والاتصال
    </div>

    <div class="enterprise-row">
        <div>
            <label class="enterprise-label">الاسم الكامل / اسم الشركة <span style="color:#e11d48;">*</span></label>
            <input asp-for="FullName" required class="enterprise-input" placeholder="مثال: محمد علي / شركة النور" />
        </div>
        <div>
            <label class="enterprise-label">رقم الجوال</label>
            <input asp-for="Phone" dir="ltr" class="enterprise-input" placeholder="05XXXXXXXX" type="tel" />
        </div>
    </div>

    <div class="enterprise-section-title" style="margin-top:24px;">
        <span class="material-symbols-outlined" style="font-size:18px;">payments</span>
        المالية والائتمان
    </div>

    <div class="enterprise-row">
        <div>
            <label class="enterprise-label">الحد الائتماني (الديون المسموحة)</label>
            <input asp-for="CreditLimit" type="number" step="0.01" class="enterprise-input" placeholder="0.00" />
        </div>
        <div>
            <label class="enterprise-label">العنوان والتفاصيل الأخرى</label>
            <input asp-for="Address" class="enterprise-input" placeholder="المدينة، الحي، الشارع" />
        </div>
    </div>

    <div class="enterprise-info-box" style="margin-top:8px;background:#f0f9ff;border-color:#bae6fd;">
        <span class="material-symbols-outlined" style="color:#0284c7;font-size:26px;">account_tree</span>
        <div style="flex:1;">
            <strong style="font-size:13px;color:#0369a1;display:block;margin-bottom:10px;">التوجيه المحاسبي الآلي</strong>
            <label class="enterprise-label" style="color:#059669;">مجموعة الحسابات المالية <span style="color:#e11d48;">*</span></label>
            <select name="ParentAccountId" required class="enterprise-select" style="border-color:#bbf7d0;max-width:400px;">
                <option value="">-- في أي مجموعة مالية ينتمي العميل؟ --</option>
                @if (ViewBag.ParentAccounts != null)
                {
                    foreach (var acc in ViewBag.ParentAccounts)
                    {
                        <option value="@acc.Value">@acc.Text</option>
                    }
                }
            </select>
            <div style="font-size:11px;color:#64748b;margin-top:6px;">
                <span class="material-symbols-outlined" style="font-size:12px;vertical-align:middle;">info</span>
                ستقوم شجرة الحسابات بإنشاء حساب مستقل تحت هذه المجموعة لتقييد مديونيات العميل.
            </div>
        </div>
    </div>

    <div class="enterprise-actions">
        <button type="button" onclick="modalNavigateBack()" class="enterprise-btn-cancel">إلغاء العملية</button>
        <button type="submit" class="enterprise-btn-submit">
            <span class="material-symbols-outlined" style="font-size:16px;">check_circle</span>
            تسجيل وإنشاء الحساب
        </button>
    </div>
</form>