@model IEnumerable<PharmaSmartWeb.Models.Customers>

@{
    ViewData["Title"] = "سجل العملاء";
    string? currentSearch = ViewBag.SearchTerm as string;
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .enterprise-header { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 10px 16px; font-size: 13px; font-weight: 700; color: #063955; }
    .enterprise-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .enterprise-table th { background: #f1f5f9; padding: 8px 12px; border-bottom: 1px solid #cbd5e1; border-top: 1px solid #cbd5e1; color: #334155; font-weight: 700; text-align: right; }
    .enterprise-table td { padding: 8px 12px; border-bottom: 1px solid #e2e8f0; color: #1e293b; }
    .enterprise-table tr:hover td { background: #f8fafc; }
    .status-badge { display: inline-block; padding: 2px 8px; border-radius: 2px; font-size: 11px; font-weight: 700; }
    .status-success { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
    .status-danger  { background: #fff1f2; color: #e11d48; border: 1px solid #fecdd3; }
    .btn-primary { background: #063955; color: white; border: none; padding: 7px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; }
    .btn-primary:hover { background: #0a4f72; color: white; }
    .btn-sm { padding: 4px 10px; font-size: 11px; border-radius: 2px; font-weight: 700; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; }
    .btn-edit { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; }
    .btn-ledger { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
    .search-form { display: flex; gap: 8px; align-items: center; }
    .search-input { border: 1px solid #d1d5db; border-radius: 2px; padding: 6px 10px; font-size: 12px; width: 240px; }
    .search-input:focus { outline: none; border-color: #063955; }
    .page-title { font-size: 16px; font-weight: 700; color: #063955; }
    .page-sub { font-size: 12px; color: #64748b; }
</style>

<!-- Page Header -->
<div class="enterprise-panel mb-4 p-3 flex justify-between items-center">
    <div>
        <h1 class="page-title">إدارة قاعدة العملاء</h1>
        <p class="page-sub">متابعة حسابات العملاء، الديون، وبيانات الاتصال</p>
    </div>
    <div style="display:flex; gap:8px; align-items:center;">
        @if (User.HasClaim("Permission", "Customers.Add"))
        {
            <a href="/Customers/Create" class="btn-primary">
                <span class="material-symbols-outlined" style="font-size:16px;">person_add</span>
                إضافة عميل جديد
            </a>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="enterprise-panel mb-4 p-3 flex items-center gap-3" style="border-right: 4px solid #059669;">
        <span class="material-symbols-outlined" style="color:#059669; font-size:18px;">check_circle</span>
        <span style="font-size:13px; color:#059669; font-weight:600;">@TempData["Success"]</span>
    </div>
}

<!-- Table -->
<div class="enterprise-panel">
    <div class="enterprise-header flex justify-between items-center">
        <span>قائمة العملاء (@Model.Count() عميل)</span>
        <form method="get" class="search-form">
            <input type="text" name="searchTerm" value="@currentSearch" placeholder="البحث بالاسم أو الهاتف..." class="search-input" />
            <button type="submit" class="btn-primary">بحث</button>
            @if (!string.IsNullOrEmpty(currentSearch))
            {
                <a href="/Customers/Index" class="btn-sm" style="background:#f1f5f9; color:#64748b; border:1px solid #e2e8f0;">مسح</a>
            }
        </form>
    </div>
    <div style="overflow-x:auto;">
        <table class="enterprise-table">
            <thead>
                <tr>
                    <th>المعرّف</th>
                    <th>العميل والتفاصيل</th>
                    <th>رقم التواصل</th>
                    <th>الحد الائتماني</th>
                    <th>الرصيد المالي</th>
                    <th>الحالة</th>
                    <th style="text-align:center;">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    decimal credit = item.CreditLimit ?? 0m;
                    decimal balance = item.Account?.Balance ?? 0m;
                    string balanceColor = balance > 0 ? "#e11d48" : "#059669";
                    <tr>
                        <td><strong style="font-family:monospace; color:#063955;">#@item.CustomerId.ToString("D4")</strong></td>
                        <td>
                            <div style="font-weight:700;">@item.FullName</div>
                            <div style="font-size:11px; color:#64748b;">@(item.Address ?? "لم يتم تحديد العنوان")</div>
                        </td>
                        <td dir="ltr" style="font-family:monospace;">@item.Phone</td>
                        <td>
                            <span class="status-badge" style="background:#fffbeb; color:#d97706; border:1px solid #fde68a;">
                                @credit.ToString("N2")
                            </span>
                        </td>
                        <td style="font-weight:700; color:@balanceColor; font-family:monospace;">@balance.ToString("N2")</td>
                        <td>
                            @if (item.IsActive == true)
                            {
                                <span class="status-badge status-success">نشط</span>
                            }
                            else
                            {
                                <span class="status-badge status-danger">موقوف</span>
                            }
                        </td>
                        <td style="text-align:center;">
                            <div style="display:flex; justify-content:center; gap:6px;">
                                <a href="/Customers/Edit/@item.CustomerId" class="btn-sm btn-edit">
                                    <span class="material-symbols-outlined" style="font-size:13px;">edit</span>
                                    تعديل
                                </a>
                                @if (item.AccountId > 0)
                                {
                                    <button type="button" onclick="openLedgerDrawer(@item.AccountId, '@Html.Raw(Html.Encode(item.FullName))')" class="btn-sm btn-ledger" title="عرض كشف حساب @item.FullName">
                                        <span class="material-symbols-outlined" style="font-size:13px;">receipt_long</span>
                                        كشف الحساب
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div style="padding:8px 12px; background:#f8fafc; border-top:1px solid #e2e8f0; font-size:11px; color:#64748b;">
        إجمالي: @Model.Count() عميل مسجل في النظام
    </div>
</div>

<!-- Ledger Side Drawer -->
<div id="ledgerDrawerOverlay" style="display:none; position:fixed; inset:0; background:rgba(15,23,42,0.55); z-index:9999;" onclick="closeLedgerDrawer()"></div>
<div id="ledgerDrawer" style="position:fixed; top:0; right:-100%; width:90%; max-width:820px; height:100%; background:white; z-index:10000; transition:right 0.35s cubic-bezier(0.4,0,0.2,1); box-shadow:-5px 0 30px rgba(0,0,0,0.4); display:flex; flex-direction:column;">
    <div style="background:#063955; padding:14px 20px; border-bottom:1px solid #0a4f72; display:flex; justify-content:space-between; align-items:center; flex-shrink:0;">
        <div>
            <h3 style="margin:0; font-weight:800; color:white; font-size:15px; display:flex; align-items:center; gap:8px;">
                <span class="material-symbols-outlined" style="color:#38bdf8;">receipt_long</span>
                كشف حساب: <span id="ledgerDrawerTitle" style="color:#7dd3fc;"></span>
            </h3>
            <span style="font-size:11px; color:rgba(255,255,255,0.6);">كشف الحساب التفصيلي للعميل | السنة الحالية</span>
        </div>
        <button onclick="closeLedgerDrawer()" style="width:32px; height:32px; border-radius:4px; background:rgba(255,255,255,0.1); color:white; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center;">
            <span class="material-symbols-outlined" style="font-size:18px;">close</span>
        </button>
    </div>
    <div id="ledgerDrawerContent" style="flex:1; overflow-y:auto; background:white;"></div>
</div>

<script>
    async function openLedgerDrawer(accountId, accountName) {
        document.getElementById('ledgerDrawerTitle').innerText = accountName;
        document.getElementById('ledgerDrawerOverlay').style.display = 'block';
        const drawer = document.getElementById('ledgerDrawer');
        drawer.style.right = '0';
        const content = document.getElementById('ledgerDrawerContent');
        content.innerHTML = `<div style="padding:20px;">
            <div style="height:28px;width:45%;background:#e2e8f0;border-radius:4px;margin-bottom:18px;animation:skpulse 1.5s infinite;"></div>
            <div style="height:18px;width:100%;background:#f1f5f9;border-radius:4px;margin-bottom:10px;animation:skpulse 1.5s infinite;"></div>
            <div style="height:18px;width:100%;background:#f1f5f9;border-radius:4px;margin-bottom:10px;animation:skpulse 1.5s infinite;"></div>
            <div style="height:18px;width:75%;background:#f1f5f9;border-radius:4px;margin-bottom:10px;animation:skpulse 1.5s infinite;"></div>
        </div>
        <style>@@keyframes skpulse{0%,100%{opacity:1}50%{opacity:.45}}</style>`;
        try {
            const today = new Date().toISOString().split('T')[0];
            const firstDay = new Date(new Date().getFullYear(), 0, 1).toISOString().split('T')[0];
            const response = await fetch(`/Report/Ledger?accountId=${accountId}&fromDate=${firstDay}&toDate=${today}&layoutTheme=drawer`);
            if (response.ok) { content.innerHTML = await response.text(); }
            else { content.innerHTML = '<div style="padding:20px;color:#e11d48;text-align:center;">تعذر جلب كشف الحساب</div>'; }
        } catch (e) {
            content.innerHTML = '<div style="padding:20px;color:#e11d48;text-align:center;">خطأ في الاتصال بالخادم</div>';
        }
    }
    function closeLedgerDrawer() {
        document.getElementById('ledgerDrawer').style.right = '-100%';
        setTimeout(() => {
            document.getElementById('ledgerDrawerOverlay').style.display = 'none';
            document.getElementById('ledgerDrawerContent').innerHTML = '';
        }, 350);
    }
</script>
