@model IEnumerable<PharmaSmartWeb.Models.Customers>

@{
    ViewData["Title"] = "سجل العملاء";
    string? currentSearch = ViewBag.SearchTerm as string;
    int totalCount = Model.Count();
    decimal totalBalance = Model.Where(c => c.Account?.Balance > 0).Sum(c => c.Account?.Balance ?? 0m);
    int activeCount = Model.Count(c => c.IsActive == true);
}

<!-- ===== رأس الصفحة ===== -->
<div class="flex flex-wrap justify-between items-start mb-5">
    <div class="flex items-center gap-3 mb-2 sm:mb-0">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-blue-700 flex items-center justify-center shadow-sm">
            <i class="fas fa-users text-white"></i>
        </div>
        <div>
            <h1 class="text-xl font-black text-gray-800">إدارة قاعدة العملاء</h1>
            <p class="text-xs text-gray-500">متابعة حسابات العملاء، الذمم، وبيانات الاتصال</p>
        </div>
    </div>
    <div class="flex gap-2 flex-wrap">
        @if (User.HasClaim("Permission", "Customers.Add"))
        {
            <a href="/Customers/Create"
               class="quick-action-btn px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5 active:scale-95">
                <i class="fas fa-user-plus"></i> إضافة عميل جديد
            </a>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="bg-emerald-50 border border-emerald-200 border-r-4 border-r-emerald-500 rounded-xl p-3 mb-4 flex items-center gap-2 text-sm text-emerald-700">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}

<!-- KPI Cards -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-5">
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-indigo-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">إجمالي العملاء</span>
            <i class="fas fa-users text-indigo-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@totalCount</div>
        <span class="text-xs text-indigo-600 font-medium">@activeCount نشط</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-rose-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-rose-700 font-semibold">الذمم المستحقة (لنا)</span>
            <i class="fas fa-hand-holding-usd text-rose-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-rose-700">@totalBalance.ToString("N0")</div>
        <a href="/Report/CustomerStatement" class="text-xs text-rose-600 font-semibold hover:underline">كشف الذمم ←</a>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-sky-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">عملاء نقديون</span>
            <i class="fas fa-user-check text-sky-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@Model.Count(c => c.CreditLimit == null || c.CreditLimit == 0)</div>
        <span class="text-xs text-gray-400">بدون ائتمان</span>
    </div>
</div>

<!-- جدول العملاء -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100">
    <div class="flex flex-wrap justify-between items-center px-5 py-4 border-b border-gray-100 gap-3">
        <h3 class="font-bold text-gray-800 text-sm">
            <i class="fas fa-list text-indigo-500 ml-1.5"></i> قائمة العملاء (@totalCount عميل)
        </h3>
        <form method="get" class="flex items-center gap-2">
            <div class="relative">
                <i class="fas fa-search absolute right-3 top-2.5 text-gray-400 text-xs"></i>
                <input type="text" name="searchTerm" value="@currentSearch"
                    placeholder="البحث بالاسم أو الهاتف..."
                    class="pr-8 pl-4 py-2 border border-gray-200 rounded-xl text-xs w-48 focus:outline-none focus:ring-2 focus:ring-indigo-400" />
            </div>
            <button type="submit"
                class="px-3 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl text-xs font-semibold transition-colors">
                بحث
            </button>
            @if (!string.IsNullOrEmpty(currentSearch))
            {
                <a href="/Customers/Index" class="px-3 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 rounded-xl text-xs font-semibold transition-colors">
                    <i class="fas fa-times text-xs"></i>
                </a>
            }
        </form>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full data-table text-sm">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">المعرّف</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">العميل والتفاصيل</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">رقم التواصل</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">الحد الائتماني</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">الرصيد الدائن</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">الحالة</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    decimal credit = item.CreditLimit ?? 0m;
                    decimal balance = item.Account?.Balance ?? 0m;
                    var balColor = balance > 0 ? "text-rose-600" : "text-emerald-600";
                    var initLetter = item.FullName?.Length > 0 ? item.FullName.Substring(0, 1) : "?";
                    <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors">
                        <td class="px-5 py-3 font-mono text-indigo-600 font-bold">#@item.CustomerId.ToString("D4")</td>
                        <td class="px-5 py-3">
                            <div class="flex items-center gap-2">
                                <div class="w-7 h-7 rounded-lg bg-indigo-100 text-indigo-700 flex items-center justify-center text-xs font-bold flex-shrink-0">
                                    @initLetter
                                </div>
                                <div>
                                    <div class="font-semibold text-gray-800">@item.FullName</div>
                                    <div class="text-[11px] text-gray-400">@(item.Address ?? "لم يتم تحديد العنوان")</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-5 py-3 font-mono text-gray-600 text-xs" dir="ltr">@item.Phone</td>
                        <td class="px-5 py-3">
                            <span class="text-[11px] px-2 py-0.5 bg-amber-50 text-amber-700 border border-amber-100 rounded-full font-bold">
                                @credit.ToString("N0")
                            </span>
                        </td>
                        <td class="px-5 py-3 font-bold font-mono @balColor">@balance.ToString("N2")</td>
                        <td class="px-5 py-3">
                            @if (item.IsActive == true)
                            {
                                <span class="text-[11px] px-2.5 py-1 bg-emerald-50 text-emerald-700 border border-emerald-100 rounded-full font-bold">نشط</span>
                            }
                            else
                            {
                                <span class="text-[11px] px-2.5 py-1 bg-red-50 text-red-700 border border-red-100 rounded-full font-bold">موقوف</span>
                            }
                        </td>
                        <td class="px-5 py-3 text-center">
                            <div class="flex items-center justify-center gap-1.5">
                                <a href="/Customers/Edit/@item.CustomerId"
                                   class="px-2.5 py-1.5 bg-amber-50 hover:bg-amber-100 border border-amber-200 text-amber-700 rounded-lg text-xs font-semibold transition-colors flex items-center gap-1">
                                    <i class="fas fa-pen text-[10px]"></i> تعديل
                                </a>
                                @if (item.AccountId > 0)
                                {
                                    <a href="/Accounting/Ledger?accountId=@item.AccountId"
                                       class="px-2.5 py-1.5 bg-blue-50 hover:bg-blue-100 border border-blue-200 text-blue-700 rounded-lg text-xs font-semibold transition-colors flex items-center gap-1">
                                        <i class="fas fa-receipt text-[10px]"></i> كشف
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 rounded-b-2xl">
        <span class="text-xs text-gray-500">إجمالي: <strong class="text-gray-700">@totalCount</strong> عميل مسجل في النظام</span>
    </div>
</div>
