@model PharmaSmartWeb.Models.Drugs

@{
    bool isPopup = ViewBag.IsPopup == true;
    Layout = isPopup ? null : "_Layout";
    ViewData["Title"] = "تعديل بيانات الصنف";
    bool hasSubUnits = Model.ConversionFactor > 1;
}

@if (isPopup)
{
    @Html.Raw(@"<!DOCTYPE html>
<html lang=""ar"" dir=""rtl"" class=""light"">
<head>
    <meta charset=""utf-8"" />
    <meta name=""viewport"" content=""width=device-width, initial-scale=1.0"" />
    <title>تعديل صنف</title>
    <script src=""~/lib/tailwindcss.js""></script>
    <script src=""/js/tailwind.config.js""></script>
    <link href=""/css/cura-styles.css"" rel=""stylesheet"" />
    <style>
        body { font-family: 'Manrope', sans-serif; background-color: transparent !important; margin: 0; padding: 0; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #c1c7cf; border-radius: 10px; }
        .edit-gradient { background: linear-gradient(135deg, #00314e 0%, #004870 100%); }
    </style>
</head>
<body class=""text-[#191c1e]"">")
}

<div class="@(isPopup ? "w-full h-full flex flex-col" : "max-w-5xl mx-auto py-12 px-6") animate-in fade-in duration-500">
    @if (!isPopup)
    {
        <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-6 print:hidden">
            <div>
                <nav class="flex items-center gap-2 text-slate-400 text-[10px] font-black uppercase mb-3 tracking-widest">
                    <a href="/Home/Index" class="hover:text-primary">الرئيسية</a>
                    <span class="material-symbols-outlined text-[12px]">chevron_left</span>
                    <a href="/Drugs/Index" class="hover:text-primary">دليل الأدوية</a>
                </nav>
                <h1 class="text-3xl font-extrabold text-primary font-headline tracking-tight">
                    تعديل بيانات الصنف
                </h1>
                <p class="text-slate-500 text-sm mt-2 font-medium">تحديث تفاصيل الدواء في المستودع</p>
            </div>
            <a href="/Drugs/Index" class="bg-white border border-slate-200 text-slate-600 px-6 py-3 rounded-sm font-bold text-sm hover:bg-slate-50 transition-all flex items-center gap-2 shadow-sm">
                العودة للتسجيلات
            </a>
        </div>
    }

    <form asp-action="Edit" method="post" enctype="multipart/form-data" id="drugForm" class="@(isPopup ? "flex flex-col h-full bg-surface-container-lowest" : "bg-surface-container-lowest rounded-sm shadow-sm border border-slate-100 overflow-hidden flex flex-col")">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="DrugId" />
        <input type="hidden" asp-for="ImagePath" />
        <input type="hidden" name="isPopup" value="@(isPopup.ToString().ToLower())" />
        
        <div class="@(isPopup ? "flex-1 overflow-y-auto p-5 custom-scrollbar" : "p-5") space-y-10">
            @if (ViewBag.Error != null)
            {
                <div class="bg-rose-50 border-r-4 border-error p-4 rounded-sm flex items-center gap-4 animate-in fade-in mb-4">
                    <span class="material-symbols-outlined text-error text-xl">error</span>
                    <p class="text-rose-700 text-sm font-bold">@ViewBag.Error</p>
                </div>
            }

            <!-- Status Section -->
            <div class="flex items-center justify-between bg-surface-container-low p-4 rounded-sm border border-transparent">
                <div class="flex items-center gap-3">
                    <span class="w-2.5 h-2.5 rounded-full @(Model.IsActive ? "bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]" : "bg-rose-500 shadow-[0_0_8px_rgba(225,29,72,0.5)]")"></span>
                    <span class="text-sm font-bold text-primary">حالة الدواء في المستودع</span>
                </div>
                <select asp-for="IsActive" class="px-4 py-2 bg-surface-container-lowest border-none rounded-sm text-sm font-bold shadow-sm focus:ring-2 focus:ring-primary/20 cursor-pointer">
                    <option value="true">صنف نشط / متاح للصرف</option>
                    <option value="false">موقوف مؤقتاً أو نهائياً</option>
                </select>
            </div>

            <!-- Section: Basic Information -->
            <section>
                <div class="flex items-center gap-2 mb-6">
                    <span class="w-1.5 h-6 bg-primary-container rounded-full"></span>
                    <h3 class="text-lg font-bold text-primary">المعلومات الأساسية</h3>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="block text-sm font-bold text-slate-500 mr-1">الاسم التجاري <span class="text-error">*</span></label>
                        <input type="text" asp-for="DrugName" required class="w-full bg-surface-container-low border-none rounded-sm px-4 py-3.5 focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all duration-200 text-primary font-bold font-headline" />
                    </div>
                    <div class="space-y-2">
                        <label class="block text-sm font-bold text-slate-500 mr-1">الشركة المصنعة</label>
                        <input type="text" asp-for="Manufacturer" class="w-full bg-surface-container-low border-none rounded-sm px-4 py-3.5 focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all duration-200 text-primary font-bold" />
                    </div>
                    <div class="space-y-2">
                        <label class="block text-sm font-bold text-slate-500 mr-1">المجموعة العلاجية</label>
                        <div class="relative">
                            <select asp-for="GroupId" asp-items="ViewBag.Groups" class="w-full bg-surface-container-low border-none rounded-sm px-4 py-3.5 focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all duration-200 text-primary font-bold appearance-none cursor-pointer">
                                <option value="">-- عام (بدون تصنيف) --</option>
                            </select>
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline pointer-events-none">expand_more</span>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="block text-sm font-bold text-slate-500 mr-1">الباركود SKU</label>
                        <div class="relative">
                            <input type="text" asp-for="Barcode" class="w-full bg-surface-container-low border-none rounded-sm px-4 py-3.5 pl-12 focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all duration-200 text-primary font-mono font-bold" />
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline">barcode_scanner</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Section: Image Upload -->
            <section>
                <div class="flex items-center gap-2 mb-6">
                    <span class="w-1.5 h-6 bg-primary-container rounded-full"></span>
                    <h3 class="text-lg font-bold text-primary">صورة المنتج</h3>
                </div>
                <div class="flex flex-col md:flex-row items-center gap-8 bg-surface-container-low p-6 rounded-sm">
                    <div class="w-32 h-32 bg-surface-container-lowest rounded-sm shadow-sm overflow-hidden flex items-center justify-center border border-outline-variant/20 shrink-0">
                        @if (!string.IsNullOrEmpty(Model.ImagePath))
                        {
                            <img src="~/images/drugs/@Model.ImagePath" class="w-full h-full object-cover p-1 rounded-[10px]" onerror="this.src='/images/placeholder.png';this.onerror='';" />
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-outline text-4xl opacity-50">imagesmode</span>
                        }
                    </div>
                    <div class="flex flex-col gap-3 w-full">
                        <p class="text-sm text-slate-600 leading-relaxed max-w-sm">يرجى رفع صورة واضحة للدواء تظهر فيها العبوة والبيانات الأساسية. (الحد الأقصى 2 ميجابايت).</p>
                        <div class="flex flex-wrap gap-3">
                            <label for="drugImage" class="bg-surface-container-lowest text-primary border border-outline-variant/30 px-5 py-2.5 rounded-sm text-sm font-bold hover:bg-primary/5 transition-colors duration-200 flex items-center gap-2 cursor-pointer shadow-sm">
                                <span class="material-symbols-outlined text-[18px]">upload</span>
                                تعديل وتحديث الصورة
                                <input type="file" id="drugImage" name="drugImage" accept="image/*" class="hidden" onchange="updateFileName(this)">
                            </label>
                        </div>
                        <div id="file-name-preview" class="hidden text-xs font-bold text-emerald-600 bg-emerald-50 px-3 py-1.5 rounded-sm mt-2 inline-block w-max"></div>
                    </div>
                </div>
            </section>

            <!-- Section: Units & Retail -->
            <section>
                <div class="flex items-center gap-2 mb-6">
                    <span class="w-1.5 h-6 bg-primary-container rounded-full"></span>
                    <h3 class="text-lg font-bold text-primary">الوحدات والتجزئة</h3>
                </div>
                <div class="bg-surface-container-low/50 p-6 rounded-sm space-y-6">
                    <div class="flex items-center justify-between">
                        <div class="flex flex-col">
                            <span class="text-sm font-bold text-primary">هل الصنف يتجزأ للبيع؟</span>
                            <span class="text-xs text-slate-500 mt-1">تمكين بيع الوحدات الصغرى للجمهور وتحويل المخزون</span>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="hasSubUnits" class="sr-only peer" onchange="toggleUOMMode()" @(hasSubUnits ? "checked" : "")>
                            <div class="w-14 h-7 bg-outline-variant peer-focus:outline-none rounded-full peer peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:right-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all peer-checked:bg-primary"></div>
                        </label>
                    </div>

                    <input type="hidden" asp-for="MainUnit" id="hiddenMainUnit" />
                    <input type="hidden" asp-for="SubUnit" id="hiddenSubUnit" />
                    <input type="hidden" asp-for="ConversionFactor" id="hiddenFactor" />

                    <!-- Single Unit Mode -->
                    <div id="singleUnitMode" class="pt-4 border-t border-outline-variant/10 @(hasSubUnits ? "hidden" : "block")">
                        <div class="max-w-sm space-y-2">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">وحدة القياس (لا تباع مجزأة)</label>
                            <div class="relative">
                                <select id="singleUnitSelect" onchange="updateHiddenUnits()" class="w-full bg-surface-container-lowest border-none rounded-sm px-4 py-3 text-sm font-bold text-primary shadow-sm appearance-none">
                                    <option value="عبوة" selected="@(Model.MainUnit == "عبوة" ? "selected" : null)">عبوة (شراب/قطرة)</option>
                                    <option value="أنبوبة" selected="@(Model.MainUnit == "أنبوبة" ? "selected" : null)">أنبوبة (مرهم/كريم)</option>
                                    <option value="قارورة" selected="@(Model.MainUnit == "قارورة" ? "selected" : null)">قارورة / زجاجة</option>
                                    <option value="فيال" selected="@(Model.MainUnit == "فيال" ? "selected" : null)">فيال (Vial)</option>
                                    <option value="قطعة" selected="@(Model.MainUnit == "قطعة" ? "selected" : null)">قطعة / حبة واحدة</option>
                                    <option value="علبة" selected="@(Model.MainUnit == "علبة" ? "selected" : null)">علبة (تباع كاملة فقط)</option>
                                </select>
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none">expand_more</span>
                            </div>
                        </div>
                    </div>

                    <!-- Multi Unit Mode -->
                    <div id="multiUnitMode" class="pt-4 border-t border-outline-variant/10 @(hasSubUnits ? "grid grid-cols-1 md:grid-cols-3 gap-6" : "hidden") animate-in fade-in">
                        <div class="space-y-2">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">الوحدة الكبرى</label>
                            <div class="relative">
                                <select id="multiMainSelect" onchange="updateHiddenUnits()" class="w-full bg-surface-container-lowest border-none rounded-sm px-4 py-3 text-sm font-bold text-primary shadow-sm appearance-none">
                                    <option value="علبة" selected="@(Model.MainUnit == "علبة" ? "selected" : null)">علبة (Box)</option>
                                    <option value="كرتون" selected="@(Model.MainUnit == "كرتون" ? "selected" : null)">كرتون (Carton)</option>
                                    <option value="باكت" selected="@(Model.MainUnit == "باكت" ? "selected" : null)">باكت (Packet)</option>
                                </select>
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none">expand_more</span>
                            </div>
                        </div>
                        <div class="space-y-2">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">الوحدة الصغرى</label>
                            <div class="relative">
                                <select id="multiSubSelect" onchange="updateHiddenUnits()" class="w-full bg-surface-container-lowest border-none rounded-sm px-4 py-3 text-sm font-bold text-primary shadow-sm appearance-none">
                                    <option value="شريط" selected="@(Model.SubUnit == "شريط" ? "selected" : null)">شريط (Strip)</option>
                                    <option value="أمبولة" selected="@(Model.SubUnit == "أمبولة" ? "selected" : null)">أمبولة (Ampoule)</option>
                                    <option value="حبة" selected="@(Model.SubUnit == "حبة" ? "selected" : null)">حبة / قرص (Tablet)</option>
                                    <option value="كيس" selected="@(Model.SubUnit == "كيس" ? "selected" : null)">كيس (Sachet)</option>
                                </select>
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline pointer-events-none">expand_more</span>
                            </div>
                        </div>
                        <div class="space-y-2">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">معامل التحويل</label>
                            <div class="flex items-center gap-2">
                                <input type="number" id="multiFactorInput" min="2" value="@(hasSubUnits ? Model.ConversionFactor : 2)" oninput="updateHiddenUnits()" class="w-full bg-surface-container-lowest border-none rounded-sm px-4 py-3 text-sm font-mono font-bold text-primary text-center shadow-sm focus:ring-2 focus:ring-primary/20" />
                                <span class="text-xs font-bold text-outline whitespace-nowrap"><span id="lblSub">شريط</span> / <span id="lblMain">علبة</span></span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <!-- Footer Actions -->
        <div class="bg-surface-container-lowest px-8 py-5 flex items-center justify-end gap-4 shadow-[0_-4px_20px_rgba(0,0,0,0.02)] shrink-0 border-t border-slate-100">
            @if(isPopup)
            {
                <button type="button" onclick="parent.closeDrugModal();" class="px-8 py-3.5 rounded-sm text-slate-500 font-bold hover:bg-surface-container-high transition-all duration-200 text-sm">
                    إلغاء الإجراء
                </button>
            }
            <button type="submit" class="px-10 py-3.5 edit-gradient text-white font-bold rounded-sm shadow-sm border border-slate-200 hover:shadow-primary/25 hover:scale-[1.02] active:scale-95 transition-all duration-200 flex items-center gap-2 text-sm ml-auto sm:ml-0">
                <span class="material-symbols-outlined text-[18px]">save_as</span>
                استكمال حفظ التعديلات
            </button>
        </div>
    </form>
</div>

<script>
    function updateFileName(input) {
        const preview = document.getElementById('file-name-preview');
        if (input.files && input.files.length > 0) {
            preview.innerHTML = `<span class="material-symbols-outlined align-middle text-sm text-emerald-500">check_circle</span> تم اختيار الإرفاق: ${input.files[0].name}`;
            preview.classList.remove('hidden');
        } else {
            preview.classList.add('hidden');
        }
    }

    function toggleUOMMode() {
        const hasSubUnits = document.getElementById('hasSubUnits').checked;
        const singleDiv = document.getElementById('singleUnitMode');
        const multiDiv = document.getElementById('multiUnitMode');

        if (hasSubUnits) {
            singleDiv.classList.add('hidden');
            multiDiv.classList.remove('hidden');
        } else {
            singleDiv.classList.remove('hidden');
            multiDiv.classList.add('hidden');
        }
        updateHiddenUnits();
    }

    function updateHiddenUnits() {
        const hasSubUnits = document.getElementById('hasSubUnits').checked;
        const hMain = document.getElementById('hiddenMainUnit');
        const hSub = document.getElementById('hiddenSubUnit');
        const hFactor = document.getElementById('hiddenFactor');

        if (!hasSubUnits) {
            const unit = document.getElementById('singleUnitSelect').value;
            hMain.value = unit; hSub.value = unit; hFactor.value = 1;
        } else {
            const mainUnit = document.getElementById('multiMainSelect').value;
            const subUnit = document.getElementById('multiSubSelect').value;
            const factor = document.getElementById('multiFactorInput').value || 1;

            hMain.value = mainUnit; hSub.value = subUnit; hFactor.value = factor;
            
            document.getElementById('lblMain').innerText = mainUnit;
            document.getElementById('lblSub').innerText = subUnit;
        }
    }

    window.onload = function () {
        updateHiddenUnits();
    };
</script>

@if (isPopup)
{
    @Html.Raw(@"</body></html>")
}