@model IEnumerable<PharmaSmartWeb.Models.Drugs>
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService

@{
    ViewData["Title"] = "دليل الأدوية";
    var totalDrugs = Model.Count();
    var inactiveDrugs = Model.Count(d => !d.IsActive);
    var activeDrugs = totalDrugs - inactiveDrugs;
    var availabilityRatio = totalDrugs > 0 ? (activeDrugs * 100 / totalDrugs) : 0;
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .enterprise-header { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 10px 16px; font-size: 13px; font-weight: 700; color: #063955; }
    .enterprise-kpi { background: white; border: 1px solid #d1d5db; border-radius: 2px; padding: 12px 16px; }
    .kpi-title { font-size: 11px; color: #64748b; font-weight: 600; margin-bottom: 4px; }
    .kpi-value { font-size: 22px; font-weight: 700; color: #0f172a; }
    .enterprise-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .enterprise-table th { background: #f1f5f9; padding: 8px 12px; border-bottom: 1px solid #cbd5e1; border-top: 1px solid #cbd5e1; color: #334155; font-weight: 700; text-align: right; }
    .enterprise-table td { padding: 8px 12px; border-bottom: 1px solid #e2e8f0; color: #1e293b; vertical-align: middle; }
    .enterprise-table tr:hover td { background: #f8fafc; }
    .status-active { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; padding: 2px 8px; border-radius: 2px; font-size: 11px; font-weight: 700; }
    .status-inactive { background: #fff1f2; color: #e11d48; border: 1px solid #fecdd3; padding: 2px 8px; border-radius: 2px; font-size: 11px; font-weight: 700; }
    .btn-primary { background: #063955; color: white; border: none; padding: 7px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; }
    .btn-primary:hover { background: #0a4f72; color: white; }
    .btn-secondary { background: #475569; color: white; border: none; padding: 7px 14px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 5px; }
    .btn-sm { padding: 4px 8px; font-size: 11px; border-radius: 2px; font-weight: 700; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 3px; }
    .btn-edit { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; }
    .btn-del { background: #fff1f2; color: #e11d48; border: 1px solid #fecdd3; }
    .search-input { border: 1px solid #d1d5db; border-radius: 2px; padding: 6px 10px; font-size: 12px; width: 260px; }
    .search-input:focus { outline: none; border-color: #063955; }
    .filter-select { border: 1px solid #d1d5db; border-radius: 2px; padding: 6px 10px; font-size: 12px; background: white; }
    .drug-icon { width: 32px; height: 32px; border-radius: 4px; background: #e8f0fe; display: flex; align-items: center; justify-content: center; flex-shrink:0; }
    .unit-badge { display: inline-block; background: #f1f5f9; color: #475569; padding: 2px 7px; border-radius: 2px; font-size: 10px; font-weight: 700; border: 1px solid #e2e8f0; font-family: monospace; }
    .page-title { font-size: 16px; font-weight: 700; color: #063955; }
    .page-sub { font-size: 12px; color: #64748b; }
</style>

@if (TempData["Success"] != null)
{
    <div class="enterprise-panel mb-4 p-3 flex items-center gap-3" style="border-right: 4px solid #059669;">
        <span class="material-symbols-outlined" style="color:#059669; font-size:18px;">check_circle</span>
        <span style="font-size:13px; color:#059669; font-weight:600;">@TempData["Success"]</span>
    </div>
}
@if (ViewBag.Error != null)
{
    <div class="enterprise-panel mb-4 p-3 flex items-center gap-3" style="border-right: 4px solid #e11d48;">
        <span class="material-symbols-outlined" style="color:#e11d48; font-size:18px;">error</span>
        <span style="font-size:13px; color:#e11d48; font-weight:600;">@ViewBag.Error</span>
    </div>
}

<!-- Page Header -->
<div class="enterprise-panel mb-4 p-3 flex justify-between items-center">
    <div>
        <h1 class="page-title">دليل الأدوية المركزي</h1>
        <p class="page-sub">إدارة وتحليل المخزون الدوائي بدقة إكلينيكية.</p>
    </div>
    <div style="display:flex; gap:8px; align-items:center;">
        <button onclick="exportTableToCSV('Drugs_Master_Data.csv')" class="btn-secondary">
            <span class="material-symbols-outlined" style="font-size:15px;">file_download</span>
            تصدير التقرير
        </button>
        @if ((await AuthorizationService.AuthorizeAsync(User, "CanAddDrug")).Succeeded)
        {
            <button onclick="openDrugModal('/Drugs/Create?isPopup=true', 'إضافة صنف جديد')" class="btn-primary">
                <span class="material-symbols-outlined" style="font-size:16px;">add_circle</span>
                إضافة صنف جديد
            </button>
        }
    </div>
</div>

<!-- KPIs -->
<div class="grid grid-cols-3 gap-3 mb-4">
    <div class="enterprise-kpi">
        <div class="kpi-title">إجمالي الأصناف</div>
        <div class="kpi-value" id="lblCount">@totalDrugs.ToString("N0")</div>
    </div>
    <div class="enterprise-kpi">
        <div class="kpi-title">أصناف موقوفة</div>
        <div class="kpi-value" style="color:#e11d48;">@inactiveDrugs.ToString("N0")</div>
    </div>
    <div class="enterprise-kpi">
        <div class="kpi-title">نسبة التوافر والنشاط</div>
        <div class="kpi-value" style="color:#059669;">@availabilityRatio%</div>
        <div style="height:4px; background:#e2e8f0; border-radius:2px; margin-top:6px;">
            <div style="height:4px; background:#059669; border-radius:2px; width:@(availabilityRatio)%;"></div>
        </div>
    </div>
</div>

<!-- Search & Filter Bar -->
<div class="enterprise-panel mb-4 p-3 flex gap-3 items-center flex-wrap">
    <input id="searchInput" onkeyup="filterTable()" class="search-input" placeholder="البحث باسم الدواء، المجموعة أو الباركود..." type="text" />
    <select id="statusFilter" onchange="filterTable()" class="filter-select">
        <option value="all">كل الحالات</option>
        <option value="active">نشط فقط</option>
        <option value="inactive">موقوف</option>
    </select>
    <button onclick="document.getElementById('searchInput').value=''; document.getElementById('statusFilter').value='all'; filterTable();"
            class="btn-sm" style="background:#f1f5f9; color:#475569; border:1px solid #e2e8f0; padding:6px 12px;">
        <span class="material-symbols-outlined" style="font-size:14px;">filter_alt_off</span>
        إلغاء التصفية
    </button>
</div>

<!-- Data Table -->
<div class="enterprise-panel">
    <div class="enterprise-header">قائمة الأصناف الدوائية المسجلة</div>
    <div style="overflow-x:auto; min-height:300px;">
        <table class="enterprise-table" id="drugsTable">
            <thead>
                <tr>
                    <th>الدواء والمجموعة</th>
                    <th>الشركة المصنعة</th>
                    <th>الباركود (SKU)</th>
                    <th>الوحدات والتحويل</th>
                    <th>الحالة</th>
                    <th style="text-align:center;" class="export-ignore">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr id="emptyRow">
                        <td colspan="6" style="text-align:center; padding:40px; color:#94a3b8;">
                            <span class="material-symbols-outlined" style="font-size:36px; display:block; margin-bottom:8px;">medication_liquid</span>
                            لا توجد أصناف مسجلة حتى الآن.
                            @if ((await AuthorizationService.AuthorizeAsync(User, "CanAddDrug")).Succeeded)
                            {
                                <button onclick="openDrugModal('/Drugs/Create?isPopup=true', 'إضافة صنف جديد')"
                                        style="margin-top:10px; background:#063955; color:white; border:none; padding:8px 16px; border-radius:2px; font-size:12px; cursor:pointer;">
                                    إضافة الدواء الأول بطريقة ذكية
                                </button>
                            }
                        </td>
                    </tr>
                }

                @foreach (var item in Model)
                {
                    <tr class="search-row" data-status="@(item.IsActive ? "active" : "inactive")">
                        <td>
                            <div style="display:flex; align-items:center; gap:8px;">
                                @if (!string.IsNullOrEmpty(item.ImagePath))
                                {
                                    <img src="~/images/drugs/@item.ImagePath" style="width:32px; height:32px; border-radius:4px; object-fit:cover; border:1px solid #e2e8f0;"
                                         onerror="this.src='@Url.Content("~/images/placeholder.png")';this.onerror='';" />
                                }
                                else
                                {
                                    <div class="drug-icon">
                                        <span class="material-symbols-outlined" style="font-size:17px; color:#063955;">pill</span>
                                    </div>
                                }
                                <div>
                                    <div style="font-weight:700; font-size:12px; color:#063955;" class="search-target">@item.DrugName</div>
                                    <div style="font-size:10px; color:#94a3b8;" class="search-target">@(item.ItemGroup?.GroupName ?? "بدون مجموعة")</div>
                                </div>
                            </div>
                        </td>
                        <td class="search-target">@(string.IsNullOrEmpty(item.Manufacturer) ? "---" : item.Manufacturer)</td>
                        <td>
                            <span class="unit-badge search-target">@(string.IsNullOrEmpty(item.Barcode) ? "بدون كود" : item.Barcode)</span>
                        </td>
                        <td>
                            @if (item.ConversionFactor > 1)
                            {
                                <div style="font-size:11px;">
                                    <span class="unit-badge">@item.MainUnit</span>
                                    <span style="color:#94a3b8; margin:0 4px;">←</span>
                                    <span class="unit-badge" style="background:#eff6ff; color:#1d4ed8; border-color:#bfdbfe;">@item.ConversionFactor @item.SubUnit</span>
                                </div>
                            }
                            else
                            {
                                <span class="unit-badge">@item.MainUnit</span>
                                <div style="font-size:10px; color:#94a3b8; margin-top:2px;">وحدة مفردة لا تتجزأ</div>
                            }
                        </td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="status-active">نشط</span>
                                <span class="hidden status-value">active</span>
                            }
                            else
                            {
                                <span class="status-inactive">موقوف</span>
                                <span class="hidden status-value">inactive</span>
                            }
                        </td>
                        <td style="text-align:center;" class="export-ignore">
                            <div style="display:flex; justify-content:center; gap:5px;">
                                @if ((await AuthorizationService.AuthorizeAsync(User, "CanEditDrug")).Succeeded)
                                {
                                    <button onclick="openDrugModal('/Drugs/Edit/@item.DrugId?isPopup=true', 'تعديل بيانات الدواء')"
                                            class="btn-sm btn-edit">
                                        <span class="material-symbols-outlined" style="font-size:13px;">edit</span>
                                    </button>
                                }
                                @if ((await AuthorizationService.AuthorizeAsync(User, "CanDeleteDrug")).Succeeded)
                                {
                                    <form asp-action="Delete" asp-route-id="@item.DrugId" method="post"
                                          onsubmit="confirmDeleteDrug(event, this);" style="display:inline;">
                                        <button type="submit" class="btn-sm btn-del">
                                            <span class="material-symbols-outlined" style="font-size:13px;">delete</span>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div style="padding:8px 12px; background:#f8fafc; border-top:1px solid #e2e8f0; font-size:11px; color:#64748b;">
        عرض <span id="visibleCount">@totalDrugs</span> من @totalDrugs.ToString("N0") أصناف مسجلة بالنظام
    </div>
</div>

<!-- Drug Popup Modal -->
<div id="drugModal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4" style="display:none; background:rgba(0,0,0,0.3);">
    <div style="background:white; border-radius:2px; width:100%; max-width:860px; max-height:90vh; display:flex; flex-direction:column; border:1px solid #d1d5db; overflow:hidden;">
        <div style="background:#063955; padding:12px 20px; display:flex; justify-content:space-between; align-items:center;">
            <div style="display:flex; align-items:center; gap:10px;">
                <span class="material-symbols-outlined" style="color:white; font-size:20px;">medication</span>
                <h2 id="drugModalTitle" style="color:white; font-size:14px; font-weight:700;">نافذة النظام</h2>
            </div>
            <button onclick="closeDrugModal()" style="color:white; background:none; border:none; cursor:pointer; font-size:18px;">✕</button>
        </div>
        <div style="position:relative; flex:1; overflow:hidden;">
            <div id="modalLoader" style="position:absolute; inset:0; background:white; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:12px; z-index:10;">
                <div style="width:36px; height:36px; border:4px solid #e2e8f0; border-top-color:#063955; border-radius:50%; animation:spin 1s linear infinite;"></div>
                <p style="font-size:12px; color:#64748b; font-weight:600;">جاري تحميل البيانات...</p>
            </div>
            <iframe id="drugModalIframe" style="width:100%; height:500px; border:none; opacity:0; transition:opacity 0.3s;"
                    onload="this.style.opacity=1; document.getElementById('modalLoader').style.display='none';"></iframe>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/lib/sweetalert2.js"></script>
<script>
    function confirmDeleteDrug(event, form) {
        event.preventDefault();
        Swal.fire({
            title: 'تنبيه أمان',
            text: 'هل أنت متأكد من إيقاف هذا الصنف نهائياً؟ سيتسبب ذلك في تلف البيانات التاريخية في حال كان عليه حركات مسبقة.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#e11d48',
            cancelButtonColor: '#94a3b8',
            confirmButtonText: 'نعم، إيقاف الصنف',
            cancelButtonText: 'إلغاء'
        }).then((result) => {
            if (result.isConfirmed) {
                form.submit();
            }
        });
    }

    function filterTable() {
        const input = document.getElementById("searchInput").value.toLowerCase();
        const filterStatus = document.getElementById("statusFilter").value;
        const rows = document.querySelectorAll(".search-row");
        let visibleCount = 0;

        rows.forEach(row => {
            const targets = row.querySelectorAll('.search-target');
            let textContent = Array.from(targets).map(t => t.innerText.toLowerCase()).join(" ");
            const statusSpan = row.querySelector('.status-value');
            const statusStr = statusSpan ? statusSpan.innerText.trim() : "";
            let textMatch = textContent.includes(input) || input === "";
            let statusMatch = (filterStatus === "all") || (statusStr === filterStatus);

            if (textMatch && statusMatch) {
                row.style.display = "";
                visibleCount++;
            } else {
                row.style.display = "none";
            }
        });

        const countLabel = document.getElementById("lblCount");
        if (countLabel) countLabel.innerText = visibleCount.toLocaleString('en-US');
        const visCount = document.getElementById("visibleCount");
        if (visCount) visCount.innerText = visibleCount;
    }

    function exportTableToCSV(filename) {
        let csv = [];
        let rows = document.querySelectorAll("#drugsTable tr");
        for (let i = 0; i < rows.length; i++) {
            let row = [], cols = rows[i].querySelectorAll("td, th");
            if (rows[i].style.display === "none") continue;
            for (let j = 0; j < cols.length; j++) {
                if (cols[j].classList.contains('export-ignore')) continue;
                let data = cols[j].innerText.replace(/(\r\n|\n|\r)/gm, " ").trim();
                row.push('"' + data + '"');
            }
            csv.push(row.join(","));
        }
        if (csv.length <= 1) { alert("لا توجد بيانات متاحة للتصدير!"); return; }
        let csvFile = new Blob(["\uFEFF" + csv.join("\n")], { type: "text/csv;charset=utf-8;" });
        let link = document.createElement("a");
        link.download = filename;
        link.href = window.URL.createObjectURL(csvFile);
        link.style.display = "none";
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }

    function openDrugModal(url, title) {
        document.getElementById('drugModalTitle').innerText = title;
        document.getElementById('modalLoader').style.display = 'flex';
        document.getElementById('drugModalIframe').style.opacity = '0';
        document.getElementById('drugModalIframe').src = url;
        document.getElementById('drugModal').style.display = 'flex';
    }

    function closeDrugModal() {
        document.getElementById('drugModal').style.display = 'none';
        document.getElementById('drugModalIframe').src = '';
    }

    window.addEventListener('message', function(event) {
        if (event.data === 'drug_added_success' || event.data === 'drug_updated_success') {
            closeDrugModal();
            window.location.reload();
        }
    });
</script>
<style>
    @@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    .hidden { display: none; }
</style>
}