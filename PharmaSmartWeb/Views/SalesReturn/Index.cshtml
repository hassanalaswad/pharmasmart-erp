@model IEnumerable<PharmaSmartWeb.Models.Sales>
@using PharmaSmartWeb.Infrastructure

@{
    ViewData["Title"] = "سجل مرتجعات المبيعات";
    var total = Model.Any() ? Model.Sum(x => x.NetAmount) : 0;
    var count = Model.Count();
}

@if (TempData["Success"] != null)
{
    <div class="bg-emerald-50 border border-emerald-200 border-r-4 border-r-emerald-500 rounded-xl p-3 mb-4 flex items-center gap-2 text-sm text-emerald-700">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="bg-red-50 border border-red-200 border-r-4 border-r-red-500 rounded-xl p-3 mb-4 flex items-center gap-2 text-sm text-red-700">
        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
    </div>
}

<!-- ===== رأس الصفحة ===== -->
<div class="flex flex-wrap justify-between items-start mb-5">
    <div class="flex items-center gap-3 mb-2 sm:mb-0">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-rose-500 to-red-700 flex items-center justify-center shadow-sm">
            <i class="fas fa-undo text-white"></i>
        </div>
        <div>
            <h1 class="text-xl font-black text-gray-800">سجل مرتجعات المبيعات</h1>
            <p class="text-xs text-gray-500">مراجعة وإدارة كافة عمليات الإرجاع المسجلة مع تفاصيلها</p>
        </div>
    </div>
    <div class="flex gap-2 flex-wrap">
        <a href="/Sales/Index" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl text-xs font-bold flex items-center gap-2 transition-colors">
            <i class="fas fa-shopping-cart text-gray-500"></i> لوحة المبيعات
        </a>
    </div>
</div>

<!-- ===== بطاقات KPI ===== -->
<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-rose-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">إجمالي عدد المرتجعات</span>
            <i class="fas fa-file-invoice text-rose-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@count</div>
        <span class="text-xs text-gray-400 font-medium">عملية إرجاع مسجلة</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-red-600">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-red-700 font-semibold">المبالغ المستردة</span>
            <i class="fas fa-money-bill-wave text-red-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-red-700">@total.ToString("N2")</div>
        <span class="text-xs text-gray-400 font-medium">إجمالي المبالغ المستردة</span>
    </div>
</div>

<!-- ===== جدول المرتجعات ===== -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100">
    <div class="flex flex-wrap justify-between items-center px-5 py-4 border-b border-gray-100 gap-3">
        <h3 class="font-bold text-gray-800 text-sm">
            <i class="fas fa-list text-rose-500 ml-1.5"></i> القائمة التفصيلية للمرتجعات (@count مرتجع)
        </h3>
        <div class="relative">
            <i class="fas fa-search absolute right-3 top-2.5 text-gray-400 text-xs"></i>
            <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="البحث برقم المرتجع أو الفاتورة..."
                class="pr-8 pl-4 py-2 border border-gray-200 rounded-xl text-xs w-56 focus:outline-none focus:ring-2 focus:ring-rose-400" />
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full data-table text-sm" id="returnsTable">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">رقم المرتجع</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">رقم الفاتورة الأصلية</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">العميل</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">التاريخ</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">المبلغ المسترد</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">بواسطة</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">التفاصيل</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-12 text-gray-400">
                            <i class="fas fa-undo text-5xl mb-3 block text-gray-200"></i>
                            لا توجد سجلات مرتجعات مبيعات حالياً.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors search-row">
                        <td class="px-5 py-3 font-mono font-bold text-gray-700 search-ret">#RET-@item.SaleId.ToString("D5")</td>
                        <td class="px-5 py-3">
                            <a href="/Sales/Details/@item.ParentSaleId" class="text-blue-600 hover:text-blue-800 font-mono text-xs font-bold search-inv transition-colors">
                                #INV-@(item.ParentSaleId?.ToString("D5") ?? "---")
                            </a>
                        </td>
                        <td class="px-5 py-3 font-semibold text-gray-800 search-cust">@(item.Customer?.FullName ?? "عميل نقدي سريع")</td>
                        <td class="px-5 py-3 text-xs text-gray-500 font-mono" dir="ltr">@item.SaleDate.ToString("yyyy-MM-dd")</td>
                        <td class="px-5 py-3 text-center font-bold font-mono text-rose-600">@item.NetAmount.ToString("N2")</td>
                        <td class="px-5 py-3 text-center text-xs text-gray-500">@(item.User?.Username ?? "System")</td>
                        <td class="px-5 py-3 text-center">
                            <a href="/Sales/Details/@item.SaleId" class="inline-flex items-center gap-1 px-3 py-1.5 bg-blue-50 hover:bg-blue-100 border border-blue-200 text-blue-700 rounded-lg text-xs font-semibold transition-all">
                                <i class="fas fa-eye text-[10px]"></i> عرض
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
function filterTable() {
    const q = document.getElementById("searchInput").value.toLowerCase();
    document.querySelectorAll(".search-row").forEach(row => {
        const ret = row.querySelector(".search-ret")?.innerText.toLowerCase() ?? "";
        const inv = row.querySelector(".search-inv")?.innerText.toLowerCase() ?? "";
        const cust = row.querySelector(".search-cust")?.innerText.toLowerCase() ?? "";
        row.style.display = (ret.includes(q) || inv.includes(q) || cust.includes(q)) ? "" : "none";
    });
}
</script>
}