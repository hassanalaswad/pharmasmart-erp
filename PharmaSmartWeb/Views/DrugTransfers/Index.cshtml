@model IEnumerable<PharmaSmartWeb.Models.Drugtransfers>

@{
    ViewData["Title"] = "التحويلات المخزنية (In-Transit)";
    int currentBranchId = ViewBag.CurrentBranchId ?? 0;
    var totalTransfers = Model.Count();
    var inTransitCount = Model.Count(t => t.Status == "Pending");
    var receivedTodayCount = Model.Count(t => t.Status != "Pending" && t.TransferDate.Date == DateTime.Today);
}

@if (TempData["Success"] != null)
{
    <div class="bg-emerald-50 border border-emerald-200 border-r-4 border-r-emerald-500 rounded-xl p-3 mb-4 flex items-center gap-2 text-sm text-emerald-700">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="bg-red-50 border border-red-200 border-r-4 border-r-red-500 rounded-xl p-3 mb-4 flex items-center gap-2 text-sm text-red-700">
        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
    </div>
}

<!-- ===== رأس الصفحة ===== -->
<div class="flex flex-wrap justify-between items-start mb-5">
    <div class="flex items-center gap-3 mb-2 sm:mb-0">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-indigo-700 flex items-center justify-center shadow-sm">
            <i class="fas fa-exchange-alt text-white"></i>
        </div>
        <div>
            <h1 class="text-xl font-black text-gray-800">إدارة التحويلات المخزنية</h1>
            <p class="text-xs text-gray-500">تتبع البضائع قيد النقل بين الفروع وإدارة الاستلام والتسليم</p>
        </div>
    </div>
    <div class="flex gap-2 flex-wrap">
        <a href="/DrugTransfers/Create" class="quick-action-btn px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm transition-all hover:-translate-y-0.5 active:scale-95">
            <i class="fas fa-plus-square"></i> إصدار بضاعة (تحويل)
        </a>
    </div>
</div>

<!-- ===== بطاقات KPI ===== -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-5">
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-blue-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-gray-500">إجمالي التحويلات</span>
            <i class="fas fa-retweet text-blue-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-gray-800">@totalTransfers</div>
        <span class="text-xs text-gray-400 font-medium">تحويل مسجل</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-amber-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-amber-700 font-semibold">قيد النقل حالياً</span>
            <i class="fas fa-truck text-amber-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-amber-600">@inTransitCount</div>
        <span class="text-xs text-gray-400 font-medium">بضاعة في الطريق</span>
    </div>
    <div class="kpi-card bg-white rounded-2xl shadow-sm p-4 border border-gray-100 border-r-4 border-r-emerald-500">
        <div class="flex justify-between items-start mb-1">
            <span class="text-xs text-emerald-700 font-semibold">تم الاستلام اليوم</span>
            <i class="fas fa-check-double text-emerald-500 text-sm"></i>
        </div>
        <div class="text-xl font-black text-emerald-600">@receivedTodayCount</div>
        <span class="text-xs text-gray-400 font-medium">شحنات مكتملة الدورة</span>
    </div>
</div>

<!-- ===== جدول التحويلات ===== -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100">
    <div class="flex flex-wrap justify-between items-center px-5 py-4 border-b border-gray-100 gap-3">
        <h3 class="font-bold text-gray-800 text-sm">
            <i class="fas fa-route text-blue-500 ml-1.5"></i> تتبع الشحنات والتحويلات النشطة
        </h3>
        <div class="relative">
            <i class="fas fa-search absolute right-3 top-2.5 text-gray-400 text-xs"></i>
            <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="البحث برقم التحويل..."
                class="pr-8 pl-4 py-2 border border-gray-200 rounded-xl text-xs w-56 focus:outline-none focus:ring-2 focus:ring-blue-400" />
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full data-table text-sm" id="transfersTable">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">رقم التحويل / التاريخ</th>
                    <th class="px-5 py-3 text-right text-gray-600 font-semibold text-xs">مسار الشحنة (من ← إلى)</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">تفاصيل الأصناف</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">الحالة</th>
                    <th class="px-5 py-3 text-center text-gray-600 font-semibold text-xs">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-12 text-gray-400">
                            <i class="fas fa-inbox text-5xl mb-3 block text-gray-200"></i>
                            لا توجد تحويلات مخزنية صادرة أو واردة لفرعك.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    bool isIncoming = item.ToBranchId == currentBranchId;
                    <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors search-row">
                        <td class="px-5 py-3 search-num">
                            <div class="font-mono font-bold text-blue-700">#TRN-@item.TransferId.ToString("D5")</div>
                            <div class="text-[11px] text-gray-400 font-mono mt-0.5" dir="ltr">@item.TransferDate.ToString("yyyy-MM-dd HH:mm")</div>
                        </td>
                        <td class="px-5 py-3">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span class="bg-gray-100 text-gray-700 px-2.5 py-1 rounded-md text-[11px] font-bold border border-gray-200">@item.FromBranch?.BranchName</span>
                                <i class="fas fa-long-arrow-alt-left text-gray-400 mx-1"></i>
                                <span class="bg-blue-50 text-blue-700 px-2.5 py-1 rounded-md text-[11px] font-bold border border-blue-200">@item.ToBranch?.BranchName</span>
                            </div>
                        </td>
                        <td class="px-5 py-3 text-center">
                            <div class="font-bold text-gray-800">
                                @item.Drugtransferdetails.Sum(d => d.Quantity) <span class="text-[10px] text-gray-400 font-normal">وحدة</span>
                            </div>
                            <div class="text-[10px] text-gray-500 mt-0.5">@item.Drugtransferdetails.Count أصناف مختلفة</div>
                        </td>
                        <td class="px-5 py-3 text-center">
                            @if (item.Status == "Pending")
                            {
                                <span class="text-[11px] px-2.5 py-1 bg-amber-50 text-amber-700 border border-amber-100 rounded-full font-bold">قيد النقل</span>
                            }
                            else
                            {
                                <span class="text-[11px] px-2.5 py-1 bg-emerald-50 text-emerald-700 border border-emerald-100 rounded-full font-bold">تم الاستلام</span>
                            }
                        </td>
                        <td class="px-5 py-3 text-center">
                            <div class="flex items-center justify-center">
                                @if (isIncoming && item.Status == "Pending")
                                {
                                    <form asp-action="ReceiveTransfer" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.TransferId" />
                                        <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-xs font-semibold transition-all">
                                            <i class="fas fa-truck-loading text-[10px]"></i> تأكيد الاستلام
                                        </button>
                                    </form>
                                }
                                else if (!isIncoming && item.Status == "Pending")
                                {
                                    <span class="inline-flex items-center gap-1.5 text-xs text-gray-500">
                                        <i class="fas fa-hourglass-half text-amber-500"></i> بانتظار استلام الوجهة
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 text-xs text-emerald-600 font-semibold">
                                        <i class="fas fa-check-double"></i> مكتمل
                                    </span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
function filterTable() {
    const q = document.getElementById("searchInput").value.toLowerCase();
    document.querySelectorAll(".search-row").forEach(row => {
        const num = row.querySelector(".search-num")?.innerText.toLowerCase() ?? "";
        row.style.display = num.includes(q) ? "" : "none";
    });
}
</script>
}