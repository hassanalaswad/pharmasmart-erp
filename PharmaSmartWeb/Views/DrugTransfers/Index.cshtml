@model IEnumerable<PharmaSmartWeb.Models.Drugtransfers>

@{
    ViewData["Title"] = "التحويلات المخزنية (In-Transit)";
    int currentBranchId = ViewBag.CurrentBranchId ?? 0;
    var totalTransfers = Model.Count();
    var inTransitCount = Model.Count(t => t.Status == "Pending");
    var receivedTodayCount = Model.Count(t => t.Status != "Pending" && t.TransferDate.Date == DateTime.Today);
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .enterprise-header { background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 10px 16px; font-size: 13px; font-weight: 700; color: #063955; }
    .enterprise-kpi { background: white; border: 1px solid #d1d5db; border-radius: 2px; padding: 12px 16px; }
    .kpi-title { font-size: 11px; color: #64748b; font-weight: 600; margin-bottom: 4px; }
    .kpi-value { font-size: 22px; font-weight: 700; color: #0f172a; }
    .enterprise-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .enterprise-table th { background: #f1f5f9; padding: 8px 12px; border-bottom: 1px solid #cbd5e1; border-top: 1px solid #cbd5e1; color: #334155; font-weight: 700; text-align: right; }
    .enterprise-table td { padding: 8px 12px; border-bottom: 1px solid #e2e8f0; color: #1e293b; vertical-align: middle; }
    .enterprise-table tr:hover td { background: #f8fafc; }
    .status-pending { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; padding: 2px 8px; border-radius: 2px; font-size: 11px; font-weight: 700; }
    .status-received { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; padding: 2px 8px; border-radius: 2px; font-size: 11px; font-weight: 700; }
    .btn-primary { background: #063955; color: white; border: none; padding: 7px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; }
    .btn-primary:hover { background: #0a4f72; color: white; }
    .btn-confirm { background: #063955; color: white; border: none; padding: 5px 12px; border-radius: 2px; font-size: 11px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; }
    .branch-badge { display: inline-block; background: #f1f5f9; color: #334155; padding: 3px 10px; border-radius: 2px; font-size: 11px; font-weight: 700; border: 1px solid #e2e8f0; }
    .branch-badge-dest { background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe; }
    .page-title { font-size: 16px; font-weight: 700; color: #063955; }
</style>

<!-- Page Header -->
<div class="enterprise-panel mb-4 p-3 flex justify-between items-center">
    <div>
        <h1 class="page-title">إدارة التحويلات المخزنية</h1>
        <p style="font-size:12px; color:#64748b;">تتبع البضائع قيد النقل بين الفروع وإدارة الاستلام والتسليم.</p>
    </div>
    <a href="/DrugTransfers/Create" class="btn-primary">
        <span class="material-symbols-outlined" style="font-size:16px;">add_box</span>
        إصدار بضاعة (تحويل)
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="enterprise-panel mb-4 p-3 flex items-center gap-3" style="border-right: 4px solid #059669;">
        <span class="material-symbols-outlined" style="color:#059669; font-size:18px;">check_circle</span>
        <span style="font-size:13px; color:#059669; font-weight:600;">@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="enterprise-panel mb-4 p-3 flex items-center gap-3" style="border-right: 4px solid #e11d48;">
        <span class="material-symbols-outlined" style="color:#e11d48; font-size:18px;">error</span>
        <span style="font-size:13px; color:#e11d48; font-weight:600;">@TempData["Error"]</span>
    </div>
}

<!-- KPIs -->
<div class="grid grid-cols-3 gap-3 mb-4">
    <div class="enterprise-kpi">
        <div class="kpi-title">إجمالي التحويلات</div>
        <div class="kpi-value">@totalTransfers</div>
    </div>
    <div class="enterprise-kpi">
        <div class="kpi-title">قيد النقل حالياً</div>
        <div class="kpi-value" style="color:#d97706;">@inTransitCount</div>
        <div style="font-size:10px; color:#94a3b8;">بضاعة في الطريق</div>
    </div>
    <div class="enterprise-kpi">
        <div class="kpi-title">تم الاستلام اليوم</div>
        <div class="kpi-value" style="color:#059669;">@receivedTodayCount</div>
        <div style="font-size:10px; color:#94a3b8;">شحنات مكتملة الدورة</div>
    </div>
</div>

<!-- Data Table -->
<div class="enterprise-panel">
    <div class="enterprise-header">تتبع الشحنات والتحويلات النشطة</div>
    <div style="overflow-x:auto;">
        <table class="enterprise-table">
            <thead>
                <tr>
                    <th>رقم التحويل / التاريخ</th>
                    <th>مسار الشحنة (من ← إلى)</th>
                    <th style="text-align:center;">تفاصيل الأصناف</th>
                    <th style="text-align:center;">الحالة</th>
                    <th style="text-align:center;">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" style="text-align:center; padding:40px; color:#94a3b8;">
                            <span class="material-symbols-outlined" style="font-size:32px; display:block; margin-bottom:8px;">inbox</span>
                            لا توجد تحويلات مخزنية صادرة أو واردة لفرعك.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    bool isIncoming = item.ToBranchId == currentBranchId;
                    <tr>
                        <td>
                            <div style="font-family:monospace; font-weight:700; color:#063955;">#TRN-@item.TransferId.ToString("D5")</div>
                            <div style="font-size:10px; color:#94a3b8;" dir="ltr">@item.TransferDate.ToString("yyyy-MM-dd HH:mm")</div>
                        </td>
                        <td>
                            <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                                <span class="branch-badge">@item.FromBranch?.BranchName</span>
                                <span class="material-symbols-outlined" style="font-size:16px; color:#94a3b8; transform:rotate(180deg);">trending_flat</span>
                                <span class="branch-badge branch-badge-dest">@item.ToBranch?.BranchName</span>
                            </div>
                        </td>
                        <td style="text-align:center;">
                            <div style="font-size:13px; font-weight:700; color:#063955;">
                                @item.Drugtransferdetails.Sum(d => d.Quantity)
                                <span style="font-size:10px; color:#94a3b8; font-weight:400;">وحدة</span>
                            </div>
                            <div style="font-size:10px; color:#64748b;">@item.Drugtransferdetails.Count أصناف مختلفة</div>
                        </td>
                        <td style="text-align:center;">
                            @if (item.Status == "Pending")
                            {
                                <span class="status-pending">قيد النقل</span>
                            }
                            else
                            {
                                <span class="status-received">تم الاستلام</span>
                            }
                        </td>
                        <td style="text-align:center;">
                            @if (isIncoming && item.Status == "Pending")
                            {
                                <form asp-action="ReceiveTransfer" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.TransferId" />
                                    <button type="submit" class="btn-confirm">
                                        <span class="material-symbols-outlined" style="font-size:13px;">local_shipping</span>
                                        تأكيد الاستلام
                                    </button>
                                </form>
                            }
                            else if (!isIncoming && item.Status == "Pending")
                            {
                                <span style="font-size:11px; color:#94a3b8; display:flex; align-items:center; justify-content:center; gap:4px;">
                                    <span class="material-symbols-outlined" style="font-size:15px;">hourglass_empty</span>
                                    بانتظار استلام الوجهة
                                </span>
                            }
                            else
                            {
                                <span style="font-size:11px; color:#059669; display:flex; align-items:center; justify-content:center; gap:4px;">
                                    <span class="material-symbols-outlined" style="font-size:15px;">done_all</span>
                                    مكتمل
                                </span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div style="padding:8px 12px; background:#f8fafc; border-top:1px solid #e2e8f0; font-size:11px; color:#64748b;">
        إجمالي: @totalTransfers تحويل — @inTransitCount قيد النقل
    </div>
</div>