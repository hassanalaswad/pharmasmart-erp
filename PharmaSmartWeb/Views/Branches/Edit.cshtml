@model PharmaSmartWeb.Models.Branches

@{
    Layout = "_ModalLayout";
    ViewData["Title"] = $"تحديث بيانات الفرع: {Model.BranchName}";
    ViewBag.ModalPanelSize = "md";
    ViewBag.ModalHeaderIcon = "edit_location_alt";
}

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="BranchId" />

    @if (ViewBag.Error != null)
    {
        <div class="ph-alert-error">⚠ @ViewBag.Error</div>
    }

    <div class="ph-form-grid ph-form-grid-2">
        <div>
            <label class="ph-form-label">كود الفرع (الرمز)</label>
            <input type="text" asp-for="BranchCode" required class="ph-form-control" style="font-family:monospace;color:#64748b;font-weight:700;" />
        </div>
        <div>
            <label class="ph-form-label">اسم الفرع</label>
            <input type="text" asp-for="BranchName" required class="ph-form-control" style="font-weight:700;" />
        </div>
    </div>

    <div class="ph-form-grid">
        <div>
            <label class="ph-form-label">الموقع الجغرافي</label>
            <input type="text" asp-for="Location" class="ph-form-control" />
        </div>
    </div>

    <div class="ph-form-panel">
        <div>
            <div class="ph-form-panel-title">حالة الفرع</div>
            <div class="ph-form-panel-hint">إغلاق الفرع سيمنع المستخدمين التابعين له من الدخول للنظام.</div>
        </div>
        <select asp-for="IsActive" class="ph-form-select" style="width:auto;min-width:11rem;">
            <option value="true">✅ فرع نشط ويعمل</option>
            <option value="false">❌ فرع مغلق أو قيد التجهيز</option>
        </select>
    </div>

    <div class="ph-modal-actions">
        <button type="button" onclick="modalNavigateBack()" class="ph-btn-back">
            <span class="material-symbols-outlined" style="font-size:18px;">cancel</span>
            إلغاء التعديل
        </button>
        <button type="submit" class="ph-btn-warning">
            <span class="material-symbols-outlined" style="font-size:18px;">save</span>
            حفظ التعديلات
        </button>
    </div>
</form>
