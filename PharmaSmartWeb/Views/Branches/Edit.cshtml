@model PharmaSmartWeb.Models.Branches

@{
    Layout = "_ModalLayout";
    ViewData["Title"] = $"تحديث بيانات الفرع: {Model.BranchName}";
    ViewBag.ModalPanelSize = "md";
    ViewBag.ModalHeaderIcon = "edit_location_alt";
}

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="BranchId" />

    @if (ViewBag.Error != null)
    {
        <div class="enterprise-alert-error">
            <span class="material-symbols-outlined" style="font-size:16px;">warning</span>
            @ViewBag.Error
        </div>
    }

    <div class="enterprise-section-title">بيانات الفرع</div>

    <div class="enterprise-row">
        <div>
            <label class="enterprise-label">كود الفرع (الرمز)</label>
            <input type="text" asp-for="BranchCode" required class="enterprise-input" style="font-family:monospace;text-transform:uppercase;" />
        </div>
        <div>
            <label class="enterprise-label">اسم الفرع</label>
            <input type="text" asp-for="BranchName" required class="enterprise-input" />
        </div>
    </div>

    <div style="margin-bottom:16px;">
        <label class="enterprise-label">الموقع الجغرافي</label>
        <input type="text" asp-for="Location" class="enterprise-input" />
    </div>

    <div class="enterprise-section-title" style="margin-top:24px;">حالة النظام</div>

    <div style="border:1px solid #e2e8f0;border-radius:2px;padding:12px 16px;display:flex;justify-content:space-between;align-items:center;background:#f8fafc;flex-wrap:wrap;gap:12px;">
        <div>
            <div style="font-size:13px;font-weight:700;color:#0f172a;">حالة الفرع</div>
            <div style="font-size:11px;color:#64748b;margin-top:2px;">إغلاق الفرع سيمنع المستخدمين التابعين له من الدخول للنظام.</div>
        </div>
        <select asp-for="IsActive" class="enterprise-select" style="width:auto;min-width:11rem;">
            <option value="true">✅ فرع نشط ويعمل</option>
            <option value="false">❌ فرع مغلق أو قيد التجهيز</option>
        </select>
    </div>

    <div class="enterprise-actions">
        <button type="button" onclick="modalNavigateBack()" class="enterprise-btn-cancel">
            <span class="material-symbols-outlined" style="font-size:16px;">cancel</span>
            إلغاء التعديل
        </button>
        <button type="submit" class="enterprise-btn-warning">
            <span class="material-symbols-outlined" style="font-size:16px;">save</span>
            حفظ التعديلات
        </button>
    </div>
</form>
