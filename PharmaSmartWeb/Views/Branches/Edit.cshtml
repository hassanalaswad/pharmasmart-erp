@model PharmaSmartWeb.Models.Branches

@{
    Layout = "_ModalLayout";
    ViewData["Title"] = $"تحديث بيانات الفرع: {Model.BranchName}";
}

<style>
    .form-label { font-size: 11px; font-weight: 700; color: #063955; margin-bottom: 4px; display: block; text-transform: uppercase; letter-spacing: 0.05em; }
    .form-control { width: 100%; border: 1px solid #cbd5e1; border-radius: 2px; padding: 7px 10px; font-size: 13px; background: #f8fafc; }
    .form-control:focus { outline: none; border-color: #063955; background: white; }
    .form-select { width: 100%; border: 1px solid #cbd5e1; border-radius: 2px; padding: 7px 10px; font-size: 13px; background: white; }
    .btn-submit { background: #d97706; color: white; border: none; padding: 9px 22px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; }
    .btn-cancel { background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; padding: 9px 18px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; }
    .alert-error { background: #fff1f2; border-right: 4px solid #e11d48; border-radius: 2px; padding: 10px 14px; font-size: 12px; color: #e11d48; margin-bottom: 14px; }
</style>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="BranchId" />

    @if (ViewBag.Error != null)
    {
        <div class="alert-error">⚠ @ViewBag.Error</div>
    }

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
        <div>
            <label class="form-label">كود الفرع (الرمز)</label>
            <input type="text" asp-for="BranchCode" required class="form-control" style="font-family:monospace; color:#64748b; font-weight:700;" />
        </div>
        <div>
            <label class="form-label">اسم الفرع</label>
            <input type="text" asp-for="BranchName" required class="form-control" style="font-weight:700;" />
        </div>
    </div>

    <div style="margin-bottom:14px;">
        <label class="form-label">الموقع الجغرافي</label>
        <input type="text" asp-for="Location" class="form-control" />
    </div>

    <div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:2px; padding:12px 14px; display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
        <div>
            <div style="font-size:12px; font-weight:700; color:#063955;">حالة الفرع</div>
            <div style="font-size:10px; color:#94a3b8; margin-top:2px;">إغلاق الفرع سيمنع المستخدمين التابعين له من الدخول للنظام.</div>
        </div>
        <select asp-for="IsActive" class="form-select" style="width:auto;">
            <option value="true">✅ فرع نشط ويعمل</option>
            <option value="false">❌ فرع مغلق أو قيد التجهيز</option>
        </select>
    </div>

    <div style="display:flex; justify-content:flex-end; gap:10px; padding-top:14px; border-top:1px solid #e2e8f0;">
        <button type="button" onclick="history.back()" class="btn-cancel">
            <span class="material-symbols-outlined" style="font-size:15px;">cancel</span>
            إلغاء التعديل
        </button>
        <button type="submit" class="btn-submit">
            <span class="material-symbols-outlined" style="font-size:15px;">save</span>
            حفظ التعديلات
        </button>
    </div>
</form>