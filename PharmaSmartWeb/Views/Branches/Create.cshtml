@model PharmaSmartWeb.Models.Branches

@{
    Layout = "_ModalLayout";
    ViewData["Title"] = "إضافة فرع جديد";
    ViewBag.ModalPanelSize = "md";
    ViewBag.ModalHeaderIcon = "domain_add";
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    @if (ViewBag.Error != null)
    {
        <div class="ph-alert-error">⚠ @ViewBag.Error</div>
    }

    <div class="ph-form-grid ph-form-grid-2">
        <div>
            <label class="ph-form-label">كود الفرع (الرمز) <span style="color:#e11d48;">*</span></label>
            <input type="text" asp-for="BranchCode" required placeholder="مثال: BR-01" class="ph-form-control" style="font-family:monospace;text-transform:uppercase;" />
        </div>
        <div>
            <label class="ph-form-label">اسم الفرع <span style="color:#e11d48;">*</span></label>
            <input type="text" asp-for="BranchName" required placeholder="مثال: فرع تالين الرئيسي" class="ph-form-control" />
        </div>
    </div>

    <div class="ph-form-grid">
        <div>
            <label class="ph-form-label">الموقع الجغرافي</label>
            <input type="text" asp-for="Location" placeholder="العنوان بالتفصيل..." class="ph-form-control" />
        </div>
    </div>

    <div class="ph-form-grid">
        <div>
            <label class="ph-form-label">حالة الفرع</label>
            <select asp-for="IsActive" class="ph-form-select">
                <option value="true">✅ فرع نشط ويعمل</option>
                <option value="false">❌ فرع مغلق أو قيد التجهيز</option>
            </select>
        </div>
    </div>

    <div class="ph-modal-actions">
        <button type="button" onclick="modalNavigateBack()" class="ph-btn-back">
            <span class="material-symbols-outlined" style="font-size:18px;">cancel</span>
            إلغاء العملية
        </button>
        <button type="submit" class="ph-btn-primary">
            <span class="material-symbols-outlined" style="font-size:18px;">check_circle</span>
            حفظ الفرع
        </button>
    </div>
</form>
