@model PharmaSmartWeb.Models.Branches

@{
    Layout = "_ModalLayout";
    ViewData["Title"] = "إضافة فرع جديد";
}

<style>
    .form-label { font-size: 11px; font-weight: 700; color: #063955; margin-bottom: 4px; display: block; }
    .form-control { width: 100%; border: 1px solid #cbd5e1; border-radius: 2px; padding: 7px 10px; font-size: 13px; background: #f8fafc; }
    .form-control:focus { outline: none; border-color: #063955; background: white; }
    .form-select { width: 100%; border: 1px solid #cbd5e1; border-radius: 2px; padding: 7px 10px; font-size: 13px; background: white; }
    .btn-submit { background: #063955; color: white; border: none; padding: 9px 22px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; }
    .btn-cancel { background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; padding: 9px 18px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; }
    .alert-error { background: #fff1f2; border-right: 4px solid #e11d48; border-radius: 2px; padding: 10px 14px; font-size: 12px; color: #e11d48; margin-bottom: 14px; }
</style>

<form asp-action="Create" method="post">
    @if (ViewBag.Error != null)
    {
        <div class="alert-error">⚠ @ViewBag.Error</div>
    }

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
        <div>
            <label class="form-label">كود الفرع (الرمز) <span style="color:#e11d48;">*</span></label>
            <input type="text" asp-for="BranchCode" required placeholder="مثال: BR-01" class="form-control" style="font-family:monospace; text-transform:uppercase;" />
        </div>
        <div>
            <label class="form-label">اسم الفرع <span style="color:#e11d48;">*</span></label>
            <input type="text" asp-for="BranchName" required placeholder="مثال: فرع تالين الرئيسي" class="form-control" />
        </div>
    </div>

    <div style="margin-bottom:14px;">
        <label class="form-label">الموقع الجغرافي</label>
        <input type="text" asp-for="Location" placeholder="العنوان بالتفصيل..." class="form-control" />
    </div>

    <div style="margin-bottom:16px;">
        <label class="form-label">حالة الفرع</label>
        <select asp-for="IsActive" class="form-select">
            <option value="true">✅ فرع نشط ويعمل</option>
            <option value="false">❌ فرع مغلق أو قيد التجهيز</option>
        </select>
    </div>

    <div style="display:flex; justify-content:flex-end; gap:10px; padding-top:14px; border-top:1px solid #e2e8f0;">
        <button type="button" onclick="history.back()" class="btn-cancel">
            <span class="material-symbols-outlined" style="font-size:15px;">cancel</span>
            إلغاء العملية
        </button>
        <button type="submit" class="btn-submit">
            <span class="material-symbols-outlined" style="font-size:15px;">check_circle</span>
            حفظ الفرع
        </button>
    </div>
</form>