@model IEnumerable<PharmaSmartWeb.Models.Branches>

@{
    ViewData["Title"] = "إدارة فروع الصيدلية";
}

<style>
    body { background-color: #f4f6f8; }
    .enterprise-panel { background: white; border: 1px solid #d1d5db; border-radius: 2px; }
    .page-title { font-size: 18px; font-weight: 800; color: #063955; margin-bottom: 2px; }
    .page-sub { font-size: 12px; color: #64748b; font-weight: bold; }
    .btn-primary { background: #063955; color: white; border: none; padding: 8px 16px; border-radius: 2px; font-size: 12px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 6px; transition: 0.2s; text-decoration: none; }
    .btn-primary:hover { background: #0a4f72; color: white; }
    .btn-edit { background: #fdf6e3; color: #b45309; border: 1px solid #fde68a; padding: 6px 12px; border-radius: 2px; font-size: 11px; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; width: 100%; justify-content: center; transition: 0.2s; }
    .btn-edit:hover { background: #fef3c7; color: #92400e; }
    .branch-card { background: white; border: 1px solid #d1d5db; border-radius: 2px; padding: 16px; transition: border-color 0.2s; display: flex; flex-direction: column; }
    .branch-card:hover { border-color: #063955; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); }
    .status-badge { display: inline-flex; align-items: center; justify-content: center; padding: 2px 8px; border-radius: 2px; font-size: 11px; font-weight: 700; border: 1px solid transparent; }
    .status-active { background: #ecfdf5; color: #059669; border-color: #a7f3d0; }
    .status-inactive { background: #fef2f2; color: #e11d48; border-color: #fecaca; }
    .stat-text { font-size: 12px; font-weight: bold; }
</style>

<div class="max-w-[1200px] mx-auto pb-12 pt-6 px-6">
    
    @if (TempData["Success"] != null)
    {
        <div class="enterprise-panel border-r-4 border-r-[#059669] p-4 mb-6 flex items-center gap-3">
            <span class="material-symbols-outlined text-[#059669] text-[20px]">check_circle</span>
            <span class="text-[13px] font-bold text-[#059669]">@TempData["Success"]</span>
        </div>
    }

    <!-- Header Section -->
    <div class="enterprise-panel border-t-4 border-t-[#063955] p-5 mb-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="page-title">هيكل الفروع والمراكز</h1>
            <p class="page-sub mt-1">إدارة المركز الرئيسي والفروع التابعة للنظام المتكامل</p>
        </div>
        <div class="flex gap-3">
            <a href="/Branches/Create" class="btn-primary">
                <span class="material-symbols-outlined text-[16px]">add_circle</span>
                إضافة فرع جديد
            </a>
        </div>
    </div>

    <!-- KPI Summary -->
    <div class="enterprise-panel p-4 mb-6 flex flex-wrap gap-8 items-center bg-slate-50">
        <div class="flex items-center gap-2">
            <span class="stat-text text-slate-500 uppercase tracking-wide">إجمالي الفروع:</span>
            <strong class="stat-text text-[#063955] text-[14px]">@Model.Count()</strong>
        </div>
        <div class="flex items-center gap-2">
            <span class="stat-text text-slate-500 uppercase tracking-wide">الفروع النشطة:</span>
            <strong class="stat-text text-[#059669] text-[14px]">@Model.Count(b => b.IsActive == true)</strong>
        </div>
        <div class="flex items-center gap-2">
            <span class="stat-text text-slate-500 uppercase tracking-wide">فروع مغلقة أو موقوفة:</span>
            <strong class="stat-text text-[#e11d48] text-[14px]">@Model.Count(b => b.IsActive != true)</strong>
        </div>
    </div>

    <!-- Branches Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        @foreach (var item in Model)
        {
            <div class="branch-card border-t-4 @(item.IsActive == true ? "border-t-[#059669]" : "border-t-[#e11d48]")">
                <div class="flex justify-between items-start mb-4">
                    <div class="w-10 h-10 bg-slate-50 border border-slate-200 rounded-sm flex items-center justify-center text-[#063955]">
                        <span class="material-symbols-outlined text-[20px]">store</span>
                    </div>
                    <span class="bg-slate-100 text-slate-600 px-2 py-0.5 rounded-sm font-mono text-[11px] font-bold border border-slate-200">
                        @item.BranchCode
                    </span>
                </div>

                <h3 class="text-[14px] font-bold text-[#063955] mb-4 h-[42px] overflow-hidden">@item.BranchName</h3>

                <div class="flex-grow space-y-3 mb-6">
                    <div class="flex items-start gap-2 text-slate-500">
                        <span class="material-symbols-outlined text-[14px] mt-0.5">location_on</span>
                        <span class="text-[11px] font-bold leading-relaxed">
                            @(string.IsNullOrEmpty(item.Location) ? "الموقع غير مسجل" : item.Location)
                        </span>
                    </div>
                    <div>
                        @if (item.IsActive == true)
                        {
                            <span class="status-badge status-active">فرع نشط ومتاح</span>
                        }
                        else
                        {
                            <span class="status-badge status-inactive">مغلق مؤقتاً</span>
                        }
                    </div>
                </div>

                <div class="pt-4 border-t border-slate-100 mt-auto">
                    <a href="/Branches/Edit/@item.BranchId" class="btn-edit">
                        <span class="material-symbols-outlined text-[14px]">edit</span>
                        تعديل بيانات الفرع
                    </a>
                </div>
            </div>
        }
    </div>
</div>